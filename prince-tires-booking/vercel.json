{
  "crons": [
    {
      "path": "/api/remind",
      "schedule": "0 15 * * *"
    }
  ],
  "functions": {
    "api/book.js":               { "maxDuration": 10 },
    "api/availability.js":       { "maxDuration": 10 },
    "api/admin-login.js":        { "maxDuration": 10 },
    "api/admin-customer.js":     { "maxDuration": 15 },
    "api/admin-approve.js":      { "maxDuration": 20 },
    "api/admin-products.js":     { "maxDuration": 10 },
    "api/admin-orders.js":       { "maxDuration": 15 },
    "api/admin-bookings.js":     { "maxDuration": 15 },
    "api/admin-all-customers.js":{ "maxDuration": 15 },
    "api/admin-booking-manage.js":{ "maxDuration": 15 },
    "api/cancel.js":              { "maxDuration": 10 },
    "api/remind.js":              { "maxDuration": 20 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",            "value": "nosniff" },
        { "key": "X-Frame-Options",                    "value": "DENY" },
        { "key": "Referrer-Policy",                    "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",                 "value": "geolocation=(), camera=(), microphone=()" },
        { "key": "Strict-Transport-Security",          "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
