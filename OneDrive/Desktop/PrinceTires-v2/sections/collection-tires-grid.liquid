      chips.push(`<div class="pt-active-chip" onclick="ptClearSize()">${sizeLabel}<svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 2l6 6M8 2l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>`);
    }
    filterState.tags.forEach(t=>{ const label=t.replace(/_/g,' ').replace(/^\w+\s/,'').replace(/-/g,' '); chips.push(`<div class="pt-active-chip" onclick="ptRemoveFilter('${t}')">${label.charAt(0).toUpperCase()+label.slice(1)}<svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 2l6 6M8 2l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>`); });
    if(filterState.minPrice||filterState.maxPrice){ const label='$'+(filterState.minPrice||0)+' – $'+(filterState.maxPrice||'∞'); chips.push(`<div class="pt-active-chip" onclick="ptClearPrice()">${label}<svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 2l6 6M8 2l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>`); }
    container.innerHTML = chips.join(''); container.classList.toggle('has-filters', chips.length>0);
  }
  function updateFilterCount(){ const count=filterState.tags.length+(filterState.minPrice||filterState.maxPrice?1:0); const badge=document.getElementById('pt-filter-count-'+SID); if(badge){ badge.textContent=count; badge.style.display=count>0?'flex':'none'; } }
  window.ptTagFilter = function(checkbox){ const val=String(checkbox.value || '').toLowerCase(); if(checkbox.checked){ if(!filterState.tags.includes(val)) filterState.tags.push(val); } else { filterState.tags = filterState.tags.filter(t=>t!==val); } applyFilters(); };
  window.ptSizeFilter = function(sid){ const w=document.getElementById('ptf-sz-w-'+sid)?.value; const p=document.getElementById('ptf-sz-p-'+sid)?.value; const r=document.getElementById('ptf-sz-r-'+sid)?.value; if(w&&p&&r){ filterState.sizeKey = (w + '-' + p + 'r' + r).toLowerCase(); } else { filterState.sizeKey = null; } applyFilters(); };
  window.ptClearSize = function(){ filterState.sizeKey=null; const w=document.getElementById('ptf-sz-w-'+SID); const p=document.getElementById('ptf-sz-p-'+SID); const r=document.getElementById('ptf-sz-r-'+SID); if(w)w.value=''; if(p)p.value=''; if(r)r.value=''; applyFilters(); };
  window.ptPriceFilter = function(sid){ filterState.minPrice = parseFloat(document.getElementById('ptf-price-min-'+sid)?.value)||null; filterState.maxPrice = parseFloat(document.getElementById('ptf-price-max-'+sid)?.value)||null; applyFilters(); };
  window.ptRemoveFilter = function(tag){ filterState.tags=filterState.tags.filter(t=>t!==tag); document.querySelectorAll(`#pt-filters-${SID} .pt-check`).forEach(cb=>{ if(cb.value===tag) cb.checked=false; }); applyFilters(); };
  window.ptClearPrice = function(){ filterState.minPrice=null; filterState.maxPrice=null; const mn=document.getElementById('ptf-price-min-'+SID); const mx=document.getElementById('ptf-price-max-'+SID); if(mn)mn.value=''; if(mx)mx.value=''; applyFilters(); };

  (function initializeFilterFromURL(){
    var params = new URLSearchParams(window.location.search);
    var w = params.get('filter.p.m.custom.tire_width');
    var p = params.get('filter.p.m.custom.tire_profile');
    var r = params.get('filter.p.m.custom.rim_diameter');
    if (w && p && r) {
      filterState.sizeKey = (w + '-' + p + 'r' + r).toLowerCase();
      applyFilters();
      var sizeInputW = document.getElementById('ptf-sz-w-'+SID);
      var sizeInputP = document.getElementById('ptf-sz-p-'+SID);
      var sizeInputR = document.getElementById('ptf-sz-r-'+SID);
      if (sizeInputW) sizeInputW.value = w;
      if (sizeInputP) sizeInputP.value = p;
      if (sizeInputR) sizeInputR.value = r;
    }
  })();

  window.ptClearFilters = function(){ window.location.href = new URL(COLLECTION_BASE_URL, window.location.origin).toString(); };
  window.ptToggleGroup = function(id){ const el=document.getElementById(id); if(el) el.classList.toggle('open'); };
  const nativeFilterForm = document.getElementById('pt-filters-form-' + SID);
  if (nativeFilterForm) {
    nativeFilterForm.addEventListener('change', function(e){
      const target = e.target;
      if (!target) return;
      if (target.matches('input[type="checkbox"], input[type="radio"], select')) {
        nativeFilterForm.submit();
      }
    });
  }
  const DEFAULT_OPEN_GROUPS = {{ section.settings.filter_default_open_groups | default: 'ptfg-size,ptfg-season' | json }};
  let openedGroups = 0;
  DEFAULT_OPEN_GROUPS.split(',').map(function(id){ return id.trim(); }).filter(Boolean).forEach(function(id){
    const el=document.getElementById(id);
    if(el) {
      el.classList.add('open');
      openedGroups += 1;
    }
  });
  if (openedGroups === 0) {
    document.querySelectorAll('#pt-filters-' + SID + ' .pt-filter-group').forEach(function(el, idx){
      if (idx < 2) el.classList.add('open');
    });
  }
  window.ptToggleMobileFilters = function(sid){
    var filters = document.getElementById('pt-filters-' + sid);
    var overlay = document.getElementById('pt-overlay-' + sid);
    var btn = document.getElementById('pt-mobile-filter-btn-' + sid);
    if (filters) filters.classList.toggle('open');
    if (overlay) overlay.classList.toggle('show');
    var open = filters && filters.classList.contains('open');
    if (btn) btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    if (document.body) document.body.style.overflow = open ? 'hidden' : '';
  };
  document.addEventListener('keydown', function(e){
    if (e.key !== 'Escape') return;
    var f = document.getElementById('pt-filters-' + SID);
    if (f && f.classList.contains('open')) window.ptToggleMobileFilters(SID);
  });
  window.ptApplySort = function(val){ const url = new URL(window.location.href); url.searchParams.set('sort_by', val); window.location.href = url.toString(); };
})();
</script>

<script>
/* ── Add to Cart – AJAX handler for .pt-btn-atc ── */
(function(){
  document.addEventListener('click', function(e){
    var btn = e.target.closest('.pt-btn-atc[data-variant-id]');
    if (!btn) return;
    e.preventDefault();
    if (btn.classList.contains('pt-atc--loading') || btn.classList.contains('pt-atc--added')) return;

    var variantId = btn.getAttribute('data-variant-id');
    var productUrl = btn.getAttribute('data-product-url') || '';
    var label = btn.querySelector('.pt-btn-atc__label');

    btn.classList.add('pt-atc--loading');
    if (label) label.textContent = 'Adding…';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      btn.classList.remove('pt-atc--loading');
      if (data.id) {
        btn.classList.add('pt-atc--added');
        if (label) label.textContent = 'Added!';
        /* Trigger cart drawer / bubble refresh if theme supports it */
        document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
        document.dispatchEvent(new CustomEvent('theme:cart:open', { bubbles: true }));
        /* Fallback: restore button after 2.5 s */
        setTimeout(function(){
          btn.classList.remove('pt-atc--added');
          if (label) label.textContent = 'Add to Cart';
        }, 2500);
      } else {
        if (label) label.textContent = 'Add to Cart';
        window.location.href = productUrl;
      }
    })
    .catch(function(){
      btn.classList.remove('pt-atc--loading');
      if (label) label.textContent = 'Add to Cart';
      window.location.href = productUrl;
    });
  });
})();
</script>

