{% comment %}
  ╔══════════════════════════════════════════════════════════╗
  ║        PRINCE TIRES — TIRE COLLECTION PAGE              ║
  ║   File: sections/collection-tires-grid.liquid           ║
  ║   Template: templates/collection.tires.json             ║
  ╚══════════════════════════════════════════════════════════╝

  SETUP NOTES FOR CURSOR:
  1. Save this file as: sections/collection-tires-grid.liquid
  2. Create: templates/collection.tires.json (see bottom of file)
  3. In Shopify Admin, assign the "tires" template to each tire collection
  4. Add product tags for filtering:
       Tire size:     size_225-65R17
       Season:        season_all-season | season_winter | season_summer | season_all-weather
       Service type:  service_P | service_LT | service_ST
       Category:      category_performance | category_touring | category_highway | category_mud-terrain
       Studs:         stud_studdable | stud_pre-studded | stud_non-studdable
{% endcomment %}

{% paginate collection.products by section.settings.products_per_page %}

<div id="pt-collection-{{ section.id }}" class="pt-col">

  <!-- ══════════════════════════════════════
       SMART TIRE SEARCH (Phase 3)
  ═══════════════════════════════════════ -->
  {%- render 'smart-tire-search' -%}

  <!-- ══════════════════════════════════════
       VEHICLE FINDER BAR
  ═══════════════════════════════════════ -->
  {% if section.settings.show_vehicle_finder %}
  <div class="pt-vfinder" id="pt-vfinder-{{ section.id }}">
    <div class="pt-vfinder__inner">
      {% if section.settings.finder_heading != blank or section.settings.finder_subheading != blank %}
        <div class="pt-vfinder__intro">
          {% if section.settings.finder_heading != blank %}
            <h2 class="pt-vfinder__heading">{{ section.settings.finder_heading }}</h2>
          {% endif %}
          {% if section.settings.finder_subheading != blank %}
            <p class="pt-vfinder__subheading">{{ section.settings.finder_subheading }}</p>
          {% endif %}
        </div>
      {% endif %}
      <div class="pt-vfinder__tire-toolbar">
        <div class="pt-vfinder__tabs" role="tablist" aria-label="Finder mode">
          <button class="pt-vfinder__tab" type="button" data-vf-tab="vehicle" role="tab" aria-selected="false">
            <span class="pt-vfinder__tab-circle" aria-hidden="true">
              <img src="{{ '4-icons-1.svg' | asset_url }}" alt="" loading="lazy">
            </span>
            <span class="pt-vfinder__tab-label">By Vehicle</span>
          </button>
          <button class="pt-vfinder__tab is-active" type="button" data-vf-tab="tire-size" role="tab" aria-selected="true">
            <span class="pt-vfinder__tab-circle" aria-hidden="true">
              <img src="{{ 'tire-stock-1.svg' | asset_url }}" alt="" loading="lazy">
            </span>
            <span class="pt-vfinder__tab-label">By Tire Size</span>
          </button>
          <button class="pt-vfinder__tab" type="button" data-vf-tab="wheel-specs" role="tab" aria-selected="false">
            <span class="pt-vfinder__tab-circle" aria-hidden="true">
              <img src="{{ '4-icons-2.svg' | asset_url }}" alt="" loading="lazy">
            </span>
            <span class="pt-vfinder__tab-label">By Wheel Specs</span>
          </button>
        </div>

        <div class="pt-vfinder__panel is-active" data-vf-panel="tire-size">
          <div class="pt-vfinder__row pt-vfinder__row--single pt-vfinder__row--single-action">
            <input
              type="text"
              class="pt-vf-sel pt-vf-size-input"
              id="pt-vf-ts-input-{{ section.id }}"
              placeholder="Quick search e.g. 205/55r16"
              aria-label="Tire size"
              autocomplete="off"
            >
            <button class="pt-vfinder__btn pt-vfinder__btn--search" type="button" data-vf-action="search">Search <span aria-hidden="true">→</span></button>
            <button class="pt-vfinder__btn pt-vfinder__btn--ghost" type="button" data-vf-action="clear">Clear</button>
          </div>
        </div>
      </div>

      <div class="pt-vfinder__panel" data-vf-panel="vehicle">
        <div class="pt-vfinder__subtabs" role="tablist" aria-label="Vehicle target">
          <button class="pt-vfinder__subtab is-active" type="button" data-vf-vehicle-mode="tires" role="tab" aria-selected="true">Tires</button>
          <button class="pt-vfinder__subtab" type="button" data-vf-vehicle-mode="wheels" role="tab" aria-selected="false">Wheels</button>
        </div>
        <div class="pt-vfinder__row pt-vfinder__row--vehicle">
          <select class="pt-vf-sel" id="pt-vf-veh-year-{{ section.id }}">
            <option value="">Year</option>
          </select>
          <select class="pt-vf-sel" id="pt-vf-veh-make-{{ section.id }}" disabled>
            <option value="">Make</option>
          </select>
          <select class="pt-vf-sel" id="pt-vf-veh-model-{{ section.id }}" disabled>
            <option value="">Model</option>
          </select>
          <select class="pt-vf-sel" id="pt-vf-veh-trim-{{ section.id }}" disabled>
            <option value="">Trim</option>
          </select>
          <select class="pt-vf-sel" id="pt-vf-veh-size-{{ section.id }}" disabled>
            <option value="">Tire Size</option>
          </select>
        </div>
        <div class="pt-vfinder__chips-wrap pt-vfinder__chips-wrap--weather" data-vf-vehicle-chips-wrap>
          <div class="pt-vfinder__chips" data-vf-chip-group="vehicle-tires">
            <button type="button" class="pt-vfinder__chip" data-chip="all-season">
              <span class="pt-vfinder__chip-icon" aria-hidden="true">
                <svg viewBox="0 0 16 16" focusable="false">
                  <circle cx="6" cy="6" r="2.5"></circle>
                  <path d="M6 1.2v1.4M6 9.4v1.4M1.2 6h1.4M9.4 6h1.4M2.6 2.6l1 1M8.4 8.4l1 1M9.4 2.6l-1 1M3.6 8.4l-1 1"></path>
                  <path d="M8.8 11.8h4.1a1.9 1.9 0 0 0 0-3.8 2.7 2.7 0 0 0-5.1-.8 2.2 2.2 0 0 0-2.7 2.1 2.4 2.4 0 0 0 2.3 2.5h1.4"></path>
                </svg>
              </span>All-Season
            </button>
            <button type="button" class="pt-vfinder__chip" data-chip="all-weather">
              <span class="pt-vfinder__chip-icon" aria-hidden="true">
                <svg viewBox="0 0 16 16" focusable="false">
                  <path d="M3.1 10.8h7.1a2 2 0 0 0 .1-4 2.8 2.8 0 0 0-5.4-.8A2.2 2.2 0 0 0 2.6 8a2.7 2.7 0 0 0 .5 2.8z"></path>
                  <path d="M6 12.4l.7 1.4M8.5 12.4l.7 1.4M11 12.4l.7 1.4"></path>
                </svg>
              </span>All-Weather
            </button>
            <button type="button" class="pt-vfinder__chip" data-chip="winter">
              <span class="pt-vfinder__chip-icon" aria-hidden="true">
                <svg viewBox="0 0 16 16" focusable="false">
                  <path d="M8 2.2v11.6M3 5.1l10 5.8M13 5.1L3 10.9M5.6 3.6L8 2.2l2.4 1.4M5.6 12.4L8 13.8l2.4-1.4M3 7.9l0-2.8M13 7.9l0-2.8"></path>
                </svg>
              </span>Winter
            </button>
            <button type="button" class="pt-vfinder__chip" data-chip="summer">
              <span class="pt-vfinder__chip-icon" aria-hidden="true">
                <svg viewBox="0 0 16 16" focusable="false">
                  <circle cx="8" cy="8" r="2.6"></circle>
                  <path d="M8 1.4v2M8 12.6v2M1.4 8h2M12.6 8h2M3.1 3.1l1.4 1.4M11.5 11.5l1.4 1.4M12.9 3.1l-1.4 1.4M4.5 11.5l-1.4 1.4"></path>
                </svg>
              </span>Summer
            </button>
          </div>
          <div class="pt-vfinder__chips is-hidden" data-vf-chip-group="vehicle-wheels">
            <button type="button" class="pt-vfinder__chip" data-chip="chrome">Chrome</button>
            <button type="button" class="pt-vfinder__chip" data-chip="gloss-black">Gloss Black</button>
            <button type="button" class="pt-vfinder__chip" data-chip="matte-black">Matte Black</button>
            <button type="button" class="pt-vfinder__chip" data-chip="gunmetal">Gunmetal</button>
            <button type="button" class="pt-vfinder__chip" data-chip="bronze">Bronze</button>
            <button type="button" class="pt-vfinder__chip" data-chip="silver">Silver</button>
          </div>
          <div class="pt-vfinder__actions">
            <button class="pt-vfinder__btn pt-vfinder__btn--ghost" type="button" data-vf-action="clear">Clear</button>
            <button class="pt-vfinder__btn pt-vfinder__btn--search" type="button" data-vf-action="search">Search <span aria-hidden="true">→</span></button>
          </div>
        </div>
      </div>

      <div class="pt-vfinder__panel" data-vf-panel="wheel-specs">
        <div class="pt-vfinder__row">
          <select class="pt-vf-sel" id="pt-vf-ws-diameter-{{ section.id }}">
            <option value="">Diameter</option>
          </select>
          <select class="pt-vf-sel" id="pt-vf-ws-width-{{ section.id }}" disabled>
            <option value="">Width</option>
          </select>
          <select class="pt-vf-sel" id="pt-vf-ws-bolt-{{ section.id }}" disabled>
            <option value="">Bolt Pattern</option>
          </select>
          <select class="pt-vf-sel" id="pt-vf-ws-finish-{{ section.id }}" disabled>
            <option value="">Finish</option>
          </select>
        </div>
        <div class="pt-vfinder__actions">
          <button class="pt-vfinder__btn pt-vfinder__btn--ghost" type="button" data-vf-action="clear">Clear</button>
          <button class="pt-vfinder__btn pt-vfinder__btn--search" type="button" data-vf-action="search">Search <span aria-hidden="true">→</span></button>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <!-- ══════════════════════════════════════
       MAIN: FILTERS + GRID
  ═══════════════════════════════════════ -->
  <div class="pt-col__body">
    {% assign active_filter_count = 0 %}
    {% for filter in collection.filters %}
      {% assign active_filter_count = active_filter_count | plus: filter.active_values.size %}
      {% if filter.type == 'price_range' %}
        {% if filter.min_value.value != blank or filter.max_value.value != blank %}
          {% assign active_filter_count = active_filter_count | plus: 1 %}
        {% endif %}
      {% endif %}
    {% endfor %}

    <!-- ── Filter Sidebar ─────────────────── -->
    <aside class="pt-filters" id="pt-filters-{{ section.id }}" aria-label="Filters">

      <div class="pt-filters__header">
        <button
          type="button"
          class="pt-filters__close-mobile"
          aria-label="Close filters"
          onclick="ptToggleMobileFilters('{{ section.id }}')"
        >
          <span aria-hidden="true">×</span>
        </button>
        <span class="pt-filters__title">{{ section.settings.filter_panel_title | default: 'Filters' }}</span>
        <button class="pt-filters__clear" onclick="ptClearFilters()" id="pt-clear-{{ section.id }}">{{ section.settings.filter_clear_label | default: 'Clear all' }}</button>
      </div>

      <form class="pt-filters__form" id="pt-filters-form-{{ section.id }}" method="get" action="{{ collection.url }}">
        <input type="hidden" name="sort_by" value="{{ collection.sort_by | default: collection.default_sort_by }}">

        <div class="pt-active-filters" id="pt-active-{{ section.id }}">
          {% for filter in collection.filters %}
            {% if filter.type == 'price_range' %}
              {% if filter.min_value.value != blank or filter.max_value.value != blank %}
                <a class="pt-active-chip" href="{{ filter.url_to_remove }}">
                  {% if filter.min_value.value != blank %}{{ filter.min_value.value | money_without_trailing_zeros }}{% else %}$0{% endif %}
                  –
                  {% if filter.max_value.value != blank %}{{ filter.max_value.value | money_without_trailing_zeros }}{% else %}Any{% endif %}
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 2l6 6M8 2l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </a>
              {% endif %}
            {% else %}
              {% for value in filter.active_values %}
                <a class="pt-active-chip" href="{{ value.url_to_remove }}">
                  {{ value.label }}
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 2l6 6M8 2l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </a>
              {% endfor %}
            {% endif %}
          {% endfor %}
        </div>

        {% for filter in collection.filters %}
          {% assign group_id = 'ptfg-native-' | append: forloop.index %}
          <div class="pt-filter-group" id="{{ group_id }}">
            <button class="pt-filter-group__head" onclick="ptToggleGroup('{{ group_id }}'); return false;">
              <span>{{ filter.label }}</span>
              <svg class="pt-fg-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="pt-filter-group__body">
              {% case filter.type %}
                {% when 'boolean', 'list' %}
                  {% for value in filter.values %}
                    {% assign value_is_disabled = false %}
                    {% if value.count == 0 and value.active == false %}
                      {% assign value_is_disabled = true %}
                    {% endif %}
                    <label class="pt-check-item{% if value_is_disabled %} is-disabled{% endif %}">
                      <input
                        type="checkbox"
                        class="pt-check"
                        name="{{ value.param_name }}"
                        value="{{ value.value | escape }}"
                        {% if value.active %}checked{% endif %}
                        {% if value_is_disabled %}disabled{% endif %}
                      >
                      <span class="pt-check-box"></span>
                      <span class="pt-check-label">{{ value.label }}</span>
                      <span class="pt-check-count">{{ value.count }}</span>
                    </label>
                  {% endfor %}
                {% when 'price_range' %}
                  <div class="pt-price-range">
                    <div class="pt-price-row">
                      <div class="pt-field-sm">
                        <span class="pt-label-sm">{{ section.settings.filter_price_min_label | default: 'Min $' }}</span>
                        <input
                          type="number"
                          class="pt-filter-input"
                          name="{{ filter.min_value.param_name }}"
                          placeholder="{{ section.settings.filter_price_min_placeholder | default: '0' }}"
                          min="0"
                          {% if filter.min_value.value != blank %}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                        >
                      </div>
                      <span class="pt-price-dash">—</span>
                      <div class="pt-field-sm">
                        <span class="pt-label-sm">{{ section.settings.filter_price_max_label | default: 'Max $' }}</span>
                        <input
                          type="number"
                          class="pt-filter-input"
                          name="{{ filter.max_value.param_name }}"
                          placeholder="{{ section.settings.filter_price_max_placeholder | default: 'Any' }}"
                          min="0"
                          {% if filter.max_value.value != blank %}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                        >
                      </div>
                    </div>
                  </div>
              {% endcase %}
            </div>
          </div>
        {% else %}
          <div class="pt-filter-group open" id="ptfg-native-empty">
            <button class="pt-filter-group__head" onclick="return false;">
              <span>No filters available</span>
            </button>
          </div>
        {% endfor %}

        <div class="pt-filters__actions">
          <button class="pt-filters__apply" type="submit">Apply filters</button>
        </div>
      </form>

    </aside><!-- /filters -->

    <!-- ── Product Grid ───────────────────── -->
    <div class="pt-grid-wrap">
      <div class="pt-grid-topbar">
        <div class="pt-grid-topbar__left">
          <button
            type="button"
            class="pt-mobile-filter-btn"
            id="pt-mobile-filter-btn-{{ section.id }}"
            onclick="ptToggleMobileFilters('{{ section.id }}')"
            aria-expanded="false"
            aria-controls="pt-filters-{{ section.id }}"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M4 6h16M7 12h10M10 18h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span>{{ section.settings.filter_panel_title | default: 'Filters' }}</span>
            {% if active_filter_count > 0 %}
              <span class="pt-mobile-filter-count">{{ active_filter_count }}</span>
            {% endif %}
          </button>
        </div>
      </div>

      <!-- ── Active filter chips ── -->
      {% assign has_active = false %}
      {% for filter in collection.filters %}
        {% if filter.active_values.size > 0 %}{% assign has_active = true %}{% endif %}
        {% if filter.type == 'price_range' %}
          {% if filter.min_value.value or filter.max_value.value %}{% assign has_active = true %}{% endif %}
        {% endif %}
      {% endfor %}
      {% if has_active %}
        <div class="pt-active-chips" id="pt-active-filters-{{ section.id }}">
          {% for filter in collection.filters %}
            {% for value in filter.active_values %}
              <a href="{{ value.url_to_remove }}" class="pt-chip-active">
                {{ value.label }}
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M1 1l8 8M9 1L1 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </a>
            {% endfor %}
            {% if filter.type == 'price_range' %}
              {% if filter.min_value.value or filter.max_value.value %}
                <a href="{{ filter.url_to_remove }}" class="pt-chip-active">
                  {% if filter.min_value.value %}{{ filter.min_value.value | money }}{% else %}$0{% endif %} – {% if filter.max_value.value %}{{ filter.max_value.value | money }}{% else %}Max{% endif %}
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M1 1l8 8M9 1L1 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </a>
              {% endif %}
            {% endif %}
          {% endfor %}
          <a href="{{ collection.url }}" class="pt-chip-active pt-chip-active--clear">
            Clear all
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M1 1l8 8M9 1L1 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </a>
        </div>
      {% endif %}

      <div class="pt-grid" id="pt-grid-{{ section.id }}">
        {% for product in collection.products %}
          {% assign tire_size    = '' %}
          {% assign tire_season  = '' %}
          {% assign season_label = '' %}
          {% assign season_icon_url = '' %}
          {% assign show_wholesale_price = false %}
          {% assign wholesale_price = 0 %}
          {% assign size_keys_csv = '' %}
          {% assign season_meta_raw = product.metafields.custom.season_type.value | default: product.metafields.custom.season.value | default: product.metafields.specs.season.value | default: product.metafields.details.season.value | default: product.metafields.custom.season_type | default: product.metafields.custom.season | default: product.metafields.specs.season | default: product.metafields.details.season %}
          {% for tag in product.tags %}
            {% if tag contains 'size_' %}
              {% assign tire_size = tag | remove: 'size_' | replace: '-', '/' %}
            {% endif %}
            {% if tire_season == '' %}
              {% assign season_tag_norm = tag | downcase | strip | replace: '_', '-' | replace: ' ', '-' %}
              {% if season_tag_norm contains 'all-weather' or season_tag_norm contains 'allweather' %}
                {% assign tire_season = 'all-weather' %}
              {% elsif season_tag_norm contains 'all-season' or season_tag_norm contains 'allseason' %}
                {% assign tire_season = 'all-season' %}
              {% elsif season_tag_norm contains 'winter' %}
                {% assign tire_season = 'winter' %}
              {% elsif season_tag_norm contains 'summer' %}
                {% assign tire_season = 'summer' %}
              {% endif %}
            {% endif %}
            {% assign tag_norm = tag | downcase | strip | replace: ' ', '' %}
            {% assign size_key = '' %}
            {% if tag_norm contains 'size_' %}
              {% assign size_key = tag_norm | remove: 'size_' | replace: '/', '-' %}
            {% elsif tag_norm contains '/' and tag_norm contains 'r' %}
              {% assign size_key = tag_norm | replace: '/', '-' %}
            {% endif %}
            {% if size_key != blank %}
              {% if size_keys_csv == '' %}
                {% assign size_keys_csv = size_key %}
              {% else %}
                {% assign size_keys_csv = size_keys_csv | append: ',' | append: size_key %}
              {% endif %}
            {% endif %}
          {% endfor %}
          {% if tire_season == '' and season_meta_raw != blank %}
            {% assign season_meta = season_meta_raw | downcase | strip | replace: '_', '-' | replace: ' ', '-' %}
            {% if season_meta contains 'all-weather' or season_meta contains 'allweather' %}
              {% assign tire_season = 'all-weather' %}
            {% elsif season_meta contains 'all-season' or season_meta contains 'allseason' %}
              {% assign tire_season = 'all-season' %}
            {% elsif season_meta contains 'winter' %}
              {% assign tire_season = 'winter' %}
            {% elsif season_meta contains 'summer' %}
              {% assign tire_season = 'summer' %}
            {% endif %}
          {% endif %}
          {% case tire_season %}
            {% when 'winter' %}
              {% assign season_label = 'Winter' %}
              {% if section.settings.icon_winter != blank %}
                {% assign season_icon_url = section.settings.icon_winter | image_url: width: 64 %}
              {% else %}
                {% assign season_icon_url = 'pt-weather-cloud.svg' | asset_url %}
              {% endif %}
            {% when 'summer' %}
              {% assign season_label = 'Summer' %}
              {% if section.settings.icon_summer != blank %}
                {% assign season_icon_url = section.settings.icon_summer | image_url: width: 64 %}
              {% else %}
                {% assign season_icon_url = 'pt-weather-sun-hot.svg' | asset_url %}
              {% endif %}
            {% when 'all-weather' %}
              {% assign season_label = 'All-Weather' %}
              {% if section.settings.icon_all_weather != blank %}
                {% assign season_icon_url = section.settings.icon_all_weather | image_url: width: 64 %}
              {% else %}
                {% assign season_icon_url = 'pt-weather-cloud.svg' | asset_url %}
              {% endif %}
            {% when 'all-season' %}
              {% assign season_label = 'All-Season' %}
              {% if section.settings.icon_all_season != blank %}
                {% assign season_icon_url = section.settings.icon_all_season | image_url: width: 64 %}
              {% else %}
                {% assign season_icon_url = 'pt-weather-partly-cloudy.svg' | asset_url %}
              {% endif %}
          {% endcase %}
          {% capture wpd_discounted_prices %}{%- render 'wcp_discount', wcp_discount: product, wpd_is_render: 'yes' -%}{% endcapture %}
          {% if wpd_discounted_prices contains '|' %}
            {%- capture wholesale_price_raw -%}{%- render 'wcp_render_discount', wpd_discounted_prices: wpd_discounted_prices, price_variable: 'wcp_price' -%}{%- endcapture -%}
            {% assign wholesale_price = wholesale_price_raw | strip | plus: 0 %}
            {% if wholesale_price > 0 and wholesale_price < product.price %}
              {% assign show_wholesale_price = true %}
            {% endif %}
          {% endif %}

          <div class="pt-card{% if tire_season != '' %} pt-card--season-{{ tire_season }}{% endif %}" data-tags="{{ product.tags | join: ',' | downcase }}" data-price="{{ product.price }}" data-vendor="{{ product.vendor | handleize }}" data-size-keys="{{ size_keys_csv | escape }}">

            {%- comment -%}── Season banner strip (colored top edge) ──{%- endcomment -%}
            {% if tire_season != '' and season_label != '' %}
              <div class="pt-card__season-banner pt-card__season-banner--{{ tire_season }}" aria-label="{{ season_label }} tire">
                {% case tire_season %}
                  {% when 'winter' %}
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2v20M2 12h20M4.93 4.93l14.14 14.14M19.07 4.93L4.93 19.07" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
                  {% when 'all-weather' %}
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><path d="M6 20.5A4 4 0 0 1 6 13h1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  {% when 'all-season' %}
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                  {% when 'summer' %}
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/><path d="M12 1v3M12 20v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M1 12h3M20 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                {% endcase %}
                <span>{{ season_label }}</span>
              </div>
            {% endif %}

            <a href="{{ product.url | within: collection }}" class="pt-card__img-wrap">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  width="600"
                  height="400"
                  loading="lazy"
                  class="pt-card__img"
                />
              {% else %}
                <div class="pt-card__img-placeholder">
                  <svg viewBox="0 0 80 80" fill="none" width="60" height="60">
                    <circle cx="40" cy="40" r="36" stroke="#e5e5e5" stroke-width="3"/>
                    <circle cx="40" cy="40" r="22" stroke="#e5e5e5" stroke-width="5"/>
                    <circle cx="40" cy="40" r="8" fill="#e5e5e5"/>
                  </svg>
                </div>
              {% endif %}

              <div class="pt-card__badges">
                {% if product.compare_at_price > product.price %}
                  {% assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                  <span class="pt-badge pt-badge--sale">-{{ discount }}%</span>
                {% endif %}
                {% if product.tags contains 'new' %}
                  <span class="pt-badge pt-badge--new">New</span>
                {% endif %}
              </div>
            </a>

            <div class="pt-card__body">
              <div class="pt-card__top-row">
                <span class="pt-card__brand">{{ product.vendor }}</span>
                {% if tire_size != '' %}
                  <span class="pt-card__size">{{ tire_size }}</span>
                {% endif %}
              </div>

              <a href="{{ product.url | within: collection }}" class="pt-card__title">
                {{ product.title | replace: product.vendor, '' | strip | truncate: 60 }}
              </a>

              <div class="pt-card__tag-row">
                {% for tag in product.tags %}
                  {% if tag contains 'service_' %}
                    <span class="pt-tag">{{ tag | remove: 'service_' }}</span>
                  {% endif %}
                  {% if tag contains 'stud_' %}
                    <span class="pt-tag pt-tag--stud">{{ tag | remove: 'stud_' | replace: '-', ' ' | capitalize }}</span>
                  {% endif %}
                {% endfor %}
              </div>

              <div class="pt-card__footer">
                <div class="pt-card__price-row">
                  <div class="pt-card__price-wrap">
                    {% if product.compare_at_price > product.price %}
                      <span class="pt-price pt-price--sale">{{ product.price | money }}</span>
                      <span class="pt-price pt-price--compare">{{ product.compare_at_price | money }}</span>
                    {% else %}
                      <span class="pt-price">{{ product.price | money }}</span>
                    {% endif %}
                    <span class="pt-price-each">/ each</span>
                  </div>
                  {% if show_wholesale_price %}
                    <div class="pt-card__wholesale-wrap">
                      <span class="pt-price-wholesale-label">Wholesale</span>
                      <span class="pt-price-wholesale">{{ wholesale_price | money }}</span>
                    </div>
                  {% endif %}
                </div>

                {%- comment -%}── Primary CTA: in stock = red, out of stock = silver (disabled look) ──{%- endcomment -%}
                {% if product.available %}
                  <a
                    class="pt-btn-atc"
                    href="{{ product.url | within: collection }}"
                    aria-label="View {{ product.title | escape }}"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/></svg>
                    <span class="pt-btn-atc__label">View</span>
                  </a>
                {% else %}
                  <span class="pt-btn-atc pt-btn-atc--soldout" aria-label="Out of stock — {{ product.title | escape }}">View</span>
                {% endif %}

                <a href="{{ product.url | within: collection }}" class="pt-btn-details">
                  View Details
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              </div>
            </div>
          </div>
        {% else %}
          <div class="pt-empty">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none" opacity=".2">
              <circle cx="32" cy="32" r="28" stroke="#cc2222" stroke-width="2.5"/>
              <circle cx="32" cy="32" r="16" stroke="#cc2222" stroke-width="5"/>
              <circle cx="32" cy="32" r="6" fill="#cc2222"/>
            </svg>
            <p class="pt-empty__title">No tires found</p>
            <p class="pt-empty__sub">Try adjusting your filters</p>
            <button class="pt-empty__btn" onclick="ptClearFilters()">Clear Filters</button>
          </div>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div class="pt-pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="pt-page-btn pt-page-btn--prev">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Prev
            </a>
          {% endif %}
          {% for part in paginate.parts %}
            {% if part.is_link %}
              <a href="{{ part.url }}" class="pt-page-num">{{ part.title }}</a>
            {% elsif part.title == paginate.current_page %}
              <span class="pt-page-num pt-page-num--active">{{ part.title }}</span>
            {% else %}
              <span class="pt-page-ellipsis">…</span>
            {% endif %}
          {% endfor %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="pt-page-btn pt-page-btn--next">
              Next
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>

  <div class="pt-filter-overlay" id="pt-overlay-{{ section.id }}" onclick="ptToggleMobileFilters('{{ section.id }}')"></div>
</div>

{%- comment -%} Phase 2: Tire comparison tray (select up to 3 tires to compare) {%- endcomment -%}
{%- render 'compare-tray' -%}

{% endpaginate %}

<style>
/* Sprint 5: Collection tokens now reference global design-tokens.css */
