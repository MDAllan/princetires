.pt-col__body { max-width: none; width: 100%; margin: 0; padding: 28px 24px; display: grid; grid-template-columns: 1fr; gap: 24px; background: var(--white); }
@media (min-width: 900px) { .pt-col__body { grid-template-columns: 400px 1fr; padding: 32px 48px; align-items: start; } }
