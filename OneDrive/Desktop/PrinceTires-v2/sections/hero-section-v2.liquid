</style>

<script>
(function() {
  var wrap = document.querySelector('#hero-{{ sid }} .pt-hero__search-wrap');
  if (!wrap) return;

  var input        = wrap.querySelector('[data-search-input]');
  var dropdown     = wrap.querySelector('[data-search-dropdown]');
  var popularDiv   = wrap.querySelector('[data-search-popular]');
  var resultsDiv   = wrap.querySelector('[data-search-results]');
  var itemsDiv     = wrap.querySelector('[data-search-items]');
  var viewAllLink  = wrap.querySelector('[data-search-view-all]');
  var modeDiv      = wrap.querySelector('[data-search-mode]');
  var modeIcon     = wrap.querySelector('[data-search-mode-icon]');
  var modeText     = wrap.querySelector('[data-search-mode-text]');
  var resultsLabel = wrap.querySelector('[data-search-results-label]');
  var form         = wrap.querySelector('[data-search-form]');
  var aiResultDiv  = wrap.querySelector('[data-ai-result]');

  /* Collection page URL — where we redirect with filter params */
  var COLLECTION_URL = '{{ section.settings.shop_tires_url | default: "/collections/all" }}';
  var SMART_SEARCH_API = 'https://prince-tires-booking.princetires111.workers.dev/smart-search';
  var baseVehicleUrl = {{ sample_vehicle_url | json }};
  var vehicleCache = {};
  var searchAbort = null;
  var debounceTimer = null;

  /* ─────────────────────────────────────────────────────────
     TIER 1: TIRE SIZE PARSER
     Handles every real-world format customers type
  ───────────────────────────────────────────────────────── */
  function parseTireSize(raw) {
    if (!raw) return null;

    /* Strip leading type prefixes: P, LT, ST, T */
    var s = raw.replace(/^\s*(P|LT|ST|T)/i, '').trim();

    /* Normalise separators: allow / - or space between numbers */
    /* Try: 225/65R17, 225-65-17, 225 65 17, 225/65/17, 22565r17, 225 65r17 */
    var patterns = [
      /* standard / and optional R: 225/65R17 or 225/65/17 */
      /^(\d{3})[\/\-](\d{2})[\/\-]?[Rr]?(\d{2})$/,
      /* no separator at all: 22565R17 or 22565r17 */
      /^(\d{3})(\d{2})[Rr](\d{2})$/,
      /* three numbers with spaces: 225 65 17 or 225 65r17 */
      /^(\d{3})\s+(\d{2})\s*[Rr]?\s*(\d{2})$/
    ];

    for (var i = 0; i < patterns.length; i++) {
      var m = s.match(patterns[i]);
      if (m) {
        return { width: m[1], aspect: m[2], diameter: m[3],
                 normalized: m[1] + '/' + m[2] + 'R' + m[3] };
      }
    }

    /* Also try to FIND a tire size embedded in a longer string
       e.g. "tires 225/65r17 winter" or "need 225 65 17 all season" */
    var embedded = raw.match(/\b(P|LT|ST)?(\d{3})[\/\-\s](\d{2})[\/\-\s]?[Rr]?(\d{2})\b/);
    if (embedded) {
      return { width: embedded[2], aspect: embedded[3], diameter: embedded[4],
               normalized: embedded[2] + '/' + embedded[3] + 'R' + embedded[4] };
    }

    return null;
  }

  /* ─────────────────────────────────────────────────────────
     TIER 2: VEHICLE PARSER
     Handles year anywhere, nicknames, partial models
  ───────────────────────────────────────────────────────── */
  var makeAliases = {
    'chevy': 'Chevrolet', 'chev': 'Chevrolet',
    'vw': 'Volkswagen', 'volkswagon': 'Volkswagen',
    'benz': 'Mercedes-Benz', 'mercedes': 'Mercedes-Benz',
    'ram': 'RAM', 'dodge ram': 'RAM',
    'land rover': 'Land Rover', 'landrover': 'Land Rover',
    'gmc': 'GMC', 'bmw': 'BMW', 'kia': 'Kia',
    'jeep': 'Jeep', 'ford': 'Ford', 'honda': 'Honda',
    'toyota': 'Toyota', 'nissan': 'Nissan', 'hyundai': 'Hyundai',
    'subaru': 'Subaru', 'mazda': 'Mazda', 'audi': 'Audi',
    'lexus': 'Lexus', 'acura': 'Acura', 'infiniti': 'Infiniti',
    'mitsubishi': 'Mitsubishi', 'volvo': 'Volvo', 'porsche': 'Porsche',
    'tesla': 'Tesla', 'lincoln': 'Lincoln', 'cadillac': 'Cadillac',
    'buick': 'Buick', 'chrysler': 'Chrysler', 'dodge': 'Dodge'
  };

  function parseVehicle(raw) {
    if (!raw) return null;
    var q = raw.toLowerCase().trim();

    /* Strip noise words */
    q = q.replace(/\b(tires?|wheels?|rims?|for|my|a|the|need|looking|fit|size|what|fits)\b/g, ' ')
          .replace(/\s+/g, ' ').trim();

    /* Extract year — 4-digit first, then 2-digit (19 → 2019, 20-26 → 202x) */
    var year = null;
    var yearMatch = q.match(/\b(19[8-9]\d|20[0-2]\d)\b/);
    if (yearMatch) {
      year = yearMatch[1];
      q = q.replace(yearMatch[0], '').trim();
    } else {
      /* 2-digit short year: '24 civic → 2024 civic */
      var shortYear = q.match(/\b'?(\d{2})\b/);
      if (shortYear) {
        var yr = parseInt(shortYear[1]);
        if (yr >= 8 && yr <= 26) {
          year = (yr <= 26 ? '20' : '19') + (yr < 10 ? '0' + yr : yr);
          q = q.replace(shortYear[0], '').trim();
        }
      }
    }

    if (!year) return null; /* need a year to look up OEM sizes */

    /* Identify make from aliases */
    var foundMake = null;
    var foundMakeRaw = null;
    var makeKeys = Object.keys(makeAliases);
    /* Sort by length desc so "land rover" matches before "land" */
    makeKeys.sort(function(a, b) { return b.length - a.length; });
    for (var i = 0; i < makeKeys.length; i++) {
      if (q.indexOf(makeKeys[i]) !== -1) {
        foundMake = makeAliases[makeKeys[i]];
        foundMakeRaw = makeKeys[i];
        q = q.replace(foundMakeRaw, '').replace(/\s+/g, ' ').trim();
        break;
      }
    }
    if (!foundMake) return null;

    /* Remaining text is the model */
    var model = q.trim().replace(/\s+/g, ' ');
    if (!model) return null;

    /* Title-case the model */
    model = model.split(' ').map(function(w) {
      return w.charAt(0).toUpperCase() + w.slice(1);
    }).join(' ');

    return { year: year, make: foundMake, model: model,
             label: year + ' ' + foundMake + ' ' + model };
  }

  /* ─────────────────────────────────────────────────────────
     TIER 3: KEYWORD / SEASON / BRAND DETECTION
  ───────────────────────────────────────────────────────── */
  var seasonKeywords = {
    'winter': 'winter', 'snow': 'winter', 'ice': 'winter',
    'all season': 'all-season', 'all-season': 'all-season', 'allseason': 'all-season', 'as': 'all-season',
    'all weather': 'all-weather', 'all-weather': 'all-weather', 'allweather': 'all-weather',
    'summer': 'summer', 'performance': 'summer'
  };
  var brands = ['michelin','bridgestone','goodyear','continental','pirelli','hankook',
                'toyo','falken','kumho','nexen','nokian','cooper','firestone',
                'bfgoodrich','yokohama','dunlop','general','nitto','maxxis'];

  function detectKeyword(q) {
    var lower = q.toLowerCase().trim();
    /* Wheels/rims */
    if (/\b(rims?|wheels?)\b/.test(lower)) {
      return { type: 'wheels' };
    }
    /* Season */
    var seasonKeys = Object.keys(seasonKeywords);
    for (var i = 0; i < seasonKeys.length; i++) {
      if (lower.indexOf(seasonKeys[i]) !== -1) {
        return { type: 'season', season: seasonKeywords[seasonKeys[i]] };
      }
    }
    /* Brand */
    for (var j = 0; j < brands.length; j++) {
      if (lower.indexOf(brands[j]) !== -1) {
        return { type: 'brand', brand: brands[j] };
      }
    }
    return null;
  }

  /* ─────────────────────────────────────────────────────────
     MASTER PARSE — runs all tiers in order
  ───────────────────────────────────────────────────────── */
  function parseInput(raw) {
    if (!raw || !raw.trim()) return null;
    var tireSize = parseTireSize(raw);
    if (tireSize) return { type: 'tire-size', data: tireSize };
    var vehicle = parseVehicle(raw);
    if (vehicle) return { type: 'vehicle', data: vehicle };
    var keyword = detectKeyword(raw);
    if (keyword) return { type: keyword.type, data: keyword };
    return { type: 'general', data: { query: raw.trim() } };
  }

  /* ─────────────────────────────────────────────────────────
     REDIRECT — builds proper collection URL with filters
  ───────────────────────────────────────────────────────── */
  function buildRedirectUrl(parsed) {
    if (!parsed) return COLLECTION_URL;
    var base = COLLECTION_URL;

    if (parsed.type === 'tire-size') {
      return base + '?size=' + encodeURIComponent(parsed.data.normalized);
    }
    if (parsed.type === 'season') {
      return base + '?season=' + encodeURIComponent(parsed.data.season);
    }
    if (parsed.type === 'brand') {
      return base + '?q=' + encodeURIComponent(parsed.data.brand);
    }
    if (parsed.type === 'wheels') {
      return '{{ section.settings.shop_wheels_url | default: "/collections/wheels" }}';
    }
    if (parsed.type === 'vehicle') {
      return base + '?vehicle=' + encodeURIComponent(parsed.data.label);
    }
    /* general fallback */
    return base + '?q=' + encodeURIComponent(parsed.data.query);
  }

  /* ─────────────────────────────────────────────────────────
     VEHICLE JSON LOOKUP
  ───────────────────────────────────────────────────────── */
  function vehicleUrlForYear(year) {
    return baseVehicleUrl.replace('pt-vehicle-2008', 'pt-vehicle-' + year);
  }
  function normalizeKey(s) {
    return String(s || '').toLowerCase().replace(/[^a-z0-9]/g, '');
  }
  function getLooseKey(obj, key) {
    if (!obj) return null;
    if (obj[key]) return obj[key];
    var wanted = normalizeKey(key);
    var keys = Object.keys(obj);
    for (var i = 0; i < keys.length; i++) {
      if (normalizeKey(keys[i]) === wanted) return obj[keys[i]];
    }
    /* partial match: key starts with wanted */
    for (var j = 0; j < keys.length; j++) {
      if (normalizeKey(keys[j]).indexOf(wanted) === 0 || wanted.indexOf(normalizeKey(keys[j])) === 0) {
        return obj[keys[j]];
      }
    }
    return null;
  }
  function fetchVehicleData(year) {
    if (vehicleCache[year]) return Promise.resolve(vehicleCache[year]);
    return fetch(vehicleUrlForYear(year))
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(data) { vehicleCache[year] = data; return data; })
      .catch(function() { return null; });
  }
  function lookupOemSizes(data, make, model) {
    if (!data || !data.models) return [];
    var makeData = getLooseKey(data.models, make);
    if (!makeData) return [];
    var modelData = getLooseKey(makeData, model);
    if (!modelData) return [];
    var sizeMap = {};
    if (Array.isArray(modelData)) {
      modelData.forEach(function(s) {
        var size = String(s).trim();
        if (size) sizeMap[size] = ['All Trims'];
      });
    } else {
      Object.keys(modelData).forEach(function(trim) {
        var sizes = modelData[trim];
        if (!Array.isArray(sizes)) return;
        sizes.forEach(function(s) {
          var size = (typeof s === 'string' ? s : (s.tireSize || s.size || '')).trim();
          if (!size) return;
          if (!sizeMap[size]) sizeMap[size] = [];
          sizeMap[size].push(trim);
        });
      });
    }
    return Object.keys(sizeMap).map(function(size) {
      return { size: size, trims: sizeMap[size] };
    });
  }

  /* ─────────────────────────────────────────────────────────
     UI HELPERS
  ───────────────────────────────────────────────────────── */
  function openDropdown() {
    dropdown.classList.add('is-open');
    wrap.classList.add('has-dropdown');
  }
  function closeDropdown() {
    dropdown.classList.remove('is-open');
    wrap.classList.remove('has-dropdown');
  }

  function buildFilterQuery(size, vehicle) {
    var params = new URLSearchParams();
    var parsed = parseTireSizeInput(size);
    if (parsed) {
      params.set('filter.p.m.custom.tire_width', parsed.width);
      params.set('filter.p.m.custom.tire_profile', parsed.profile);
      params.set('filter.p.m.custom.rim_diameter', parsed.rim);
    } else {
      params.set('size', size);
    }
    if (vehicle) {
      if (vehicle.year) params.set('vehicle_year', vehicle.year);
      if (vehicle.make) params.set('vehicle_make', vehicle.make);
      if (vehicle.model) params.set('vehicle_model', vehicle.model);
      if (vehicle.trim) params.set('vehicle_trim', vehicle.trim);
      if (vehicle.year && vehicle.make && vehicle.model && vehicle.trim) {
        params.set('vehicle', vehicle.year + ' ' + vehicle.make + ' ' + vehicle.model + ' ' + vehicle.trim);
      }
    }
    return params.toString();
  }

  function buildSizeRow(size, trims, vehicle) {
    var enc = encodeURIComponent(size);
    var trimText = (trims || []).join(', ');
    if (trimText.length > 80) trimText = trimText.substring(0, 77) + '...';
    var filterQuery = buildFilterQuery(size, vehicle);
    var baseUrl = COLLECTION_URL + '?' + filterQuery;
    return '<div class="pt-hero__ai-size-row" style="cursor:pointer" onclick="window.location=\'' + baseUrl + '\'">'
      + (trimText ? '<div class="pt-hero__ai-size-row__trims">' + trimText + '</div>' : '')
      + '<div class="pt-hero__ai-size-row__size">' + size + '</div>'
      + '<div class="pt-hero__ai-size-row__seasons">'
      + '<a href="' + baseUrl + '&filter.p.product_type=Winter+Tires" class="pt-hero__ai-season-pill pt-hero__ai-season-pill--winter">❄ Winter</a>'
      + '<a href="' + baseUrl + '&filter.p.product_type=All-Season+Tires" class="pt-hero__ai-season-pill pt-hero__ai-season-pill--allseason">🌿 All-Season</a>'
      + '<a href="' + baseUrl + '&filter.p.product_type=All-Weather+Tires" class="pt-hero__ai-season-pill pt-hero__ai-season-pill--allweather">⛅ All-Weather</a>'
      + '</div>'
      + '</div>';
  }

  /* ─────────────────────────────────────────────────────────
     SMART SEARCH API CALL (with local-first fallback)
  ───────────────────────────────────────────────────────── */
  function doSmartSearch(q) {
    if (searchAbort) searchAbort.abort();
    searchAbort = new AbortController();

    /* Run local parser first — if confident, show instantly */
    var local = parseInput(q);
    if (local && local.type === 'tire-size') {
      showTireSizeResult(local.data.normalized, []);
      return;
    }
    if (local && local.type === 'vehicle') {
      /* local vehicle — fetch JSON directly */
      showVehicleLoading(local.data.label);
      fetchVehicleData(local.data.year).then(function(yearData) {
        var sizes = lookupOemSizes(yearData, local.data.make, local.data.model);
        showVehicleResult(local.data, sizes);
      });
      return;
    }
    if (local && local.type === 'season') {
      showKeywordResult('\uD83C\uDF19 Season filter', 'Tap to browse ' + local.data.season + ' tires', COLLECTION_URL + '?season=' + local.data.season);
      return;
    }
    if (local && local.type === 'brand') {
      showKeywordResult('\uD83C\uDFF7\uFE0F Brand', 'Browse ' + local.data.brand + ' tires', COLLECTION_URL + '?q=' + encodeURIComponent(local.data.brand));
      return;
    }
    if (local && local.type === 'wheels') {
      showKeywordResult('\u26AA Wheels & Rims', 'Shop our full wheels collection', '{{ section.settings.shop_wheels_url | default: "/collections/wheels" }}');
      return;
    }

    /* Fallback: hit the smart search API for ambiguous queries */
    aiResultDiv.style.display = '';
    aiResultDiv.innerHTML = '<div class="pt-hero__ai-badge pt-hero__ai-badge--loading">\uD83D\uDD0D Searching\u2026</div>';
    popularDiv.style.display = 'none';
    resultsDiv.style.display = 'none';

    fetch(SMART_SEARCH_API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ query: q }),
      signal: searchAbort.signal
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.intent === 'vehicle' && data.vehicle && data.vehicle.year) {
        showVehicleLoading(data.vehicle.year + ' ' + data.vehicle.make + ' ' + data.vehicle.model);
        fetchVehicleData(data.vehicle.year).then(function(yearData) {
          var sizes = lookupOemSizes(yearData, data.vehicle.make, data.vehicle.model);
          showVehicleResult(data.vehicle, sizes);
        });
      } else if (data.intent === 'size' && data.size) {
        showTireSizeResult(data.size.formatted, []);
      } else {
        aiResultDiv.style.display = 'none';
        fetchShopifyResults(q);
      }
    })
    .catch(function(err) {
      if (err.name === 'AbortError') return;
      aiResultDiv.style.display = 'none';
      fetchShopifyResults(q);
    });
  }

  function showVehicleLoading(label) {
    aiResultDiv.style.display = '';
    aiResultDiv.innerHTML = '<div class="pt-hero__ai-badge pt-hero__ai-badge--loading">\uD83D\uDE97 ' + label + ' \u2014 loading sizes\u2026</div>';
    popularDiv.style.display = 'none';
    resultsDiv.style.display = 'none';
  }

  function showVehicleResult(vehicle, oemSizes) {
    var label = vehicle.year + ' ' + vehicle.make + ' ' + (vehicle.model || '');
    if (vehicle.trim) {
      label += ' ' + vehicle.trim;
    }
    var allSizes = oemSizes.map(function(s) { return s.size; }).join(', ') || 'not found';
    var trimPrompt = '';
    if (!vehicle.trim && oemSizes.some(function(item){ return Array.isArray(item.trims) && item.trims.length > 1; })) {
      trimPrompt = '<p style="color: #ffe4e1; margin: 8px 0 6px; font-size: 13px;">Please select your trim to confirm fitment before choosing a size. Then pick the size row.</p>';
    }
    var html = '<div class="pt-hero__ai-badge pt-hero__ai-badge--vehicle">\uD83D\uDE97 Vehicle found</div>';
    html += '<p class="pt-hero__ai-info">\u2014 ' + label + ' \u2014 OEM sizes: ' + allSizes + '</p>';
    if (trimPrompt) html += trimPrompt;
    if (oemSizes.length > 0) {
      html += '<p class="pt-hero__ai-label">SELECT YOUR SIZE</p>';
      html += '<div class="pt-hero__ai-sizes">';
      oemSizes.forEach(function(item) {
        html += buildSizeRow(item.size, item.trims, vehicle);
      });
      html += '</div>';
    } else {
      html += '<a href="' + COLLECTION_URL + '?vehicle=' + encodeURIComponent(label) + '" class="pt-hero__ai-size-link">Browse tires for ' + label + ' \u2192</a>';
    }
    aiResultDiv.innerHTML = html;
    aiResultDiv.style.display = '';
    popularDiv.style.display = 'none';
    resultsDiv.style.display = 'none';
  }

  function showTireSizeResult(size, trims) {
    var html = '<div class="pt-hero__ai-badge pt-hero__ai-badge--size">\uD83D\uDCD0 Tire size detected</div>';
    html += '<p class="pt-hero__ai-info">Size: ' + size + '</p>';
    html += '<div class="pt-hero__ai-sizes">' + buildSizeRow(size, trims) + '</div>';
    aiResultDiv.innerHTML = html;
    aiResultDiv.style.display = '';
    popularDiv.style.display = 'none';
    resultsDiv.style.display = 'none';
  }

  function showKeywordResult(badge, info, href) {
    var html = '<div class="pt-hero__ai-badge pt-hero__ai-badge--vehicle">' + badge + '</div>';
    html += '<p class="pt-hero__ai-info">' + info + '</p>';
    html += '<a href="' + href + '" class="pt-hero__ai-size-link">Browse now \u2192</a>';
    aiResultDiv.innerHTML = html;
    aiResultDiv.style.display = '';
    popularDiv.style.display = 'none';
    resultsDiv.style.display = 'none';
  }

  function fetchShopifyResults(q) {
    var url = '/search/suggest.json?q=' + encodeURIComponent(q) + '&resources[type]=product&resources[limit]=6';
    fetch(url)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var products = (data.resources && data.resources.results && data.resources.results.products) || [];
        if (!products.length) { resultsDiv.style.display = 'none'; return; }
        resultsLabel.textContent = products.length + ' result' + (products.length !== 1 ? 's' : '');
        itemsDiv.innerHTML = '';
        products.forEach(function(p) {
          var img = (p.image || p.featured_image || {}).url || '';
          var price = p.price ? ('$' + (parseFloat(p.price) / 100).toFixed(2)) : '';
          var a = document.createElement('a');
          a.href = p.url;
          a.className = 'pt-hero__search-item';
          a.innerHTML =
            (img ? '<img class="pt-hero__search-item-img" src="' + img + '" alt="" loading="lazy">' : '<div class="pt-hero__search-item-img"></div>') +
            '<div class="pt-hero__search-item-info">' +
              (p.vendor ? '<p class="pt-hero__search-item-brand">' + p.vendor + '</p>' : '') +
              '<p class="pt-hero__search-item-title">' + (p.title || '') + '</p>' +
            '</div>' +
            (price ? '<span class="pt-hero__search-item-price">' + price + '</span>' : '');
          itemsDiv.appendChild(a);
        });
        viewAllLink.href = '/search?q=' + encodeURIComponent(q) + '&type=product';
        resultsDiv.style.display = '';
      })
      .catch(function() { resultsDiv.style.display = 'none'; });
  }

  /* ── Event listeners ──────────────────────────────────── */
  input.addEventListener('input', function() {
    var q = input.value.trim();
    clearTimeout(debounceTimer);
    var local = parseInput(q);
    if (local && modeDiv) {
      var icons = { 'tire-size': '\uD83D\uDCD0', 'vehicle': '\uD83D\uDE97', 'season': '\u2744\uFE0F', 'brand': '\uD83C\uDFF7\uFE0F', 'wheels': '\u26AA' };
      modeIcon.textContent = icons[local.type] || '\uD83D\uDD0D';
      modeText.textContent = local.type === 'tire-size' ? 'Tire size: ' + local.data.normalized
        : local.type === 'vehicle' ? 'Vehicle: ' + local.data.label
        : local.type === 'season' ? 'Season: ' + local.data.season
        : local.type === 'brand' ? 'Brand: ' + local.data.brand
        : local.type === 'wheels' ? 'Wheels & Rims' : 'Searching\u2026';
      modeDiv.style.display = '';
    } else if (modeDiv) {
      modeDiv.style.display = 'none';
    }

    if (q.length < 2) {
      if (popularDiv) popularDiv.style.display = '';
      if (resultsDiv) resultsDiv.style.display = 'none';
      if (aiResultDiv) aiResultDiv.style.display = 'none';
      openDropdown(); return;
    }
    if (popularDiv) popularDiv.style.display = 'none';
    debounceTimer = setTimeout(function() { doSmartSearch(q); }, 350);
    openDropdown();
  });

  input.addEventListener('focus', function() {
    openDropdown();
    if (!input.value.trim()) {
      if (popularDiv) popularDiv.style.display = '';
      if (resultsDiv) resultsDiv.style.display = 'none';
      if (aiResultDiv) aiResultDiv.style.display = 'none';
    }
  });

  document.addEventListener('click', function(e) {
    if (!wrap.contains(e.target)) closeDropdown();
  });

  input.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeDropdown(); input.blur(); }
  });

  /* Pill clicks */
  wrap.querySelectorAll('[data-search-suggest]').forEach(function(pill) {
    pill.addEventListener('click', function() {
      input.value = pill.getAttribute('data-search-suggest');
      input.dispatchEvent(new Event('input'));
      input.focus();
    });
  });

  /* Form submit — smart redirect using master parser */
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var q = input.value.trim();
    if (!q) return;
    var parsed = parseInput(q);
    window.location.href = buildRedirectUrl(parsed);
    closeDropdown();
  });
})();
</script>

