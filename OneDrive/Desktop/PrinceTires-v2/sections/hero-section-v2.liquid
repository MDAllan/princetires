      padding: 16px 56px 16px 18px;
      font-size: 15px;
    }

    /* ── Compact inline action pills on mobile ──────────── */
    #hero-{{ sid }} .pt-hero__actions {
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      gap: 8px;
      flex-wrap: nowrap;
    }
    #hero-{{ sid }} .pt-hero__action {
      padding: 7px 14px;
      font-size: 12px;
      min-width: unset;
      gap: 5px;
      border-color: rgba(255,255,255,0.12);
