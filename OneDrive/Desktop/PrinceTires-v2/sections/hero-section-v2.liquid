    #hero-{{ sid }} .pt-hero__action svg {
      width: 13px;
      height: 13px;
    }
    #hero-{{ sid }} .pt-hero__action-label-full  { display: none; }
    #hero-{{ sid }} .pt-hero__action-label-short { display: inline; }

    /* Dropdown mobile tweaks */
    #hero-{{ sid }} .pt-hero__search-dropdown {
      max-height: 340px;
      padding: 12px;
    }
    #hero-{{ sid }} .pt-hero__search-pills {
      gap: 6px;
    }
    #hero-{{ sid }} .pt-hero__search-pill {
      font-size: 11px;
      padding: 6px 11px;
    }
    #hero-{{ sid }} .pt-hero__search-item-img {
      width: 38px;
      height: 38px;
    }
    #hero-{{ sid }} .pt-hero__ai-season-pill {
      font-size: 10px;
      padding: 4px 10px;
