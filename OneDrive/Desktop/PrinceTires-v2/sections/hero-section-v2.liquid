{%- assign sample_vehicle_url = 'pt-vehicle-2008.json' | asset_url -%}
{% comment %}
  PRINCE TIRES — HERO SECTION V2 (MINIMAL CENTERED)
  Matches prototype: black bg, centered headline, search bar, pill CTAs
  Smart search autocomplete with popular searches, live results, mode detection
  AI-powered smart search for vehicle lookups and tire size detection
  Season pills (winter / all-season / all-weather) for size & vehicle results
{% endcomment %}

{%- liquid
  assign bg_color     = section.settings.bg_color     | default: '#000000'
  assign accent_color = section.settings.accent_color | default: '#B91C1C'
  assign text_color   = section.settings.text_color   | default: '#FFFFFF'
  assign muted_color  = section.settings.muted_color  | default: '#6B7280'
  assign sid          = section.id
-%}

<section
  id="hero-{{ sid }}"
  class="pt-hero"
  role="banner"
  {{ section.shopify_attributes }}
  style="
    --hero-bg: {{ bg_color }};
    --hero-accent: {{ accent_color }};
    --hero-text: {{ text_color }};
    --hero-muted: {{ muted_color }};
  "
>
  {%- comment -%} Decorative red glow — top-right {%- endcomment -%}
  <div class="pt-hero__glow" aria-hidden="true"></div>

  {%- comment -%} Bottom fade for smooth section transition {%- endcomment -%}
  <div class="pt-hero__fade" aria-hidden="true"></div>

  <div class="pt-hero__inner">

    {%- comment -%} ── Headline ────────────────────────────── {%- endcomment -%}
    <h1 class="pt-hero__headline pt-hero__anim" style="--delay: 0.1s">
      {{ section.settings.headline_line1 | default: "Calgary's Trusted" }}<br>
      <em>{{ section.settings.headline_accent | default: "Tire Shop" }}</em>
    </h1>

    <p class="pt-hero__sub pt-hero__anim" style="--delay: 0.2s">
      {{ section.settings.subtitle | default: "The right tires the right price" }}
    </p>

    {%- comment -%} ── Smart Search label ───────────────────── {%- endcomment -%}
    <div class="pt-hero__smart-label pt-hero__anim" style="--delay: 0.25s">
      <span class="pt-hero__smart-dot" aria-hidden="true"></span>
      <span class="pt-hero__smart-text">Powered by <strong>Smart Search</strong></span>
    </div>

    {%- comment -%} ── Search bar ──────────────────────────── {%- endcomment -%}
    <div class="pt-hero__search-wrap pt-hero__anim" style="--delay: 0.3s">
      <form
        action="{{ section.settings.search_url | default: '/pages/tires-1' }}"
        method="get"
        class="pt-hero__search-form"
        role="search"
        aria-label="Search tires"
        data-search-form
      >
        <input
          type="text"
          name="q"
          class="pt-hero__search-input"
          placeholder="{{ section.settings.search_placeholder | default: 'e.g. 2025 Toyota RAV4 or 225/65R17' }}"
          autocomplete="off"
          aria-label="Search by vehicle or tire size"
          data-search-input
        >
        <button type="submit" class="pt-hero__search-go" aria-label="Search tires">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </button>
      </form>

      {%- comment -%} ── Search dropdown / autocomplete ─────── {%- endcomment -%}
      <div class="pt-hero__search-dropdown" data-search-dropdown>
        <div class="pt-hero__ai-result" data-ai-result style="display:none"></div>
        <div class="pt-hero__search-popular" data-search-popular style="display:none"></div>
        <div class="pt-hero__search-results" data-search-results style="display:none">
          <p class="pt-hero__search-dropdown-label" data-search-results-label>Results</p>
          <div class="pt-hero__search-items" data-search-items></div>
          <a href="#" class="pt-hero__search-view-all" data-search-view-all>View all results &rarr;</a>
        </div>
        <div class="pt-hero__search-mode" data-search-mode style="display:none">
          <div class="pt-hero__search-mode-icon" data-search-mode-icon></div>
          <div class="pt-hero__search-mode-text" data-search-mode-text></div>
        </div>
      </div>
    </div>

    {%- comment -%} ── Action pills ────────────────────────── {%- endcomment -%}
    <div class="pt-hero__actions pt-hero__anim" style="--delay: 0.45s">
      {%- if section.settings.action_1_text != blank -%}
        <a href="{{ section.settings.shop_tires_url | default: '/collections/all' }}" class="pt-hero__action">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
          <span class="pt-hero__action-label-full">{{ section.settings.action_1_text }}</span>
          <span class="pt-hero__action-label-short">Tires</span>
        </a>
      {%- endif -%}

      {%- if section.settings.action_2_text != blank -%}
        <a href="{{ section.settings.shop_wheels_url | default: '/collections/wheels' }}" class="pt-hero__action">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="1"/></svg>
          <span class="pt-hero__action-label-full">{{ section.settings.action_2_text }}</span>
          <span class="pt-hero__action-label-short">Wheels</span>
        </a>
      {%- endif -%}

      {%- if section.settings.action_3_text != blank -%}
        <a href="tel:{{ section.settings.phone_number | default: '4034524283' }}" class="pt-hero__action">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <span class="pt-hero__action-label-full">{{ section.settings.action_3_text }}</span>
          <span class="pt-hero__action-label-short">Book</span>
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

<style>
  /* ── Hero container ─────────────────────────────────────── */
  #hero-{{ sid }} {
    position: relative;
    min-height: 100vh;
    background: var(--hero-bg);
    overflow: clip;
    display: flex;
    align-items: center;
    padding: 120px 0 120px;
  }

  /* ── Decorative glow ────────────────────────────────────── */
  #hero-{{ sid }} .pt-hero__glow {
    position: absolute;
    top: -200px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(185,28,28,0.08) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  /* ── Bottom fade for smooth section transition ──────────── */
  #hero-{{ sid }} .pt-hero__fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, var(--hero-bg));
    pointer-events: none;
    z-index: 1;
  }

  /* ── Inner content ──────────────────────────────────────── */
  #hero-{{ sid }} .pt-hero__inner {
    position: relative;
    z-index: 2;
    max-width: 680px;
    margin: 0;
    padding: 0 56px;
    text-align: left;
    width: 100%;
  }

  /* ── Headline ───────────────────────────────────────────── */
  #hero-{{ sid }} .pt-hero__headline {
    font-size: clamp(32px, 4.5vw, 52px);
    font-weight: 800;
    line-height: 1.08;
    color: var(--hero-text);
    letter-spacing: -0.04em;
    margin: 0 0 16px;
  }

  #hero-{{ sid }} .pt-hero__headline em {
    font-style: normal;
    color: var(--hero-accent);
  }

  /* ── Subtitle ───────────────────────────────────────────── */
  #hero-{{ sid }} .pt-hero__sub {
    font-size: 15px;
    color: var(--hero-muted);
    max-width: 400px;
    margin: 0 0 40px;
    line-height: 1.6;
    font-weight: 400;
    letter-spacing: 0;
  }

  /* ── Smart Search label ──────────────────────────────────── */
  #hero-{{ sid }} .pt-hero__smart-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 12px;
    padding: 5px 14px 5px 10px;
    background: rgba(185,28,28,0.08);
    border: 1px solid rgba(185,28,28,0.2);
    border-radius: 999px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  #hero-{{ sid }} .pt-hero__smart-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #B91C1C;
    box-shadow: 0 0 6px rgba(185,28,28,0.6);
    animation: ptSmartPulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes ptSmartPulse {
    0%, 100% { box-shadow: 0 0 4px rgba(185,28,28,0.4); opacity: 1; }
    50% { box-shadow: 0 0 10px rgba(185,28,28,0.8); opacity: 0.7; }
  }

  #hero-{{ sid }} .pt-hero__smart-text {
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.45);
    font-weight: 400;
  }

  #hero-{{ sid }} .pt-hero__smart-text strong {
    color: rgba(255,255,255,0.7);
    font-weight: 600;
  }

  /* ── Mobile/desktop label toggling ─────────────────────── */
  #hero-{{ sid }} .pt-hero__action-label-short { display: none; }
  #hero-{{ sid }} .pt-hero__action-label-full  { display: inline; }

  /* ── Search bar ─────────────────────────────────────────── */
  #hero-{{ sid }} .pt-hero__search-wrap {
    position: relative;
    max-width: 520px;
    margin: 0 0 28px;
  }

  #hero-{{ sid }} .pt-hero__search-form {
    position: relative;
  }

  #hero-{{ sid }} .pt-hero__search-input {
    width: 100%;
    padding: 18px 60px 18px 22px;
    background: rgba(255,255,255,0.06);
    border: 1.5px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    color: var(--hero-text);
    font-size: 16px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
    -webkit-appearance: none;
  }

  #hero-{{ sid }} .pt-hero__search-input::placeholder {
    color: var(--hero-muted);
  }

  #hero-{{ sid }} .pt-hero__search-input:focus {
    border-color: var(--hero-accent);
    box-shadow: 0 0 0 3px rgba(185,28,28,0.15);
  }

  #hero-{{ sid }} .pt-hero__search-go {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    background: var(--hero-accent);
    border: none;
    border-radius: 10px;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, transform 0.15s;
  }

  #hero-{{ sid }} .pt-hero__search-go:hover {
    background: #a01818;
    transform: translateY(-50%) scale(1.05);
  }

  #hero-{{ sid }} .pt-hero__search-go:active {
    transform: translateY(-50%) scale(0.97);
  }

  #hero-{{ sid }} .pt-hero__search-go svg {
    width: 20px;
    height: 20px;
  }

  /* ── Search dropdown / autocomplete ─────────────────────── */
  #hero-{{ sid }} .pt-hero__search-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: rgba(20,20,20,0.96);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 16px;
    z-index: 50;
    display: none;
    box-shadow: 0 16px 48px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.04);
    max-height: 420px;
    overflow-y: auto;
  }

  #hero-{{ sid }} .pt-hero__search-dropdown.is-open {
    display: block;
    animation: ptDropdownIn 0.2s ease-out;
  }
  /* Hide action pills when dropdown is open */
  #hero-{{ sid }} .pt-hero__search-wrap.has-dropdown ~ .pt-hero__actions {
    display: none !important;
  }

  @keyframes ptDropdownIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  #hero-{{ sid }} .pt-hero__search-dropdown-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.35);
    margin: 0 0 10px;
  }

  /* Pills */
  #hero-{{ sid }} .pt-hero__search-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  #hero-{{ sid }} .pt-hero__search-pill {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    color: rgba(255,255,255,0.8);
    font-size: 12px;
    padding: 7px 14px;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
    white-space: nowrap;
  }

  #hero-{{ sid }} .pt-hero__search-pill:hover {
    background: rgba(185,28,28,0.15);
    border-color: rgba(185,28,28,0.4);
    color: #fff;
  }

  /* Result items */
  #hero-{{ sid }} .pt-hero__search-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.15s;
    text-decoration: none;
    color: inherit;
  }

  #hero-{{ sid }} .pt-hero__search-item:hover {
    background: rgba(255,255,255,0.06);
  }

  #hero-{{ sid }} .pt-hero__search-item-img {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    background: rgba(255,255,255,0.05);
    object-fit: contain;
    flex-shrink: 0;
  }

  #hero-{{ sid }} .pt-hero__search-item-info {
    flex: 1;
    min-width: 0;
    text-align: left;
  }

  #hero-{{ sid }} .pt-hero__search-item-brand {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #B91C1C;
    margin: 0 0 2px;
  }

  #hero-{{ sid }} .pt-hero__search-item-title {
    font-size: 13px;
    font-weight: 500;
    color: #fff;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  #hero-{{ sid }} .pt-hero__search-item-price {
    font-size: 13px;
    font-weight: 700;
    color: #B91C1C;
    flex-shrink: 0;
  }

  /* View all link */
  #hero-{{ sid }} .pt-hero__search-view-all {
    display: block;
    text-align: center;
    font-size: 12px;
    font-weight: 600;
    color: #B91C1C;
    text-decoration: none;
    padding: 10px 0 2px;
    transition: opacity 0.2s;
  }

  #hero-{{ sid }} .pt-hero__search-view-all:hover {
    opacity: 0.8;
  }

  /* Mode badge */
  #hero-{{ sid }} .pt-hero__search-mode {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(185,28,28,0.08);
    border-radius: 10px;
    padding: 10px 14px;
    margin-top: 10px;
  }

  #hero-{{ sid }} .pt-hero__search-mode-icon {
    font-size: 16px;
    flex-shrink: 0;
  }

  #hero-{{ sid }} .pt-hero__search-mode-text {
    font-size: 12px;
    color: rgba(255,255,255,0.7);
    line-height: 1.4;
  }

  /* ── AI Result styles ──────────────────────────────────── */
  #hero-{{ sid }} .pt-hero__ai-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 20px;
    margin-bottom: 8px;
  }

  #hero-{{ sid }} .pt-hero__ai-badge--vehicle {
    background: #065f46;
    color: #10b981;
  }

  #hero-{{ sid }} .pt-hero__ai-badge--size {
    background: #1e3a5f;
    color: #3b82f6;
  }

  #hero-{{ sid }} .pt-hero__ai-badge--loading {
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.5);
    animation: ptAiPulse 1.2s ease-in-out infinite;
  }

  @keyframes ptAiPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  #hero-{{ sid }} .pt-hero__ai-info {
    font-size: 12px;
    color: rgba(255,255,255,0.45);
    margin: 0 0 10px;
    line-height: 1.4;
  }

  #hero-{{ sid }} .pt-hero__ai-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.35);
    margin: 0 0 6px;
  }

  #hero-{{ sid }} .pt-hero__ai-sizes {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  /* ── AI Size Row (replaces ai-size-card) ───────────────── */
  #hero-{{ sid }} .pt-hero__ai-size-row {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 12px 14px;
    text-align: left;
  }

  #hero-{{ sid }} .pt-hero__ai-size-row__trims {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    margin: 0 0 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  #hero-{{ sid }} .pt-hero__ai-size-row__size {
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 8px;
  }

  /* ── Season pills row ──────────────────────────────────── */
  #hero-{{ sid }} .pt-hero__ai-size-row__seasons {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  #hero-{{ sid }} .pt-hero__ai-season-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 20px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
    cursor: pointer;
    white-space: nowrap;
  }

  #hero-{{ sid }} .pt-hero__ai-season-pill:active {
    transform: scale(0.96);
  }

  /* Winter — blue */
  #hero-{{ sid }} .pt-hero__ai-size-link {
    display: block;
    margin-top: 8px;
    font-size: 12px;
    font-weight: 600;
    color: #B91C1C;
    text-decoration: none;
    transition: color 0.15s;
  }
  #hero-{{ sid }} .pt-hero__ai-size-link:hover {
    color: #ef4444;
  }
  #hero-{{ sid }} .pt-hero__ai-season-pill--all {
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.7);
    border-color: rgba(255,255,255,0.15);
  }
  #hero-{{ sid }} .pt-hero__ai-season-pill--all:hover {
    background: rgba(255,255,255,0.15);
    color: #fff;
    border-color: rgba(255,255,255,0.3);
  }
  #hero-{{ sid }} .pt-hero__ai-season-pill--winter {
    background: rgba(59,130,246,0.12);
    border: 1px solid rgba(59,130,246,0.3);
    color: #60a5fa;
  }

  #hero-{{ sid }} .pt-hero__ai-season-pill--winter:hover {
    background: rgba(59,130,246,0.25);
    border-color: rgba(59,130,246,0.6);
    color: #93bbfd;
  }

  /* All-Season — green */
  #hero-{{ sid }} .pt-hero__ai-season-pill--allseason {
    background: rgba(16,185,129,0.12);
    border: 1px solid rgba(16,185,129,0.3);
    color: #34d399;
  }

  #hero-{{ sid }} .pt-hero__ai-season-pill--allseason:hover {
    background: rgba(16,185,129,0.25);
    border-color: rgba(16,185,129,0.6);
    color: #6ee7b7;
  }

  /* All-Weather — purple */
  #hero-{{ sid }} .pt-hero__ai-season-pill--allweather {
    background: rgba(139,92,246,0.12);
    border: 1px solid rgba(139,92,246,0.3);
    color: #a78bfa;
  }

  #hero-{{ sid }} .pt-hero__ai-season-pill--allweather:hover {
    background: rgba(139,92,246,0.25);
    border-color: rgba(139,92,246,0.6);
    color: #c4b5fd;
  }

  /* ── Action pills ───────────────────────────────────────── */
  #hero-{{ sid }} .pt-hero__actions {
    display: flex;
    gap: 12px;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  #hero-{{ sid }} .pt-hero__action {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    border: 1.5px solid rgba(255,255,255,0.2);
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    background: rgba(255,255,255,0.04);
    text-decoration: none;
    letter-spacing: 0.01em;
    -webkit-tap-highlight-color: transparent;
  }

  #hero-{{ sid }} .pt-hero__action:hover {
    border-color: var(--hero-accent);
    color: #fff;
    background: rgba(185,28,28,0.1);
    transform: translateY(-1px);
  }

  #hero-{{ sid }} .pt-hero__action:active {
    transform: translateY(0);
  }

  #hero-{{ sid }} .pt-hero__action svg {
    width: 16px;
    height: 16px;
    opacity: 0.8;
    flex-shrink: 0;
  }

  #hero-{{ sid }} .pt-hero__action:hover svg {
    opacity: 1;
  }

  /* ── Fade-up animation ──────────────────────────────────── */
  #hero-{{ sid }} .pt-hero__anim {
    opacity: 0;
    transform: translateY(20px);
    animation: ptHeroFadeUp 0.6s ease-out both;
    animation-delay: var(--delay, 0s);
  }

  @keyframes ptHeroFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    #hero-{{ sid }} {
      min-height: 100svh;
      padding: 0;
