<div class="sbc">
  <div class="sbc__container">

    <div class="sbc__top">
      <div class="sbc__header">
        <span class="sbc__eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="sbc__heading">{{ section.settings.heading }}</h2>
      </div>
    </div>

    <div class="sbc__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="sbc__card sbc__card--{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="sbc__card-bg">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: class: 'sbc__card-img' }}
            {%- endif -%}
          </div>
          <div class="sbc__card-overlay"></div>
          <div class="sbc__card-content">
            <span class="sbc__card-count" data-sbc-count>{{ block.settings.product_count }}</span>
            <h3 class="sbc__card-title">{{ block.settings.title }}</h3>
            <span class="sbc__card-cta">
              Shop now
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
          <div class="sbc__card-shine"></div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</div>

{% stylesheet %}
  .sbc {
    background: #fff;
    padding: 7rem 0;
  }

  .sbc__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 6rem;
  }

  .sbc__top {
    margin-bottom: 3.5rem;
  }

  .sbc__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sbc__eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 400;
    color: #dc2626;
    letter-spacing: 0.02em;
  }

  .sbc__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 3rem;
    font-weight: 600;
    color: #111;
    margin: 0;
    line-height: 1.1;
  }

  /* ── Grid: bento layout ── */
  .sbc__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: 22rem 22rem;
    gap: 1.4rem;
  }

  .sbc__card--1 {
    grid-column: 1 / 3;
    grid-row: 1 / 2;
  }

  .sbc__card--2 {
    grid-column: 3 / 4;
    grid-row: 1 / 3;
  }

  .sbc__card--3 {
    grid-column: 4 / 5;
    grid-row: 1 / 2;
  }

  .sbc__card--4 {
    grid-column: 1 / 2;
    grid-row: 2 / 3;
  }

  .sbc__card--5 {
    grid-column: 2 / 3;
    grid-row: 2 / 3;
  }

  .sbc__card--6 {
    grid-column: 4 / 5;
    grid-row: 2 / 3;
  }

  /* ── Card ── */
  .sbc__card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    text-decoration: none;
    color: #fff;
    cursor: pointer;
  }

  .sbc__card-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: #1a1a1a;
  }

  .sbc__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.4s ease;
  }

  .sbc__card:hover .sbc__card-img {
    transform: scale(1.08);
    filter: brightness(1.1);
  }

  .sbc__card-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.15) 50%, rgba(0,0,0,0) 100%);
    transition: background 0.4s ease;
  }

  .sbc__card:hover .sbc__card-overlay {
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.05) 100%);
  }

  .sbc__card-content {
    position: relative;
    z-index: 2;
    padding: 2rem 2.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    width: 100%;
  }

  .sbc__card-count {
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: rgba(255,255,255,0.5);
  }

  .sbc__card-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2rem;
    font-weight: 600;
    color: #fff;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.1;
  }

  .sbc__card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    font-weight: 400;
    color: rgba(255,255,255,0.6);
    margin-top: 0.4rem;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease, gap 0.2s ease;
  }

  .sbc__card:hover .sbc__card-cta {
    opacity: 1;
    transform: translateY(0);
  }

  .sbc__card:hover .sbc__card-cta:hover {
    gap: 0.8rem;
    color: #fff;
  }

  /* ── Shine sweep on hover ── */
  .sbc__card-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
    z-index: 3;
    pointer-events: none;
    transition: none;
  }

  .sbc__card:hover .sbc__card-shine {
    animation: sbc-shine 0.6s ease-out forwards;
  }

  @keyframes sbc-shine {
    0% { left: -60%; }
    100% { left: 120%; }
  }

  /* ── Red accent line on hover ── */
  .sbc__card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 3px;
    background: #dc2626;
    z-index: 4;
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sbc__card:hover::after {
    width: 100%;
  }

  /* ── Responsive ── */
  @media (max-width: 989px) {
    .sbc__grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
    }
    .sbc__card--1,
    .sbc__card--2,
    .sbc__card--3,
    .sbc__card--4,
    .sbc__card--5,
    .sbc__card--6 {
      grid-column: auto;
      grid-row: auto;
      min-height: 20rem;
    }
    .sbc__container {
      padding: 0 3rem;
    }
  }

  @media (max-width: 480px) {
    .sbc__grid {
      grid-template-columns: 1fr;
    }
    .sbc__container {
      padding: 0 2rem;
    }
    .sbc__heading {
      font-size: 2.4rem;
    }
    .sbc__card-cta {
      opacity: 1;
      transform: translateY(0);
    }
  }
{% endstylesheet %}

{% schema %}
