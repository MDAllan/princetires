{%- if section.settings.enable_shop_login_button == false -%}
  {%- assign hide_shop_login_button = true -%}
{%- endif -%}

<div class="auth-page">
  <!-- Left brand panel — garage themed -->
  <div class="auth-page__brand">
    <div class="auth-page__brand-tread" aria-hidden="true"></div>
    <div class="auth-page__brand-content">
      <div class="auth-page__brand-top">
        <a href="{{ routes.root_url }}" class="auth-page__logo">
          {%- if section.settings.logo != blank -%}
            {{ section.settings.logo | image_url: width: 240 | image_tag: class: 'auth-page__logo-img' }}
          {%- else -%}
            <span class="auth-page__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <div class="auth-page__brand-middle">
        <span class="auth-page__brand-eyebrow">Prince Tires · Calgary</span>
        <span class="auth-page__brand-rule" aria-hidden="true"></span>
        <h2 class="auth-page__brand-headline" id="AuthBrandHeadline" data-headline-customer="{{ section.settings.headline | escape }}" data-headline-shop="{{ section.settings.headline_dealer | escape }}">{{ section.settings.headline }}</h2>
        <p class="auth-page__brand-desc" id="AuthBrandDesc" data-tagline-customer="{{ section.settings.tagline | escape }}" data-tagline-shop="{{ section.settings.tagline_dealer | escape }}">{{ section.settings.tagline }}</p>
      </div>

      <div class="auth-page__brand-bottom">
        <div class="auth-page__trust">
          <div class="auth-page__trust-stars">
            {%- for i in (1..5) -%}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#F5820B"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- endfor -%}
          </div>
          <span class="auth-page__trust-text">{{ section.settings.trust_text }}</span>
        </div>
        <div class="auth-page__trust-secure">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <span>{{ 'customer.auth.secure_connection' | t }}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Right form panel -->
  <div class="auth-page__form-panel">
    <div class="auth-page__form-container">

      <!-- Password recovery form (hidden by default) -->
      <div id="recover-form" class="auth-page__form-section" style="display:none;">
        <div class="auth-page__form-header">
          <h1 class="auth-page__title">{{ 'customer.recover_password.title' | t }}</h1>
          <p class="auth-page__subtitle">{{ 'customer.recover_password.subtext' | t }}</p>
        </div>

        {%- form 'recover_customer_password' -%}
          {% assign recover_success = form.posted_successfully? %}

          <div class="auth-page__field">
            <label class="auth-page__label" for="RecoverEmail">{{ 'customer.login_page.email' | t }}</label>
            <div class="auth-page__input-wrap">
              <svg class="auth-page__input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <input
                class="auth-page__input"
                type="email"
                value=""
                name="email"
                id="RecoverEmail"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                placeholder="{{ 'customer.auth.email_placeholder' | t }}"
                {% if form.errors %}
                  aria-invalid="true"
                  aria-describedby="RecoverEmail-email-error"
                  autofocus
                {% endif %}
              >
            </div>
            {%- if form.errors -%}
              <span id="RecoverEmail-email-error" class="auth-page__error">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                {{ form.errors.messages.form }}
              </span>
            {%- endif -%}
          </div>

          <button type="submit" class="auth-page__btn auth-page__btn--primary" data-submit-btn>
            <span class="auth-page__btn-inner">{{ 'customer.login_page.submit' | t }}</span>
            <span class="auth-page__btn-spinner" aria-hidden="true" style="display:none">
              <svg class="auth-page__spinner-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            </span>
          </button>

          <button type="button" class="auth-page__btn auth-page__btn--text" data-toggle-recover>
            {{ 'customer.auth.back_to_login' | t }}
          </button>
        {%- endform -%}
      </div>

      <!-- Login form -->
      <div id="login-form" class="auth-page__form-section">

        <!-- Account type toggle -->
        <div class="auth-type-toggle" id="AuthTypeToggle">
          <button type="button" class="auth-type-toggle__btn auth-type-toggle__btn--active" data-type="customer" id="AuthTypeCustomer">
            <span class="auth-type-toggle__icon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg>
            </span>
            My Garage
          </button>
          <button type="button" class="auth-type-toggle__btn" data-type="shop" id="AuthTypeShop">
            <span class="auth-type-toggle__icon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><line x1="9" y1="22" x2="9" y2="12"/><line x1="15" y1="22" x2="15" y2="12"/><line x1="3" y1="13" x2="21" y2="13"/></svg>
            </span>
            Dealer Access
          </button>
        </div>

        <div class="auth-page__form-header">
          <span class="auth-page__garage-badge" id="AuthBadgeIcon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" id="AuthIconCustomer"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" id="AuthIconShop" style="display:none"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><line x1="9" y1="22" x2="9" y2="12"/><line x1="15" y1="22" x2="15" y2="12"/><line x1="3" y1="13" x2="21" y2="13"/></svg>
          </span>
          <h1 class="auth-page__title" id="AuthTitle">{{ 'customer.auth.welcome_back' | t }}</h1>
          <p class="auth-page__subtitle" id="AuthSubtitle">{{ 'customer.auth.login_subtitle' | t }}</p>
        </div>

        {%- if recover_success == true -%}
          <div class="auth-page__success" role="status">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>{{ 'customer.recover_password.success' | t }}</span>
          </div>
        {%- endif -%}

        {%- form 'customer_login', novalidate: 'novalidate' -%}
          <input type="hidden" name="return_to" id="AuthReturnTo" value="/account">
          {%- if form.errors -%}
            <div class="auth-page__error-banner" role="alert" tabindex="-1" autofocus>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <div>
                <span class="visually-hidden">{{ 'accessibility.error' | t }} </span>
                <strong>{{ 'templates.contact.form.error_heading' | t }}</strong>
                {{ form.errors | default_errors }}
              </div>
            </div>
          {%- endif -%}

          {%- if shop.features.login_with_shop_classic_customer_accounts? -%}
            {%- unless hide_shop_login_button -%}
              <div class="auth-page__shop-login">
                {{ shop | login_button: hide_button: hide_shop_login_button }}
                <div class="auth-page__divider">
                  <span>{{ 'customer.login_page.alternate_provider_separator' | t }}</span>
                </div>
              </div>
            {%- endunless -%}
          {%- endif -%}

          <div class="auth-page__field">
            <label class="auth-page__label" for="CustomerEmail">{{ 'customer.login_page.email' | t }}</label>
            <div class="auth-page__input-wrap">
              <svg class="auth-page__input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <input
                class="auth-page__input"
                type="email"
                name="customer[email]"
                id="CustomerEmail"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                placeholder="{{ 'customer.auth.email_placeholder' | t }}"
                {% if form.errors contains 'form' %}
                  aria-invalid="true"
                {% endif %}
              >
            </div>
          </div>

          {%- if form.password_needed -%}
            <div class="auth-page__field">
              <label class="auth-page__label" for="CustomerPassword">{{ 'customer.login_page.password' | t }}</label>
              <div class="auth-page__input-wrap">
                <svg class="auth-page__input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <input
                  class="auth-page__input auth-page__input--password"
                  type="password"
                  value=""
                  name="customer[password]"
                  id="CustomerPassword"
                  autocomplete="current-password"
                  placeholder="{{ 'customer.auth.password_placeholder' | t }}"
                  {% if form.errors contains 'form' %}
                    aria-invalid="true"
                  {% endif %}
                >
                <button type="button" class="auth-page__toggle-pw" aria-label="{{ 'customer.auth.show_password' | t }}" data-toggle-password>
                  <svg class="auth-page__eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  <svg class="auth-page__eye-closed" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                </button>
              </div>
              <a href="#" class="auth-page__forgot" data-toggle-recover>
                {{ 'customer.login_page.forgot_password' | t }}
              </a>
            </div>
          {%- endif -%}

          <button type="submit" class="auth-page__btn auth-page__btn--primary" data-submit-btn>
            <span class="auth-page__btn-inner">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="AuthBtnIcon"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg>
              <span class="auth-page__btn-text" id="AuthBtnText">{{ 'customer.auth.enter_garage' | t }}</span>
              <svg class="auth-page__btn-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
            <span class="auth-page__btn-spinner" aria-hidden="true" style="display:none">
              <svg class="auth-page__spinner-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            </span>
          </button>
        {%- endform -%}

        <div class="auth-page__switch">
          <span>{{ 'customer.auth.no_account' | t }}</span>
          <a href="{{ routes.account_register_url }}" id="AuthRegisterLink">{{ 'customer.auth.signup_cta' | t }}</a>
        </div>
        <div class="auth-page__switch" id="AuthShopRegisterNote" style="display:none;margin-top:8px;">
          <span>Need dealer access?</span>
          <a href="/pages/wholesale-register">Apply for dealer account →</a>
        </div>

        {%- if shop.checkout.guest_login -%}
          <div class="auth-page__guest">
            <div class="auth-page__divider">
              <span>{{ 'customer.login_page.alternate_provider_separator' | t }}</span>
            </div>
            {%- form 'guest_login' -%}
              <button type="submit" class="auth-page__btn auth-page__btn--secondary">
                {{ 'customer.login_page.guest_continue' | t }}
              </button>
            {%- endform -%}
          </div>
        {%- endif -%}

      </div>

    </div>
  </div>
</div>

{% stylesheet %}
  /* ═══════════════════════════════════════════
     AUTH PAGE – Ferrari editorial chiaroscuro
     Pure black hero · Ferrari Red · sharp 2-4px
     ═══════════════════════════════════════════ */

  .auth-page {
    display: flex;
    min-height: 100vh;
    min-height: 100dvh;
    font-family: 'Outfit', sans-serif;
    background: #ffffff;
  }

  /* When the auth page is mounted, hide the theme's header + footer so
     the login goes full-bleed. The body class is added by JS on init. */
  body.auth-page-body .shopify-section-group-header-group,
  body.auth-page-body .shopify-section-group-footer-group,
  body.auth-page-body sticky-header,
  body.auth-page-body site-header,
  body.auth-page-body .header-wrapper,
  body.auth-page-body .header,
  body.auth-page-body footer,
  body.auth-page-body .footer,
  body.auth-page-body .pt-sticky-bar { display: none !important; }
  body.auth-page-body { padding: 0 !important; margin: 0 !important; }

  /* ── Left brand panel — pure cinematic black ── */
  .auth-page__brand {
    display: none;
    width: 45%;
    max-width: 600px;
    background: #000000;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 900px) {
    .auth-page__brand {
      display: flex;
    }
  }

  /* Pure black — no chrome, no glow, no accent stripes. Typography carries it. */

  /* Tire tread diagonal texture — barely visible */
  .auth-page__brand-tread {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 18px,
        rgba(255, 255, 255, 0.015) 18px,
        rgba(255, 255, 255, 0.015) 19px
      );
    pointer-events: none;
    z-index: 0;
  }

  .auth-page__brand-content {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 3.5rem;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .auth-page__logo {
    text-decoration: none;
    display: inline-block;
  }

  .auth-page__logo-img {
    max-height: 40px;
    width: auto;
  }

  .auth-page__logo-text {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  /* ── Editorial brand panel content ── */
  .auth-page__brand-middle {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    flex: 1;
    text-align: left;
    gap: 1.4rem;
    max-width: 460px;
  }

  .auth-page__brand-eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.45);
  }

  .auth-page__brand-rule {
    display: block;
    width: 64px;
    height: 1px;
    background: rgba(255, 255, 255, 0.25);
    margin: 0.4rem 0 0.6rem;
  }

  .auth-page__brand-headline {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 5.2rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    line-height: 0.98;
    letter-spacing: -0.012em;
    text-transform: uppercase;
  }

  .auth-page__brand-desc {
    font-size: 1.5rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.55);
    margin: 0.6rem 0 0;
    line-height: 1.55;
    max-width: 38ch;
  }

  .auth-page__brand-bottom {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .auth-page__trust {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .auth-page__trust-stars {
    display: flex;
    gap: 2px;
  }

  .auth-page__trust-text {
    font-size: 1.15rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.04em;
  }

  .auth-page__trust-secure {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.35);
  }

  .auth-page__trust-secure svg {
    opacity: 0.6;
  }

  /* ── Right form panel ── */
  .auth-page__form-panel {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 6rem;
    background: #fff;
    min-height: 100vh;
    min-height: 100dvh;
  }

  .auth-page__form-container {
    width: 100%;
    max-width: 420px;
  }

  .auth-page__form-section {
    animation: auth-fade-in 0.3s ease;
  }

  @keyframes auth-fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Header with garage badge ── */
  .auth-page__form-header {
    margin-bottom: 2.5rem;
  }

  .auth-page__garage-badge {
    display: none;
  }

  /* (No decorative rule above title — kept clean) */

  .auth-page__title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 3.4rem;
    font-weight: 700;
    color: #000;
    margin: 0 0 0.6rem;
    line-height: 1.0;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .auth-page__subtitle {
    font-size: 1.35rem;
    font-weight: 300;
    color: #475569;
    margin: 0;
    line-height: 1.5;
    max-width: 32ch;
  }

  /* ── Fields ── */
  .auth-page__field {
    margin-bottom: 1.5rem;
  }

  .auth-page__label {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6b7280;
    margin-bottom: 0.7rem;
  }

  .auth-page__input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .auth-page__input {
    width: 100%;
    height: 52px;
    padding: 0 1.4rem 0 3.2rem;
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: #000;
    background: #ffffff;
    border: 1px solid #d4d4d4;
    border-radius: 2px;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
    -webkit-appearance: none;
    appearance: none;
  }

  .auth-page__input::placeholder {
    color: #9ca3af;
    font-weight: 300;
  }

  .auth-page__input:focus {
    border-color: #DA291C;
    box-shadow: inset 0 -2px 0 0 #DA291C;
  }

  .auth-page__input[aria-invalid="true"] {
    border-color: #DA291C;
    box-shadow: inset 0 -2px 0 0 #DA291C;
  }

  .auth-page__input--password {
    padding-right: 3.2rem;
  }

  .auth-page__input-icon {
    position: absolute;
    left: 0.9rem;
    color: #9ca3af;
    pointer-events: none;
    transition: color 0.2s ease;
    z-index: 1;
  }

  .auth-page__input:focus ~ .auth-page__input-icon,
  .auth-page__input-wrap:focus-within .auth-page__input-icon {
    color: #DA291C;
  }

  /* ── Password toggle ── */
  .auth-page__toggle-pw {
    position: absolute;
    right: 0.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    background: transparent;
    color: #9ca3af;
    cursor: pointer;
    border-radius: 6px;
    transition: color 0.2s ease, background 0.2s ease;
    padding: 0;
  }

  .auth-page__toggle-pw:hover {
    color: #374151;
    background: rgba(0, 0, 0, 0.04);
  }

  /* ── Forgot password ── */
  .auth-page__forgot {
    display: inline-block;
    font-size: 1.05rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #000;
    text-decoration: none;
    margin-top: 0.8rem;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: border-color 0.15s ease;
  }

  .auth-page__forgot:hover {
    border-bottom-color: #DA291C;
    color: #DA291C;
  }

  /* ── Buttons ── */
  .auth-page__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    height: 56px;
    border: none;
    border-radius: 2px;
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
    text-decoration: none;
  }

  .auth-page__btn-inner {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .auth-page__btn--primary {
    background: #DA291C;
    color: #fff;
    margin-top: 0.8rem;
  }

  .auth-page__btn--primary:hover {
    background: #B01E0A;
  }

  .auth-page__btn--primary:active {
    background: #9D2211;
  }

  .auth-page__btn--primary .auth-page__btn-arrow {
    transition: transform 0.2s ease;
  }

  .auth-page__btn--primary:hover .auth-page__btn-arrow {
    transform: translateX(4px);
  }

  /* Loading state */
  .auth-page__btn--loading {
    opacity: 0.75;
    cursor: not-allowed;
    pointer-events: none;
  }

  .auth-page__spinner-icon {
    animation: auth-spin 0.8s linear infinite;
  }

  @keyframes auth-spin {
    to { transform: rotate(360deg); }
  }

  .auth-page__btn--secondary {
    background: transparent;
    color: #000;
    border: 1px solid #000;
  }

  .auth-page__btn--secondary:hover {
    background: #000;
    color: #fff;
  }

  .auth-page__btn--text {
    background: transparent;
    color: #6b7280;
    height: auto;
    padding: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 1rem;
    margin-top: 0.5rem;
  }

  .auth-page__btn--text:hover {
    color: #DA291C;
  }

  /* ── Divider ── */
  .auth-page__divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 1.5rem 0;
    color: #9ca3af;
    font-size: 1.2rem;
    font-weight: 400;
  }

  .auth-page__divider::before,
  .auth-page__divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #e5e7eb;
  }

  /* ── Shop login ── */
  .auth-page__shop-login {
    margin-bottom: 0.5rem;
  }

  /* ── Error & success ── */
  .auth-page__error-banner {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 10px;
    padding: 1.2rem 1.4rem;
    margin-bottom: 1.5rem;
    color: #991b1b;
    font-size: 1.3rem;
    line-height: 1.5;
    animation: auth-shake 0.4s ease;
  }

  .auth-page__error-banner svg {
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .auth-page__error-banner strong {
    display: block;
    font-weight: 600;
    margin-bottom: 0.3rem;
  }

  .auth-page__error-banner ul {
    margin: 0;
    padding-left: 1.4rem;
  }

  @keyframes auth-shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-6px); }
    40% { transform: translateX(6px); }
    60% { transform: translateX(-4px); }
    80% { transform: translateX(4px); }
  }

  .auth-page__error {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #dc2626;
    font-size: 1.2rem;
    margin-top: 0.5rem;
  }

  .auth-page__error svg { flex-shrink: 0; }

  .auth-page__success {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 10px;
    padding: 1.2rem 1.4rem;
    margin-bottom: 1.5rem;
    color: #166534;
    font-size: 1.3rem;
    line-height: 1.5;
  }

  .auth-page__success svg { flex-shrink: 0; }

  /* ── Switch link ── */
  .auth-page__switch {
    text-align: center;
    margin-top: 2.4rem;
    font-size: 1.2rem;
    font-weight: 400;
    color: #6b7280;
    letter-spacing: 0.02em;
  }

  .auth-page__switch a {
    color: #000;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 1.05rem;
    text-decoration: none;
    margin-left: 0.5rem;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .auth-page__switch a:hover {
    color: #DA291C;
    border-bottom-color: #DA291C;
  }

  .auth-page__guest {
    margin-top: 0.5rem;
  }

  /* ── Mobile ── */
  @media (max-width: 899px) {
    .auth-page { min-height: auto; }
    .auth-page__form-panel {
      min-height: 100vh;
      min-height: 100dvh;
      padding: 5rem 4rem;
    }
  }

  @media (max-width: 480px) {
    .auth-page__form-panel { padding: 4rem 2.5rem; }
    .auth-page__title { font-size: 2.4rem; }
    .auth-page__garage-badge { width: 42px; height: 42px; }
    .auth-page__input { height: 48px; font-size: 1.6rem; }
    .auth-page__btn { height: 48px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .auth-page__form-section,
    .auth-page__error-banner { animation: none; }
    .auth-page__btn--primary:hover { transform: none; }
    .auth-page__spinner-icon { animation: none; }
  }

  /* ── Account type toggle (Customer / Shop) ── */
  .auth-type-toggle {
    display: flex;
    border: 1px solid #e5e7eb;
    border-radius: 2px;
    margin-bottom: 2.8rem;
  }

  .auth-type-toggle__btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 44px;
    border: none;
    border-right: 1px solid #e5e7eb;
    background: transparent;
    font-family: 'Outfit', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #9ca3af;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .auth-type-toggle__btn:last-child {
    border-right: none;
  }

  .auth-type-toggle__btn:hover:not(.auth-type-toggle__btn--active) {
    color: #000;
  }

  .auth-type-toggle__btn--active {
    background: #000;
    color: #fff;
  }

  .auth-type-toggle__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* Shop mode: brand rule turns black, primary CTA turns black */
  .auth-page--shop-mode .auth-page__form-header::before {
    background: #000;
  }

  .auth-page--shop-mode .auth-page__btn--primary {
    background: #000;
  }

  .auth-page--shop-mode .auth-page__btn--primary:hover {
    background: #1a1a1a;
  }

  .auth-page--shop-mode .auth-page__input:focus {
    border-color: #000;
    box-shadow: inset 0 -2px 0 0 #000;
  }

  .auth-page--shop-mode .auth-page__forgot:hover,
  .auth-page--shop-mode .auth-page__switch a:hover {
    color: #000;
    border-bottom-color: #000;
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    function initAuthPage() {
    var section = document.querySelector('.auth-page');
    if (!section) return;

    // Mark body so the auth-only stylesheet rules (hide theme header/footer) apply
    document.body.classList.add('auth-page-body');

    // Password visibility toggle
    section.querySelectorAll('[data-toggle-password]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var input = this.closest('.auth-page__input-wrap').querySelector('input');
        var eyeOpen = this.querySelector('.auth-page__eye-open');
        var eyeClosed = this.querySelector('.auth-page__eye-closed');
        if (input.type === 'password') {
          input.type = 'text';
          eyeOpen.style.display = 'none';
          eyeClosed.style.display = 'block';
        } else {
          input.type = 'password';
          eyeOpen.style.display = 'block';
          eyeClosed.style.display = 'none';
        }
        input.focus();
      });
    });

    // Toggle between login and recover — with auto-fill email
    var loginForm = document.getElementById('login-form');
    var recoverForm = document.getElementById('recover-form');
    section.querySelectorAll('[data-toggle-recover]').forEach(function(trigger) {
      trigger.addEventListener('click', function(e) {
        e.preventDefault();
        if (loginForm.style.display === 'none') {
          recoverForm.style.display = 'none';
          loginForm.style.display = 'block';
        } else {
          loginForm.style.display = 'none';
          recoverForm.style.display = 'block';
          // Auto-fill email from login field into recover field
          var loginEmail = document.getElementById('CustomerEmail');
          var recoverEmail = document.getElementById('RecoverEmail');
          if (loginEmail && recoverEmail && loginEmail.value) {
            recoverEmail.value = loginEmail.value;
          }
          if (recoverEmail) recoverEmail.focus();
        }
      });
    });

    if (window.location.hash === '#recover') {
      loginForm.style.display = 'none';
      recoverForm.style.display = 'block';
    }

    // ── Account type toggle (Customer ↔ Shop) ──
    var toggleCustomer = document.getElementById('AuthTypeCustomer');
    var toggleShop     = document.getElementById('AuthTypeShop');
    var returnToInput  = document.getElementById('AuthReturnTo');
    var titleEl        = document.getElementById('AuthTitle');
    var subtitleEl     = document.getElementById('AuthSubtitle');
    var btnTextEl      = document.getElementById('AuthBtnText');
    var btnIconEl      = document.getElementById('AuthBtnIcon');
    var iconCustomer   = document.getElementById('AuthIconCustomer');
    var iconShop       = document.getElementById('AuthIconShop');
    var registerLink   = document.getElementById('AuthRegisterLink');
    var shopNote       = document.getElementById('AuthShopRegisterNote');
    var authSwitchRow  = registerLink ? registerLink.closest('.auth-page__switch') : null;
    var brandHeadline  = document.getElementById('AuthBrandHeadline');
    var brandDesc      = document.getElementById('AuthBrandDesc');

    var shopIconSVGPaths = '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><line x1="9" y1="22" x2="9" y2="12"/><line x1="15" y1="22" x2="15" y2="12"/><line x1="3" y1="13" x2="21" y2="13"/>';
    var garageIconSVGPaths = '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/>';

    function setMode(mode) {
      var isShop = mode === 'shop';

      // Toggle button active state
      toggleCustomer.classList.toggle('auth-type-toggle__btn--active', !isShop);
      toggleShop.classList.toggle('auth-type-toggle__btn--active', isShop);

      // Visual mode class on root
      section.classList.toggle('auth-page--shop-mode', isShop);

      // return_to destination
      if (returnToInput) returnToInput.value = isShop ? '/pages/wholesale-portal' : '/account';

      // Badge icon
      if (iconCustomer) iconCustomer.style.display = isShop ? 'none' : 'block';
      if (iconShop)     iconShop.style.display     = isShop ? 'block' : 'none';

      // Heading (right panel)
      if (titleEl)    titleEl.textContent    = isShop ? 'Dealer sign in' : 'Welcome back';
      if (subtitleEl) subtitleEl.textContent = isShop
        ? 'Trade pricing, fleet orders, and your dealer dashboard.'
        : 'Sign in to your garage and manage your vehicles & orders.';

      // Left-panel brand headline + tagline (mode-aware via data-* attributes)
      if (brandHeadline) {
        var hk = isShop ? brandHeadline.getAttribute('data-headline-shop') : brandHeadline.getAttribute('data-headline-customer');
        if (hk) brandHeadline.textContent = hk;
      }
      if (brandDesc) {
        var tk = isShop ? brandDesc.getAttribute('data-tagline-shop') : brandDesc.getAttribute('data-tagline-customer');
        if (tk) brandDesc.textContent = tk;
      }

      // Button icon & label
      if (btnIconEl) btnIconEl.innerHTML = isShop ? shopIconSVGPaths : garageIconSVGPaths;
      if (btnTextEl) btnTextEl.textContent = isShop ? 'Enter dealer portal' : 'Enter my garage';

      // Register link row
      if (authSwitchRow) authSwitchRow.style.display = isShop ? 'none' : '';
      if (shopNote)      shopNote.style.display      = isShop ? 'block' : 'none';
    }

    if (toggleCustomer) toggleCustomer.addEventListener('click', function() { setMode('customer'); });
    if (toggleShop)     toggleShop.addEventListener('click',     function() { setMode('shop'); });

    // Initialise — if URL has ?type=shop, pre-select shop tab
    if (window.location.search.indexOf('type=shop') !== -1) {
      setMode('shop');
    }

    // Submit button loading state
    section.querySelectorAll('form').forEach(function(form) {
      form.addEventListener('submit', function() {
        var btn = form.querySelector('[data-submit-btn]');
        if (!btn) return;
        var inner = btn.querySelector('.auth-page__btn-inner');
        var spinner = btn.querySelector('.auth-page__btn-spinner');
        btn.disabled = true;
        btn.classList.add('auth-page__btn--loading');
        if (inner) inner.style.display = 'none';
        if (spinner) spinner.style.display = 'flex';
      });
    });
    } // end initAuthPage
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAuthPage);
    } else {
      initAuthPage();
    }
  })();
{% endjavascript %}

