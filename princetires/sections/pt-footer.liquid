{%- liquid
  assign footer_logo = section.settings.logo | default: settings.logo
-%}

<footer class="pt-footer">
  <span class="pt-footer__accent" aria-hidden="true"></span>

  <div class="pt-footer__main">
    <!-- ── Brand column ── -->
    <div class="pt-footer__brand">
      <a href="{{ routes.root_url }}" class="pt-footer__logo" aria-label="{{ shop.name }}">
        {%- if footer_logo != blank -%}
          {{ footer_logo | image_url: width: 240 | image_tag: style: 'height:42px;width:auto', alt: shop.name }}
        {%- else -%}
          <span class="pt-footer__wordmark">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- if section.settings.tagline != blank -%}
        <p class="pt-footer__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}

      <!-- Social icons -->
      {%- assign has_social = false -%}
      {%- if section.settings.facebook_url != blank
         or section.settings.instagram_url != blank
         or section.settings.google_url != blank
         or section.settings.youtube_url != blank -%}
        {%- assign has_social = true -%}
      {%- endif -%}
      {%- if has_social -%}
        <div class="pt-footer__socials">
          {%- if section.settings.facebook_url != blank -%}
            <a class="pt-footer__social" href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.instagram_url != blank -%}
            <a class="pt-footer__social" href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.google_url != blank -%}
            <a class="pt-footer__social" href="{{ section.settings.google_url }}" target="_blank" rel="noopener" aria-label="Google reviews">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.youtube_url != blank -%}
            <a class="pt-footer__social" href="{{ section.settings.youtube_url }}" target="_blank" rel="noopener" aria-label="YouTube">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      <p class="pt-footer__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
    </div>

    <!-- ── Block columns (links + contact) ── -->
    <div class="pt-footer__columns">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_column' -%}
          <div class="pt-footer__col" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h4 class="pt-footer__col-heading">{{ block.settings.heading }}</h4>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="pt-footer__links">
                {%- for link in linklists[block.settings.menu].links -%}
                  <li><a href="{{ link.url }}" class="pt-footer__link">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if block.type == 'contact' -%}
          <div class="pt-footer__col" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h4 class="pt-footer__col-heading">{{ block.settings.heading }}</h4>
            {%- endif -%}
            <ul class="pt-footer__links">
              {%- if block.settings.phone != blank -%}
                {%- assign pd = block.settings.phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' -%}
                <li>
                  <a href="tel:+1{{ pd }}" class="pt-footer__link pt-footer__link--strong">{{ block.settings.phone }}</a>
                </li>
              {%- endif -%}
              {%- if block.settings.email != blank -%}
                <li>
                  <a href="mailto:{{ block.settings.email }}" class="pt-footer__link">{{ block.settings.email }}</a>
                </li>
              {%- endif -%}
              {%- if block.settings.address != blank -%}
                <li>
                  <span class="pt-footer__link pt-footer__link--static">{{ block.settings.address }}</span>
                </li>
              {%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <!-- ── Newsletter column ── -->
      {%- if section.settings.show_newsletter -%}
        <div class="pt-footer__col pt-footer__col--newsletter">
          <h4 class="pt-footer__col-heading">{{ section.settings.newsletter_heading | default: 'Stay in the loop' }}</h4>
          <p class="pt-footer__newsletter-sub">{{ section.settings.newsletter_sub }}</p>

          {%- form 'customer', class: 'pt-footer__newsletter' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="pt-footer__newsletter-row">
              <label for="NewsletterFooter--{{ section.id }}" class="visually-hidden">Email address</label>
              <input
                id="NewsletterFooter--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="pt-footer__newsletter-input"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                spellcheck="false"
                placeholder="{{ section.settings.newsletter_placeholder | default: 'you@email.com' }}"
                required
              >
              <button type="submit" class="pt-footer__newsletter-submit" name="commit" aria-label="Subscribe">
                <span>Subscribe</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </button>
            </div>

            {%- if form.posted_successfully? -%}
              <p class="pt-footer__newsletter-msg pt-footer__newsletter-msg--ok">
                Thanks — you're on the list.
              </p>
            {%- endif -%}
            {%- if form.errors -%}
              <p class="pt-footer__newsletter-msg pt-footer__newsletter-msg--err">
                {{ form.errors | default_errors }}
              </p>
            {%- endif -%}

            <p class="pt-footer__newsletter-fineprint">
              {{ section.settings.newsletter_consent | default: 'By subscribing you agree to receive marketing emails from Prince Tires. Unsubscribe anytime.' }}
            </p>
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% stylesheet %}
  /* ═══════════════════════════════════════════════════════════
     PT-FOOTER — matches contact-page card aesthetic
     ═══════════════════════════════════════════════════════════ */
  .pt-footer {
    --pt-red: #DA291C;
    --pt-orange: #F5820B;
    --pt-mute: rgba(255, 255, 255, 0.6);
    --pt-line: rgba(255, 255, 255, 0.10);
    background: #050505;
    font-family: 'Outfit', sans-serif;
    color: #fff;
    padding: 4.8rem 0 3.2rem;
    position: relative;
    isolation: isolate;
  }
  .pt-footer * { box-sizing: border-box; }

  .pt-footer__accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--pt-red) 0%, var(--pt-orange) 100%);
  }

  .pt-footer__main {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2.4rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 3.2rem;
  }
  @media (min-width: 900px) {
    .pt-footer__main {
      grid-template-columns: 1fr 2fr;
      gap: 5rem;
    }
  }

  /* ── Brand column ── */
  .pt-footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }
  .pt-footer__logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    width: fit-content;
  }
  .pt-footer__wordmark {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.4rem;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .pt-footer__tagline {
    font-size: 1.4rem;
    line-height: 1.5;
    color: var(--pt-mute);
    margin: 0;
    max-width: 32ch;
    font-weight: 400;
  }

  /* Social row */
  .pt-footer__socials {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.4rem;
  }
  .pt-footer__social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--pt-line);
    color: rgba(255, 255, 255, 0.85);
    border-radius: 50%;
    text-decoration: none;
    transition: background-color 160ms ease, color 160ms ease, border-color 160ms ease, transform 80ms ease;
  }
  .pt-footer__social:hover {
    background: var(--pt-red);
    border-color: var(--pt-red);
    color: #fff;
    transform: translateY(-2px);
  }

  .pt-footer__copy {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.42);
    line-height: 1.4;
    margin: 1rem 0 0;
    font-weight: 400;
  }

  /* ── Columns ── */
  .pt-footer__columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2.4rem 1.6rem;
  }
  @media (min-width: 700px) {
    .pt-footer__columns { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (min-width: 1100px) {
    .pt-footer__columns { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }

  .pt-footer__col { min-width: 0; }
  .pt-footer__col-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 1.4rem;
  }

  .pt-footer__links {
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pt-footer__link {
    font-size: 1.4rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    line-height: 1.4;
    transition: color 0.15s;
    word-break: break-word;
  }
  a.pt-footer__link:hover { color: var(--pt-red); }
  .pt-footer__link--strong {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.7rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.005em;
    font-variant-numeric: tabular-nums;
  }
  .pt-footer__link--static { color: rgba(255, 255, 255, 0.6); }

  /* ── Newsletter ── */
  .pt-footer__col--newsletter {
    grid-column: 1 / -1;
  }
  @media (min-width: 1100px) {
    .pt-footer__col--newsletter { grid-column: span 2; }
  }
  .pt-footer__newsletter-sub {
    font-size: 1.3rem;
    line-height: 1.45;
    color: var(--pt-mute);
    margin: -0.3rem 0 1.2rem;
    max-width: 38ch;
  }
  .pt-footer__newsletter { display: flex; flex-direction: column; gap: 0.6rem; }
  .pt-footer__newsletter-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .pt-footer__newsletter-input {
    flex: 1;
    min-width: 0;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--pt-line);
    color: #fff;
    font-family: inherit;
    font-size: 1.05rem;
    padding: 0.85rem 1rem;
    border-radius: 4px;
    transition: border-color 160ms ease, background-color 160ms ease;
  }
  .pt-footer__newsletter-input::placeholder { color: rgba(255, 255, 255, 0.32); }
  .pt-footer__newsletter-input:focus,
  .pt-footer__newsletter-input:focus-visible {
    outline: none;
    border-color: var(--pt-red);
    background: rgba(255, 255, 255, 0.06);
  }
  .pt-footer__newsletter-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, var(--pt-red) 0%, #b9221a 100%);
    color: #fff;
    border: 0;
    border-radius: 4px;
    padding: 0.85rem 1.5rem;
    font-family: 'Outfit', sans-serif;
    font-size: 0.86rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    cursor: pointer;
    transition: background 160ms ease, transform 80ms ease;
    white-space: nowrap;
  }
  .pt-footer__newsletter-submit:hover {
    background: linear-gradient(135deg, #f53224 0%, var(--pt-red) 100%);
  }
  .pt-footer__newsletter-submit:active { transform: translateY(1px); }
  .pt-footer__newsletter-submit:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }
  .pt-footer__newsletter-submit svg { transition: transform 160ms ease; }
  .pt-footer__newsletter-submit:hover svg { transform: translateX(3px); }

  .pt-footer__newsletter-msg {
    margin: 0.4rem 0 0;
    font-size: 1.05rem;
    line-height: 1.4;
    padding: 0.6rem 0.9rem;
    border-radius: 4px;
  }
  .pt-footer__newsletter-msg--ok {
    background: rgba(34, 197, 94, 0.12);
    border: 1px solid rgba(34, 197, 94, 0.4);
    color: #6ee7a3;
  }
  .pt-footer__newsletter-msg--err {
    background: rgba(218, 41, 28, 0.12);
    border: 1px solid var(--pt-red);
    color: #ff8a82;
  }
  .pt-footer__newsletter-fineprint {
    margin: 0.4rem 0 0;
    font-size: 1.02rem;
    color: rgba(255, 255, 255, 0.42);
    line-height: 1.4;
  }

  /* ── Mobile readability — bump weight 300 → 400, tighter spacing ── */
  @media (max-width: 768px) {
    .pt-footer { padding: 3.2rem 0 2rem; }
    .pt-footer__main { padding: 0 1.6rem; gap: 2.4rem; }
    .pt-footer__wordmark { font-size: 2rem; }
    .pt-footer__tagline { font-size: 1.3rem; }
    .pt-footer__col-heading { font-size: 1.3rem; margin: 0 0 1rem; }
    .pt-footer__link { font-size: 1.3rem; }
    .pt-footer__link--strong { font-size: 1.6rem; }
    .pt-footer__copy { font-size: 1.1rem; }
    .pt-footer__newsletter-row { flex-direction: column; }
    .pt-footer__newsletter-submit { width: 100%; justify-content: center; }
  }

  .visually-hidden {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    overflow: hidden !important;
    clip: rect(0,0,0,0) !important;
    white-space: nowrap !important;
    border: 0 !important;
    padding: 0 !important;
    margin: -1px !important;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PT Footer",
  "class": "pt-footer-section",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo",
      "info": "Falls back to theme logo if empty"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Calgary's most trusted tire shop. Walk-ins welcome."
    },
    {
      "type": "header",
      "content": "Social"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "google_url",
      "label": "Google reviews URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Heading",
      "default": "Stay in the loop"
    },
    {
      "type": "textarea",
      "id": "newsletter_sub",
      "label": "Sub-text",
      "default": "Seasonal tips, tire deals, and reminders when it's time to book your next change-over."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email placeholder",
      "default": "you@email.com"
    },
    {
      "type": "textarea",
      "id": "newsletter_consent",
      "label": "Consent fineprint",
      "default": "By subscribing you agree to receive marketing emails from Prince Tires. Unsubscribe anytime."
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contact",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Contact"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone",
          "default": "(403) 452-4283"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email",
          "default": "info@princetires.ca"
        },
        {
          "type": "text",
          "id": "address",
          "label": "Address",
          "default": "Calgary, Alberta, Canada"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PT Footer",
      "blocks": [
        {
          "type": "link_column",
          "settings": { "heading": "About", "menu": "footer" }
        },
        {
          "type": "link_column",
          "settings": { "heading": "Account", "menu": "main-menu" }
        },
        {
          "type": "contact",
          "settings": {
            "heading": "Contact",
            "phone": "(403) 452-4283",
            "email": "info@princetires.ca",
            "address": "Calgary, Alberta, Canada"
          }
        }
      ]
    }
  ]
}
{% endschema %}
