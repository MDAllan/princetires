<product-recommendations
  class="pt-rp"
  data-url="{{ routes.product_recommendations_url }}?limit=8"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
>
  {% if recommendations.performed and recommendations.products_count > 0 %}
    <div class="pt-rp__inner">
      <p class="pt-rp__label">You may also like</p>
      <div class="pt-rp__scroll">
        {%- for product in recommendations.products -%}
          {%- liquid
            assign tire_size = product.metafields.custom.tire_size | default: ''
            assign card_title = product.title
            if tire_size != blank
              assign card_title = product.title | remove: tire_size | strip
            endif
          -%}
          <a href="{{ product.url }}" class="pt-rp__card">
            <div class="pt-rp__img">
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' | image_tag: class: 'pt-rp__img-el', loading: 'lazy' }}
              {%- else -%}
                <div class="pt-rp__img-ph">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                </div>
              {%- endif -%}
            </div>
            <div class="pt-rp__body">
              <span class="pt-rp__vendor">{{ product.vendor }}</span>
              <h3 class="pt-rp__title">{{ card_title }}</h3>
              {%- if tire_size != blank -%}
                <span class="pt-rp__size">{{ tire_size }}</span>
              {%- endif -%}
              <div class="pt-rp__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="pt-rp__price-sale">${{ product.price | money_without_currency }}</span>
                  <span class="pt-rp__price-was">${{ product.compare_at_price | money_without_currency }}</span>
                {%- else -%}
                  <span>${{ product.price | money_without_currency }}</span>
                {%- endif -%}
                <span class="pt-rp__price-per">/tire</span>
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>
    </div>
  {% endif %}
</product-recommendations>

{% stylesheet %}
  .pt-rp {
    border-top: 1px solid #f3f4f6;
  }
  .pt-rp__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem 4rem;
  }
  .pt-rp__label {
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    font-weight: 500;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 1.5rem;
  }
  .pt-rp__scroll {
    display: flex;
    gap: 1.4rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
  }
  .pt-rp__scroll::-webkit-scrollbar { display: none; }

  .pt-rp__card {
    display: flex;
    flex-direction: column;
    flex: 0 0 22rem;
    scroll-snap-align: start;
    text-decoration: none;
    color: inherit;
    background: #f5f5f5;
    border-radius: 10px;
    overflow: hidden;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .pt-rp__card:hover {
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.07);
    transform: translateY(-2px);
  }

  .pt-rp__img {
    aspect-ratio: 1;
    overflow: hidden;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  .pt-rp__img-el {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.4s ease;
  }
  .pt-rp__card:hover .pt-rp__img-el {
    transform: scale(1.04);
  }
  .pt-rp__img-ph {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .pt-rp__body {
    padding: 1.2rem 1.4rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    background: #fff;
  }
  .pt-rp__vendor {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 400;
    color: #9ca3af;
  }
  .pt-rp__title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: #111;
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.2s;
  }
  .pt-rp__card:hover .pt-rp__title {
    color: #dc2626;
  }
  .pt-rp__size {
    font-family: 'Outfit', sans-serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: #F5820B;
  }
  .pt-rp__price {
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: #111;
    margin-top: 0.3rem;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .pt-rp__price-sale { color: #dc2626; }
  .pt-rp__price-was {
    font-size: 1rem;
    font-weight: 400;
    color: #9ca3af;
    text-decoration: line-through;
  }
  .pt-rp__price-per {
    font-size: 1rem;
    font-weight: 400;
    color: #9ca3af;
  }

  @media (max-width: 749px) {
    .pt-rp__inner { padding: 2rem 1.6rem 3rem; }
    .pt-rp__card { flex: 0 0 16rem; }
    .pt-rp__body { padding: 1rem 1.2rem 1.4rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PT Related products",
  "tag": "section",
  "class": "section-pt-related",
  "settings": [],
  "presets": [
    {
      "name": "PT Related products"
    }
  ]
}
{% endschema %}
