<header class="pt-header" data-pt-header>
  <div class="pt-header__container">

    {%- comment -%} Logo — left corner {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="pt-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: height: 44 | image_tag: class: "pt-header__logo-img" }}
      {%- else -%}
        <div class="pt-header__logo-mark"><span>P</span></div>
      {%- endif -%}
    </a>

    {%- comment -%} Nav links — center {%- endcomment -%}
    <nav class="pt-header__nav" aria-label="{{ 'sections.pt_header.navigation' | t }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_link' -%}
            <a
              href="{{ block.settings.link | default: '#' }}"
              class="pt-header__link"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.label }}
            </a>
          {%- endif -%}
        {%- endfor -%}
    </nav>

    {%- comment -%} Icons — right {%- endcomment -%}
    <div class="pt-header__icons">
        {%- if customer -%}
          {%- if customer.tags contains 'wholesale' -%}
            <a href="/pages/wholesale-portal" class="pt-header__icon pt-header__garage-link" aria-label="My portal">
              <span class="pt-header__garage-label">My portal</span>
            </a>
          {%- else -%}
            <a href="{{ routes.account_url }}" class="pt-header__icon pt-header__garage-link" aria-label="{{ 'sections.pt_header.garage' | t }}" data-garage-customer-id="{{ customer.id }}">
              <span class="pt-header__garage-label">{{ 'sections.pt_header.my_garage' | t }}</span>
              <span class="pt-header__garage-count" data-garage-count hidden>0</span>
            </a>
          {%- endif -%}
        {%- else -%}
          <a href="{{ routes.account_login_url }}" class="pt-header__icon" aria-label="{{ 'sections.pt_header.account' | t }}">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.phone_number != blank -%}
          {%- assign phone_clean = section.settings.phone_number | remove: ' ' | remove: '(' | remove: ')' | remove: '-' -%}
          <a href="tel:+1{{ phone_clean }}" class="pt-header__icon pt-header__phone" aria-label="{{ 'sections.pt_header.call_us' | t }}">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.18 6.18l.98-.98a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7a2 2 0 0 1 1.72 2.02z"/>
            </svg>
          </a>
        {%- endif -%}
        <a href="{{ routes.cart_url }}" class="pt-header__icon pt-header__cart" aria-label="{{ 'sections.pt_header.cart' | t }}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="pt-header__cart-count">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
    </div>

    {%- comment -%} Mobile hamburger {%- endcomment -%}
    <button class="pt-header__menu-btn" aria-label="{{ 'sections.pt_header.menu' | t }}" data-pt-menu-toggle aria-expanded="false">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

    {%- comment -%} Mobile cart (always visible on mobile) {%- endcomment -%}
    <a href="{{ routes.cart_url }}" class="pt-header__icon pt-header__cart pt-header__cart-mobile" aria-label="{{ 'sections.pt_header.cart' | t }}">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      {%- if cart.item_count > 0 -%}
        <span class="pt-header__cart-count">{{ cart.item_count }}</span>
      {%- endif -%}
    </a>
  </div>

  {%- comment -%} Mobile drawer {%- endcomment -%}
  <div class="pt-header__mobile-menu" data-pt-mobile-menu>
    <nav class="pt-header__mobile-nav">
      {%- for block in section.blocks -%}
        {%- if block.type == 'nav_link' -%}
          <a href="{{ block.settings.link | default: '#' }}" class="pt-header__mobile-link">{{ block.settings.label }}</a>
        {%- endif -%}
      {%- endfor -%}
      {%- if customer -%}
        {%- if customer.tags contains 'wholesale' -%}
          <a href="/pages/wholesale-portal" class="pt-header__mobile-link pt-header__mobile-garage">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><path d="M12 12v4"/><path d="M8 12h8"/></svg>
            My portal
          </a>
        {%- else -%}
          <a href="/pages/garage" class="pt-header__mobile-link pt-header__mobile-garage">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg>
            {{ 'sections.pt_header.my_garage' | t }}
          </a>
        {%- endif -%}
      {%- else -%}
        <a href="{{ routes.account_login_url }}" class="pt-header__mobile-link">{{ 'customer.login_page.sign_in' | t }}</a>
      {%- endif -%}
    </nav>
  </div>
</header>

<script>
  (function() {
    var toggle = document.querySelector('[data-pt-menu-toggle]');
    var menu   = document.querySelector('[data-pt-mobile-menu]');
    if (toggle && menu) {
      toggle.addEventListener('click', function() {
        var isOpen = menu.classList.toggle('pt-header__mobile-menu--open');
        toggle.setAttribute('aria-expanded', String(isOpen));
      });
    }
  })();
</script>

{% stylesheet %}
  /* ═══════════════════════════════════════════
     PT-HEADER — Single-row, logo left
     Palette: OLED black · red #dc2626 · white
  ═══════════════════════════════════════════ */
  .pt-header {
    background: #000;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid #1a1a1a;
  }

  /* ── Single flex row ── */
  .pt-header__container {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 2rem;
    height: 72px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* ── Logo — left ── */
  .pt-header__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .pt-header__logo-img {
    height: 44px;
    width: auto;
    display: block;
  }
  .pt-header__logo-mark {
    width: 40px;
    height: 40px;
    background: #dc2626;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pt-header__logo-mark span {
    color: #fff;
    font-weight: 800;
    font-size: 18px;
    line-height: 1;
  }

  /* ── Nav links — grow to fill, center content ── */
  .pt-header__nav {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
  }
  .pt-header__link {
    color: #a1a1aa;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    transition: color 0.18s, background 0.18s;
    white-space: nowrap;
  }
  .pt-header__link:hover {
    color: #fff;
    background: rgba(255,255,255,0.06);
  }
  .pt-header__link:focus-visible {
    outline: 2px solid #dc2626;
    outline-offset: 2px;
  }

  /* ── Icons — right ── */
  .pt-header__icons {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .pt-header__icon {
    color: #a1a1aa;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    transition: color 0.18s, background 0.18s;
    position: relative;
  }
  .pt-header__icon:hover {
    color: #fff;
    background: rgba(255,255,255,0.08);
  }

  /* Cart badge */
  .pt-header__cart-count {
    position: absolute;
    top: 4px;
    right: 4px;
    background: #dc2626;
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    min-width: 16px;
    height: 16px;
    border-radius: 99px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    line-height: 1;
  }

  /* Garage / Portal pill */
  .pt-header__garage-link {
    width: auto;
    padding: 0 14px;
    gap: 7px;
    color: #dc2626;
    background: rgba(220, 38, 38, 0.08);
    border: 1px solid rgba(220, 38, 38, 0.25);
  }
  .pt-header__garage-link:hover {
    color: #fff;
    background: #dc2626;
    border-color: #dc2626;
  }
  .pt-header__garage-label {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }
  .pt-header__garage-count {
    background: #dc2626;
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    min-width: 16px;
    height: 16px;
    border-radius: 99px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    line-height: 1;
  }

  /* ── Hamburger — hidden on desktop ── */
  .pt-header__menu-btn {
    display: none;
    background: none;
    border: none;
    color: #a1a1aa;
    cursor: pointer;
    padding: 0;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    flex-shrink: 0;
    transition: background 0.18s, color 0.18s;
  }
  .pt-header__menu-btn:hover {
    background: rgba(255,255,255,0.08);
    color: #fff;
  }

  /* ── Mobile drawer ── */
  .pt-header__mobile-menu {
    display: none;
    border-top: 1px solid #1a1a1a;
    padding: 1.25rem 1.5rem 1.5rem;
    background: #000;
  }
  .pt-header__mobile-menu--open {
    display: block;
  }
  .pt-header__mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .pt-header__mobile-link {
    color: #a1a1aa;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    transition: color 0.18s, background 0.18s;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-height: 44px;
  }
  .pt-header__mobile-link:hover {
    color: #fff;
    background: rgba(255,255,255,0.06);
  }
  .pt-header__mobile-garage {
    color: #dc2626;
    font-weight: 700;
    background: rgba(220, 38, 38, 0.08);
  }
  .pt-header__mobile-garage:hover {
    color: #fff;
    background: #dc2626;
  }

  /* ══════════════════════════
     MOBILE  (≤ 768px)
  ══════════════════════════ */
  @media (max-width: 768px) {
    .pt-header__container {
      padding: 0 1rem;
      height: 60px;
      gap: 0;
    }
    .pt-header__nav { display: none; }
    .pt-header__icons { display: none; }
    .pt-header__menu-btn { display: flex; }

    /* Mobile top row: hamburger | logo (center) | cart */
    .pt-header__logo {
      flex: 1;
      justify-content: center;
    }
  }

  /* Hide mobile cart on desktop */
  .pt-header__cart-mobile {
    display: none;
  }
  @media (max-width: 768px) {
    .pt-header__cart-mobile {
      display: flex;
      width: 40px;
      height: 40px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pt-header__link,
    .pt-header__icon,
    .pt-header__garage-link { transition: none; }
  }
{% endstylesheet %}

{% javascript %}
  /* Garage badge */
  (function() {
    var badge = document.querySelector('[data-garage-count]');
    if (!badge) return;

    function updateBadge(count) {
      if (count > 0) {
        badge.textContent = count;
        badge.hidden = false;
      } else {
        badge.hidden = true;
      }
    }

    /* Read initial count from localStorage */
    var garageLink = document.querySelector('[data-garage-customer-id]');
    var customerId = garageLink ? garageLink.dataset.garageCustomerId : null;
    if (customerId) {
      try {
        var raw = localStorage.getItem('pt-garage-' + customerId);
        var vehicles = raw ? JSON.parse(raw) : [];
        updateBadge(vehicles.length);
      } catch(e) {}
    }

    /* Subscribe to live updates */
    if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
      subscribe(PUB_SUB_EVENTS.garageUpdate, function(data) {
        updateBadge(data.vehicles ? data.vehicles.length : 0);
      });
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.pt_header.name",
  "blocks": [
    {
      "type": "nav_link",
      "name": "t:sections.pt_header.blocks.nav_link.name",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.pt_header.blocks.nav_link.settings.label",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.pt_header.blocks.nav_link.settings.link"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:sections.pt_header.settings.logo"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number",
      "placeholder": "703-555-1234",
      "info": "Displays a phone icon next to the cart in the navbar"
    }
  ]
}
{% endschema %}
