            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div>
          <div class="wh-dash-qlink__body">
            <span class="wh-dash-qlink__title">Request delivery</span>
            <span class="wh-dash-qlink__sub">Order tires delivered to your shop</span>
          </div>
          <svg class="wh-dash-qlink__arr" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </div>

      <!-- Promo banner -->
      {%- if section.settings.promo_text != blank -%}
