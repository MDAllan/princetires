{%- comment -%}
  Prince Tires — Wholesale section
  Used by two templates:
    page.wholesale         → /pages/wholesale        = info landing (always)
    page.wholesale-portal  → /pages/wholesale-portal = B2B dashboard (wholesale customers only)

  States on info landing (/pages/wholesale):
    1. Guest                   → Info + Register CTA
    2. Wholesale customer      → Info + "Go to my portal" CTA
    3. Pending                 → Info + Pending notice
    4. Regular logged-in       → Info + Apply CTA

  States on portal (/pages/wholesale-portal):
    1. Wholesale customer      → Full dashboard
    2. Anyone else             → Redirect to /pages/wholesale
{%- endcomment -%}

{%- liquid
  assign is_wholesale    = false
  assign is_pending      = false
  assign is_portal_page  = false
  if template.suffix == 'wholesale-portal'
    assign is_portal_page = true
  endif
  if customer
    if customer.tags contains 'wholesale'
      assign is_wholesale = true
    elsif customer.note contains 'WHOLESALE:'
      assign is_pending = true
    endif
  endif
-%}

{%- comment -%} ── Portal page: redirect non-wholesale away ── {%- endcomment -%}
{%- if is_portal_page -%}
  {%- unless is_wholesale -%}
    <script>window.location.replace('/pages/wholesale');</script>
  {%- endunless -%}
{%- endif -%}

<style>
/* ═══════════════════════════════════════════════════
   WHOLESALE PAGE — Prince Tires
   Red #DC2626 · Dark #111111 · Fonts: Barlow Condensed + Outfit
═══════════════════════════════════════════════════ */
.wh {
  --red:       #DC2626;
  --red-dim:   #B91C1C;
  --red-glow:  rgba(220,38,38,0.18);
  --red-soft:  #FEF2F2;
  --dark:      #111111;
  --navy:      #1a1a1a;
  --mid:       #334155;
  --muted:     #64748B;
  --subtle:    #94A3B8;
  --border:    #E2E8F0;
  --surface:   #F8FAFC;
  --white:     #FFFFFF;
  --green:     #16A34A;
  --green-bg:  #F0FDF4;
  --amber:     #D97706;
  --amber-bg:  #FFFBEB;
  --inner:     1100px;
  --px:        clamp(20px, 4vw, 48px);
  font-family: 'Outfit', sans-serif;
  color: var(--navy);
}

/* ── HERO ── */
.wh-hero {
  background: #fff;
  border-bottom: 1px solid var(--border);
  padding: 0 var(--px);
  position: relative;
  overflow: hidden;
}
.wh-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 80% at 100% 60%, rgba(220,38,38,0.05) 0%, transparent 60%),
    radial-gradient(ellipse 40% 50% at 0% 0%, rgba(220,38,38,0.03) 0%, transparent 55%);
  pointer-events: none;
}
.wh-hero::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--red);
  pointer-events: none;
}
.wh-hero__inner {
  max-width: var(--inner);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 72px;
  align-items: center;
  padding: 88px 0 104px;
  position: relative;
  z-index: 1;
}
.wh-hero__left { padding-right: 16px; }
.wh-hero__tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--red);
  background: rgba(220,38,38,0.1);
  border: 1px solid rgba(220,38,38,0.22);
  padding: 6px 14px;
  border-radius: 99px;
  margin-bottom: 20px;
}
.wh-hero__tag svg { width:12px;height:12px; }
.wh-hero__h1 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(46px, 6.5vw, 80px);
  font-weight: 800;
  color: var(--dark);
  line-height: 0.95;
  text-transform: uppercase;
  letter-spacing: -0.01em;
  margin: 0 0 22px;
}
.wh-hero__h1 em { color: var(--red); font-style: normal; }
.wh-hero__sub {
  font-size: clamp(15px, 2vw, 18px);
  font-weight: 300;
  color: var(--muted);
  line-height: 1.7;
  max-width: 520px;
  margin: 0 0 36px;
}
.wh-hero__sub strong { color: var(--mid); font-weight: 600; }
.wh-hero__cta-row {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}
.wh-hero__pending-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--amber-bg);
  border: 1px solid #fcd34d;
  color: var(--amber);
  font-size: 13px;
  font-weight: 500;
  padding: 10px 16px;
  border-radius: 99px;
}

/* ── REGISTER CARD (right side of hero) ── */
.wh-reg-card {
  background: #fff;
  border-radius: 20px;
  padding: 36px 32px;
  box-shadow: 0 8px 40px rgba(15,23,42,0.10), 0 0 0 1px var(--border);
  position: relative;
}
.wh-reg-card::before {
  content: '';
  position: absolute;
  top: 0; left: 32px; right: 32px;
  height: 3px;
  background: var(--red);
  border-radius: 0 0 3px 3px;
}
.wh-reg-card__head {
  margin-bottom: 24px;
  text-align: center;
}
.wh-reg-card__icon {
  width: 56px; height: 56px;
  background: var(--red-soft);
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--red);
  margin: 0 auto 14px;
}
.wh-reg-card__icon svg { width:24px;height:24px; }
.wh-reg-card__title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 24px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--navy);
  margin: 0 0 6px;
  letter-spacing: 0.01em;
}
.wh-reg-card__sub {
  font-size: 13px;
  color: var(--muted);
  margin: 0;
  font-weight: 300;
}
.wh-reg-card__perks {
  list-style: none;
  padding: 0;
  margin: 0 0 24px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.wh-reg-card__perk {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13.5px;
  color: var(--mid);
}
.wh-reg-card__perk-check {
  width: 20px; height: 20px;
  background: var(--green-bg);
  border-radius: 50%;
  color: var(--green);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.wh-reg-card__perk-check svg { width:11px;height:11px; }
.wh-reg-card__btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  height: 52px;
  background: var(--red);
  color: #fff;
  border-radius: 10px;
  text-decoration: none;
  font-size: 15px;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: background 0.18s, transform 0.18s, box-shadow 0.18s;
  letter-spacing: 0.01em;
  position: relative;
  overflow: hidden;
  margin-bottom: 12px;
}
.wh-reg-card__btn::before {
  content: '';
  position: absolute;
  top: 0; left: -75%;
  width: 50%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
  transform: skewX(-20deg);
  animation: wh-shimmer 3s ease-in-out infinite;
}
@keyframes wh-shimmer { 0%{left:-75%} 60%{left:125%} 100%{left:125%} }
.wh-reg-card__btn:hover { background: var(--red-dim); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(220,38,38,0.28); }
.wh-reg-card__btn svg { width:17px;height:17px; flex-shrink:0; }
.wh-reg-card__login {
  text-align: center;
  font-size: 12.5px;
  color: var(--muted);
}
.wh-reg-card__login a { color: var(--red); text-decoration: none; font-weight: 500; }
.wh-reg-card__login a:hover { text-decoration: underline; }
.wh-reg-card__divider {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 18px 0;
}
.wh-reg-card__divider::before,
.wh-reg-card__divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}
.wh-reg-card__divider span {
  font-size: 11px;
  font-weight: 600;
  color: var(--subtle);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  white-space: nowrap;
}
.wh-reg-card__approval {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
  font-size: 12px;
  color: var(--muted);
}
.wh-reg-card__approval svg { width:14px;height:14px; color:var(--green); flex-shrink:0; }

/* ── STATS BAR ── */
.wh-stats-bar {
  background: var(--red);
  padding: 0 var(--px);
}
.wh-stats-bar__inner {
  max-width: var(--inner);
  margin: 0 auto;
  display: flex;
  align-items: stretch;
}
.wh-stat {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  padding: 22px 20px;
  border-right: 1px solid rgba(255,255,255,0.15);
  text-align: center;
}
.wh-stat:last-child { border-right: none; }
.wh-stat__val {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 36px;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  display: block;
  letter-spacing: -0.01em;
}
.wh-stat__label {
  font-size: 11px;
  font-weight: 500;
  color: rgba(255,255,255,0.6);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-top: 5px;
  display: block;
}

/* ── SECTION SHARED ── */
.wh-section {
  padding: 80px var(--px);
}
.wh-section--alt { background: var(--surface); }
.wh-section__inner {
  max-width: var(--inner);
  margin: 0 auto;
}
.wh-section__hd { margin-bottom: 52px; }
.wh-section__hd--center { text-align: center; }
.wh-eyebrow {
  display: block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 10px;
}
.wh-h2 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(28px, 4vw, 42px);
  font-weight: 700;
  color: var(--navy);
  text-transform: uppercase;
  letter-spacing: -0.01em;
  margin: 0 0 12px;
}
.wh-lead {
  font-size: 15.5px;
  font-weight: 300;
  color: var(--muted);
  line-height: 1.75;
  max-width: 560px;
}
.wh-lead--center { margin: 0 auto; text-align: center; }

/* ── BENEFITS ── */
.wh-benefits {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  max-width: 960px;
  margin: 0 auto;
}
.wh-benefit {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 28px;
  position: relative;
  overflow: hidden;
  transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
}
.wh-benefit::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--red);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.25s;
}
.wh-benefit:hover { box-shadow: 0 8px 32px rgba(15,23,42,0.08); transform: translateY(-3px); border-color: rgba(220,38,38,0.18); }
.wh-benefit:hover::after { transform: scaleX(1); }
.wh-benefit__icon {
  width: 48px; height: 48px;
  background: var(--red-soft);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--red);
  margin-bottom: 16px;
}
.wh-benefit__icon svg { width:22px;height:22px; }
.wh-benefit__title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 19px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--navy);
  margin: 0 0 8px;
}
.wh-benefit__text {
  font-size: 13.5px;
  font-weight: 300;
  color: var(--muted);
  line-height: 1.65;
  margin: 0;
}

/* ── HOW IT WORKS ── */
.wh-steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  position: relative;
  max-width: 860px;
  margin: 0 auto;
}
.wh-steps::before {
  content: '';
  position: absolute;
  top: 31px;
  left: calc(12.5% + 16px);
  right: calc(12.5% + 16px);
  height: 2px;
  background: linear-gradient(90deg, var(--red), var(--border), var(--red));
}
.wh-step {
  text-align: center;
  padding: 0 16px 24px;
  position: relative;
}
.wh-step__num {
  width: 62px; height: 62px;
  border-radius: 50%;
  background: var(--red-soft);
  color: var(--red);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 26px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 18px;
  position: relative;
  z-index: 1;
  border: 3px solid rgba(220,38,38,0.15);
  transition: background 0.2s, border-color 0.2s, transform 0.2s;
}
.wh-step:hover .wh-step__num {
  background: var(--red);
  border-color: var(--red);
  color: #fff;
  transform: scale(1.08);
}
.wh-step h4 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 17px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--navy);
  margin: 0 0 8px;
  letter-spacing: 0.02em;
}
.wh-step p {
  font-size: 13px;
  color: var(--muted);
  margin: 0;
  line-height: 1.6;
  font-weight: 300;
}

/* ── WHO QUALIFIES ── */
.wh-who-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 48px;
  align-items: start;
  max-width: 960px;
  margin: 0 auto;
}
.wh-who__list {
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.wh-who__item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 16px 18px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 10px;
  transition: border-color 0.18s, box-shadow 0.18s;
}
.wh-who__item:hover {
  border-color: var(--red);
  box-shadow: 0 4px 16px rgba(220,38,38,0.08);
}
.wh-who__item-icon {
  width: 38px; height: 38px;
  background: var(--red-soft);
  border-radius: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--red);
  flex-shrink: 0;
}
.wh-who__item-icon svg { width:17px;height:17px; }
.wh-who__item-title {
  font-size: 14.5px;
  font-weight: 600;
  color: var(--navy);
  margin: 0 0 3px;
  display: block;
}
.wh-who__item-desc {
  font-size: 12.5px;
  color: var(--muted);
  font-weight: 300;
  margin: 0;
  line-height: 1.5;
}

/* ── CTA BOX (right of who qualifies) ── */
.wh-cta-box {
  background: var(--white);
  border: 1px solid var(--border);
  border-top: 4px solid var(--red);
  border-radius: 20px;
  padding: 44px 36px;
  text-align: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(15,23,42,0.06);
}
.wh-cta-box::before {
  content: '';
  position: absolute;
  bottom: -60px; right: -60px;
  width: 220px; height: 220px;
  border-radius: 50%;
  background: rgba(220,38,38,0.04);
  pointer-events: none;
}
.wh-cta-box::after { display: none; }
.wh-cta-box__badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--red);
  background: var(--red-soft);
  border: 1px solid rgba(220,38,38,0.2);
  padding: 5px 12px;
  border-radius: 99px;
  margin-bottom: 18px;
  position: relative;
  z-index: 1;
}
.wh-cta-box__badge svg { width:10px;height:10px; }
.wh-cta-box__title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 36px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--dark);
  margin: 0 0 12px;
  position: relative;
  z-index: 1;
}
.wh-cta-box__text {
  font-size: 14px;
  font-weight: 300;
  color: var(--muted);
  line-height: 1.7;
  margin: 0 0 28px;
  position: relative;
  z-index: 1;
}
.wh-cta-box__btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  height: 50px;
  background: var(--red);
  color: #fff;
  border-radius: 10px;
  text-decoration: none;
  font-size: 15px;
  font-weight: 600;
  transition: background 0.18s, box-shadow 0.18s;
  position: relative;
  z-index: 1;
  margin-bottom: 14px;
}
.wh-cta-box__btn:hover { background: var(--red-dim); box-shadow: 0 6px 20px rgba(220,38,38,0.3); }
.wh-cta-box__btn svg { width:16px;height:16px; flex-shrink:0; }
.wh-cta-box__note {
  font-size: 12px;
  color: var(--subtle);
  position: relative;
  z-index: 1;
}

/* ── FAQ ── */
.wh-faq { display: flex; flex-direction: column; gap: 0; }
.wh-faq-item {
  border-bottom: 1px solid var(--border);
}
.wh-faq-item:first-child { border-top: 1px solid var(--border); }
.wh-faq-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 20px 0;
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  font-family: 'Outfit', sans-serif;
  font-size: 15px;
  font-weight: 600;
  color: var(--navy);
  transition: color 0.15s;
}
.wh-faq-btn:hover { color: var(--red); }
.wh-faq-btn svg { width:18px;height:18px; flex-shrink:0; color:var(--muted); transition: transform 0.22s, color 0.15s; }
.wh-faq-btn[aria-expanded="true"] svg { transform: rotate(45deg); color: var(--red); }
.wh-faq-body {
  display: none;
  font-size: 14px;
  font-weight: 300;
  color: var(--muted);
  line-height: 1.75;
  padding-bottom: 20px;
  max-width: 700px;
}
.wh-faq-body.is-open { display: block; }

/* ── BOTTOM CTA ── */
.wh-bottom-cta {
  background: var(--red-soft);
  border-top: 1px solid rgba(220,38,38,0.12);
  padding: 96px var(--px);
  text-align: center;
  position: relative;
  overflow: hidden;
}
.wh-bottom-cta::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 80% at 50% 110%, rgba(220,38,38,0.08) 0%, transparent 65%);
  pointer-events: none;
}
.wh-bottom-cta__inner { position: relative; z-index: 1; max-width: 680px; margin: 0 auto; }
.wh-bottom-cta__title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(34px, 5vw, 58px);
  font-weight: 800;
  text-transform: uppercase;
  color: var(--dark);
  margin: 0 0 16px;
  line-height: 1;
}
.wh-bottom-cta__title em { color: var(--red); font-style: normal; }
.wh-bottom-cta__sub {
  font-size: 16px;
  font-weight: 300;
  color: var(--muted);
  margin: 0 0 36px;
  line-height: 1.7;
}
.wh-bottom-cta__actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
}

/* ── SHARED BUTTONS ── */
.wh-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  height: 50px;
  padding: 0 26px;
  border-radius: 10px;
  font-size: 14.5px;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
  border: none;
  transition: all 0.18s;
  white-space: nowrap;
  font-family: 'Outfit', sans-serif;
  letter-spacing: 0.01em;
}
.wh-btn--red { background: var(--red); color: #fff; box-shadow: 0 4px 16px rgba(220,38,38,0.2); }
.wh-btn--red:hover { background: var(--red-dim); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(220,38,38,0.3); }
.wh-btn--ghost { background: #fff; color: var(--mid); border: 1px solid var(--border); }
.wh-btn--ghost:hover { background: var(--surface); border-color: #cbd5e1; color: var(--navy); }
.wh-btn svg { width:16px;height:16px;flex-shrink:0; }

/* ── PENDING / UPGRADE / DASHBOARD states ── */
.wh-state {
  max-width: 560px;
  margin: 80px auto;
  padding: 0 var(--px);
  text-align: center;
}
.wh-state__icon {
  width: 80px; height: 80px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 22px;
}
.wh-state__icon svg { width:34px;height:34px; }
.wh-state__icon--amber { background: var(--amber-bg); color: var(--amber); }
.wh-state__icon--red   { background: var(--red-soft); color: var(--red); }
.wh-state__title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 36px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--navy);
  margin: 0 0 12px;
}
.wh-state__text {
  font-size: 15px;
  color: var(--muted);
  line-height: 1.7;
  margin: 0 0 28px;
  font-weight: 300;
}
.wh-state__card {
  border-radius: 12px;
  padding: 18px 22px;
  text-align: left;
  font-size: 13.5px;
  line-height: 1.65;
  margin-bottom: 28px;
}
.wh-state__card--amber { background: var(--amber-bg); border: 1px solid rgba(217,119,6,0.2); color: var(--amber); }
.wh-state__btns { display:flex;gap:12px;justify-content:center;flex-wrap:wrap; }
.wh-btn--outline { border: 1.5px solid var(--red); color: var(--red); background: transparent; }
.wh-btn--outline:hover { background: var(--red); color: #fff; }

/* ── DASHBOARD ── */
.wh-dash { max-width: var(--inner); margin: 0 auto; padding: 52px var(--px); }
.wh-dash__hero {
  background: var(--navy);
  border-radius: 16px;
  padding: 32px 36px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  margin-bottom: 28px;
  position: relative;
  overflow: hidden;
}
.wh-dash__hero::before { content:'';position:absolute;top:-40px;right:-40px;width:220px;height:220px;border-radius:50%;background:rgba(220,38,38,0.08);pointer-events:none; }
.wh-dash__badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--red);
  background: rgba(220,38,38,0.1);
  border: 1px solid rgba(220,38,38,0.2);
  padding: 4px 10px;
  border-radius: 99px;
  margin-bottom: 10px;
}
.wh-dash__badge svg { width:10px;height:10px; }
.wh-dash__title { font-family:'Barlow Condensed',sans-serif;font-size:clamp(22px,4vw,34px);font-weight:700;color:#fff;margin:0 0 4px;text-transform:uppercase; }
.wh-dash__sub { font-size:13px;color:rgba(255,255,255,0.45);margin:0; }
.wh-dash__actions { display:flex;gap:10px;flex-wrap:wrap;flex-shrink:0; }
.wh-dash__stats { display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px; }
.wh-stat-card { background:var(--white);border:1px solid var(--border);border-radius:12px;padding:20px;display:flex;align-items:center;gap:14px; }
.wh-stat-card__icon { width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0; }
.wh-stat-card__icon--red   { background:var(--red-soft);color:var(--red); }
.wh-stat-card__icon--green { background:var(--green-bg);color:var(--green); }
.wh-stat-card__icon--blue  { background:#EFF6FF;color:#3B82F6; }
.wh-stat-card__icon--amber { background:var(--amber-bg);color:var(--amber); }
.wh-stat-card__icon svg { width:18px;height:18px; }
.wh-stat-card__val { font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:700;color:var(--navy);line-height:1;display:block; }
.wh-stat-card__label { font-size:11.5px;color:var(--muted);display:block;margin-top:3px; }
.wh-dash__grid { display:grid;grid-template-columns:1fr 1fr;gap:20px; }
.wh-dash__panel { background:var(--white);border:1px solid var(--border);border-radius:14px;overflow:hidden; }
.wh-dash__panel-head { display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--border); }
.wh-dash__panel-head h3 { font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;text-transform:uppercase;color:var(--navy);margin:0;letter-spacing:.02em; }
.wh-dash__panel-head a { font-size:12px;font-weight:500;color:var(--red);text-decoration:none; }
.wh-dash__panel-head a:hover { text-decoration:underline; }
.wh-dash__panel-body { padding:18px 20px; }
.wh-qlinks { display:flex;flex-direction:column;gap:10px; }
.wh-qlink { display:flex;align-items:center;gap:12px;padding:11px 13px;background:var(--surface);border:1px solid var(--border);border-radius:8px;text-decoration:none;transition:border-color .15s,background .15s; }
.wh-qlink:hover { border-color:var(--red);background:var(--red-soft); }
.wh-qlink__icon { width:34px;height:34px;background:#fff;border:1px solid var(--border);border-radius:7px;display:flex;align-items:center;justify-content:center;color:var(--red);flex-shrink:0; }
.wh-qlink__icon svg { width:15px;height:15px; }
.wh-qlink__label { font-size:13.5px;font-weight:500;color:var(--navy);flex:1; }
.wh-qlink__arr { color:var(--subtle); }
.wh-qlink__arr svg { width:13px;height:13px; }
.wh-mgr { display:flex;align-items:center;gap:12px;padding:14px;background:var(--surface);border-radius:9px;border:1px solid var(--border);margin-bottom:14px; }
.wh-mgr__av { width:44px;height:44px;border-radius:50%;background:var(--navy);color:#fff;display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;flex-shrink:0; }
.wh-mgr__name { font-size:13.5px;font-weight:600;color:var(--navy);margin:0 0 2px;display:block; }
.wh-mgr__role { font-size:12px;color:var(--muted);margin:0; }
.wh-contacts { display:flex;flex-direction:column;gap:8px; }
.wh-contact { display:flex;align-items:center;gap:8px;font-size:13px;color:var(--muted);text-decoration:none;transition:color .15s; }
.wh-contact:hover { color:var(--red); }
.wh-contact svg { width:14px;height:14px;flex-shrink:0; }
.wh-orders-empty { text-align:center;padding:28px;color:var(--muted);font-size:13.5px; }
.wh-order-row { display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);font-size:13px; }
.wh-order-row:last-child { border-bottom:none; }
.wh-order-num { font-weight:600;color:var(--navy);min-width:70px; }
.wh-order-num a { color:var(--red);text-decoration:none; }
.wh-order-date { color:var(--muted);flex:1; }
.wh-order-total { font-weight:600;color:var(--navy); }
.wh-order-status { padding:2px 8px;border-radius:99px;font-size:11px;font-weight:600; }
.wh-order-status--paid    { background:var(--green-bg);color:var(--green); }
.wh-order-status--pending { background:var(--amber-bg);color:var(--amber); }

/* ── PRICING TIERS ── */
.wh-tiers {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  position: relative;
  max-width: 980px;
  margin: 0 auto;
}
.wh-tier {
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  position: relative;
}
.wh-tier:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(15,23,42,0.1); }
.wh-tier--popular {
  border-color: var(--red);
  box-shadow: 0 4px 24px rgba(220,38,38,0.14);
}
.wh-tier--popular .wh-tier__header { background: var(--red); }
.wh-tier--popular .wh-tier__badge { background: rgba(255,255,255,0.2); color: #fff; }
.wh-tier--popular .wh-tier__discount { color: #fff; }
.wh-tier--popular .wh-tier__off { color: rgba(255,255,255,0.7); }
.wh-tier__popular-tag {
  position: absolute;
  top: -1px; left: 50%;
  transform: translateX(-50%);
  background: var(--red);
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 4px 14px;
  border-radius: 0 0 8px 8px;
  white-space: nowrap;
  z-index: 2;
}
.wh-tier__header {
  padding: 28px 22px 22px;
  background: var(--surface);
  text-align: center;
  border-bottom: 1px solid var(--border);
}
.wh-tier__badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 99px;
  margin-bottom: 14px;
}
.wh-tier__badge--starter    { background: #f0fdf4; color: #16a34a; }
.wh-tier__badge--pro        { background: #eff6ff; color: #2563eb; }
.wh-tier__badge--business   { background: #fef9c3; color: #92400e; }
.wh-tier__badge--enterprise { background: var(--dark); color: rgba(255,255,255,0.85); }
.wh-tier__discount {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 52px;
  font-weight: 800;
  color: var(--navy);
  line-height: 1;
  display: block;
}
.wh-tier__off {
  font-size: 13px;
  color: var(--muted);
  font-weight: 400;
  display: block;
  margin-top: 4px;
}
.wh-tier__volume {
  font-size: 12px;
  font-weight: 600;
  color: var(--mid);
  text-align: center;
  padding: 12px 22px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  letter-spacing: 0.01em;
}
.wh-tier__perks {
  list-style: none;
  padding: 18px 20px;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.wh-tier__perk {
  display: flex;
  align-items: flex-start;
  gap: 9px;
  font-size: 12.5px;
  color: var(--mid);
  line-height: 1.4;
}
.wh-tier__perk-icon {
  width: 16px; height: 16px;
  color: var(--green);
  flex-shrink: 0;
  margin-top: 1px;
}
.wh-tier__perk-icon svg { width:16px;height:16px; }
.wh-tier__perk--locked .wh-tier__perk-icon { color: var(--subtle); }
.wh-tier__perk--locked span { color: var(--subtle); }
.wh-tier__cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  height: 42px;
  margin: 0 20px 20px;
  border-radius: 9px;
  font-size: 13px;
  font-weight: 600;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: all 0.18s;
  font-family: 'Outfit', sans-serif;
}
.wh-tier__cta--primary { background: var(--red); color: #fff; }
.wh-tier__cta--primary:hover { background: var(--red-dim); box-shadow: 0 4px 14px rgba(220,38,38,0.25); }
.wh-tier__cta--outline { background: transparent; color: var(--navy); border: 1.5px solid var(--border); }
.wh-tier__cta--outline:hover { border-color: var(--red); color: var(--red); }

/* ── SAVINGS CALCULATOR ── */
.wh-calc {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 20px;
  overflow: hidden;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  position: relative;
  box-shadow: 0 4px 24px rgba(15,23,42,0.06);
}
.wh-calc::before { display: none; }
.wh-calc__left {
  padding: 48px 44px;
  position: relative;
  z-index: 1;
}
.wh-calc__right {
  padding: 48px 44px;
  background: var(--red-soft);
  border-left: 1px solid rgba(220,38,38,0.1);
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  z-index: 1;
}
.wh-calc__eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--red);
  display: block;
  margin-bottom: 10px;
}
.wh-calc__title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(26px, 3.5vw, 38px);
  font-weight: 700;
  text-transform: uppercase;
  color: var(--dark);
  margin: 0 0 8px;
  line-height: 1.1;
}
.wh-calc__sub {
  font-size: 14px;
  font-weight: 300;
  color: var(--muted);
  line-height: 1.65;
  margin: 0 0 32px;
}
.wh-calc__label {
  font-size: 13px;
  font-weight: 500;
  color: var(--muted);
  margin-bottom: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.wh-calc__label span { color: var(--dark); font-weight: 700; font-size: 14px; }
.wh-calc__slider {
  -webkit-appearance: none;
  appearance: none;
  width: 100%;
  height: 6px;
  border-radius: 99px;
  background: var(--border);
  outline: none;
  margin-bottom: 10px;
}
.wh-calc__slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 22px; height: 22px;
  border-radius: 50%;
  background: var(--red);
  cursor: pointer;
  box-shadow: 0 2px 8px rgba(220,38,38,0.3);
  border: 3px solid #fff;
  transition: transform 0.15s;
}
.wh-calc__slider::-webkit-slider-thumb:hover { transform: scale(1.15); }
.wh-calc__slider::-moz-range-thumb {
  width: 22px; height: 22px;
  border-radius: 50%;
  background: var(--red);
  cursor: pointer;
  box-shadow: 0 2px 8px rgba(220,38,38,0.3);
  border: 3px solid #fff;
}
.wh-calc__ticks {
  display: flex;
  justify-content: space-between;
  margin-top: 6px;
}
.wh-calc__tick {
  font-size: 10.5px;
  color: var(--subtle);
  font-weight: 400;
}
.wh-calc__avg-price {
  margin-top: 20px;
}
.wh-calc__avg-label {
  font-size: 12px;
  font-weight: 500;
  color: var(--muted);
  margin-bottom: 8px;
}
.wh-calc__avg-inputs {
  display: flex;
  gap: 8px;
  align-items: center;
}
.wh-calc__price-input {
  height: 38px;
  padding: 0 12px;
  font-family: 'Outfit', sans-serif;
  font-size: 13.5px;
  font-weight: 500;
  color: var(--dark);
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 8px;
  outline: none;
  width: 110px;
  transition: border-color 0.2s;
}
.wh-calc__price-input:focus {
  border-color: var(--red);
}
.wh-calc__price-label {
  font-size: 12px;
  color: var(--subtle);
}

/* Result panel */
.wh-calc__savings-num {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(48px, 7vw, 72px);
  font-weight: 800;
  color: var(--red);
  line-height: 1;
  display: block;
  margin-bottom: 6px;
}
.wh-calc__savings-label {
  font-size: 13px;
  font-weight: 300;
  color: var(--muted);
  margin-bottom: 28px;
}
.wh-calc__tier-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 6px 14px;
  border-radius: 99px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 24px;
}
.wh-calc__tier-badge--starter  { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
.wh-calc__tier-badge--bronze   { background: #fef3c7; color: #78350f; border: 1px solid #fcd34d; }
.wh-calc__tier-badge--silver   { background: #f1f5f9; color: #334155; border: 1px solid #cbd5e1; }
.wh-calc__tier-badge--gold     { background: #fffbeb; color: #92400e; border: 1px solid #fcd34d; }
.wh-calc__tier-badge--platinum { background: #eff6ff; color: #1e40af; border: 1px solid #93c5fd; }
.wh-calc__tier-badge--elite    { background: #fef2f2; color: #991b1b; border: 1px solid #fca5a5; }
.wh-calc__breakdown {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 24px;
}
.wh-calc__breakdown-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 12.5px;
}
.wh-calc__breakdown-row span:first-child { color: var(--muted); }
.wh-calc__breakdown-row span:last-child { color: var(--mid); font-weight: 500; }
.wh-calc__breakdown-row--savings span:last-child { color: var(--green); font-weight: 700; }

/* ── RESPONSIVE ── */
@media (max-width: 1140px) {
  .wh-hero__inner { grid-template-columns: 1fr 380px; gap: 52px; }
}
@media (max-width: 1024px) {
  .wh-tiers { grid-template-columns: repeat(2, 1fr); max-width: 640px; }
  .wh-calc { grid-template-columns: 1fr; }
  .wh-calc__right { border-left: none; border-top: 1px solid rgba(220,38,38,0.1); }
  .wh-benefits { grid-template-columns: repeat(2, 1fr); max-width: 700px; }
  .wh-who-grid { grid-template-columns: 1fr; max-width: 600px; gap: 32px; }
  .wh-cta-box { padding: 36px 28px; }
  .wh-dash__stats { grid-template-columns: repeat(2, 1fr); }
  .wh-dash__grid { grid-template-columns: 1fr; }
  .wh-calc__left, .wh-calc__right { padding: 40px 36px; }
}
/* Hero stacks at 960px — prevents cramped 2-col at narrow tablet viewports */
@media (max-width: 960px) {
  .wh-hero__inner { grid-template-columns: 1fr; gap: 44px; padding: 64px 0 60px; }
  .wh-hero__left { padding-right: 0; }
  .wh-reg-card { max-width: 500px; }
}
/* Steps switch to 2×2 grid at 900px instead of cramping into 4 columns */
@media (max-width: 900px) {
  .wh-steps { grid-template-columns: 1fr 1fr; max-width: 560px; }
  .wh-steps::before { display: none; }
}
@media (max-width: 768px) {
  .wh-stats-bar__inner { flex-wrap: wrap; }
  .wh-stat { min-width: 50%; border-right: none; border-bottom: 1px solid rgba(255,255,255,0.15); }
  .wh-stat:nth-child(odd) { border-right: 1px solid rgba(255,255,255,0.15); }
  .wh-stat:nth-last-child(-n+2) { border-bottom: none; }
  .wh-section { padding: 60px var(--px); }
  .wh-dash__hero { flex-direction: column; align-items: flex-start; padding: 26px; }
  .wh-calc__left, .wh-calc__right { padding: 32px 26px; }
}
@media (max-width: 560px) {
  /* Benefits stay 2-col down to 560px — 1-col only on phones */
  .wh-benefits { grid-template-columns: 1fr; max-width: 440px; }
  .wh-hero__inner { padding: 52px 0 48px; }
  .wh-hero__cta-row { flex-direction: column; align-items: flex-start; }
  .wh-bottom-cta__actions { flex-direction: column; align-items: center; }
  .wh-reg-card { padding: 28px 22px; }
  .wh-steps { grid-template-columns: 1fr; }
  .wh-steps::before { display: none; }
  .wh-dash__stats { grid-template-columns: 1fr 1fr; }
  .wh-tiers { grid-template-columns: 1fr; max-width: 360px; }
  .wh-calc__left, .wh-calc__right { padding: 28px 20px; }
  .wh-section { padding: 52px var(--px); }
}
@media (prefers-reduced-motion: reduce) {
  .wh-benefit, .wh-btn, .wh-reg-card__btn, .wh-step__num { transition: none; }
  .wh-reg-card__btn::before { animation: none; }
}

/* ══════════════════════════════════════════════
   WHOLESALE DASHBOARD — Prince Tires
   Accent palette: Red #DC2626 · Green #10b981 · Amber #f59e0b
   Swiss Modernism: strict grid, mathematical spacing, single accent per element
══════════════════════════════════════════════ */

/* Portal shell */
.wh-dash-portal { background: #f8fafc; min-height: 100vh; font-family: 'Outfit', sans-serif; }

/* Thin red rule at the very top — brand anchor */
.wh-dash-portal::before { content: ''; display: block; height: 3px; background: linear-gradient(90deg, #DC2626 0%, #f87171 60%, transparent 100%); }

/* ── Hero ── */
.wh-dash-hero { background: #fff; border-bottom: 1px solid #e2e8f0; padding: 36px var(--px, 24px) 0; position: relative; overflow: hidden; }
/* Subtle radial glow behind the title */
.wh-dash-hero::after { content: ''; position: absolute; top: -60px; left: -40px; width: 340px; height: 260px; background: radial-gradient(ellipse at top left, rgba(220,38,38,.05) 0%, transparent 70%); pointer-events: none; }
.wh-dash-hero__inner { max-width: var(--inner, 1100px); margin: 0 auto; display: flex; flex-wrap: wrap; gap: 32px; align-items: flex-end; justify-content: space-between; position: relative; z-index: 1; }
.wh-dash-hero__left { padding-bottom: 28px; }

/* Tier badge — jewel pill */
.wh-dash-hero__badge { display: inline-flex; align-items: center; gap: 6px; font-size: 10.5px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; padding: 5px 14px; border-radius: 100px; margin-bottom: 14px; }
.wh-dash-hero__badge--bronze   { background: linear-gradient(135deg,#fef3c7,#fde68a); color: #78350f; border: 1px solid #fcd34d; box-shadow: 0 2px 8px rgba(245,158,11,.18); }
.wh-dash-hero__badge--silver   { background: linear-gradient(135deg,#f1f5f9,#e2e8f0); color: #334155; border: 1px solid #cbd5e1; box-shadow: 0 2px 8px rgba(100,116,139,.12); }
.wh-dash-hero__badge--gold     { background: linear-gradient(135deg,#fffbeb,#fef3c7); color: #92400e; border: 1px solid #fcd34d; box-shadow: 0 2px 8px rgba(245,158,11,.2); }
.wh-dash-hero__badge--platinum { background: linear-gradient(135deg,#eff6ff,#dbeafe); color: #1e40af; border: 1px solid #93c5fd; box-shadow: 0 2px 8px rgba(59,130,246,.15); }
.wh-dash-hero__badge--elite    { background: linear-gradient(135deg,#fef2f2,#fee2e2); color: #991b1b; border: 1px solid #fca5a5; box-shadow: 0 2px 8px rgba(220,38,38,.18); }

.wh-dash-hero__title { font-family: 'Barlow Condensed', sans-serif; font-size: clamp(28px,4vw,42px); font-weight: 800; color: #111111; margin: 0 0 5px; line-height: 1.05; letter-spacing: -.01em; }
.wh-dash-hero__title em { color: #DC2626; font-style: normal; }
.wh-dash-hero__sub { font-size: 13px; color: #94a3b8; margin: 0; display: flex; align-items: center; gap: 8px; }
.wh-dash-hero__sub::before { content: ''; display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #10b981; flex-shrink: 0; box-shadow: 0 0 0 3px rgba(16,185,129,.15); }

/* Stat strip — sits at base of hero, flush */
.wh-dash-hero__stats { display: grid; grid-template-columns: repeat(4, 1fr); margin-top: 28px; border-top: 1px solid #f1f5f9; }
.wh-dash-stat { padding: 20px 20px 22px; text-align: center; border-right: 1px solid #f1f5f9; position: relative; }
.wh-dash-stat:last-child { border-right: none; }
/* Accent bar on hover */
.wh-dash-stat::after { content: ''; position: absolute; bottom: 0; left: 20%; right: 20%; height: 2px; border-radius: 2px 2px 0 0; background: #DC2626; opacity: 0; transition: opacity .2s; }
.wh-dash-stat:hover::after { opacity: 1; }
.wh-dash-stat__icon { width: 32px; height: 32px; border-radius: 9px; display: flex; align-items: center; justify-content: center; margin: 0 auto 10px; }
.wh-dash-stat__icon svg { width: 15px; height: 15px; }
/* Coloured icons per stat (applied via nth-child) */
.wh-dash-stat:nth-child(1) .wh-dash-stat__icon { background: #fef2f2; color: #DC2626; }
.wh-dash-stat:nth-child(2) .wh-dash-stat__icon { background: #ecfdf5; color: #10b981; }
.wh-dash-stat:nth-child(3) .wh-dash-stat__icon { background: #fffbeb; color: #f59e0b; }
.wh-dash-stat:nth-child(4) .wh-dash-stat__icon { background: #f0f9ff; color: #0ea5e9; }
.wh-dash-stat__val { display: block; font-family: 'Barlow Condensed', sans-serif; font-size: 30px; font-weight: 800; color: #111111; line-height: 1; margin-bottom: 3px; }
.wh-dash-stat:nth-child(3) .wh-dash-stat__val { color: #10b981; } /* savings = green */
.wh-dash-stat__lbl { display: block; font-size: 10.5px; color: #94a3b8; text-transform: uppercase; letter-spacing: .06em; font-weight: 600; }

/* ── Tab bar ── */
.wh-dash-tabs { position: sticky; top: 0; z-index: 50; background: #fff; border-bottom: 1px solid #e2e8f0; box-shadow: 0 2px 12px rgba(0,0,0,.05); }
.wh-dash-tabs__inner { max-width: var(--inner, 1100px); margin: 0 auto; padding: 0 var(--px, 24px); display: flex; gap: 2px; overflow-x: auto; scrollbar-width: none; }
.wh-dash-tabs__inner::-webkit-scrollbar { display: none; }
.wh-dash-tab { flex-shrink: 0; background: none; border: none; cursor: pointer; padding: 15px 22px; font-size: 13px; font-weight: 600; color: #94a3b8; border-bottom: 3px solid transparent; margin-bottom: -1px; transition: color .18s, border-color .18s; text-decoration: none; display: inline-block; letter-spacing: .01em; }
.wh-dash-tab:hover { color: #374151; }
.wh-dash-tab--active { color: #111111; border-bottom-color: #DC2626; }
/* Shop Tires — red pill CTA */
.wh-dash-tab--link { background: #DC2626; color: #fff !important; border-radius: 8px; margin: 9px 0 9px 8px; padding: 8px 18px; border-bottom: none !important; font-size: 12px; transition: background .18s, transform .15s; }
.wh-dash-tab--link:hover { background: #b91c1c; transform: translateY(-1px); }

/* ── Content ── */
.wh-dash-content { max-width: var(--inner, 1100px); margin: 0 auto; padding: 32px var(--px, 24px) 72px; }
.wh-dash-panel--hidden { display: none; }

/* ── Cards ── */
.wh-dash-content__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
.wh-dash-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,.04); transition: box-shadow .2s, transform .2s; }
.wh-dash-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,.08); transform: translateY(-1px); }
.wh-dash-card--full { width: 100%; }
.wh-dash-card--full:hover { transform: none; }
/* Coloured top accent line on cards */
.wh-dash-card:first-child { border-top: 3px solid #DC2626; }
.wh-dash-card:nth-child(2) { border-top: 3px solid #10b981; }
.wh-dash-card__head { display: flex; align-items: center; justify-content: space-between; padding: 18px 22px 0; }
.wh-dash-card__head h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; font-weight: 700; color: #94a3b8; margin: 0; letter-spacing: .1em; text-transform: uppercase; }
.wh-dash-card__link { background: none; border: none; cursor: pointer; font-size: 12px; font-weight: 600; color: #DC2626; text-decoration: none; padding: 0; transition: opacity .15s; }
.wh-dash-card__link:hover { opacity: .75; }
.wh-dash-card__note { font-size: 11px; color: #94a3b8; }
.wh-dash-card__note a { color: #DC2626; }
.wh-dash-card__body { padding: 16px 22px 22px; }

/* ── Tier badge (inline) ── */
.wh-dash-tier-badge { font-size: 10px; font-weight: 700; letter-spacing: .07em; text-transform: uppercase; padding: 3px 10px; border-radius: 100px; }
.wh-dash-tier-badge--bronze   { background: #fef3c7; color: #78350f; }
.wh-dash-tier-badge--silver   { background: #f1f5f9; color: #334155; }
.wh-dash-tier-badge--gold     { background: #fffbeb; color: #92400e; }
.wh-dash-tier-badge--platinum { background: #eff6ff; color: #1e40af; }
.wh-dash-tier-badge--elite    { background: #fef2f2; color: #991b1b; }

/* Tier dots */
.wh-dash-tier-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 7px; vertical-align: middle; }
.wh-dash-tier-dot--bronze   { background: #f59e0b; }
.wh-dash-tier-dot--silver   { background: #94a3b8; }
.wh-dash-tier-dot--gold     { background: #eab308; box-shadow: 0 0 0 2px rgba(234,179,8,.2); }
.wh-dash-tier-dot--platinum { background: #3b82f6; box-shadow: 0 0 0 2px rgba(59,130,246,.2); }
.wh-dash-tier-dot--elite    { background: #DC2626; box-shadow: 0 0 0 2px rgba(220,38,38,.2); }

/* ── Tier progress card ── */
.wh-dash-tier-info { display: flex; align-items: baseline; gap: 10px; margin-bottom: 4px; }
.wh-dash-tier-pct { font-family: 'Barlow Condensed', sans-serif; font-size: 52px; font-weight: 900; color: #DC2626; line-height: 1; letter-spacing: -.02em; }
.wh-dash-tier-all { font-size: 13px; color: #94a3b8; padding-bottom: 4px; }
.wh-dash-tier-progress-wrap { margin-bottom: 10px; }
.wh-dash-tier-progress-labels { display: flex; justify-content: space-between; font-size: 10px; color: #cbd5e1; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 6px; }
.wh-dash-tier-progress { background: #f1f5f9; border-radius: 100px; height: 10px; overflow: hidden; }
.wh-dash-tier-progress__bar { height: 100%; border-radius: 100px; background: linear-gradient(90deg, #f59e0b 0%, #DC2626 100%); transition: width .9s cubic-bezier(.34,1.56,.64,1); box-shadow: 0 2px 6px rgba(220,38,38,.25); }
.wh-dash-tier-msg { font-size: 12px; color: #94a3b8; margin: 0; line-height: 1.5; }
.wh-dash-tier-msg strong { color: #374151; font-weight: 700; }

/* ── Order mini rows ── */
.wh-dash-order-mini { display: flex; flex-direction: column; gap: 6px; }
.wh-dash-order-mini-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; background: #f8fafc; border-radius: 10px; border: 1px solid #f1f5f9; gap: 10px; transition: background .15s, border-color .15s; }
.wh-dash-order-mini-row:hover { background: #fff; border-color: #e2e8f0; box-shadow: 0 2px 8px rgba(0,0,0,.04); }
.wh-dash-order-mini-num { font-size: 13px; font-weight: 700; color: #111111; text-decoration: none; }
.wh-dash-order-mini-num:hover { color: #DC2626; }
.wh-dash-order-mini-meta { font-size: 11px; color: #94a3b8; flex: 1; }
.wh-dash-order-mini-total { font-size: 13px; font-weight: 700; color: #10b981; white-space: nowrap; }
.wh-dash-empty { font-size: 13px; color: #94a3b8; padding: 24px 0; text-align: center; line-height: 1.6; }
.wh-dash-empty a { color: #DC2626; font-weight: 600; text-decoration: none; }

/* ── Quick links ── */
.wh-dash-quicklinks { display: flex; flex-direction: column; margin-bottom: 20px; background: #fff; border: 1px solid #e2e8f0; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,.04); }
.wh-dash-qlink { display: flex; align-items: center; gap: 16px; padding: 15px 20px; text-decoration: none; transition: background .15s; border-bottom: 1px solid #f8fafc; position: relative; }
.wh-dash-qlink:last-child { border-bottom: none; }
.wh-dash-qlink::before { content: ''; position: absolute; left: 0; top: 10%; bottom: 10%; width: 3px; border-radius: 0 3px 3px 0; opacity: 0; transition: opacity .18s; }
/* Per-link accent colours */
.wh-dash-qlink:nth-child(1)::before { background: #DC2626; }
.wh-dash-qlink:nth-child(2)::before { background: #f59e0b; }
.wh-dash-qlink:nth-child(3)::before { background: #10b981; }
.wh-dash-qlink:hover::before { opacity: 1; }
.wh-dash-qlink:hover { background: #fafafa; }
.wh-dash-qlink__icon { width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: transform .2s; }
.wh-dash-qlink:hover .wh-dash-qlink__icon { transform: scale(1.08); }
.wh-dash-qlink:nth-child(1) .wh-dash-qlink__icon { background: #fef2f2; color: #DC2626; }
.wh-dash-qlink:nth-child(2) .wh-dash-qlink__icon { background: #fffbeb; color: #f59e0b; }
.wh-dash-qlink:nth-child(3) .wh-dash-qlink__icon { background: #ecfdf5; color: #10b981; }
.wh-dash-qlink__icon svg { width: 18px; height: 18px; }
.wh-dash-qlink__body { flex: 1; }
.wh-dash-qlink__title { display: block; font-size: 14px; font-weight: 600; color: #111111; }
.wh-dash-qlink__sub { display: block; font-size: 12px; color: #94a3b8; margin-top: 2px; }
.wh-dash-qlink__arr { width: 16px; height: 16px; color: #cbd5e1; flex-shrink: 0; transition: transform .2s, color .2s; }
.wh-dash-qlink:hover .wh-dash-qlink__arr { transform: translateX(3px); color: #94a3b8; }
.wh-dash-qlink--btn { cursor: pointer; background: none; border: none; width: 100%; text-align: left; font-family: 'Outfit', sans-serif; }

/* ── Promo banner ── */
.wh-dash-promo { background: linear-gradient(135deg, #fef2f2 0%, #fff5f5 100%); border: 1px solid #fecaca; border-left: 4px solid #DC2626; border-radius: 12px; padding: 16px 20px; display: flex; flex-wrap: wrap; align-items: center; gap: 10px; }
.wh-dash-promo__label { font-size: 13px; font-weight: 700; color: #DC2626; }
.wh-dash-promo__text { font-size: 13px; color: #6b7280; flex: 1; min-width: 0; }
.wh-dash-promo__link { font-size: 12px; font-weight: 700; color: #fff; background: #DC2626; padding: 5px 14px; border-radius: 100px; text-decoration: none; white-space: nowrap; transition: background .15s; }
.wh-dash-promo__link:hover { background: #b91c1c; }

/* ── Order history table ── */
.wh-dash-order-table { width: 100%; border-collapse: collapse; }
.wh-dash-order-table th { font-size: 10.5px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: .08em; padding: 0 12px 12px; text-align: left; border-bottom: 2px solid #f1f5f9; }
.wh-dash-order-table td { font-size: 13px; color: #374151; padding: 13px 12px; border-bottom: 1px solid #f8fafc; vertical-align: middle; }
.wh-dash-order-table tr:last-child td { border-bottom: none; }
.wh-dash-order-table tr:hover td { background: #fafafa; }
/* Order # in red, total in green */
.wh-dash-order-table td:first-child a { color: #DC2626; font-weight: 700; text-decoration: none; }
.wh-dash-order-table td:first-child a:hover { text-decoration: underline; }
.wh-dash-order-table td:nth-child(4) { color: #10b981; font-weight: 700; }
.wh-dash-order-action { display: inline-flex; align-items: center; gap: 5px; font-size: 12px; font-weight: 600; padding: 5px 14px; border-radius: 100px; text-decoration: none !important; transition: all .15s; border: 1.5px solid #e2e8f0; color: #374151; background: #fff; }
.wh-dash-order-action:hover { border-color: #DC2626; color: #DC2626; background: #fef2f2; }

/* ── Account tab ── */
.wh-dash-account-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
.wh-dash-biz-list { display: grid; grid-template-columns: auto 1fr; gap: 8px 16px; margin: 0; align-items: center; }
.wh-dash-biz-list dt { font-size: 10.5px; color: #94a3b8; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
.wh-dash-biz-list dd { font-size: 13px; color: #111111; margin: 0; font-weight: 500; }

.wh-dash-tier-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.wh-dash-tier-table th { font-size: 10.5px; color: #94a3b8; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; padding: 0 8px 10px 0; text-align: left; border-bottom: 2px solid #f1f5f9; }
.wh-dash-tier-table td { padding: 9px 8px 9px 0; color: #64748b; border-bottom: 1px solid #f8fafc; }
.wh-dash-tier-table tr:last-child td { border-bottom: none; }
.wh-dash-tier-table tr.is-current td { color: #111111; font-weight: 700; }
.wh-dash-tier-table tr.is-current td:first-child { border-radius: 8px 0 0 8px; padding-left: 10px; background: linear-gradient(90deg, #fef2f2, transparent); }
.wh-dash-tier-table__disc { color: #64748b; }
.wh-dash-tier-table tr.is-current .wh-dash-tier-table__disc { color: #DC2626; font-weight: 800; font-size: 14px; }
.wh-dash-payment-terms { font-size: 11px; color: #94a3b8; margin: 14px 0 0; border-top: 1px solid #f1f5f9; padding-top: 12px; }

.wh-dash-mgr { display: flex; align-items: center; gap: 14px; margin-bottom: 18px; }
.wh-dash-mgr__av { width: 46px; height: 46px; border-radius: 50%; background: linear-gradient(135deg, #DC2626, #b91c1c); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 14px; color: #fff; flex-shrink: 0; box-shadow: 0 4px 12px rgba(220,38,38,.3); }
.wh-dash-mgr__name { display: block; font-size: 14px; font-weight: 700; color: #111111; }
.wh-dash-mgr__role { display: block; font-size: 12px; color: #94a3b8; margin-top: 2px; }
.wh-dash-mgr__contacts { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
.wh-dash-contact-btn { display: flex; align-items: center; gap: 10px; padding: 11px 14px; background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 10px; text-decoration: none; font-size: 13px; font-weight: 600; color: #374151; transition: all .15s; }
.wh-dash-contact-btn:hover { background: #fef2f2; border-color: #fecaca; color: #DC2626; }
.wh-dash-contact-btn svg { width: 16px; height: 16px; flex-shrink: 0; color: #DC2626; }
.wh-dash-signout { display: block; text-align: center; font-size: 13px; font-weight: 600; color: #94a3b8; text-decoration: none; padding: 10px; border: 1.5px dashed #e2e8f0; border-radius: 10px; transition: all .15s; }
.wh-dash-signout:hover { color: #DC2626; border-color: #fecaca; border-style: solid; }

/* ── Delivery modal ── */
.wh-delivery-modal { display: none; position: fixed; inset: 0; z-index: 999; }
.wh-delivery-modal.is-open { display: flex; align-items: center; justify-content: center; padding: 20px; }
.wh-delivery-modal__overlay { position: fixed; inset: 0; background: rgba(15,23,42,.45); backdrop-filter: blur(3px); }
.wh-delivery-modal__box { position: relative; z-index: 1; background: #fff; border-radius: 20px; width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto; box-shadow: 0 32px 80px rgba(0,0,0,.18), 0 0 0 1px rgba(0,0,0,.04); }
.wh-delivery-modal__head { padding: 24px 28px 16px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
/* Red strip on modal */
.wh-delivery-modal__box::before { content: ''; display: block; height: 4px; background: linear-gradient(90deg, #DC2626, #f87171); border-radius: 20px 20px 0 0; }
.wh-delivery-modal__title { font-family: 'Barlow Condensed', sans-serif; font-size: 24px; font-weight: 800; color: #111111; margin: 0 0 3px; }
.wh-delivery-modal__sub { font-size: 12px; color: #94a3b8; margin: 0; }
.wh-delivery-modal__close { width: 32px; height: 32px; border: 1.5px solid #e2e8f0; border-radius: 8px; background: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #94a3b8; flex-shrink: 0; transition: all .15s; }
.wh-delivery-modal__close:hover { background: #fef2f2; border-color: #fecaca; color: #DC2626; }
.wh-delivery-modal__body { padding: 20px 28px 28px; }
.wh-delivery-field { margin-bottom: 16px; }
.wh-delivery-label { display: block; font-size: 11px; font-weight: 700; color: #374151; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 6px; }
.wh-delivery-input, .wh-delivery-select { width: 100%; height: 44px; padding: 0 14px; font-family: 'Outfit', sans-serif; font-size: 14px; color: #111; background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 9px; outline: none; box-sizing: border-box; transition: border-color .2s, box-shadow .2s; }
.wh-delivery-input:focus, .wh-delivery-select:focus { border-color: #DC2626; background: #fff; box-shadow: 0 0 0 3px rgba(220,38,38,.06); }
.wh-delivery-select { cursor: pointer; }
.wh-delivery-textarea { width: 100%; min-height: 80px; padding: 10px 14px; font-family: 'Outfit', sans-serif; font-size: 14px; color: #111; background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 9px; outline: none; box-sizing: border-box; resize: vertical; transition: border-color .2s; }
.wh-delivery-textarea:focus { border-color: #DC2626; background: #fff; box-shadow: 0 0 0 3px rgba(220,38,38,.06); }
.wh-delivery-note { display: flex; align-items: flex-start; gap: 10px; font-size: 12px; color: #6b7280; background: #fffbeb; border: 1px solid #fde68a; border-radius: 9px; padding: 11px 14px; margin-bottom: 16px; }
.wh-delivery-note::before { content: '💡'; font-size: 14px; flex-shrink: 0; margin-top: -1px; }
.wh-delivery-note strong { color: #92400e; }
.wh-delivery-submit { width: 100%; height: 50px; border: none; border-radius: 10px; background: linear-gradient(135deg, #DC2626, #b91c1c); color: #fff; font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 700; cursor: pointer; transition: all .2s; margin-top: 6px; box-shadow: 0 4px 16px rgba(220,38,38,.25); letter-spacing: .01em; }
.wh-delivery-submit:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(220,38,38,.3); }
.wh-delivery-success { text-align: center; padding: 36px 0; }
.wh-delivery-success__icon { width: 60px; height: 60px; border-radius: 50%; background: #ecfdf5; color: #10b981; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; box-shadow: 0 0 0 8px rgba(16,185,129,.08); }
.wh-delivery-success p { font-size: 14px; color: #374151; line-height: 1.7; }

/* ── Update form ── */
.wh-dash-update-toggle { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 600; color: #DC2626; background: none; border: none; cursor: pointer; padding: 0; margin-top: 16px; opacity: .75; transition: opacity .15s; }
.wh-dash-update-toggle:hover { opacity: 1; }
.wh-dash-update-form { display: none; margin-top: 16px; padding-top: 16px; border-top: 1px solid #f1f5f9; }
.wh-dash-update-form.is-open { display: block; }
.wh-dash-update-form .wh-delivery-field { margin-bottom: 12px; }
.wh-dash-update-submit { height: 40px; padding: 0 20px; border: none; border-radius: 8px; background: #DC2626; color: #fff; font-size: 13px; font-weight: 600; cursor: pointer; font-family: 'Outfit', sans-serif; transition: background .15s; }
.wh-dash-update-submit:hover { background: #b91c1c; }
.wh-dash-update-cancel { height: 40px; padding: 0 16px; border: 1.5px solid #e2e8f0; border-radius: 8px; background: none; color: #64748b; font-size: 13px; font-weight: 600; cursor: pointer; font-family: 'Outfit', sans-serif; transition: all .15s; }
.wh-dash-update-cancel:hover { border-color: #cbd5e1; color: #374151; }

/* ── Order pagination ── */
.wh-dash-order-pagination { display: flex; align-items: center; justify-content: center; gap: 14px; padding: 18px 20px 4px; border-top: 1px solid #f1f5f9; margin-top: 4px; }
.wh-dash-order-page-btn { font-size: 13px; font-weight: 600; color: #DC2626; text-decoration: none; padding: 7px 16px; border: 1.5px solid #fecaca; border-radius: 8px; transition: all .15s; white-space: nowrap; }
.wh-dash-order-page-btn:hover { background: #fef2f2; border-color: #DC2626; }
.wh-dash-order-page-info { font-size: 12px; color: #94a3b8; font-weight: 500; }

/* ── Responsive ── */
@media (max-width: 900px) {
  .wh-dash-hero__inner { flex-direction: column; align-items: flex-start; }
  .wh-dash-hero__stats { grid-template-columns: repeat(2, 1fr); width: 100%; }
  .wh-dash-content__grid { grid-template-columns: 1fr; }
  .wh-dash-account-grid { grid-template-columns: 1fr; }
  .wh-dash-card:first-child, .wh-dash-card:nth-child(2) { border-top-width: 3px; }
}
@media (max-width: 540px) {
  .wh-dash-hero__stats { grid-template-columns: repeat(2, 1fr); }
  .wh-dash-order-table th:nth-child(3), .wh-dash-order-table td:nth-child(3) { display: none; }
  .wh-dash-tab--link { margin: 8px 0 8px 4px; padding: 7px 14px; }
}
</style>

<div class="wh">

{%- if is_portal_page and is_wholesale -%}
{%- comment -%} ══════════ DASHBOARD ══════════ {%- endcomment -%}
{%- liquid
  assign wh_orders = customer.orders_count
  assign wh_tier_name = 'Bronze'
  assign wh_tier_pct  = 5
  assign wh_tier_cls  = 'bronze'
  assign wh_next_tier_name = 'Silver'
  if wh_orders >= 81
    assign wh_tier_name = 'Elite'
    assign wh_tier_pct  = 25
    assign wh_tier_cls  = 'elite'
    assign wh_next_tier_name = ''
  elsif wh_orders >= 41
    assign wh_tier_name = 'Platinum'
    assign wh_tier_pct  = 20
    assign wh_tier_cls  = 'platinum'
    assign wh_next_tier_name = 'Elite'
  elsif wh_orders >= 21
    assign wh_tier_name = 'Gold'
    assign wh_tier_pct  = 15
    assign wh_tier_cls  = 'gold'
    assign wh_next_tier_name = 'Platinum'
  elsif wh_orders >= 11
    assign wh_tier_name = 'Silver'
    assign wh_tier_pct  = 10
    assign wh_tier_cls  = 'silver'
    assign wh_next_tier_name = 'Gold'
  endif
  assign wh_bar_pct = 100
  if wh_tier_cls == 'bronze'
    assign wh_bar_pct = wh_orders | times: 100 | divided_by: 11
  elsif wh_tier_cls == 'silver'
    assign wh_bar_pct = wh_orders | minus: 11 | times: 100 | divided_by: 10
  elsif wh_tier_cls == 'gold'
    assign wh_bar_pct = wh_orders | minus: 21 | times: 100 | divided_by: 20
  elsif wh_tier_cls == 'platinum'
    assign wh_bar_pct = wh_orders | minus: 41 | times: 100 | divided_by: 40
  endif
  if wh_bar_pct > 99
    assign wh_bar_pct = 99
  endif
-%}

{%- paginate customer.orders by 50 -%}
<script type="application/json" id="wh-order-data">
  {"orders":[{%- for order in customer.orders -%}{"id":{{ order.id | json }},"number":{{ order.order_number | json }},"date":{{ order.created_at | date: "%Y-%m-%dT%H:%M:%S" | json }},"total":{{ order.total_price | json }},"items":{{ order.line_items.size | json }}}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],"page":{{ paginate.current_page }},"pages":{{ paginate.pages }},"next":{% if paginate.next.url %}"{{ paginate.next.url | escape }}"{% else %}null{% endif %},"prev":{% if paginate.previous.url %}"{{ paginate.previous.url | escape }}"{% else %}null{% endif %},"total":{{ customer.orders_count }}}
</script>

<div class="wh-dash-portal"
