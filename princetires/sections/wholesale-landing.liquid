        {%- endif -%}
      </div>
      {%- endif -%}
    </div>

    <!-- Panel: Order History -->
    <div class="wh-dash-panel wh-dash-panel--hidden" data-wh-panel="orders">
      <div class="wh-dash-card wh-dash-card--full">
        <div class="wh-dash-card__head">
          <h3>Order history</h3>
