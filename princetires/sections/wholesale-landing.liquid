<script>
(function() {

  /* ── Savings Calculator ── */
  var slider    = document.getElementById('CalcSlider');
  var priceIn   = document.getElementById('CalcRetailPrice');

  if (slider) {
    var tiers = [
      { name: 'Bronze tier',   min: 1,  max: 10,  pct: 5,  cls: 'bronze' },
      { name: 'Silver tier',   min: 11, max: 20,  pct: 10, cls: 'silver' },
      { name: 'Gold tier',     min: 21, max: 40,  pct: 15, cls: 'gold' },
      { name: 'Platinum tier', min: 41, max: 80,  pct: 20, cls: 'platinum' },
      { name: 'Elite tier',    min: 81, max: 999, pct: 25, cls: 'elite' }
    ];

    function fmt(n) {
      return '$' + n.toLocaleString('en-CA', { maximumFractionDigits: 0 });
    }

    function calcUpdate() {
      var volume = parseInt(slider.value, 10);
      var retail = parseFloat((priceIn && priceIn.value) || 180);

      var tier = tiers[0];
      for (var i = 0; i < tiers.length; i++) {
        if (volume >= tiers[i].min && volume <= tiers[i].max) { tier = tiers[i]; break; }
        if (volume > tiers[tiers.length - 1].min) { tier = tiers[tiers.length - 1]; }
      }

      var monthlyRetail  = volume * retail;
      var monthlySavings = monthlyRetail * (tier.pct / 100);
      var annualSavings  = monthlySavings * 12;

      var volDisplay = document.getElementById('CalcVolumeDisplay');
      if (volDisplay) volDisplay.textContent = volume + ' tires/mo';

      var savingsEl = document.getElementById('CalcSavings');
      if (savingsEl) savingsEl.textContent = fmt(annualSavings);

      var badgeEl = document.getElementById('CalcTierBadge');
      if (badgeEl) {
        badgeEl.className = 'wh-calc__tier-badge wh-calc__tier-badge--' + tier.cls;
      }
      var tierName = document.getElementById('CalcTierName');
      if (tierName) tierName.textContent = tier.name;

      var retM = document.getElementById('CalcRetailMonthly');
      if (retM) retM.textContent = fmt(monthlyRetail);

      var discPct = document.getElementById('CalcDiscountPct');
      if (discPct) discPct.textContent = tier.pct + '%';

      var monSav = document.getElementById('CalcMonthlySavings');
      if (monSav) monSav.textContent = fmt(monthlySavings);

      var annSav = document.getElementById('CalcAnnualSavings');
      if (annSav) annSav.textContent = fmt(annualSavings);

      // Update slider track fill
      var pct = ((volume - 1) / (150 - 1)) * 100;
      slider.style.background = 'linear-gradient(to right, #DC2626 ' + pct + '%, #E2E8F0 ' + pct + '%)';
    }

    slider.addEventListener('input', calcUpdate);
    if (priceIn) priceIn.addEventListener('input', calcUpdate);
    calcUpdate(); // init
  }

  /* ── FAQ accordion ── */
  document.querySelectorAll('.wh-faq-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var body   = this.nextElementSibling;
      var isOpen = this.getAttribute('aria-expanded') === 'true';
      /* close all */
      document.querySelectorAll('.wh-faq-btn').forEach(function(b) {
        b.setAttribute('aria-expanded', 'false');
        b.nextElementSibling.classList.remove('is-open');
      });
      /* open clicked if it was closed */
      if (!isOpen) {
        this.setAttribute('aria-expanded', 'true');
        body.classList.add('is-open');
      }
    });
  });
})();

/* ── Wholesale Dashboard Portal ── */
(function() {
  var portal = document.querySelector('.wh-dash-portal');
  if (!portal) return;

  /* 1. Note parsing */
  var rawNote = portal.dataset.whNote || '';
  var bizData = {};
  rawNote.replace(/^WHOLESALE:\s*/i, '').split('|').forEach(function(seg) {
    var idx = seg.indexOf('=');
    if (idx < 0) return;
    var key = seg.slice(0, idx).trim().toLowerCase();
    var val = seg.slice(idx + 1).trim();
    if (key && val) bizData[key] = val;
  });

  /* Populate business name in hero */
  var bizNameEl = portal.querySelector('[data-wh-biz-name]');
  if (bizNameEl && bizData['business']) bizNameEl.textContent = bizData['business'];

  /* Populate business detail fields */
  portal.querySelectorAll('[data-wh-biz]').forEach(function(el) {
    var field = el.dataset.whBiz;
    el.textContent = bizData[field] || '\u2014';
  });

  /* 2. Order data + stat cards */
  var orderDataEl = document.getElementById('wh-order-data');
  var orders = [];
  var orderMeta = { page: 1, pages: 1, next: null, prev: null, total: 0 };
  if (orderDataEl) {
    try {
      var parsed = JSON.parse(orderDataEl.textContent);
      if (Array.isArray(parsed)) {
        orders = parsed; /* legacy fallback */
      } else {
        orders = parsed.orders || [];
        orderMeta = { page: parsed.page || 1, pages: parsed.pages || 1, next: parsed.next || null, prev: parsed.prev || null, total: parsed.total || 0 };
      }
    } catch(e) {}
  }
  var tierPct = parseInt(portal.dataset.whTierPct, 10) || 5;
  var now = new Date();
  var thisMonth = now.getMonth();
  var thisYear  = now.getFullYear();
  var ordersThisMonth = 0, tiresThisMonth = 0, savingsCents = 0;
  orders.forEach(function(o) {
    var d = new Date(o.date);
    if (d.getMonth() === thisMonth && d.getFullYear() === thisYear) {
      ordersThisMonth++;
      tiresThisMonth += (o.items || 0);
      savingsCents += Math.round((o.total || 0) * tierPct / 100);
    }
  });
  function fmtMoney(cents) {
    return '$' + (cents / 100).toLocaleString('en-CA', { maximumFractionDigits: 0 });
  }
  var statMap = { 'orders-month': ordersThisMonth.toString(), 'tires-month': tiresThisMonth.toString(), 'savings-month': fmtMoney(savingsCents) };
  Object.keys(statMap).forEach(function(key) {
    var el = portal.querySelector('[data-wh-stats="' + key + '"]');
    if (el) el.textContent = statMap[key];
  });

  /* 3. Recent orders mini list (last 5) */
  var recentEl = document.getElementById('wh-recent-orders');
  if (recentEl) {
    if (!orders.length) {
      recentEl.innerHTML = '<div class="wh-dash-empty">No orders yet. <a href="/collections/tires">Start shopping \u2192</a></div>';
    } else {
      var rows = orders.slice(0, 5).map(function(o) {
        var d = new Date(o.date).toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' });
        var tot = '$' + (o.total / 100).toLocaleString('en-CA', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        return '<div class="wh-dash-order-mini-row">'
          + '<a class="wh-dash-order-mini-num" href="/account/orders/' + o.id + '">#' + o.number + '</a>'
          + '<span class="wh-dash-order-mini-meta">' + d + ' &middot; ' + o.items + ' item' + (o.items !== 1 ? 's' : '') + '</span>'
          + '<span class="wh-dash-order-mini-total">' + tot + '</span>'
          + '</div>';
      }).join('');
      recentEl.innerHTML = '<div class="wh-dash-order-mini">' + rows + '</div>';
    }
  }

  /* 4. Full order history table */
  var tableEl = document.getElementById('wh-orders-table');
  if (tableEl) {
    if (!orders.length) {
      tableEl.innerHTML = '<div class="wh-dash-empty" style="padding:32px 0">No orders yet. <a href="/collections/tires">Start shopping \u2192</a></div>';
    } else {
      var tableRows = orders.map(function(o) {
        var d = new Date(o.date).toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' });
        var tot = '$' + (o.total / 100).toLocaleString('en-CA', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        return '<tr>'
          + '<td><a href="/account/orders/' + o.id + '">#' + o.number + '</a></td>'
          + '<td>' + d + '</td>'
          + '<td>' + o.items + ' item' + (o.items !== 1 ? 's' : '') + '</td>'
          + '<td>' + tot + '</td>'
          + '<td><a href="/account/orders/' + o.id + '" class="wh-dash-order-action">View order</a></td>'
          + '</tr>';
      }).join('');
      tableEl.innerHTML = '<table class="wh-dash-order-table"><thead><tr><th>Order</th><th>Date</th><th>Items</th><th>Total</th><th></th></tr></thead><tbody>' + tableRows + '</tbody></table>';
    }
  }

  /* 4b. Order pagination */
  var paginEl = document.getElementById('wh-orders-pagination');
  if (paginEl && orderMeta.pages > 1) {
    var pHtml = '';
    if (orderMeta.prev) pHtml += '<a href="' + orderMeta.prev + '" class="wh-dash-order-page-btn">\u2190 Previous</a>';
    pHtml += '<span class="wh-dash-order-page-info">Page ' + orderMeta.page + ' of ' + orderMeta.pages + ' &middot; ' + orderMeta.total + ' orders total</span>';
    if (orderMeta.next) pHtml += '<a href="' + orderMeta.next + '" class="wh-dash-order-page-btn">Next \u2192</a>';
    paginEl.innerHTML = pHtml;
    paginEl.style.display = 'flex';
  }

  /* 5. Tab switching */
  var tabs   = portal.querySelectorAll('[data-wh-tab]');
  var panels = portal.querySelectorAll('[data-wh-panel]');

  function switchTab(name) {
    tabs.forEach(function(t) {
      var active = t.dataset.whTab === name;
      t.classList.toggle('wh-dash-tab--active', active);
      t.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    panels.forEach(function(p) {
      p.classList.toggle('wh-dash-panel--hidden', p.dataset.whPanel !== name);
    });
  }

  tabs.forEach(function(t) {
    if (!t.dataset.whTab) return;
    t.addEventListener('click', function() { switchTab(t.dataset.whTab); });
  });

  portal.querySelectorAll('[data-wh-tab-switch]').forEach(function(btn) {
    btn.addEventListener('click', function() { switchTab(btn.dataset.whTabSwitch); });
  });

  /* 6. Progress bar animation */
  var bar = portal.querySelector('[data-wh-bar-target]');
  if (bar) {
    var target = parseInt(bar.dataset.whBarTarget, 10) || 0;
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        bar.style.width = target + '%';
      });
    });
  }

  /* 7. Delivery request modal */
  var modal   = document.getElementById('wh-delivery-modal');
  var overlay = document.getElementById('wh-delivery-overlay');
  var openBtn = document.getElementById('wh-delivery-open');
  var closeBtn= document.getElementById('wh-delivery-close');

  function openModal() {
    if (!modal) return;
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    if (!modal) return;
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  if (openBtn)  openBtn.addEventListener('click', openModal);
  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  if (overlay)  overlay.addEventListener('click', closeModal);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeModal();
  });

  /* Assemble hidden body for delivery form */
  var deliveryForm = document.getElementById('WholesaleDeliveryForm');
  if (deliveryForm) {
    deliveryForm.addEventListener('submit', function() {
      var hiddenBody = document.getElementById('wh-del-hidden-body');
      if (!hiddenBody) return;
      var tires   = (document.getElementById('wh-del-tires')   || {}).value   || '';
      var qty     = (document.getElementById('wh-del-qty')     || {}).value   || '';
      var addr    = (document.getElementById('wh-del-address') || {}).value   || '';
      var date    = (document.getElementById('wh-del-date')    || {}).value   || '';
      var notes   = (document.getElementById('wh-del-notes')   || {}).value   || '';
      hiddenBody.value = 'DELIVERY REQUEST\nTires: ' + tires + '\nQty: ' + qty + '\nAddress: ' + addr + '\nDate: ' + date + '\nNotes: ' + notes;
    });
  }

  /* 8. Update business info toggle */
  var updateToggle = document.getElementById('wh-biz-update-toggle');
  var updateForm   = document.getElementById('wh-biz-update-form');
  var updateCancel = document.getElementById('wh-biz-update-cancel');

  if (updateToggle && updateForm) {
    updateToggle.addEventListener('click', function() {
      updateForm.classList.toggle('is-open');
    });
  }
  if (updateCancel && updateForm) {
    updateCancel.addEventListener('click', function() {
      updateForm.classList.remove('is-open');
    });
  }

})();
</script>

