<div class="faq-home">
  <div class="faq-home__container">

    <div class="faq-home__top">
      <div class="faq-home__header">
        <span class="faq-home__eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="faq-home__heading">{{ section.settings.heading }}</h2>
      </div>

      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: '#' }}" class="faq-home__cta">
          {{ section.settings.cta_label }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="faq-home__grid">
      {%- for block in section.blocks -%}
        <details class="faq-home__card" {{ block.shopify_attributes }}>
          <summary class="faq-home__question">
            <span class="faq-home__q-text">{{ block.settings.question }}</span>
            <span class="faq-home__q-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </span>
          </summary>
          <div class="faq-home__answer">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>

  </div>
</div>

{%- if section.blocks.size > 0 -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- for block in section.blocks -%}
        {%- if forloop.first == false -%},{%- endif -%}
        {
          "@type": "Question",
          "name": {{ block.settings.question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | json }}
          }
        }
      {%- endfor -%}
    ]
  }
  </script>
{%- endif -%}

{% stylesheet %}
  .faq-home {
    background: #fff;
    padding: 7rem 0;
  }

  .faq-home__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 6rem;
  }

  .faq-home__top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 4rem;
  }

  .faq-home__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .faq-home__eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 400;
    color: #dc2626;
    letter-spacing: 0.02em;
  }

  .faq-home__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 3rem;
    font-weight: 600;
    color: #111;
    margin: 0;
    line-height: 1.1;
  }

  .faq-home__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    color: #dc2626;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: gap 0.2s;
  }

  .faq-home__cta:hover {
    gap: 0.8rem;
  }

  /* ── Wrapper ── */
  .faq-home__grid {
    background: #f7f7f7;
    border-radius: 8px;
    overflow: hidden;
  }

  /* ── Card ── */
  .faq-home__card {
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .faq-home__card:last-child {
    border-bottom: none;
  }

  .faq-home__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.6rem;
    padding: 1.4rem 2.4rem;
    cursor: pointer;
    list-style: none;
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 500;
    color: #222;
    transition: color 0.2s, background 0.15s;
  }

  .faq-home__question::-webkit-details-marker {
    display: none;
  }

  .faq-home__question:hover {
    color: #dc2626;
    background: rgba(0, 0, 0, 0.02);
  }

  .faq-home__q-text {
    flex: 1;
    line-height: 1.4;
  }

  .faq-home__q-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #9ca3af;
    transition: transform 0.3s ease, color 0.2s;
  }

  .faq-home__card[open] .faq-home__q-icon {
    transform: rotate(180deg);
    color: #dc2626;
  }

  .faq-home__card[open] .faq-home__question {
    color: #dc2626;
  }

  .faq-home__answer {
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 300;
    color: #6b7280;
    line-height: 1.65;
    padding: 0 2.4rem 1.6rem;
  }

  @media (max-width: 768px) {
    .faq-home__container {
      padding: 0 2rem;
    }
    .faq-home__top {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.2rem;
    }
    .faq-home__heading {
      font-size: 2.4rem;
    }
    .faq-home__question {
      padding: 1.2rem 1.6rem;
    }
    .faq-home__answer {
      padding: 0 1.6rem 1.4rem;
    }
  }

  @media (max-width: 480px) {
    .faq-home {
      padding: 4rem 0;
    }
    .faq-home__container {
      padding: 0 1.6rem;
    }
    .faq-home__heading {
      font-size: clamp(2rem, 6vw, 2.4rem);
    }
    .faq-home__question {
      padding: 1.4rem 1.2rem;
      font-size: 1.4rem;
      min-height: 4.8rem;
      gap: 1.2rem;
    }
    .faq-home__answer {
      padding: 0 1.2rem 1.4rem;
      font-size: 1.2rem;
    }
    .faq-home__cta {
      font-size: 1.2rem;
      min-height: 4.4rem;
      display: inline-flex;
      align-items: center;
    }
    .faq-home__top {
      margin-bottom: 2.5rem;
    }
  }

  @media (max-width: 360px) {
    .faq-home__container {
      padding: 0 1.2rem;
    }
    .faq-home__question {
      padding: 1.2rem 1rem;
      font-size: 1.3rem;
      gap: 1rem;
    }
    .faq-home__answer {
      padding: 0 1rem 1.2rem;
      font-size: 1.2rem;
      line-height: 1.5;
    }
    .faq-home__heading {
      font-size: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What services do you offer?"
