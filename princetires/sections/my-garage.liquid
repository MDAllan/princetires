{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- if customer -%}
  <script src="{{ 'my-garage.js' | asset_url }}" defer="defer"></script>

  <script data-garage-config type="application/json">
    {
      "customerId": {{ customer.id | json }},
      "customerName": {{ customer.first_name | json }},
      "ordersCount": {{ customer.orders_count | json }},
      "minYear": {{ settings.smart_search_min_year | default: 2001 }},
      "maxYear": {{ settings.smart_search_max_year | default: 2026 }},
      "assetUrlBase": {{ 'pt-vehicle-2025.json' | asset_url | split: 'pt-vehicle-2025.json' | first | json }},
      "maxVehicles": 10,
      "customImage": {% if section.settings.garage_image != blank %}{{ section.settings.garage_image | image_url: width: 160 | json }}{% else %}null{% endif %}
    }
  </script>

  {%- comment -%} Order history data — filtered by JS per vehicle's tire size {%- endcomment -%}
  <script type="application/json" id="pt-order-history">
    [
      {%- for order in customer.orders limit: 30 -%}
        {
          "name": {{ order.name | json }},
          "date": {{ order.created_at | date: "%b %d, %Y" | json }},
          "url": {{ order.customer_url | json }},
          "items": [
            {%- for item in order.line_items -%}
              {
                "title": {{ item.title | json }},
                "product_url": {{ item.product.url | json }},
                "tire_size": {{ item.product.metafields.custom.tire_size | json }},
                "price": {{ item.price | money | json }}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  </script>

  <my-garage class="customer garage section-{{ section.id }}-padding" data-garage>

    <div class="garage__dashboard">
      <div class="garage__dashboard-top">
        <div class="garage__dashboard-greeting">
          <h1 class="garage__dashboard-name">
            {%- if customer.first_name != blank -%}
              {{ customer.first_name | escape }}'s Garage
            {%- else -%}
              {{ 'sections.my_garage.title' | t }}
            {%- endif -%}
          </h1>
          <p class="garage__subtitle">{{ 'sections.my_garage.subtitle' | t }}</p>
        </div>
        <div class="garage__dashboard-stats" data-garage-stats></div>
      </div>
      <div class="garage__seasonal-tip" data-garage-seasonal hidden></div>
    </div>

    {%- comment -%} Add Vehicle Toggle + Form {%- endcomment -%}
    <div class="garage__add-section">
      <button type="button" class="garage__add-btn" data-garage-toggle-add
              aria-expanded="false" aria-controls="garage-add-form">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        {{ 'sections.my_garage.add_vehicle' | t }}
      </button>

      <p class="garage__max-msg" data-garage-max hidden>
        {{ 'sections.my_garage.max_reached' | t: max: 10 }}
      </p>

      <div id="garage-add-form" class="garage__add-form" hidden>
        <h2>{{ 'sections.my_garage.add_vehicle' | t }}</h2>
        <div class="garage__selects">
          <div class="garage__field">
            <label for="garage-year">{{ 'sections.my_garage.year' | t }}</label>
            <select id="garage-year" data-garage-year>
              <option value="">{{ 'sections.my_garage.select_year' | t }}</option>
            </select>
          </div>
          <div class="garage__field">
            <label for="garage-make">{{ 'sections.my_garage.make' | t }}</label>
            <select id="garage-make" data-garage-make data-placeholder="{{ 'sections.my_garage.select_make' | t }}" disabled>
              <option value="">{{ 'sections.my_garage.select_make' | t }}</option>
            </select>
          </div>
          <div class="garage__field">
            <label for="garage-model">{{ 'sections.my_garage.model' | t }}</label>
            <select id="garage-model" data-garage-model data-placeholder="{{ 'sections.my_garage.select_model' | t }}" disabled>
              <option value="">{{ 'sections.my_garage.select_model' | t }}</option>
            </select>
          </div>
          <div class="garage__field">
            <label for="garage-trim">{{ 'sections.my_garage.trim' | t }}</label>
            <select id="garage-trim" data-garage-trim data-placeholder="{{ 'sections.my_garage.select_trim' | t }}" disabled>
              <option value="">{{ 'sections.my_garage.select_trim' | t }}</option>
            </select>
          </div>
        </div>

        <p class="garage__size-preview" data-garage-size-preview hidden></p>

        <div class="garage__form-actions">
          <button type="button" class="garage__save-btn" data-garage-save disabled>
            {{ 'sections.my_garage.save_vehicle' | t }}
          </button>
          <button type="button" class="garage__cancel-btn" data-garage-cancel>
            {{ 'sections.my_garage.cancel' | t }}
          </button>
        </div>
      </div>
    </div>

    {%- comment -%} Empty State {%- endcomment -%}
    <div class="garage__empty" data-garage-empty hidden>
      {%- if section.settings.garage_image != blank -%}
        <img
          src="{{ section.settings.garage_image | image_url: width: 200 }}"
          alt=""
          class="garage__empty-icon garage__empty-icon--custom"
          aria-hidden="true"
          width="120"
        >
      {%- else -%}
        <svg width="56" height="56" viewBox="0 0 80 34" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="garage__empty-icon">
          <path d="M4 22 L12 13 L22 9 L58 9 L68 13 L76 17 L76 22 L4 22 Z"/><circle cx="18" cy="24" r="5"/><circle cx="62" cy="24" r="5"/>
        </svg>
      {%- endif -%}
      <p class="garage__empty-headline">{{ 'sections.my_garage.empty_headline' | t }}</p>
      <p class="garage__empty-sub">{{ 'sections.my_garage.empty_sub' | t }}</p>
    </div>

    {%- comment -%} Vehicle Cards {%- endcomment -%}
    <ul class="garage__vehicles" role="list" data-garage-list></ul>

    {%- comment -%} Activity Feed {%- endcomment -%}
    <div class="garage__activity" data-garage-activity hidden>
      <div class="garage__activity-header">
        <h2 class="garage__activity-title">Recent activity</h2>
        <span class="garage__activity-sub">Service history across all vehicles</span>
      </div>
      <ul class="garage__activity-list" data-garage-activity-list></ul>
    </div>

  </my-garage>

{%- else -%}
  <div class="customer garage garage--guest section-{{ section.id }}-padding">
    <div class="garage__header">
      <h1>{{ 'sections.my_garage.title' | t }}</h1>
      <p>{{ 'sections.my_garage.login_required' | t }}</p>
      <a href="{{ routes.account_login_url }}" class="garage__login-btn">
        {{ 'sections.my_garage.login' | t }}
      </a>
    </div>
  </div>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% stylesheet %}
/* ══════════════════════════════════
   MY GARAGE — Prince Tires
   Matches product page design
══════════════════════════════════ */
.garage {
  --g-font: 'Outfit', sans-serif;
  --g-heading: 'Barlow Condensed', sans-serif;
  --g-text: #111;
  --g-muted: #9ca3af;
  --g-subtle: #6b7280;
  --g-bg: #ffffff;
  --g-bg2: #f7f7f8;
  --g-border: #f0f0f0;
  --g-border-soft: #e5e7eb;
  --g-accent: #F5820B;
  --g-red: #dc2626;
  --g-red-hover: #b91c1c;
  --g-r: 10px;
  --g-r-sm: 8px;
  max-width: 1200px;
  margin: 0 auto;
  padding-left: 2rem;
  padding-right: 2rem;
  font-family: var(--g-font);
  color: var(--g-text);
  background: var(--g-bg);
}

/* ── Header ── */
.garage__header { margin-bottom: 2.5rem; }
.garage__header h1 {
  font-family: var(--g-heading);
  font-size: 3rem;
  font-weight: 700;
  color: var(--g-text);
  margin: 0 0 0.375rem;
  letter-spacing: 0.02em;
  line-height: 1.1;
}
.garage__subtitle {
  font-family: var(--g-font);
  color: var(--g-muted);
  font-size: 1rem;
  font-weight: 300;
  margin: 0;
}

/* ── Add Vehicle Section ── */
.garage__add-section { margin-bottom: 2.5rem; }
.garage__add-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--g-red);
  color: #fff;
  border: none;
  padding: 0.875rem 1.75rem;
  border-radius: var(--g-r);
  font-family: var(--g-font);
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
  min-height: 44px;
}
.garage__add-btn:hover { background: var(--g-red-hover); }
.garage__add-btn:disabled { background: var(--g-border-soft); color: var(--g-muted); cursor: not-allowed; }
.garage__max-msg { color: #d97706; font-size: 0.875rem; margin-top: 0.75rem; }

.garage__add-form {
  background: var(--g-bg2);
  border: 1px solid var(--g-border-soft);
  border-radius: var(--g-r);
  padding: 1.75rem;
  margin-top: 1rem;
  animation: garage-slide-down 0.2s ease;
}
@keyframes garage-slide-down {
  from { opacity: 0; transform: translateY(-8px); }
  to   { opacity: 1; transform: translateY(0); }
}
.garage__add-form h2 {
  font-family: var(--g-heading);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--g-text);
  margin: 0 0 1.25rem;
  letter-spacing: 0.02em;
}
.garage__selects {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.875rem;
  margin-bottom: 1rem;
}
@media (max-width: 700px) { .garage__selects { grid-template-columns: 1fr 1fr; } }
@media (max-width: 420px) { .garage__selects { grid-template-columns: 1fr; } }

.garage__field label {
  display: block;
  font-size: 0.6875rem;
  font-weight: 700;
  color: var(--g-subtle);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 0.375rem;
}
.garage__field select {
  width: 100%;
  padding: 0.625rem 0.75rem;
  background: #fff;
  border: 1.5px solid var(--g-border-soft);
  border-radius: var(--g-r-sm);
  color: var(--g-text);
  font-family: var(--g-font);
  font-size: 0.9rem;
  min-height: 44px;
  transition: border-color 0.2s;
}
.garage__field select:focus { outline: none; border-color: var(--g-red); }
.garage__field select:disabled { opacity: 0.45; cursor: not-allowed; background: var(--g-bg2); }
.garage__size-preview {
  color: var(--g-accent);
  font-size: 1rem;
  font-weight: 700;
  margin: 0.75rem 0;
}
.garage__form-actions {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-top: 1rem;
}
.garage__save-btn {
  background: var(--g-red);
  color: #fff;
  border: none;
  padding: 0.75rem 1.5rem;
  border-radius: var(--g-r);
  font-family: var(--g-font);
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  min-height: 44px;
  transition: background 0.2s;
}
.garage__save-btn:hover { background: var(--g-red-hover); }
.garage__save-btn:disabled { background: var(--g-border-soft); color: var(--g-muted); cursor: not-allowed; }
.garage__cancel-btn {
  background: #fff;
  color: var(--g-subtle);
  border: 1.5px solid var(--g-border-soft);
  padding: 0.75rem 1.5rem;
  border-radius: var(--g-r);
  font-family: var(--g-font);
  font-size: 0.9rem;
  cursor: pointer;
  min-height: 44px;
  transition: border-color 0.2s, color 0.2s;
}
.garage__cancel-btn:hover { color: var(--g-text); border-color: #9ca3af; }

/* ── Empty State ── */
.garage__empty {
  text-align: center;
  padding: 5rem 1rem;
  color: var(--g-muted);
}
.garage__empty-icon {
  margin-bottom: 1.5rem;
  opacity: 0.12;
  display: block;
  margin-left: auto;
  margin-right: auto;
  color: var(--g-text);
}
.garage__empty-icon--custom {
  opacity: 1;
  width: 120px;
  height: auto;
  object-fit: contain;
}
.garage__empty-headline {
  font-family: var(--g-heading);
  font-size: 1.75rem;
  font-weight: 700;
  color: var(--g-text);
  margin: 0 0 0.5rem;
  letter-spacing: 0.02em;
}
.garage__empty-sub {
  font-size: 1rem;
  color: var(--g-muted);
  margin: 0;
}

/* ── Vehicle Grid ── */
.garage__vehicles {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 1.25rem;
  list-style: none;
  padding: 0;
  margin: 0;
}
@media (max-width: 480px) { .garage__vehicles { grid-template-columns: 1fr; } }

/* ── Vehicle Card ── */
.garage__card {
  background: #fff;
  border: 1px solid var(--g-border);
  border-radius: var(--g-r);
  padding: 1.5rem;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  transition: box-shadow 0.2s, border-color 0.2s;
  animation: garage-card-in 0.25s ease;
}
@keyframes garage-card-in {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
.garage__card:hover { border-color: var(--g-border-soft); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
.garage__card--default { border-left: 3px solid var(--g-red); }

/* ── Card Identity Zone ── */
.garage__card-identity {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1rem;
}
.garage__card-icon-wrap {
  flex-shrink: 0;
  width: 64px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.18;
}
.garage__vehicle-icon { width: 64px; height: auto; color: var(--g-text); }
.garage__vehicle-icon--custom { opacity: 1; width: 64px; height: auto; object-fit: contain; }
.garage__card-icon-wrap:has(.garage__vehicle-icon--custom) { opacity: 1; }
.garage__card-meta { flex: 1; min-width: 0; }
.garage__card-header {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  flex-wrap: wrap;
  margin-bottom: 0.2rem;
}
.garage__badge {
  background: var(--g-red);
  color: #fff;
  font-size: 0.625rem;
  font-weight: 700;
  padding: 0.15rem 0.6rem;
  border-radius: 100px;
  text-transform: uppercase;
  letter-spacing: 0.07em;
}
.garage__nickname { color: var(--g-muted); font-size: 0.75rem; font-style: italic; }

/* Status pill */
.garage__status {
  font-size: 0.625rem;
  font-weight: 700;
  padding: 0.15rem 0.6rem;
  border-radius: 100px;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  margin-left: auto;
}
.garage__status--good { background: #f0fdf4; color: #16a34a; }
.garage__status--due-soon { background: #fffbeb; color: #d97706; }
.garage__status--overdue { background: #fef2f2; color: #dc2626; }

.garage__card-title {
  font-family: var(--g-heading);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--g-text);
  margin: 0 0 0.1rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 0.02em;
  line-height: 1.2;
}
.garage__card-trim { color: var(--g-muted); font-size: 0.875rem; margin: 0 0 0.625rem; }
.garage__size-chip {
  display: inline-block;
  background: var(--g-accent);
  color: #fff;
  font-family: var(--g-font);
  font-size: 0.78rem;
  font-weight: 600;
  padding: 0.2rem 0.65rem;
  border-radius: 100px;
  letter-spacing: 0.02em;
}

/* ── Reminders ── */
.garage__reminders { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem; }
.garage__reminder {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0.75rem;
  border-radius: var(--g-r-sm);
  font-size: 0.85rem;
  font-weight: 500;
}
.garage__reminder--soon { background: #fffbeb; color: #92400e; border: 1px solid #fde68a; }
.garage__reminder--overdue { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
.garage__reminder span { flex: 1; }
.garage__reminder-book {
  background: transparent;
  border: 1px solid currentColor;
  color: inherit;
  padding: 0.2rem 0.6rem;
  border-radius: 100px;
  font-size: 0.7rem;
  font-weight: 700;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.15s;
  min-height: 30px;
}
.garage__reminder-book:hover { background: rgba(0,0,0,0.06); }

/* ── Upsell Strip ── */
.garage__upsell-strip {
  display: flex;
  gap: 0.375rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
  padding: 0.75rem 0;
  border-top: 1px solid var(--g-border);
  border-bottom: 1px solid var(--g-border);
}
.garage__upsell-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.375rem 0.75rem;
  background: var(--g-bg2);
  border: 1px solid var(--g-border-soft);
  border-radius: 100px;
  color: var(--g-subtle);
  font-family: var(--g-font);
  font-size: 0.78rem;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
  min-height: 34px;
}
.garage__upsell-btn:hover { background: #fff; color: var(--g-text); border-color: #9ca3af; }
.garage__upsell-btn--primary { background: #fef2f2; border-color: #fecaca; color: var(--g-red); }
.garage__upsell-btn--primary:hover { background: #fee2e2; color: var(--g-red-hover); border-color: #fca5a5; }

/* ── Card Actions ── */
.garage__card-actions { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.5rem; }
.garage__action {
  padding: 0.4rem 0.8rem;
  border-radius: 100px;
  font-family: var(--g-font);
  font-size: 0.75rem;
  font-weight: 600;
  cursor: pointer;
  text-decoration: none;
  border: 1px solid transparent;
  transition: all 0.15s;
  min-height: 32px;
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
}
.garage__action--shop { background: var(--g-red); color: #fff; border-color: var(--g-red); }
.garage__action--shop:hover { background: var(--g-red-hover); border-color: var(--g-red-hover); color: #fff; }
.garage__action--default { background: #eff6ff; color: #2563eb; border-color: #bfdbfe; }
.garage__action--default:hover { background: #dbeafe; }
.garage__action--nickname,
.garage__action--log,
.garage__action--orders { background: var(--g-bg2); color: var(--g-subtle); border-color: var(--g-border-soft); }
.garage__action--nickname:hover,
.garage__action--log:hover,
.garage__action--orders:hover { color: var(--g-text); border-color: #9ca3af; background: #fff; }
.garage__action--remove { background: #fff; color: var(--g-red); border-color: #fecaca; }
.garage__action--remove:hover { background: #fef2f2; }

/* ── Last service line ── */
.garage__last-service {
  color: var(--g-muted);
  font-size: 0.75rem;
  margin: 0.5rem 0 0;
  padding-top: 0.5rem;
  border-top: 1px solid var(--g-border);
}

/* ── Maintenance Panel ── */
.garage__maint-panel, .garage__orders {
  border-top: 1px solid var(--g-border);
  margin-top: 1rem;
  padding-top: 1rem;
  animation: garage-slide-down 0.2s ease;
}
.garage__maint-form-title {
  font-family: var(--g-heading);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--g-text);
  margin: 0 0 0.75rem;
  letter-spacing: 0.02em;
}
.garage__maint-fields {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}
@media (max-width: 540px) { .garage__maint-fields { grid-template-columns: 1fr; } }
.garage__maint-select, .garage__maint-input {
  width: 100%;
  padding: 0.5rem 0.625rem;
  background: #fff;
  border: 1.5px solid var(--g-border-soft);
  border-radius: var(--g-r-sm);
  color: var(--g-text);
  font-family: var(--g-font);
  font-size: 0.85rem;
  min-height: 40px;
  transition: border-color 0.2s;
}
.garage__maint-select:focus, .garage__maint-input:focus { outline: none; border-color: var(--g-red); }
.garage__maint-form-actions { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
.garage__maint-save {
  background: #16a34a;
  color: #fff;
  border: none;
  padding: 0.5rem 1.25rem;
  border-radius: var(--g-r);
  font-family: var(--g-font);
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  min-height: 40px;
  transition: background 0.15s;
}
.garage__maint-save:hover { background: #15803d; }
.garage__maint-cancel {
  background: #fff;
  color: var(--g-subtle);
  border: 1.5px solid var(--g-border-soft);
  padding: 0.5rem 1.25rem;
  border-radius: var(--g-r);
  font-family: var(--g-font);
  font-size: 0.85rem;
  cursor: pointer;
  min-height: 40px;
  transition: border-color 0.2s, color 0.2s;
}
.garage__maint-cancel:hover { border-color: #9ca3af; color: var(--g-text); }

/* Maintenance history */
.garage__maint-history { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem; }
.garage__maint-entry {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.5rem 0;
  border-bottom: 1px solid var(--g-border);
  font-size: 0.85rem;
}
.garage__maint-entry:last-child { border-bottom: none; }
.garage__maint-entry--empty { color: var(--g-muted); font-style: italic; border: none; }
.garage__maint-type-label { color: var(--g-text); font-weight: 600; flex: 1; }
.garage__maint-date-label { color: var(--g-muted); white-space: nowrap; }
.garage__maint-km-label {
  color: var(--g-subtle);
  font-size: 0.75rem;
  white-space: nowrap;
  background: var(--g-bg2);
  padding: 0.125rem 0.4rem;
  border-radius: 100px;
}

/* ── Order History Panel ── */
.garage__orders-empty { color: var(--g-muted); font-size: 0.875rem; font-style: italic; margin: 0; }
.garage__orders-title {
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--g-subtle);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin: 0 0 0.75rem;
}
.garage__order-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.625rem 0;
  border-bottom: 1px solid var(--g-border);
}
.garage__order-row:last-child { border-bottom: none; }
.garage__order-info { flex: 1; min-width: 0; }
.garage__order-name {
  display: block;
  color: var(--g-text);
  font-size: 0.875rem;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.garage__order-meta { display: block; color: var(--g-muted); font-size: 0.75rem; margin-top: 0.125rem; }
.garage__order-reorder {
  background: #fef2f2;
  border: 1px solid #fecaca;
  color: var(--g-red);
  padding: 0.35rem 0.75rem;
  border-radius: 100px;
  font-size: 0.75rem;
  font-weight: 700;
  text-decoration: none;
  white-space: nowrap;
  transition: background 0.15s;
  min-height: 34px;
  display: inline-flex;
  align-items: center;
}
.garage__order-reorder:hover { background: #fee2e2; }

/* ── Guest State ── */
.garage--guest { text-align: center; padding-top: 5rem; padding-bottom: 5rem; }
.garage--guest h1 {
  font-family: var(--g-heading);
  font-size: 3rem;
  font-weight: 700;
  color: var(--g-text);
  letter-spacing: 0.02em;
  line-height: 1.1;
  margin: 0 0 0.75rem;
}
.garage--guest p { color: var(--g-muted); margin: 0 0 1.5rem; font-size: 1rem; }
.garage__login-btn {
  display: inline-block;
  background: var(--g-red);
  color: #fff;
  text-decoration: none;
  padding: 0.875rem 2.5rem;
  border-radius: var(--g-r);
  font-family: var(--g-font);
  font-weight: 600;
  font-size: 1rem;
  transition: background 0.2s;
}
.garage__login-btn:hover { background: var(--g-red-hover); color: #fff; }

/* ── Dashboard Hero ── */
.garage__dashboard { margin-bottom: 2rem; }
.garage__dashboard-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1.25rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
}
.garage__dashboard-name {
  font-family: var(--g-heading);
  font-size: 3rem;
  font-weight: 700;
  color: var(--g-text);
  margin: 0 0 0.375rem;
  letter-spacing: 0.02em;
  line-height: 1.1;
}

/* ── Stats Pills ── */
.garage__dashboard-stats {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  align-items: center;
  padding-top: 0.5rem;
}
.garage__stat-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.35rem 0.8rem;
  border-radius: 100px;
  font-size: 0.78rem;
  font-weight: 600;
  background: var(--g-bg2);
  border: 1px solid var(--g-border-soft);
  color: var(--g-subtle);
  white-space: nowrap;
}
.garage__stat-pill--alert {
  background: #fef2f2;
  border-color: #fecaca;
  color: var(--g-red);
}
.garage__stat-pill--good {
  background: #f0fdf4;
  border-color: #bbf7d0;
  color: #16a34a;
}
.garage__stat-pill--next {
  background: #eff6ff;
  border-color: #bfdbfe;
  color: #2563eb;
}

/* ── Seasonal Tip Banner ── */
.garage__seasonal-tip {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.25rem;
  background: #fafaf9;
  border: 1px solid var(--g-border-soft);
  border-left: 3px solid var(--g-accent);
  border-radius: var(--g-r);
  font-size: 0.875rem;
}
.garage__seasonal-tip-icon { font-size: 1.5rem; flex-shrink: 0; line-height: 1; }
.garage__seasonal-tip-text { flex: 1; }
.garage__seasonal-tip-label {
  font-weight: 700;
  color: var(--g-text);
  margin-bottom: 0.15rem;
}
.garage__seasonal-tip-sub { color: var(--g-subtle); line-height: 1.4; }
.garage__seasonal-tip-action {
  flex-shrink: 0;
  background: var(--g-accent);
  color: #fff;
  border: none;
  padding: 0.45rem 0.9rem;
  border-radius: 100px;
  font-family: var(--g-font);
  font-size: 0.75rem;
  font-weight: 700;
  text-decoration: none;
  cursor: pointer;
  transition: opacity 0.15s;
  white-space: nowrap;
}
.garage__seasonal-tip-action:hover { opacity: 0.88; color: #fff; }

/* ── Activity Feed ── */
.garage__activity {
  margin-top: 2.5rem;
  padding-top: 1.75rem;
  border-top: 1px solid var(--g-border);
}
.garage__activity-header {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  margin-bottom: 1rem;
}
.garage__activity-title {
  font-family: var(--g-heading);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--g-text);
  margin: 0;
  letter-spacing: 0.02em;
}
.garage__activity-sub {
  color: var(--g-muted);
  font-size: 0.85rem;
}
.garage__activity-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.garage__activity-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.8rem 0;
  border-bottom: 1px solid var(--g-border);
  font-size: 0.875rem;
}
.garage__activity-item:last-child { border-bottom: none; }
.garage__activity-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--g-accent);
  flex-shrink: 0;
}
.garage__activity-info { flex: 1; min-width: 0; }
.garage__activity-what { font-weight: 600; color: var(--g-text); }
.garage__activity-vehicle {
  color: var(--g-muted);
  font-size: 0.78rem;
  margin-top: 0.1rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.garage__activity-km {
  color: var(--g-subtle);
  font-size: 0.75rem;
  background: var(--g-bg2);
  padding: 0.1rem 0.4rem;
  border-radius: 100px;
  white-space: nowrap;
  flex-shrink: 0;
}
.garage__activity-when {
  color: var(--g-muted);
  white-space: nowrap;
  font-size: 0.8rem;
}

/* ── Mobile ── */
@media (max-width: 768px) {
  .garage { padding-left: 1.25rem; padding-right: 1.25rem; }
  .garage__card { padding: 1.25rem; }
  .garage__card-icon-wrap { width: 48px; height: 28px; }
  .garage__vehicle-icon { width: 48px; }
  .garage__card-actions { gap: 0.375rem; }
  .garage__upsell-strip { gap: 0.25rem; }
  .garage__dashboard-top { flex-direction: column; gap: 0.75rem; }
  .garage__dashboard-name { font-size: 2.25rem; }
  .garage__seasonal-tip { flex-wrap: wrap; }
  .garage__seasonal-tip-action { width: 100%; text-align: center; margin-top: 0.25rem; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.my_garage.name",
  "settings": [
    {
      "type": "header",
      "content": "Vehicle image"
    },
    {
      "type": "image_picker",
      "id": "garage_image",
      "label": "Custom vehicle image",
      "info": "Upload a GIF, SVG, or image to replace the default car icon on cards and the empty state. Recommended size: 160×80px."
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
