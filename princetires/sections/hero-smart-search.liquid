    }

    searchIcon() {
      return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M16 16L21 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>';
    }

    phoneIcon() {
      return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22 16.92V19.92C22 20.48 21.56 20.93 21 20.97C20.66 21 20.33 21.01 20 21.01C10.61 21.01 3 13.4 3 3.97C3 3.64 3.01 3.31 3.03 2.97C3.07 2.41 3.52 1.97 4.08 1.97H7.08C7.56 1.97 7.97 2.33 8.03 2.81C8.09 3.33 8.2 3.84 8.37 4.33C8.52 4.76 8.41 5.24 8.08 5.57L6.62 7.03C8.06 9.78 10.22 11.94 12.97 13.38L14.43 11.92C14.76 11.59 15.24 11.48 15.67 11.63C16.16 11.8 16.67 11.91 17.19 11.97C17.67 12.03 18.03 12.44 18.03 12.92V16.92H22Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
    }

    escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    escapeAttr(text) {
      return text.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }
  }

  document.querySelectorAll('[data-smart-search]').forEach(el => {
    new SmartTireSearch(el.closest('.hero-smart-search'));
  });

  /* Garage pre-fill removed — typewriter handles placeholder */

  (function() {
    var heading = document.querySelector('[data-hero-heading]');
    if (!heading) return;

    var left = heading.querySelector('[data-hero-left]');
    var right = heading.querySelector('[data-hero-right]');
    var searchWrap = document.querySelector('.hero-smart-search__input-wrapper');

    function trigger() {
      if (left) left.classList.add('is-animated');
      if (right) right.classList.add('is-animated');
      if (searchWrap) searchWrap.classList.add('is-animated');
    }

    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            setTimeout(trigger, 200);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      observer.observe(heading);
    } else {
      setTimeout(trigger, 300);
    }
  })();

  /* Typewriter placeholder effect */
  (function() {
    var el = document.querySelector('[data-typewriter]');
    var input = document.querySelector('[data-smart-search-input]');
    if (!el || !input) return;

    var intro = 'What are you looking for?';
    var phrases = [
      'tires for Honda Civic SI 2025',
      'Michelin 225/65R17',
      'winter tires for my RAV4',
      'Ford F-150 2024',
      'all season tires 2055516',
      'Bridgestone Subaru Outback',
      'crv 2025 winter',
      'Toyota Camry LE 2024',
    ];
    var phase = 'intro';       /* intro → examples */
    var phraseIndex = 0;
    var charIndex = 0;
    var isDeleting = false;
    var isPaused = false;
    var isActive = true;

    function tick() {
      if (!isActive) return;

      /* Phase 1: Show intro instantly, pause, then clear */
      if (phase === 'intro') {
        el.textContent = intro;
        phase = 'intro-clear';
        setTimeout(tick, 2000);
        return;
      }

      if (phase === 'intro-clear') {
        el.textContent = '';
        phase = 'examples';
        setTimeout(tick, 300);
        return;
      }

      /* Phase 2: Cycle through examples */
      var current = phrases[phraseIndex];

      if (isPaused) {
        isPaused = false;
        isDeleting = true;
        setTimeout(tick, 25);
        return;
      }

      if (!isDeleting) {
        charIndex++;
        el.textContent = current.slice(0, charIndex);
        if (charIndex >= current.length) {
          isPaused = true;
          setTimeout(tick, 1600);
          return;
        }
        setTimeout(tick, 35 + Math.random() * 25);
      } else {
        charIndex--;
        el.textContent = current.slice(0, charIndex);
        if (charIndex <= 0) {
          isDeleting = false;
          phraseIndex = (phraseIndex + 1) % phrases.length;
          setTimeout(tick, 250);
          return;
        }
        setTimeout(tick, 20);
      }
    }

    /* Hide typewriter when user focuses or types */
    input.addEventListener('focus', function() {
      el.classList.add('is-hidden');
    });
    input.addEventListener('blur', function() {
      if (!input.value) {
        el.classList.remove('is-hidden');
        if (!isActive) {
          isActive = true;
          tick();
        }
      }
    });
    input.addEventListener('input', function() {
      if (input.value) {
        el.classList.add('is-hidden');
        isActive = false;
      } else {
        el.classList.remove('is-hidden');
        if (!isActive) {
          isActive = true;
          charIndex = 0;
          tick();
        }
      }
    });

    /* Start after heading animation completes */
    setTimeout(tick, 1200);
  })();

  /* ── Hero slideshow cycler ─────────────────────────────────── */
  (function () {
    var root = document.querySelector('[data-hero-slideshow]');
    if (!root) return;
    var slides = root.querySelectorAll('.hero-smart-search__slide');
    if (slides.length < 2) return;

    var interval = parseInt(root.dataset.interval, 10) || 5000;
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return;

    var current = 0;
    var timer = null;

    function show(next) {
      var prev = current;
      if (next === prev) return;

      var prevEl = slides[prev];
      var nextEl = slides[next];

      prevEl.classList.remove('is-active');
      prevEl.classList.add('is-leaving');
      nextEl.classList.remove('is-leaving');
      nextEl.classList.add('is-entering', 'is-active');

      // Cleanup the leaving class after the exit animation finishes
      window.setTimeout(function () { prevEl.classList.remove('is-leaving'); }, 1100);
      window.setTimeout(function () { nextEl.classList.remove('is-entering'); }, 700);

      current = next;
    }

    function next() {
      show((current + 1) % slides.length);
    }

    function start() {
      if (timer) return;
      timer = window.setInterval(next, interval);
    }
    function stop() {
      if (!timer) return;
      window.clearInterval(timer);
      timer = null;
    }

    document.addEventListener('visibilitychange', function () {
      if (document.visibilityState === 'hidden') stop();
      else start();
    });

    start();
  })();
});
</script>

