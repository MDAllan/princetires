<script>
document.addEventListener('DOMContentLoaded', function() {
  class SmartTireSearch {
    constructor(container) {
      this.container = container;
      this.input = container.querySelector('[data-smart-search-input]');
      this.results = container.querySelector('[data-smart-search-results]');
      this.list = container.querySelector('[data-smart-search-list]');
      this.submit = container.querySelector('[data-smart-search-submit]');
      this.loading = container.querySelector('[data-smart-search-loading]');
      this.selectedIndex = -1;
      this.items = [];
      this.debounceTimer = null;
      this.vehicleCache = {};
      this.geminiCache = {};
      this.abortController = null;

      const configEl = document.querySelector('[data-smart-search-config]');
      this.config = configEl ? JSON.parse(configEl.textContent) : {};

      this.awaitingTrim = false;

      this.tireSizeRegex = /(?:^|[\s,])([Pp]?(?:[Ll][Tt]|[Ss][Tt])?\d{3}\/?\d{2,3}[Rr]\d{2}(?:\.\d)?|(?:[Ll][Tt])?\d{2}[xX\/]\d{2}\.\d{1,2}[Rr]\d{2})/;
      this.brands = ['michelin','bridgestone','goodyear','continental','toyo','pirelli','falken','kumho','yokohama','firestone','cooper','bfgoodrich','bf goodrich','general','uniroyal','hankook','nitto','mickey thompson','firemax','linglong','farroad','yeada','fortune','radar','rotalla','haida','carlstar'];

      this.knownMakes = ['acura','alfa romeo','aston martin','audi','bmw','bentley','buick','cadillac','chevrolet','chevy','chrysler','dodge','ferrari','fiat','ford','gmc','genesis','honda','hyundai','ineos','infiniti','jaguar','jeep','karma','kia','lamborghini','land rover','lexus','lincoln','lotus','lucid','maserati','mazda','mclaren','mercedes-benz','mercedes','benz','mini','mitsubishi','nissan','polestar','porsche','ram','rivian','rolls-royce','subaru','tesla','toyota','vinfast','volkswagen','vw','volvo'];
      this.makeAliases = {'chevy':'Chevrolet','vw':'Volkswagen','mercedes':'Mercedes-Benz','benz':'Mercedes-Benz'};
      this.modelShortcuts = {
        'crv':'CR-V','cr-v':'CR-V','hrv':'HR-V','hr-v':'HR-V','rav':'RAV4','rav4':'RAV4',
        'f150':'F-150','f-150':'F-150','f250':'F-250','f-250':'F-250','f350':'F-350','f-350':'F-350',
        '4runner':'4Runner','forerunner':'4Runner','camry':'Camry','corolla':'Corolla',
        'cx5':'CX-5','cx-5':'CX-5','cx50':'CX-50','cx-50':'CX-50','cx9':'CX-9','cx-9':'CX-9','cx30':'CX-30','cx-30':'CX-30',
        'mazda3':'Mazda3','mazda6':'Mazda6',
        'q5':'Q5','q7':'Q7','q3':'Q3','x3':'X3','x5':'X5','x1':'X1',
        'crz':'CR-Z','brz':'BRZ','grz':'GR86','gr86':'GR86',
        'wrx':'WRX','sti':'WRX STI','outback':'Outback','forester':'Forester','crosstrek':'Crosstrek',
        'silverado':'Silverado 1500','sierra':'Sierra 1500','tahoe':'Tahoe','suburban':'Suburban',
        'wrangler':'Wrangler','cherokee':'Cherokee','grandcherokee':'Grand Cherokee','grand cherokee':'Grand Cherokee',
        'mustang':'Mustang','bronco':'Bronco','escape':'Escape','explorer':'Explorer','expedition':'Expedition',
        'tacoma':'Tacoma','tundra':'Tundra','highlander':'Highlander','prius':'Prius','supra':'GR Supra',
        'civic':'Civic','accord':'Accord','pilot':'Pilot','odyssey':'Odyssey','ridgeline':'Ridgeline',
        'altima':'Altima','maxima':'Maxima','sentra':'Sentra','rogue':'Rogue','pathfinder':'Pathfinder','frontier':'Frontier',
        'elantra':'Elantra','sonata':'Sonata','tucson':'Tucson','santafe':'Santa Fe','santa fe':'Santa Fe','palisade':'Palisade',
        'sorento':'Sorento','sportage':'Sportage','forte':'Forte','telluride':'Telluride',
        'jetta':'Jetta','tiguan':'Tiguan','atlas':'Atlas','golf':'Golf','passat':'Passat',
        'model3':'Model 3','modely':'Model Y','modelx':'Model X','models':'Model S',
        'glc':'GLC','gle':'GLE','gls':'GLS','cclass':'C-Class','eclass':'E-Class',
        'ram1500':'1500','ram2500':'2500','ram3500':'3500',
        'malibu':'Malibu','equinox':'Equinox','traverse':'Traverse','trax':'Trax','blazer':'Blazer',
        'terrain':'Terrain','acadia':'Acadia','yukon':'Yukon',
        'durango':'Durango','charger':'Charger','challenger':'Challenger',
        'outback':'Outback','impreza':'Impreza','legacy':'Legacy',
        'maverick':'Maverick','ranger':'Ranger',
        'ioniq5':'Ioniq 5','ioniq6':'Ioniq 6','kona':'Kona',
        'ct4':'CT4','ct5':'CT5','escalade':'Escalade','xt5':'XT5','xt6':'XT6',
      };
      this.noiseWords = ['tires','tire','for','my','the','a','an','need','needs','looking','want','i','on','new','set','of','best','good','cheap','get','find','buy','shop','what','fit','fits','size','sizes'];

      this.bindEvents();
    }

    levenshtein(a, b) {
      if (a.length === 0) return b.length;
      if (b.length === 0) return a.length;
      var matrix = [];
      for (var i = 0; i <= b.length; i++) matrix[i] = [i];
      for (var j = 0; j <= a.length; j++) matrix[0][j] = j;
      for (var i = 1; i <= b.length; i++) {
        for (var j = 1; j <= a.length; j++) {
          var cost = a[j - 1] === b[i - 1] ? 0 : 1;
          matrix[i][j] = Math.min(matrix[i - 1][j] + 1, matrix[i][j - 1] + 1, matrix[i - 1][j - 1] + cost);
        }
      }
      return matrix[b.length][a.length];
    }

    fuzzyMatchMake(word) {
      /* Exact match first */
      if (this.knownMakes.indexOf(word) >= 0) return this.makeAliases[word] || word;
      /* Fuzzy: allow 1-2 typos depending on word length */
      var maxDist = word.length <= 4 ? 1 : 2;
      var best = null, bestDist = maxDist + 1;
      for (var i = 0; i < this.knownMakes.length; i++) {
        var mk = this.knownMakes[i];
        if (Math.abs(mk.length - word.length) > maxDist) continue;
        var d = this.levenshtein(word, mk);
        if (d < bestDist) { bestDist = d; best = mk; }
      }
      if (best) return this.makeAliases[best] || best;
      return null;
    }

    parseSearchIntent(query) {
      const q = query.toLowerCase();
      const intent = { season: null, brand: null };

      if (q.includes('winter') || q.includes('snow') || q.includes('ice')) intent.season = 'Winter';
      else if (q.includes('all-season') || q.includes('all season') || q.includes('allseason')) intent.season = 'All-Season';
      else if (q.includes('all-weather') || q.includes('all weather')) intent.season = 'All-Weather';
      else if (q.includes('summer') || q.includes('performance')) intent.season = 'Summer';

      for (const brand of this.brands) {
        var escapedBrand = brand.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        if (new RegExp('\\b' + escapedBrand + '\\b', 'i').test(q)) {
          intent.brand = brand.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
          if (intent.brand === 'Bfgoodrich' || intent.brand === 'Bf Goodrich') intent.brand = 'BFGoodrich';
          break;
        }
      }
      return intent;
    }

    extractTireSize(query) {
      var n = this.normalizeTireSize(query);
      return n ? n.size : null;
    }

    buildCollectionUrl(params) {
      const base = '/collections/tires';
      const urlParams = new URLSearchParams();

      /* If a full tire size string is passed (e.g. from vehicle lookup "195/65R15"),
         parse it into components and use individual metafield filters.
         Strip any P / LT / ST prefix before filtering. */
      if (params.tireSize) {
        var sizeStr = String(params.tireSize).replace(/^[Pp]?(?:[Ll][Tt]|[Ss][Tt])?/, '');
        var pm = sizeStr.match(/(\d{3})\/?(\d{2,3})[Rr](\d{2}(?:\.\d)?)/);
        if (pm) {
          urlParams.set('filter.p.m.custom.tire_width', pm[1]);
          urlParams.set('filter.p.m.custom.tire_profile', pm[2]);
          urlParams.set('filter.p.m.custom.rim_diameter', pm[3]);
        }
      }

      /* Individual components take precedence (passed directly from normalizeTireSize) */
      if (params.width)  urlParams.set('filter.p.m.custom.tire_width',   params.width);
      if (params.aspect) urlParams.set('filter.p.m.custom.tire_profile',  params.aspect);
      if (params.rim)    urlParams.set('filter.p.m.custom.rim_diameter',  params.rim);

      if (params.brand)  urlParams.set('filter.p.vendor',                  params.brand);
      if (params.season) urlParams.set('filter.p.m.custom.seasonality',    params.season);

      const qs = urlParams.toString();
      return qs ? base + '?' + qs : base;
    }

    bindEvents() {
      this.input.addEventListener('input', () => this.onInput());
      this.input.addEventListener('keydown', (e) => this.onKeydown(e));
      this.submit.addEventListener('click', () => this.onSubmit());
      this.input.addEventListener('focus', () => {
        if (this.input.value.trim().length >= 2) this.search(this.input.value.trim());
      });
      document.addEventListener('click', (e) => {
        if (!this.container.querySelector('[data-smart-search]').contains(e.target)) {
          this.hideResults();
        }
      });
    }

    onInput() {
      clearTimeout(this.debounceTimer);
      this.debounceTimer = setTimeout(() => {
        const query = this.input.value.trim();
        if (query.length < 2) {
          this.hideResults();
          return;
        }
        this.search(query);
      }, 300);
    }

    normalizeTireSize(query) {
      /* Standard metric format: 225/65R17, P225/65R17, LT225/65R17 */
      var m = query.match(/[Pp]?(?:[Ll][Tt]|[Ss][Tt])?(\d{3})\/?(\d{2,3})[Rr](\d{2}(?:\.\d)?)/);
      if (m) return { width: m[1], aspect: m[2], rim: m[3], size: m[1] + '/' + m[2] + 'R' + m[3] };

      /* Flotation/inch format: 33x12.50R20, LT33x12.50R20, 33/12.50R20
         Decimal aspect ratio is required to distinguish from metric format */
      var fi = query.match(/(?:[Ll][Tt])?(\d{2})[xX\/](\d{2}\.\d{1,2})[Rr](\d{2})/);
      if (fi) return { width: fi[1], aspect: fi[2], rim: fi[3], size: fi[1] + 'x' + fi[2] + 'R' + fi[3] };

      /* Compact digits only: 2255517 (7 digits, width=3, aspect=2, rim=2) */
      var compact = query.replace(/[\s\/\-rR]/g, '');
      var dm = compact.match(/[Pp]?(?:[Ll][Tt]|[Ss][Tt])?(\d{3})(\d{2})(\d{2})$/);
      if (dm) return { width: dm[1], aspect: dm[2], rim: dm[3], size: dm[1] + '/' + dm[2] + 'R' + dm[3] };

      /* Spaced format: 225 55 17 */
      var spaced = query.match(/(\d{3})\s+(\d{2})\s+(\d{2})/);
      if (spaced) return { width: spaced[1], aspect: spaced[2], rim: spaced[3], size: spaced[1] + '/' + spaced[2] + 'R' + spaced[3] };

      return null;
    }

    async search(query) {
      if (this.abortController) this.abortController.abort();
      this.abortController = new AbortController();

      var normalized = this.normalizeTireSize(query);
      if (normalized) {
        this.handleTireSizeMatch(normalized, query);
        return;
      }

      await this.handleVehicleQuery(query);
    }

    handleTireSizeMatch(parsed, query) {
      const width = parsed.width;
      const aspect = parsed.aspect || '';
      const rim = parsed.rim || '';
      const sizeStr = parsed.size;

      const intent = this.parseSearchIntent(query);
      const intentLabel = intent.season ? ' · ' + intent.season : '';

      const results = [{
        type: 'size',
        title: sizeStr + (intent.brand ? ' by ' + intent.brand : ''),
        meta: 'Filter collection' + intentLabel,
        url: this.buildCollectionUrl({ width: width, aspect: aspect, rim: rim, brand: intent.brand, season: intent.season }),
      }];

      if (width && aspect && !rim) {
        const commonRims = ['15', '16', '17', '18', '19', '20'];
        commonRims.forEach(r => {
          const full = width + '/' + aspect + 'R' + r;
          if (full !== sizeStr) {
            results.push({
              type: 'size',
              title: full,
              meta: 'Filter collection' + intentLabel,
              url: this.buildCollectionUrl({ width: width, aspect: aspect, rim: r, brand: intent.brand, season: intent.season }),
            });
          }
        });
      }

      this.renderResults(results.slice(0, 6));
    }

    cleanQueryForVehicle(query, intent) {
      var q = query.toLowerCase();
      /* Strip season words */
      var seasonWords = ['winter','snow','ice','all-season','all season','allseason','all-weather','all weather','summer','performance'];
      for (var i = 0; i < seasonWords.length; i++) {
        q = q.replace(new RegExp('\\b' + seasonWords[i].replace(/-/g, '[-\\s]?') + '\\b', 'g'), ' ');
      }
      /* Strip matched brand */
      if (intent.brand) {
        var brandLower = intent.brand.toLowerCase();
        q = q.replace(new RegExp('\\b' + brandLower.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '\\b', 'g'), ' ');
        /* Also strip common brand variants */
        for (var b of this.brands) {
          if (q.includes(b)) q = q.replace(new RegExp('\\b' + b.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '\\b', 'g'), ' ');
        }
      }
      return q.replace(/\s+/g, ' ').trim();
    }

    async handleVehicleQuery(query) {
      this.showLoading();
      const intent = this.parseSearchIntent(query);
      const cleanedQuery = this.cleanQueryForVehicle(query, intent);

      try {
        const vehicle = cleanedQuery.length >= 2 ? await this.recognizeVehicle(cleanedQuery) : null;

        if (!vehicle || (!vehicle.year && !vehicle.model && !vehicle.make)) {
          if (intent.brand || intent.season) {
            var filterTitle = [intent.brand, intent.season].filter(Boolean).join(' ') + ' tires';
            this.renderResults([{
              type: 'search',
              title: filterTitle,
              meta: 'Filter collection',
              url: this.buildCollectionUrl({ brand: intent.brand, season: intent.season }),
            }]);
          } else {
            this.showFallback(query);
          }
          return;
        }

        const trims = await this.lookupVehicleTrims(vehicle);
        const vLabel = vehicle.year + ' ' + (vehicle.make || '') + ' ' + (vehicle.model || '');
        const vLabelClean = vLabel.replace(/\s+/g, ' ').trim();

        if (trims && trims.length === 1 && vehicle.trim) {
          /* User specified a trim and we found it — go straight to collection */
          const trimLabel = vLabelClean + ' ' + trims[0].trim;
          const url = this.buildCollectionUrl({ tireSize: trims[0].size, brand: intent.brand, season: intent.season });
          this.renderResults([{
            type: 'vehicle',
            title: trimLabel,
            meta: trims[0].size + (intent.season ? ' · ' + intent.season : '') + (intent.brand ? ' · ' + intent.brand : ''),
            url: url,
          }]);
        } else if (trims && trims.length > 0) {
          this.renderTrimResults(vLabelClean, trims, intent);
        } else {
          this.renderResults([{
            type: 'vehicle',
            title: vLabelClean,
            meta: 'Browse all tires',
            url: this.buildCollectionUrl({ brand: intent.brand, season: intent.season }),
          }]);
        }
      } catch (err) {
        if (err.name === 'AbortError') return;
        if (intent.brand || intent.season) {
          this.renderResults([{
            type: 'search',
            title: (intent.brand || '') + (intent.season ? ' ' + intent.season : '') + ' tires',
            meta: 'Filter collection',
            url: this.buildCollectionUrl({ brand: intent.brand, season: intent.season }),
          }]);
        } else {
          this.showFallback(query);
        }
      }
    }

    async recognizeVehicle(query) {
      if (this.geminiCache[query]) return this.geminiCache[query];

      const directParse = this.tryDirectParse(query);
      if (directParse) {
        this.geminiCache[query] = directParse;
        return directParse;
      }

      if (!this.config.geminiKey) {
        return null;
      }

      try {
        const response = await fetch(
          'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=' + this.config.geminiKey,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            signal: this.abortController.signal,
            body: JSON.stringify({
              contents: [{
                parts: [{
                  text: 'Extract vehicle info from this search query: "' + query + '"\n\nReturn ONLY a JSON object with these fields:\n- year (number, 4 digits, default to ' + this.config.maxYear + ' if not specified)\n- make (string, full brand name e.g. "Honda" not "honda")\n- model (string, official model name)\n- trim (string or null)\n\nExamples:\n"2020 Honda Civic" -> {"year":2020,"make":"Honda","model":"Civic","trim":null}\n"\'19 Civic" -> {"year":2019,"make":"Honda","model":"Civic","trim":null}\n"F-150" -> {"year":' + this.config.maxYear + ',"make":"Ford","model":"F-150","trim":null}\n"corolla le" -> {"year":' + this.config.maxYear + ',"make":"Toyota","model":"Corolla","trim":"LE"}\n"rav4" -> {"year":' + this.config.maxYear + ',"make":"Toyota","model":"RAV4","trim":null}\n\nIf the input is not a vehicle at all, return {"year":null,"make":null,"model":null,"trim":null}\n\nReturn ONLY the JSON, no markdown, no explanation.'
                }]
              }],
              generationConfig: {
                temperature: 0,
                maxOutputTokens: 100,
              }
            })
          }
        );

        if (!response.ok) return null;

        const data = await response.json();
        const text = data.candidates?.[0]?.content?.parts?.[0]?.text || '';
        const jsonStr = text.replace(/```json\n?/g, '').replace(/```/g, '').trim();
        const vehicle = JSON.parse(jsonStr);

        if (vehicle.year && vehicle.make && vehicle.model) {
          this.geminiCache[query] = vehicle;
          return vehicle;
        }
        return null;
      } catch (err) {
        if (err.name === 'AbortError') throw err;
        return null;
      }
    }

    tryDirectParse(query) {
      var q = query.trim().toLowerCase();

      /* Strip noise words */
      var words = q.split(/\s+/).filter(function(w) { return this.noiseWords.indexOf(w) === -1; }.bind(this));
      if (words.length === 0) return null;

      /* Extract year from anywhere */
      var year = null;
      var yearIndex = -1;
      for (var i = 0; i < words.length; i++) {
        var w = words[i].replace(/^[''\u2018\u2019]/, '');
        var ym = w.match(/^(\d{2,4})$/);
        if (ym) {
          var y = ym[1];
          if (y.length === 2) y = (parseInt(y) > 50 ? '19' : '20') + y;
          var yn = parseInt(y);
          if (yn >= this.config.minYear && yn <= this.config.maxYear) {
            year = yn;
            yearIndex = i;
            break;
          }
        }
      }
      if (yearIndex >= 0) words.splice(yearIndex, 1);
      if (words.length === 0) return null;

      /* Try to find a known make */
      var make = null;
      var makeEnd = -1;

      /* Check two-word makes first (e.g. "alfa romeo", "land rover") */
      for (var i = 0; i < words.length - 1; i++) {
        var twoWord = words[i] + ' ' + words[i + 1];
        if (this.knownMakes.indexOf(twoWord) >= 0) {
          make = this.makeAliases[twoWord] || twoWord.split(' ').map(function(w) { return w.charAt(0).toUpperCase() + w.slice(1); }).join(' ');
          words.splice(i, 2);
          break;
        }
      }

      /* Check single-word makes (exact then fuzzy) */
      if (!make) {
        for (var i = 0; i < words.length; i++) {
          var matched = this.fuzzyMatchMake(words[i]);
          if (matched) {
            make = matched;
            if (make === 'Bmw') make = 'BMW';
            if (make === 'Gmc') make = 'GMC';
            if (make === 'Ram') make = 'RAM';
            make = make.charAt(0).toUpperCase() + make.slice(1);
            if (this.makeAliases[words[i]]) make = this.makeAliases[words[i]];
            words.splice(i, 1);
            break;
          }
        }
      }

      /* Remaining words are model (+ optional trim) */
      if (words.length === 0 && !make) return null;

      var model = null;
      var trim = null;
      if (words.length > 0) {
        /* Check model shortcuts first (try multi-word then single) */
        var modelJoined = words.join(' ');
        var modelNoSpace = words.join('');
        if (this.modelShortcuts[modelJoined]) {
          model = this.modelShortcuts[modelJoined];
          words = [];
        } else if (this.modelShortcuts[modelNoSpace]) {
          model = this.modelShortcuts[modelNoSpace];
          words = [];
        } else if (this.modelShortcuts[words[0]]) {
          model = this.modelShortcuts[words[0]];
          words.splice(0, 1);
          trim = words.length > 0 ? words.join(' ') : null;
        } else {
          model = words[0];
          trim = words.length > 1 ? words.slice(1).join(' ') : null;
        }
      }

      /* Default year to max if not provided */
      if (!year) year = this.config.maxYear;

      return { year: year, make: make, model: model, trim: trim };
    }

    capitalizeMake(make) {
      return make.charAt(0).toUpperCase() + make.slice(1).toLowerCase();
    }

    async loadVehicleData(year) {
      if (this.vehicleCache[year]) return this.vehicleCache[year];

      const numYear = parseInt(year);
      if (numYear < this.config.minYear || numYear > this.config.maxYear) return null;

      try {
        const url = this.config.assetUrlBase + 'pt-vehicle-' + year + '.json';
        const resp = await fetch(url, { signal: this.abortController.signal });
        if (!resp.ok) return null;
        const data = await resp.json();
        this.vehicleCache[year] = data;
        return data;
      } catch (err) {
        if (err.name === 'AbortError') throw err;
        return null;
      }
    }

    async lookupVehicleSizes(vehicle) {
      const data = await this.loadVehicleData(vehicle.year);
      if (!data || !data.models) return [];

      let makeData = null;
      if (vehicle.make) {
        makeData = data.models[vehicle.make];
        if (!makeData) {
          const makeLower = vehicle.make.toLowerCase();
          for (const [key, val] of Object.entries(data.models)) {
            if (key.toLowerCase() === makeLower) {
              makeData = val;
              break;
            }
          }
        }
      }

      if (!makeData && vehicle.model) {
        for (const [mk, models] of Object.entries(data.models)) {
          for (const modelName of Object.keys(models)) {
            if (modelName.toLowerCase() === vehicle.model.toLowerCase()) {
              makeData = models;
              vehicle.make = mk;
              break;
            }
          }
          if (makeData) break;
        }
      }

      if (!makeData) return [];

      let modelData = makeData[vehicle.model];
      if (!modelData) {
        const modelLower = vehicle.model.toLowerCase();
        for (const [key, val] of Object.entries(makeData)) {
          if (key.toLowerCase() === modelLower) {
            modelData = val;
            break;
          }
        }
      }

      if (!modelData) return [];

      if (vehicle.trim) {
        const trimLower = vehicle.trim.toLowerCase();
        for (const [trimName, sizes] of Object.entries(modelData)) {
          if (trimName.toLowerCase() === trimLower || trimName.toLowerCase().includes(trimLower)) {
            return Array.isArray(sizes) ? sizes : [];
          }
        }
      }

      const allSizes = new Set();
      for (const sizes of Object.values(modelData)) {
        if (Array.isArray(sizes)) {
          sizes.forEach(s => allSizes.add(s));
        }
      }
      return [...allSizes];
    }

    _findModelData(data, vehicle) {
      if (!data || !data.models) return null;
      var makeData = null;
      var foundMake = vehicle.make;
      var foundModel = vehicle.model;

      if (vehicle.make) {
        makeData = data.models[vehicle.make];
        if (!makeData) {
          var ml = vehicle.make.toLowerCase();
          for (var [k, v] of Object.entries(data.models)) {
            if (k.toLowerCase() === ml) { makeData = v; foundMake = k; break; }
          }
        }
      }

      if (!vehicle.model) return null;

      var modelLower = vehicle.model.toLowerCase();
      var modelClean = modelLower.replace(/[-\s]/g, '');
      var searchIn = makeData ? [[foundMake, makeData]] : Object.entries(data.models);
      var modelData = null;

      for (var [mk, models] of searchIn) {
        for (var [mn, md] of Object.entries(models)) {
          if (mn.toLowerCase() === modelLower) { modelData = md; foundMake = mk; foundModel = mn; break; }
        }
        if (modelData) break;

        for (var [mn, md] of Object.entries(models)) {
          var mnClean = mn.toLowerCase().replace(/[-\s]/g, '');
          if (mnClean.includes(modelClean) || modelClean.includes(mnClean)) { modelData = md; foundMake = mk; foundModel = mn; break; }
        }
        if (modelData) break;

        var bestModel = null, bestDist = 3, bestMd = null;
        for (var [mn, md] of Object.entries(models)) {
          var mnClean = mn.toLowerCase().replace(/[-\s]/g, '');
          var maxDist = modelClean.length <= 4 ? 1 : 2;
          if (Math.abs(mnClean.length - modelClean.length) > maxDist) continue;
          var d = this.levenshtein(modelClean, mnClean);
          if (d <= maxDist && d < bestDist) { bestDist = d; bestModel = mn; bestMd = md; }
        }
        if (bestModel) { modelData = bestMd; foundMake = mk; foundModel = bestModel; break; }
      }

      if (!modelData) return null;
      return { makeKey: foundMake, modelKey: foundModel, modelData: modelData };
    }

    async lookupVehicleTrims(vehicle) {
      var data = await this.loadVehicleData(vehicle.year);
      var match = this._findModelData(data, vehicle);

      /* Multi-year fallback: if not found in requested year, try the previous year */
      if (!match && vehicle.year > this.config.minYear) {
        data = await this.loadVehicleData(vehicle.year - 1);
        match = this._findModelData(data, vehicle);
        if (match) vehicle.year = vehicle.year - 1;
      }

      if (!match) return [];

      vehicle.make = match.makeKey || vehicle.make;
      vehicle.model = match.modelKey || vehicle.model;
      var modelData = match.modelData;

      /* If a trim was specified, filter to matching trims only */
      var trims = [];
      if (vehicle.trim) {
        var trimLower = vehicle.trim.toLowerCase();
        for (var [trimName, sizes] of Object.entries(modelData)) {
          if (Array.isArray(sizes) && sizes.length > 0) {
            var tn = trimName.toLowerCase();
            if (tn === trimLower || tn.includes(trimLower) || trimLower.includes(tn)) {
              trims.push({ trim: trimName, size: sizes[0], allSizes: sizes });
            }
          }
        }
      }

      /* If no trim specified or no match found, return all trims */
      if (trims.length === 0) {
        for (var [trimName, sizes] of Object.entries(modelData)) {
          if (Array.isArray(sizes) && sizes.length > 0) {
            trims.push({ trim: trimName, size: sizes[0], allSizes: sizes });
          }
        }
      }
      return trims;
    }

    renderTrimResults(vehicleLabel, trims, intent) {
      this.loading.hidden = true;
      intent = intent || {};

      const seasonBadge = intent.season ? ' <span class="hero-smart-search__intent-badge">' + this.escapeHtml(intent.season) + '</span>' : '';
      const brandBadge = intent.brand ? ' <span class="hero-smart-search__intent-badge">' + this.escapeHtml(intent.brand) + '</span>' : '';

      let html = '<li class="hero-smart-search__trim-header">' +
        '<span class="hero-smart-search__trim-vehicle">' + this.escapeHtml(vehicleLabel) + seasonBadge + brandBadge + '</span>' +
        '<span class="hero-smart-search__trim-label">Choose your trim</span>' +
      '</li>';

      html += trims.map((t, i) => {
        const url = this.buildCollectionUrl({ tireSize: t.size, brand: intent.brand, season: intent.season });
        const sizeLabel = t.allSizes && t.allSizes.length > 1
          ? t.allSizes.slice(0, 2).join(' / ') + (t.allSizes.length > 2 ? ' +' + (t.allSizes.length - 2) : '')
          : t.size;
        return '<li class="hero-smart-search__trim-row" role="option" data-index="' + i + '" data-url="' + this.escapeAttr(url) + '">' +
          '<span class="hero-smart-search__trim-name">' + this.escapeHtml(t.trim) + '</span>' +
          '<span class="hero-smart-search__trim-size">' + this.escapeHtml(sizeLabel) + '</span>' +
        '</li>';
      }).join('');

      this.list.innerHTML = html;

      this.items = this.list.querySelectorAll('.hero-smart-search__trim-row');
      this.items.forEach(item => {
        item.addEventListener('click', () => this.selectResult(item));
      });

      this.awaitingTrim = true;
      this.selectedIndex = -1;
      this.results.hidden = false;
      this.input.setAttribute('aria-expanded', 'true');
    }

    showLoading() {
      this.results.hidden = false;
      this.loading.hidden = false;
      this.list.innerHTML = '';
      this.input.setAttribute('aria-expanded', 'true');
    }

    renderResults(results) {
      this.loading.hidden = true;
      this.awaitingTrim = false;
      this.awaitingSelection = false;

      if (results.length === 0) {
        this.hideResults();
        return;
      }

      this.list.innerHTML = results.map((r, i) =>
        '<li class="hero-smart-search__result-item" role="option" data-index="' + i + '" data-url="' + this.escapeAttr(r.url) + '">' +
          '<span class="hero-smart-search__result-icon">' +
            (r.type === 'size' ? this.tireIcon() : r.type === 'vehicle' ? this.vehicleIcon() : this.searchIcon()) +
          '</span>' +
          '<span class="hero-smart-search__result-info">' +
            '<span class="hero-smart-search__result-title">' + this.escapeHtml(r.title) + '</span>' +
            '<span class="hero-smart-search__result-meta">' + this.escapeHtml(r.meta) + '</span>' +
          '</span>' +
          '<span class="hero-smart-search__result-tag">' +
            (r.type === 'size' ? 'Size' : r.type === 'vehicle' ? 'Vehicle' : 'Search') +
          '</span>' +
        '</li>'
      ).join('');

      this.items = this.list.querySelectorAll('.hero-smart-search__result-item');
      this.items.forEach(item => {
        item.addEventListener('click', () => this.selectResult(item));
      });

      this.awaitingSelection = true;
      this.selectedIndex = -1;
      this.results.hidden = false;
      this.input.setAttribute('aria-expanded', 'true');
    }

    hideResults() {
      this.results.hidden = true;
      this.loading.hidden = true;
      this.input.setAttribute('aria-expanded', 'false');
      this.selectedIndex = -1;
      this.awaitingTrim = false;
      this.awaitingSelection = false;
    }

    highlightItem() {
      this.items.forEach((item, i) => {
        item.setAttribute('aria-selected', i === this.selectedIndex ? 'true' : 'false');
      });
      if (this.selectedIndex >= 0) {
        this.items[this.selectedIndex].scrollIntoView({ block: 'nearest' });
      }
    }

    selectResult(item) {
      this.awaitingTrim = false;
      this.awaitingSelection = false;
      const url = item.dataset.url;
      if (url) window.location.href = url;
    }

    showPrompt(message) {
      const existing = this.list.querySelector('.hero-smart-search__trim-prompt');
      if (existing) {
        existing.textContent = message;
        existing.classList.remove('hero-smart-search__trim-prompt--shake');
        void existing.offsetWidth; /* reflow to restart animation */
        existing.classList.add('hero-smart-search__trim-prompt--shake');
        return;
      }
      const li = document.createElement('li');
      li.className = 'hero-smart-search__trim-prompt';
      li.setAttribute('aria-live', 'polite');
      li.textContent = message;
      this.list.appendChild(li);
    }

    onKeydown(e) {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (!this.items.length) return;
        this.selectedIndex = Math.min(this.selectedIndex + 1, this.items.length - 1);
        this.highlightItem();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (!this.items.length) return;
        this.selectedIndex = Math.max(this.selectedIndex - 1, 0);
        this.highlightItem();
      } else if (e.key === 'Enter') {
        e.preventDefault();
        if (this.selectedIndex >= 0 && this.items[this.selectedIndex]) {
          this.selectResult(this.items[this.selectedIndex]);
        } else if (this.awaitingTrim) {
          this.showPrompt('Please select your car trim above');
        } else {
          this.onSubmit();
        }
      } else if (e.key === 'Escape') {
        this.hideResults();
      }
    }

    onSubmit() {
      if (this.awaitingTrim) {
        this.showPrompt('Please select your car trim above');
        return;
      }

      const query = this.input.value.trim();
      if (!query) return;

      const parsed = this.normalizeTireSize(query);
      const intent = this.parseSearchIntent(query);

      if (parsed) {
        window.location.href = this.buildCollectionUrl({
          width: parsed.width,
          aspect: parsed.aspect,
          rim: parsed.rim,
          brand: intent.brand,
          season: intent.season,
        });
      } else if (intent.brand || intent.season) {
        window.location.href = this.buildCollectionUrl({
          brand: intent.brand,
          season: intent.season,
        });
      } else {
        this.showFallback(query);
      }
    }

    showFallback(query) {
      const phone = this.config.fallbackPhone || '403 452 4283';
      const phoneClean = phone.replace(/\s/g, '');
      this.loading.hidden = true;
      this.awaitingTrim = false;
      this.awaitingSelection = false;

      this.list.innerHTML =
        '<li class="hero-smart-search__fallback">' +
          '<span class="hero-smart-search__fallback-icon">' + this.phoneIcon() + '</span>' +
          '<span class="hero-smart-search__fallback-text">' +
            '<span class="hero-smart-search__fallback-title">We couldn\'t find a match</span>' +
            '<span class="hero-smart-search__fallback-sub">Reach out to our office &mdash; we\'ll help you find the right tire</span>' +
          '</span>' +
          '<a href="tel:' + phoneClean + '" class="hero-smart-search__fallback-phone">' + phone + '</a>' +
        '</li>';

      this.items = [];
      this.selectedIndex = -1;
      this.results.hidden = false;
      this.input.setAttribute('aria-expanded', 'true');
    }

    tireIcon() {
      return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="6" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="2" fill="currentColor"/></svg>';
    }

    vehicleIcon() {
