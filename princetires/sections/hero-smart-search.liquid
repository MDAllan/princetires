<div
  class="hero-smart-search"
  style="
    --hero-bg: {{ section.settings.background_color }};
    --hero-accent: {{ section.settings.accent_color }};
    --hero-text: {{ section.settings.text_color }};
    --hero-subtitle-opacity: {{ section.settings.subtitle_opacity | divided_by: 100.0 }};
  "
>
  {%- assign slide_blocks = section.blocks | where: 'type', 'slide_image' -%}

  {%- if slide_blocks.size > 0 -%}
    <div
      class="hero-smart-search__slideshow"
      data-hero-slideshow
      data-direction="{{ section.settings.slideshow_direction | default: 'up' }}"
      data-interval="{{ section.settings.slideshow_interval_s | default: 5 | times: 1000 }}"
      aria-hidden="true"
    >
      {%- for block in slide_blocks -%}
        {%- if block.settings.image != blank -%}
          <picture class="hero-smart-search__slide-pic">
            {%- if block.settings.mobile_image != blank -%}
              <source
                media="(max-width: 768px)"
                srcset="{{ block.settings.mobile_image | image_url: width: 600 }} 600w, {{ block.settings.mobile_image | image_url: width: 900 }} 900w, {{ block.settings.mobile_image | image_url: width: 1200 }} 1200w"
                sizes="100vw"
              >
            {%- endif -%}
            <img
              class="hero-smart-search__slide{% if forloop.first %} is-active{% endif %}"
              src="{{ block.settings.image | image_url: width: 2400 }}"
              srcset="{{ block.settings.image | image_url: width: 900 }} 900w, {{ block.settings.image | image_url: width: 1400 }} 1400w, {{ block.settings.image | image_url: width: 2000 }} 2000w, {{ block.settings.image | image_url: width: 2400 }} 2400w"
              sizes="100vw"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              alt=""
              {{ block.shopify_attributes }}
            >
          </picture>
        {%- endif -%}
      {%- endfor -%}
      <div
        class="hero-smart-search__slideshow-overlay"
        style="--hero-overlay-opacity: {{ section.settings.slideshow_overlay_opacity | default: 60 | divided_by: 100.0 }};"
      ></div>
    </div>
  {%- elsif section.settings.hero_3d_scene_url != blank -%}
    <div class="hero-smart-search__spline" aria-hidden="true">
      <spline-viewer
        url="{{ section.settings.hero_3d_scene_url }}"
        loading-anim-type="spinner-small-light"
        events-target="global"
      ></spline-viewer>
    </div>
  {%- endif -%}

  <div class="hero-smart-search__container">
    <div class="hero-smart-search__content">
      {%- if section.settings.heading != blank -%}
        <h1 class="hero-smart-search__heading aeo-speakable-title" data-hero-heading>
          <span class="hero-smart-search__heading-left" data-hero-left>{{ section.settings.heading }}</span>
          {%- if section.settings.heading_accent != blank -%}
            <span class="hero-smart-search__heading-right" data-hero-right>{{ section.settings.heading_accent }}</span>
          {%- endif -%}
        </h1>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="hero-smart-search__subtitle aeo-speakable-summary">
          {{ section.settings.subtitle }}
        </p>
      {%- endif -%}

      <div class="hero-smart-search__search-wrapper">
        <div class="hero-smart-search__badge">
          <span class="hero-smart-search__badge-dot"></span>
          {{ 'sections.hero_smart_search.powered_by' | t }}
          <strong>{{ 'sections.hero_smart_search.smart_search' | t }}</strong>
        </div>

        <div class="hero-smart-search__search" data-smart-search>
          <div class="hero-smart-search__input-wrapper">
            <input
              type="text"
              class="hero-smart-search__input"
              data-smart-search-input
              placeholder=""
              autocomplete="off"
              aria-label="{{ 'sections.hero_smart_search.search_label' | t }}"
              aria-expanded="false"
              aria-controls="smart-search-results"
              role="combobox"
            >
            <span class="hero-smart-search__typewriter" data-typewriter aria-hidden="true"></span>
            <button
              class="hero-smart-search__submit"
              data-smart-search-submit
              aria-label="{{ 'sections.hero_smart_search.search_submit' | t }}"
            >
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>

          <div class="hero-smart-search__results" id="smart-search-results" data-smart-search-results hidden>
            <div class="hero-smart-search__loading" data-smart-search-loading hidden>
              <span class="hero-smart-search__spinner"></span>
              <span>{{ 'sections.hero_smart_search.ai_thinking' | t }}</span>
            </div>
            <ul class="hero-smart-search__results-list" role="listbox" data-smart-search-list></ul>
          </div>
        </div>
      </div>

      {%- comment -%}
        Action buttons: Book service + the hardcoded phone link both removed —
        the new mobile sticky bar carries those CTAs (and on desktop the
        header phone icon does). Other action blocks (tire search, wheel
        search, etc) are still rendered as before.
      {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        {%- assign visible_block_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.action != 'book_service'
             and block.settings.label != blank
             and block.settings.icon != 'phone' -%}
            {%- assign visible_block_count = visible_block_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if visible_block_count > 0 -%}
          <div class="hero-smart-search__actions">
            {%- for block in section.blocks -%}
              {%- if block.settings.action == 'book_service' -%}{%- continue -%}{%- endif -%}
              {%- if block.settings.label == blank -%}{%- continue -%}{%- endif -%}
              {%- if block.settings.icon == 'phone' -%}{%- continue -%}{%- endif -%}

              <a
                href="{% if block.settings.link != blank %}{{ block.settings.link }}{% else %}#{% endif %}"
                class="hero-smart-search__btn"
                {{ block.shopify_attributes }}
              >
                {%- case block.settings.icon -%}
                  {%- when 'tire' -%}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                      <circle cx="12" cy="12" r="6" stroke="currentColor" stroke-width="1.5"/>
                      <circle cx="12" cy="12" r="2" fill="currentColor"/>
                    </svg>
                  {%- when 'wheel' -%}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                      <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                      <path d="M12 2V9M12 15V22M2 12H9M15 12H22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  {%- when 'calendar' -%}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
                      <path d="M16 2V6M8 2V6M3 10H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  {%- else -%}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                {%- endcase -%}
                {{ block.settings.label | escape }}
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</div>

{%- comment -%}
  Config block — passes Liquid values to JavaScript since
  Liquid can't render inside {% javascript %} tags.
{%- endcomment -%}
<script data-smart-search-config type="application/json">
  {
    "geminiKey": {{ settings.gemini_api_key | json }},
    "minYear": {{ settings.smart_search_min_year | default: 2001 }},
    "maxYear": {{ settings.smart_search_max_year | default: 2026 }},
    "assetUrlBase": {{ 'pt-vehicle-2025.json' | asset_url | split: 'pt-vehicle-2025.json' | first | json }},
    "fallbackPhone": {{ settings.smart_search_fallback_phone | default: '403 452 4283' | json }}
  }
</script>

{%- if section.settings.hero_3d_scene_url != blank -%}
  <script
    type="module"
    src="https://unpkg.com/@splinetool/viewer@1.9.71/build/spline-viewer.js"
    defer
  ></script>
{%- endif -%}

{% stylesheet %}
  .hero-smart-search {
    background-color: var(--hero-bg, #000000);
    color: var(--hero-text, #ffffff);
    /* True vertical center, with bottom padding 40px heavier than top —
       shifts the centroid ~20px upward as requested. */
    padding: 4rem 2rem 6.5rem;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  /* ── 3D Spline scene (optional background) ── */
  .hero-smart-search__spline {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.65;
    mix-blend-mode: screen;
  }
  .hero-smart-search__spline spline-viewer,
  .hero-smart-search__spline canvas {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }
  /* Dim further on small screens so the search bar stays legible */
  @media (max-width: 749px) {
    .hero-smart-search__spline { opacity: 0.45; }
  }
  /* Honor user motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .hero-smart-search__spline { display: none; }
  }

  /* ── Slideshow background (optional, replaces Spline if both set) ── */
  .hero-smart-search__slideshow {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  /* <picture> wrapper sits in normal flow but is invisible — only the img renders */
  .hero-smart-search__slide-pic { display: contents; }
  .hero-smart-search__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transform: scale(1) rotateX(0deg);
    transform-origin: center;
    will-change: transform, opacity;
  }
  .hero-smart-search__slide.is-entering {
    animation: hero-slide-in 0.55s cubic-bezier(0.645, 0.045, 0.355, 1.0) forwards;
  }
  .hero-smart-search__slide.is-active {
    opacity: 1;
    z-index: 1;
  }
  /* Ken Burns — slow zoom while a slide is active. Only kicks in after the
     entry animation finishes (the :not(.is-entering) gate). 7s zoom matches
     the default 5s slide interval + 2s tail for a soft motion bed. */
  .hero-smart-search__slide.is-active:not(.is-entering):not(.is-leaving) {
    animation: hero-ken-burns 7s cubic-bezier(0.16, 0.6, 0.3, 1.0) forwards;
  }
  .hero-smart-search__slide.is-leaving {
    z-index: 1;
    opacity: 1;
    animation: hero-slide-out-up 1.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  .hero-smart-search__slideshow[data-direction="down"] .hero-smart-search__slide.is-leaving {
    animation-name: hero-slide-out-down;
  }
  @keyframes hero-slide-in {
    from { opacity: 0; transform: scale(0.4) rotateX(45deg); }
    to   { opacity: 1; transform: scale(1) rotateX(0deg); }
  }
  @keyframes hero-ken-burns {
    from { transform: scale(1)    rotateX(0deg); }
    to   { transform: scale(1.07) rotateX(0deg); }
  }
  /* Softer exits: shorter travel + opacity fade so the image dissolves
     instead of hard-dropping. Reads gracefully on mobile. */
  @keyframes hero-slide-out-up {
    0%   { opacity: 1; transform: translateY(0)    scale(1.07); }
    60%  { opacity: 0.6; }
    100% { opacity: 0; transform: translateY(-40%) scale(1.10); }
  }
  @keyframes hero-slide-out-down {
    0%   { opacity: 1; transform: translateY(0)   scale(1.07); }
    60%  { opacity: 0.6; }
    100% { opacity: 0; transform: translateY(40%) scale(1.10); }
  }
  .hero-smart-search__slideshow-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--hero-overlay-opacity, 0.6));
    z-index: 2;
    pointer-events: none;
  }
  /* Reduced-motion: skip animations, just show the active slide */
  @media (prefers-reduced-motion: reduce) {
    .hero-smart-search__slide.is-entering,
    .hero-smart-search__slide.is-leaving {
      animation: none;
    }
    .hero-smart-search__slide:not(.is-active) { display: none; }
  }
  .hero-smart-search__container {
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-smart-search__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-smart-search__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(3rem, 4.5vw, 4.2rem);
    font-weight: 600;
    line-height: 1.1;
    margin: 0 0 1rem;
    letter-spacing: 0.06em;
    color: var(--hero-text, #ffffff);
    text-transform: uppercase;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3em;
    overflow: hidden;
  }

  .hero-smart-search__heading-left,
  .hero-smart-search__heading-right {
    display: inline-block;
    opacity: 0;
    animation: hero-fallback 0s 2.5s forwards;
  }

  .hero-smart-search__heading-left {
    transform: translateX(-120%);
  }

  .hero-smart-search__heading-right {
    color: var(--hero-accent, #DC2626);
    transform: translateX(120%);
  }

  @keyframes hero-fallback {
    to { opacity: 1; transform: translateX(0); }
  }

  .hero-smart-search__heading-left.is-animated {
    animation: hero-slide-left 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-smart-search__heading-right.is-animated {
    animation: hero-slide-right 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.08s forwards;
  }

  @keyframes hero-slide-left {
    0% { transform: translateX(-120%); opacity: 0; filter: blur(8px); }
    60% { filter: blur(2px); }
    100% { transform: translateX(0); opacity: 1; filter: blur(0); }
  }

  @keyframes hero-slide-right {
    0% { transform: translateX(120%); opacity: 0; filter: blur(8px); }
    60% { filter: blur(2px); }
    100% { transform: translateX(0); opacity: 1; filter: blur(0); }
  }


  .hero-smart-search__subtitle {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    margin: 0 0 4rem;
    color: #6B7280;
    font-weight: 300;
    letter-spacing: 0.04em;
  }

  .hero-smart-search__search-wrapper {
    margin-bottom: 2.4rem;
    width: 100%;
    max-width: 48rem;
  }

  .hero-smart-search__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.1rem;
    padding: 0.4rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 2rem;
    margin-bottom: 1.2rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
  }

  .hero-smart-search__badge-dot {
    width: 7px;
    height: 7px;
    background: #F5820B;
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 6px rgba(245, 130, 11, 0.5);
  }

  .hero-smart-search__search {
    position: relative;
  }

  .hero-smart-search__input-wrapper {
    display: flex;
    align-items: center;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 3px;
    overflow: visible;
    transition: border-color 0.2s ease;
    position: relative;
    isolation: isolate;
  }

  @keyframes hero-search-fade-in {
    0% { opacity: 0; transform: translateY(10px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .hero-smart-search__input-wrapper::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 4px;
    background: linear-gradient(90deg, #525252, #525252, #dc2626, #F5820B, #525252, #525252);
    background-size: 300% 100%;
    z-index: -1;
    animation: hero-border-shimmer 4s ease-in-out infinite;
  }

  .hero-smart-search__input-wrapper::after {
    content: '';
    position: absolute;
    inset: 0px;
    border-radius: 2px;
    background: #000;
    z-index: -1;
  }

  @keyframes hero-border-shimmer {
    0% { background-position: 100% 0; }
    50% { background-position: 0% 0; }
    100% { background-position: 100% 0; }
  }

  .hero-smart-search__input-wrapper:focus-within::before {
    background: linear-gradient(90deg, #dc2626, #F5820B, #dc2626, #F5820B, #dc2626);
    background-size: 300% 100%;
  }

  .hero-smart-search__input {
    flex: 1;
    background: none;
    border: none;
    padding: 1.4rem 2rem;
    font-size: 1.4rem;
    color: var(--hero-text, #ffffff);
    outline: none;
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
  }

  .hero-smart-search__input::placeholder {
    color: #6B7280;
  }

  .hero-smart-search__typewriter {
    position: absolute;
    left: 2rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 300;
    color: #6B7280;
    pointer-events: none;
    white-space: nowrap;
    overflow: hidden;
  }

  .hero-smart-search__typewriter::after {
    content: '|';
    animation: hero-cursor-blink 0.7s step-end infinite;
    color: #F5820B;
    font-weight: 300;
    margin-left: 1px;
  }

  .hero-smart-search__typewriter.is-hidden {
    display: none;
  }

  @keyframes hero-cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-smart-search__submit {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4.4rem;
    height: 4.4rem;
    margin: 0.3rem;
    background: var(--hero-accent, #DC2626);
    color: #ffffff;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    transition: opacity 0.2s ease;
    flex-shrink: 0;
  }

  .hero-smart-search__submit:hover {
    opacity: 0.85;
  }

  .hero-smart-search__results {
    position: absolute;
    top: calc(100% + 0.6rem);
    left: 0;
    right: 0;
    background: #2a2a2a;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    max-height: 32rem;
    overflow-y: auto;
    z-index: 100;
    box-shadow: 0 1.2rem 3.2rem rgba(0, 0, 0, 0.4);
  }

  .hero-smart-search__results[hidden] {
    display: none;
  }

  .hero-smart-search__results-list {
    list-style: none;
    margin: 0;
    padding: 0.6rem;
  }

  .hero-smart-search__loading {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.4rem 1.6rem;
    font-size: 1.3rem;
    opacity: 0.7;
    color: var(--hero-text, #ffffff);
  }

  .hero-smart-search__loading[hidden] {
    display: none;
  }

  .hero-smart-search__spinner {
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-top-color: var(--hero-accent, #c0392b);
    border-radius: 50%;
    animation: smart-search-spin 0.6s linear infinite;
  }

  @keyframes smart-search-spin {
    to { transform: rotate(360deg); }
  }

  .hero-smart-search__result-item {
    padding: 1.2rem 1.4rem;
    border-radius: 3px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 1.2rem;
    font-size: 1.4rem;
    transition: background 0.15s ease;
    color: var(--hero-text, #ffffff);
  }

  .hero-smart-search__result-item:hover,
  .hero-smart-search__result-item[aria-selected="true"] {
    background: rgba(255, 255, 255, 0.08);
  }

  .hero-smart-search__result-icon {
    width: 3.2rem;
    height: 3.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.6rem;
    background: rgba(255, 255, 255, 0.06);
    flex-shrink: 0;
  }

  .hero-smart-search__result-info {
    flex: 1;
    min-width: 0;
  }

  .hero-smart-search__result-title {
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .hero-smart-search__result-meta {
    font-size: 1.2rem;
    opacity: 0.5;
    margin-top: 0.2rem;
  }

  .hero-smart-search__result-tag {
    font-size: 1.1rem;
    padding: 0.2rem 0.6rem;
    border-radius: 0.4rem;
    background: rgba(255, 255, 255, 0.08);
    opacity: 0.6;
    flex-shrink: 0;
  }

  .hero-smart-search__error {
    padding: 1.2rem 1.6rem;
    font-size: 1.3rem;
    opacity: 0.6;
    color: var(--hero-text, #ffffff);
  }

  .hero-smart-search__fallback {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.4rem 1.6rem;
    list-style: none;
  }

  .hero-smart-search__fallback-icon {
    flex-shrink: 0;
    width: 3.6rem;
    height: 3.6rem;
    background: rgba(245, 130, 11, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #F5820B;
  }

  .hero-smart-search__fallback-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
  }

  .hero-smart-search__fallback-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 600;
    color: #fff;
  }

  .hero-smart-search__fallback-sub {
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    color: #6B7280;
  }

  .hero-smart-search__fallback-phone {
    flex-shrink: 0;
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #F5820B;
    text-decoration: none;
    white-space: nowrap;
    padding: 0.4rem 1rem;
    border: 1px solid rgba(245, 130, 11, 0.35);
    border-radius: 4px;
