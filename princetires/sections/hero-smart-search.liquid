<div
  class="hero-smart-search"
  style="
    --hero-bg: {{ section.settings.background_color }};
    --hero-accent: {{ section.settings.accent_color }};
    --hero-text: {{ section.settings.text_color }};
    --hero-subtitle-opacity: {{ section.settings.subtitle_opacity | divided_by: 100.0 }};
  "
>
  <div class="hero-smart-search__container">
    <div class="hero-smart-search__content">
      {%- if section.settings.heading != blank -%}
        <h1 class="hero-smart-search__heading aeo-speakable-title" data-hero-heading>
          <span class="hero-smart-search__heading-left" data-hero-left>{{ section.settings.heading }}</span>
          {%- if section.settings.heading_accent != blank -%}
            <span class="hero-smart-search__heading-right" data-hero-right>{{ section.settings.heading_accent }}</span>
          {%- endif -%}
        </h1>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="hero-smart-search__subtitle aeo-speakable-summary">
          {{ section.settings.subtitle }}
        </p>
      {%- endif -%}

      <div class="hero-smart-search__search-wrapper">
        <div class="hero-smart-search__badge">
          <span class="hero-smart-search__badge-dot"></span>
          {{ 'sections.hero_smart_search.powered_by' | t }}
          <strong>{{ 'sections.hero_smart_search.smart_search' | t }}</strong>
        </div>

        <div class="hero-smart-search__search" data-smart-search>
          <div class="hero-smart-search__input-wrapper">
            <input
              type="text"
              class="hero-smart-search__input"
              data-smart-search-input
              placeholder=""
              autocomplete="off"
              aria-label="{{ 'sections.hero_smart_search.search_label' | t }}"
              aria-expanded="false"
              aria-controls="smart-search-results"
              role="combobox"
            >
            <span class="hero-smart-search__typewriter" data-typewriter aria-hidden="true"></span>
            <button
              class="hero-smart-search__submit"
              data-smart-search-submit
              aria-label="{{ 'sections.hero_smart_search.search_submit' | t }}"
            >
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>

          <div class="hero-smart-search__results" id="smart-search-results" data-smart-search-results hidden>
            <div class="hero-smart-search__loading" data-smart-search-loading hidden>
              <span class="hero-smart-search__spinner"></span>
              <span>{{ 'sections.hero_smart_search.ai_thinking' | t }}</span>
            </div>
            <ul class="hero-smart-search__results-list" role="listbox" data-smart-search-list></ul>
          </div>
        </div>
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="hero-smart-search__actions">
          {%- for block in section.blocks -%}
            {%- if block.settings.label != blank -%}
              {%- assign is_service_trigger = false -%}
              {%- if block.settings.action == 'book_service' -%}
                {%- assign is_service_trigger = true -%}
              {%- endif -%}

              {%- if is_service_trigger -%}
                <button
                  class="hero-smart-search__btn"
                  data-book-service
                  {{ block.shopify_attributes }}
                >
              {%- else -%}
                <a
                  href="{% if block.settings.phone != blank %}tel:{{ block.settings.phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' }}{% elsif block.settings.link != blank %}{{ block.settings.link }}{% else %}#{% endif %}"
                  class="hero-smart-search__btn"
                  {{ block.shopify_attributes }}
                >
              {%- endif -%}

                {%- case block.settings.icon -%}
                  {%- when 'tire' -%}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                      <circle cx="12" cy="12" r="6" stroke="currentColor" stroke-width="1.5"/>
                      <circle cx="12" cy="12" r="2" fill="currentColor"/>
                    </svg>
                  {%- when 'wheel' -%}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                      <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                      <path d="M12 2V9M12 15V22M2 12H9M15 12H22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  {%- when 'phone' -%}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M22 16.92V19.92C22 20.48 21.56 20.93 21 20.97C20.66 21 20.33 21.01 20 21.01C10.61 21.01 3 13.4 3 3.97C3 3.64 3.01 3.31 3.03 2.97C3.07 2.41 3.52 1.97 4.08 1.97H7.08C7.56 1.97 7.97 2.33 8.03 2.81C8.09 3.33 8.2 3.84 8.37 4.33C8.52 4.76 8.41 5.24 8.08 5.57L6.62 7.03C8.06 9.78 10.22 11.94 12.97 13.38L14.43 11.92C14.76 11.59 15.24 11.48 15.67 11.63C16.16 11.8 16.67 11.91 17.19 11.97C17.67 12.03 18.03 12.44 18.03 12.92V16.92H22Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {%- when 'calendar' -%}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
                      <path d="M16 2V6M8 2V6M3 10H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  {%- else -%}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                {%- endcase -%}
                {{ block.settings.label | escape }}

              {%- if is_service_trigger -%}
                </button>
              {%- else -%}
                </a>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{%- comment -%}
  Config block — passes Liquid values to JavaScript since
  Liquid can't render inside {% javascript %} tags.
{%- endcomment -%}
<script data-smart-search-config type="application/json">
  {
    "geminiKey": {{ settings.gemini_api_key | json }},
    "minYear": {{ settings.smart_search_min_year | default: 2001 }},
    "maxYear": {{ settings.smart_search_max_year | default: 2026 }},
    "assetUrlBase": {{ 'pt-vehicle-2025.json' | asset_url | split: 'pt-vehicle-2025.json' | first | json }},
    "fallbackPhone": {{ settings.smart_search_fallback_phone | default: '403 452 4283' | json }}
  }
</script>

{% stylesheet %}
  .hero-smart-search {
    background-color: var(--hero-bg, #000000);
    color: var(--hero-text, #ffffff);
    padding: 0 2rem 8rem;
    min-height: 85vh;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .hero-smart-search__container {
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
  }

  .hero-smart-search__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-smart-search__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(3rem, 4.5vw, 4.2rem);
    font-weight: 600;
    line-height: 1.1;
    margin: 0 0 1rem;
    letter-spacing: 0.06em;
    color: var(--hero-text, #ffffff);
    text-transform: uppercase;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3em;
    overflow: hidden;
  }

  .hero-smart-search__heading-left,
  .hero-smart-search__heading-right {
    display: inline-block;
    opacity: 0;
    animation: hero-fallback 0s 2.5s forwards;
  }

  .hero-smart-search__heading-left {
    transform: translateX(-120%);
  }

  .hero-smart-search__heading-right {
    color: var(--hero-accent, #DC2626);
    transform: translateX(120%);
  }

  @keyframes hero-fallback {
    to { opacity: 1; transform: translateX(0); }
  }

  .hero-smart-search__heading-left.is-animated {
    animation: hero-slide-left 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-smart-search__heading-right.is-animated {
    animation: hero-slide-right 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.08s forwards;
  }

  @keyframes hero-slide-left {
    0% { transform: translateX(-120%); opacity: 0; filter: blur(8px); }
    60% { filter: blur(2px); }
    100% { transform: translateX(0); opacity: 1; filter: blur(0); }
  }

  @keyframes hero-slide-right {
    0% { transform: translateX(120%); opacity: 0; filter: blur(8px); }
    60% { filter: blur(2px); }
    100% { transform: translateX(0); opacity: 1; filter: blur(0); }
  }


  .hero-smart-search__subtitle {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    margin: 0 0 4rem;
    color: #6B7280;
    font-weight: 300;
    letter-spacing: 0.04em;
  }

  .hero-smart-search__search-wrapper {
    margin-bottom: 2.4rem;
    width: 100%;
    max-width: 48rem;
  }

  .hero-smart-search__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.1rem;
    padding: 0.4rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 2rem;
    margin-bottom: 1.2rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
  }

  .hero-smart-search__badge-dot {
    width: 7px;
    height: 7px;
    background: #F5820B;
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 6px rgba(245, 130, 11, 0.5);
  }

  .hero-smart-search__search {
    position: relative;
  }

  .hero-smart-search__input-wrapper {
    display: flex;
    align-items: center;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 3px;
    overflow: visible;
    transition: border-color 0.2s ease;
    position: relative;
    isolation: isolate;
  }

  @keyframes hero-search-fade-in {
    0% { opacity: 0; transform: translateY(10px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .hero-smart-search__input-wrapper::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 4px;
    background: linear-gradient(90deg, #525252, #525252, #dc2626, #F5820B, #525252, #525252);
    background-size: 300% 100%;
    z-index: -1;
    animation: hero-border-shimmer 4s ease-in-out infinite;
  }

  .hero-smart-search__input-wrapper::after {
    content: '';
    position: absolute;
    inset: 0px;
    border-radius: 2px;
    background: #000;
    z-index: -1;
  }

  @keyframes hero-border-shimmer {
    0% { background-position: 100% 0; }
    50% { background-position: 0% 0; }
    100% { background-position: 100% 0; }
  }

  .hero-smart-search__input-wrapper:focus-within::before {
    background: linear-gradient(90deg, #dc2626, #F5820B, #dc2626, #F5820B, #dc2626);
    background-size: 300% 100%;
  }

  .hero-smart-search__input {
    flex: 1;
    background: none;
    border: none;
    padding: 1.4rem 2rem;
    font-size: 1.4rem;
    color: var(--hero-text, #ffffff);
    outline: none;
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
  }

  .hero-smart-search__input::placeholder {
    color: #6B7280;
  }

  .hero-smart-search__typewriter {
    position: absolute;
    left: 2rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 300;
    color: #6B7280;
    pointer-events: none;
    white-space: nowrap;
    overflow: hidden;
  }

  .hero-smart-search__typewriter::after {
    content: '|';
    animation: hero-cursor-blink 0.7s step-end infinite;
    color: #F5820B;
    font-weight: 300;
    margin-left: 1px;
  }

  .hero-smart-search__typewriter.is-hidden {
    display: none;
  }

  @keyframes hero-cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-smart-search__submit {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4.4rem;
    height: 4.4rem;
    margin: 0.3rem;
    background: var(--hero-accent, #DC2626);
    color: #ffffff;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    transition: opacity 0.2s ease;
    flex-shrink: 0;
  }

  .hero-smart-search__submit:hover {
    opacity: 0.85;
  }

  .hero-smart-search__results {
    position: absolute;
    top: calc(100% + 0.6rem);
    left: 0;
    right: 0;
    background: #2a2a2a;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    max-height: 32rem;
    overflow-y: auto;
    z-index: 100;
    box-shadow: 0 1.2rem 3.2rem rgba(0, 0, 0, 0.4);
  }

  .hero-smart-search__results[hidden] {
    display: none;
  }

  .hero-smart-search__results-list {
    list-style: none;
    margin: 0;
    padding: 0.6rem;
  }

  .hero-smart-search__loading {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.4rem 1.6rem;
    font-size: 1.3rem;
    opacity: 0.7;
    color: var(--hero-text, #ffffff);
  }

  .hero-smart-search__loading[hidden] {
    display: none;
  }

  .hero-smart-search__spinner {
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-top-color: var(--hero-accent, #c0392b);
    border-radius: 50%;
    animation: smart-search-spin 0.6s linear infinite;
  }

  @keyframes smart-search-spin {
    to { transform: rotate(360deg); }
  }

  .hero-smart-search__result-item {
    padding: 1.2rem 1.4rem;
    border-radius: 3px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 1.2rem;
    font-size: 1.4rem;
    transition: background 0.15s ease;
    color: var(--hero-text, #ffffff);
  }

  .hero-smart-search__result-item:hover,
  .hero-smart-search__result-item[aria-selected="true"] {
    background: rgba(255, 255, 255, 0.08);
  }

  .hero-smart-search__result-icon {
    width: 3.2rem;
    height: 3.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.6rem;
    background: rgba(255, 255, 255, 0.06);
    flex-shrink: 0;
  }

  .hero-smart-search__result-info {
    flex: 1;
    min-width: 0;
  }

  .hero-smart-search__result-title {
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .hero-smart-search__result-meta {
    font-size: 1.2rem;
    opacity: 0.5;
    margin-top: 0.2rem;
  }

  .hero-smart-search__result-tag {
    font-size: 1.1rem;
    padding: 0.2rem 0.6rem;
    border-radius: 0.4rem;
    background: rgba(255, 255, 255, 0.08);
    opacity: 0.6;
    flex-shrink: 0;
  }

  .hero-smart-search__error {
    padding: 1.2rem 1.6rem;
    font-size: 1.3rem;
    opacity: 0.6;
    color: var(--hero-text, #ffffff);
  }

  .hero-smart-search__fallback {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.4rem 1.6rem;
    list-style: none;
  }

  .hero-smart-search__fallback-icon {
    flex-shrink: 0;
    width: 3.6rem;
    height: 3.6rem;
    background: rgba(245, 130, 11, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #F5820B;
  }

  .hero-smart-search__fallback-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
  }

  .hero-smart-search__fallback-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 600;
    color: #fff;
  }

  .hero-smart-search__fallback-sub {
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    color: #6B7280;
  }

  .hero-smart-search__fallback-phone {
    flex-shrink: 0;
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #F5820B;
    text-decoration: none;
    white-space: nowrap;
    padding: 0.4rem 1rem;
    border: 1px solid rgba(245, 130, 11, 0.35);
    border-radius: 4px;
    transition: background 0.15s;
  }

  .hero-smart-search__fallback-phone:hover {
    background: rgba(245, 130, 11, 0.1);
  }

  .hero-smart-search__trim-prompt {
    padding: 0.8rem 1.4rem;
    font-size: 1.2rem;
    font-family: 'Outfit', sans-serif;
    color: #F5820B;
    border-top: 1px solid rgba(245, 130, 11, 0.2);
    background: rgba(245, 130, 11, 0.06);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-smart-search__trim-prompt::before {
    content: '↑';
    font-size: 1rem;
    opacity: 0.8;
  }

  .hero-smart-search__trim-prompt--shake {
    animation: hero-trim-shake 0.4s ease;
  }

  @keyframes hero-trim-shake {
    0%, 100% { transform: translateX(0); }
    20%       { transform: translateX(-6px); }
    40%       { transform: translateX(6px); }
    60%       { transform: translateX(-4px); }
    80%       { transform: translateX(4px); }
  }

  /* ── Trim results ── */
  .hero-smart-search__trim-header {
    padding: 1.2rem 1.4rem 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .hero-smart-search__trim-vehicle {
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 600;
    color: #fff;
  }

  .hero-smart-search__trim-label {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6b7280;
  }

  .hero-smart-search__trim-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 1.4rem;
    cursor: pointer;
    transition: background 0.15s;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }

  .hero-smart-search__trim-row:last-child {
    border-bottom: none;
  }

  .hero-smart-search__trim-row:hover,
  .hero-smart-search__trim-row[aria-selected="true"] {
    background: rgba(255, 255, 255, 0.06);
  }

  .hero-smart-search__trim-name {
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    color: #e5e7eb;
  }

  .hero-smart-search__trim-size {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    font-weight: 400;
    color: #F5820B;
    letter-spacing: 0.02em;
  }

  .hero-smart-search__intent-badge {
    display: inline-block;
    font-size: 0.95rem;
    font-weight: 500;
    color: #F5820B;
    background: rgba(245, 130, 11, 0.1);
    padding: 0.1rem 0.5rem;
    border-radius: 3px;
    margin-left: 0.4rem;
    vertical-align: middle;
  }

  .hero-smart-search__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: center;
  }

  .hero-smart-search__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.6rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 3px;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    background: transparent;
    font-family: 'Outfit', sans-serif;
  }

  .hero-smart-search__btn:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.3);
    color: #ffffff;
  }

  @media screen and (max-width: 749px) {
    .hero-smart-search {
      padding: 0 1.6rem 4rem;
      min-height: 80vh;
    }

    .hero-smart-search__heading {
      font-size: 2.8rem;
    }

    .hero-smart-search__subtitle {
      font-size: 1.3rem;
      margin-bottom: 2rem;
    }

    .hero-smart-search__actions {
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: center;
      gap: 0.6rem;
    }

    .hero-smart-search__btn {
      padding: 0.6rem 1.2rem;
      font-size: 1rem;
    }
  }

  @media screen and (max-width: 480px) {
    .hero-smart-search {
      padding: 0 1.2rem 3rem;
      min-height: 80vh;
    }
    .hero-smart-search__heading {
      font-size: clamp(2.2rem, 7vw, 2.8rem);
      flex-direction: column;
      gap: 0;
    }
    .hero-smart-search__subtitle {
      font-size: 1.2rem;
      margin-bottom: 1.5rem;
    }
    .hero-smart-search__search-wrapper {
      max-width: 100%;
    }
    .hero-smart-search__input {
      padding: 1.2rem 1.4rem;
      font-size: 1.6rem;
    }
    .hero-smart-search__typewriter {
      left: 1.4rem;
      font-size: 1.4rem;
    }
    .hero-smart-search__badge {
      font-size: 1rem;
      padding: 0.3rem 0.8rem;
    }
    .hero-smart-search__actions {
      flex-direction: row;
      flex-wrap: nowrap;
      width: 100%;
      gap: 0.5rem;
