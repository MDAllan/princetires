<div class="tst">
  <div class="tst__container">

    <div class="tst__top">
      <div class="tst__header">
        <span class="tst__eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="tst__heading">{{ section.settings.heading }}</h2>
      </div>
      <div class="tst__rating-badge">
        <div class="tst__rating-stars">
          {%- for i in (1..5) -%}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#F5820B"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          {%- endfor -%}
        </div>
        <span class="tst__rating-text">{{ section.settings.rating_text }}</span>
      </div>
    </div>

    {%- capture review_cards -%}
      {%- for block in section.blocks -%}
        <div class="tst__card" {{ block.shopify_attributes }}>
          <div class="tst__card-stars">
            {%- assign star_count = block.settings.rating | default: 5 -%}
            {%- for i in (1..star_count) -%}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#F5820B"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- endfor -%}
          </div>
          <p class="tst__card-text">"{{ block.settings.text }}"</p>
          <div class="tst__card-author">
            <div class="tst__card-avatar">{{ block.settings.name | slice: 0 }}</div>
            <div class="tst__card-info">
              <span class="tst__card-name">{{ block.settings.name }}</span>
              {%- if block.settings.date != blank -%}
                <span class="tst__card-date">{{ block.settings.date }}</span>
              {%- endif -%}
            </div>
            <svg class="tst__card-google" width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          </div>
        </div>
      {%- endfor -%}
    {%- endcapture -%}

    <div class="tst__marquee">
      <div class="tst__marquee-track">
        {{ review_cards }}
        {{ review_cards }}
      </div>
    </div>

  </div>
</div>

{% stylesheet %}
  .tst {
    background: #f7f7f7;
    padding: 7rem 0;
  }

  .tst__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 6rem;
  }

  .tst__top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 3.5rem;
  }

  .tst__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tst__eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 400;
    color: #dc2626;
    letter-spacing: 0.02em;
  }

  .tst__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 3rem;
    font-weight: 600;
    color: #111;
    margin: 0;
    line-height: 1.1;
  }

  .tst__rating-badge {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-shrink: 0;
  }

  .tst__rating-stars {
    display: flex;
    gap: 2px;
  }

  .tst__rating-text {
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 400;
    color: #6b7280;
  }

  /* ── Marquee ── */
  .tst__marquee {
    overflow: hidden;
    width: 100%;
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
  }

  .tst__marquee-track {
    display: flex;
    gap: 1.8rem;
    width: max-content;
    animation: tst-scroll 60s linear infinite;
  }

  .tst__marquee:hover .tst__marquee-track {
    animation-play-state: paused;
  }

  @keyframes tst-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Card ── */
  .tst__card {
    min-width: 34rem;
    max-width: 34rem;
    flex-shrink: 0;
    scroll-snap-align: start;
    background: #fff;
    border-radius: 10px;
    padding: 2.4rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .tst__card:hover {
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .tst__card-stars {
    display: flex;
    gap: 2px;
  }

  .tst__card-text {
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 300;
    color: #374151;
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .tst__card-author {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-top: auto;
    padding-top: 0.4rem;
  }

  .tst__card-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #dc2626;
    color: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    text-transform: uppercase;
  }

  .tst__card-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1;
  }

  .tst__card-name {
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 600;
    color: #111;
  }

  .tst__card-date {
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    font-weight: 300;
    color: #9ca3af;
  }

  .tst__card-google {
    flex-shrink: 0;
    opacity: 0.6;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .tst__container {
      padding: 0 2rem;
    }
    .tst__card {
      min-width: 28rem;
      max-width: 28rem;
    }
    .tst__top {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.2rem;
    }
    .tst__heading {
      font-size: 2.4rem;
    }
  }

  @media (max-width: 480px) {
    .tst {
      padding: 4rem 0;
    }
    .tst__container {
      padding: 0 1.6rem;
    }
    .tst__heading {
      font-size: clamp(2rem, 6vw, 2.4rem);
    }
    .tst__card {
      min-width: 80vw;
      max-width: 80vw;
      padding: 2rem;
    }
    .tst__card-text {
      font-size: 1.3rem;
    }
    .tst__rating-text {
      font-size: 1.1rem;
    }
    .tst__card-name {
      font-size: 1.2rem;
    }
    .tst__top {
      margin-bottom: 2.5rem;
    }
  }

  @media (max-width: 360px) {
    .tst__container {
      padding: 0 1.2rem;
    }
    .tst__card {
      min-width: 85vw;
      max-width: 85vw;
      padding: 1.6rem;
    }
    .tst__card-text {
      font-size: 1.2rem;
    }
    .tst__heading {
      font-size: 2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tst__marquee-track {
      animation: none !important;
    }
    .tst__card {
      transition: none !important;
    }
  }
{% endstylesheet %}


{% schema %}
{
