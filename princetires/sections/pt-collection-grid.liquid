<script>
document.addEventListener('DOMContentLoaded', function() {

  /* ── Typewriter placeholder ── */
  (function() {
    var input = document.querySelector('[data-ptg-typewriter]');
    if (!input) return;
    var phrases = [
      'Search by vehicle...',
      '2025 Toyota RAV4',
      'Search by tire size...',
      '225/65R17',
      'Smart search...',
      'Michelin Defender'
    ];
    var phraseIdx = 0, charIdx = 0, deleting = false, paused = false;

    function tick() {
      if (paused || input === document.activeElement || input.value !== '') return;
      var phrase = phrases[phraseIdx];

      if (!deleting) {
        charIdx++;
        input.setAttribute('placeholder', phrase.slice(0, charIdx));
        if (charIdx >= phrase.length) {
          deleting = true;
          setTimeout(tick, 1800);
          return;
        }
        setTimeout(tick, 70);
      } else {
        charIdx--;
        input.setAttribute('placeholder', phrase.slice(0, charIdx));
        if (charIdx <= 0) {
          deleting = false;
          phraseIdx = (phraseIdx + 1) % phrases.length;
          setTimeout(tick, 300);
          return;
        }
        setTimeout(tick, 25);
      }
    }

    input.addEventListener('focus', function() { paused = true; input.setAttribute('placeholder', ''); });
    input.addEventListener('blur', function() {
      paused = false;
      if (input.value === '') { charIdx = 0; deleting = false; tick(); }
    });

    tick();
  })();

  var activeFiltersBar = document.querySelector('[data-active-filters-sidebar]');
  var params = new URLSearchParams(window.location.search);
  var baseUrl = window.location.pathname;

  // Result count — show tire size context if filtered
  (function() {
    var sizeParam = params.get('filter.p.m.custom.tire_size');
    if (sizeParam) {
      var sizeSpan = document.querySelector('[data-results-size]');
      var sizeVal = document.querySelector('[data-results-size-val]');
      if (sizeSpan && sizeVal) { sizeVal.textContent = sizeParam; sizeSpan.hidden = false; }
    }
  })();

  function isFilterActive(key, value) {
    var found = false;
    params.forEach(function(v, k) { if (k === key && v === value) found = true; });
    return found;
  }

  function toggleFilter(key, value) {
    var newParams = new URLSearchParams();
    var removed = false;
    params.forEach(function(v, k) {
      if (k === key && v === value) { removed = true; }
      else { newParams.append(k, v); }
    });
    if (!removed) newParams.append(key, value);
    var qs = newParams.toString();
    try { sessionStorage.setItem('ptg_filter_open', '1'); } catch(e) {}
    window.location.href = baseUrl + (qs ? '?' + qs : '');
  }

  // Universal filter links (brands, product types, etc.)
  document.querySelectorAll('[data-filter-key]').forEach(function(el) {
    var key = el.dataset.filterKey;
    var val = el.dataset.filterValue;
    if (isFilterActive(key, val)) el.classList.add('ptg__filter-link--active');
    el.addEventListener('click', function(e) {
      e.preventDefault();
      toggleFilter(key, val);
    });
  });

  // Season icons
  document.querySelectorAll('[data-meta-filter]').forEach(function(el) {
    var key = 'filter.p.m.custom.' + el.dataset.metaFilter;
    var val = el.dataset.metaValue;
    if (isFilterActive(key, val)) {
      el.classList.add('ptg__season-icon--active');
    }
    el.addEventListener('click', function(e) {
      e.preventDefault();
      toggleFilter(key, val);
    });
  });

  // Active filter bubbles
  var activeFilters = [];
  params.forEach(function(v, k) {
    if (k.startsWith('filter.') && !k.includes('price') && !k.includes('tire_size')) {
      activeFilters.push({ key: k, value: v });
    }
  });

  if (activeFilters.length > 0 && activeFiltersBar) {
    var html = '';
    activeFilters.forEach(function(f) {
      html += '<button type="button" class="ptg__active-tag" data-rk="' + f.key + '" data-rv="' + f.value + '">' +
        f.value +
        '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>' +
      '</button>';
    });
    html += '<button type="button" class="ptg__active-clear" data-clear-all>Clear all</button>';
    activeFiltersBar.innerHTML = html;
    activeFiltersBar.hidden = false;

    activeFiltersBar.querySelectorAll('[data-rk]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        toggleFilter(this.dataset.rk, this.dataset.rv);
      });
    });
    var clearAll = activeFiltersBar.querySelector('[data-clear-all]');
    if (clearAll) clearAll.addEventListener('click', function() {
      // Preserve tire_size when clearing other filters
      var tireSize = params.get('filter.p.m.custom.tire_size');
      if (tireSize) {
        window.location.href = baseUrl + '?filter.p.m.custom.tire_size=' + encodeURIComponent(tireSize);
      } else {
        window.location.href = baseUrl;
      }
    });
  }

  // Editable tire size — populated from URL via JS
  var sizeDisplay = document.querySelector('[data-size-display]');
  var sizeEdit = document.querySelector('[data-size-edit]');
  var sizeClearLink = document.querySelector('[data-size-clear-link]');
  var activeTireSize = params.get('filter.p.m.custom.tire_size');

  if (activeTireSize && sizeEdit) {
    sizeEdit.value = activeTireSize;
    // Show X button when size is active
    if (sizeClearLink) {
      sizeClearLink.hidden = false;
      var clearParams = new URLSearchParams();
      params.forEach(function(v, k) {
        if (!k.includes('tire_size')) clearParams.append(k, v);
      });
      var qs = clearParams.toString();
      sizeClearLink.href = baseUrl + (qs ? '?' + qs : '');
    }
  }

  if (sizeEdit) {
    sizeEdit.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        var val = this.value.trim();
        if (!val) {
          if (sizeClearLink) window.location.href = sizeClearLink.href;
          return;
        }
        var m = val.match(/(\d{2,3})\/?(\d{2,3})[Rr](\d{2})/);
        if (!m) return;
        var sizeStr = m[1] + '/' + m[2] + 'R' + m[3];
        var newParams = new URLSearchParams();
        params.forEach(function(v, k) {
          if (!k.includes('tire_size')) newParams.append(k, v);
        });
        newParams.set('filter.p.m.custom.tire_size', sizeStr);
        window.location.href = baseUrl + '?' + newParams.toString();
      }
    });
  }

  // Price slider
  var minSlider = document.querySelector('[data-price-min]');
  var maxSlider = document.querySelector('[data-price-max]');
  var minDisplay = document.querySelector('[data-price-min-display]');
  var maxDisplay = document.querySelector('[data-price-max-display]');
  if (minSlider && maxSlider) {
    var priceTimer = null;
    function updatePrice() {
      var mn = parseInt(minSlider.value);
      var mx = parseInt(maxSlider.value);
      if (mn > mx) { minSlider.value = mx; mn = mx; }
      if (mx < mn) { maxSlider.value = mn; mx = mn; }
      minDisplay.textContent = '$' + mn;
      maxDisplay.textContent = '$' + mx;
    }
    function applyPrice() {
      clearTimeout(priceTimer);
      priceTimer = setTimeout(function() {
        var mn = parseInt(minSlider.value);
        var mx = parseInt(maxSlider.value);
        var newParams = new URLSearchParams();
        params.forEach(function(v, k) {
          if (!k.includes('price')) newParams.append(k, v);
        });
        newParams.set('filter.price.min', mn);
        newParams.set('filter.price.max', mx);
        try { sessionStorage.setItem('ptg_filter_open', '1'); } catch(e) {}
        window.location.href = baseUrl + '?' + newParams.toString();
      }, 800);
    }
    minSlider.addEventListener('input', updatePrice);
    maxSlider.addEventListener('input', updatePrice);
    minSlider.addEventListener('change', applyPrice);
    maxSlider.addEventListener('change', applyPrice);
  }


  // Approximate filter counts from visible cards
  (function() {
    var cards = document.querySelectorAll('.ptg__card[data-vendor]');
    var vendorCounts = {};
    var typeCounts = {};
    cards.forEach(function(card) {
      var v = card.dataset.vendor;
      if (v) vendorCounts[v] = (vendorCounts[v] || 0) + 1;
      var t = card.dataset.type;
      if (t) typeCounts[t] = (typeCounts[t] || 0) + 1;
    });
    document.querySelectorAll('[data-filter-cnt]').forEach(function(el) {
      var parts = el.dataset.filterCnt.split(':');
      var kind = parts[0], key = parts[1];
      var count = 0;
      if (kind === 'vendor') count = vendorCounts[key] || 0;
      else if (kind === 'type') count = typeCounts[key] || 0;
      if (count > 0) el.textContent = '(' + count + ')';
    });
  })();

  // Vehicle fitment confirmation on cards
  (function() {
    var fitmentBadges = document.querySelectorAll('[data-card-fitment]');
    if (!fitmentBadges.length) return;
    try {
      var keys = Object.keys(localStorage).filter(function(k) { return k.startsWith('pt-garage-'); });
      var vehicleSizes = [];
      for (var i = 0; i < keys.length; i++) {
        var vehicles = JSON.parse(localStorage.getItem(keys[i]));
        var def = (vehicles || []).find(function(v) { return v.isDefault; });
        if (def && def.sizes) { vehicleSizes = def.sizes; break; }
      }
      if (vehicleSizes.length > 0) {
        document.querySelectorAll('.ptg__card[data-tire-size]').forEach(function(card) {
          var cardSize = card.dataset.tireSize;
          if (cardSize && vehicleSizes.indexOf(cardSize) !== -1) {
            var badge = card.querySelector('[data-card-fitment]');
            if (badge) badge.hidden = false;
          }
        });
      }
    } catch(e) {}
  })();

  // Collection smart search — same logic as hero
  (function() {
    var wrap = document.querySelector('[data-ptg-smart-search]');
    if (!wrap) return;
    var input = wrap.querySelector('[data-ptg-search]');
    var results = wrap.querySelector('[data-ptg-results]');
    var loading = wrap.querySelector('[data-ptg-loading]');
    var list = wrap.querySelector('[data-ptg-list]');
    var configEl = document.querySelector('[data-smart-search-config]');
    var config = configEl ? JSON.parse(configEl.textContent) : {};
    var tireSizeRegex = /(?:^|[\s,])([Pp]?[LlTtSs]?[Tt]?\d{3}\/?\d{2,3}[Rr]\d{2}(?:\.\d)?)/;
    var vehicleCache = {};
    var debounceTimer = null;
    var brands = ['michelin','bridgestone','goodyear','continental','toyo','pirelli','falken','kumho','yokohama','firestone','cooper','bfgoodrich','bf goodrich','general','uniroyal','hankook','nitto','mickey thompson','firemax','linglong','farroad','yeada','fortune','radar','rotalla','haida','carlstar'];
    var knownMakes = ['acura','alfa romeo','aston martin','audi','bmw','bentley','buick','cadillac','chevrolet','chevy','chrysler','dodge','ferrari','fiat','ford','gmc','genesis','honda','hyundai','ineos','infiniti','jaguar','jeep','karma','kia','lamborghini','land rover','lexus','lincoln','lotus','lucid','maserati','mazda','mclaren','mercedes-benz','mercedes','benz','mini','mitsubishi','nissan','polestar','porsche','ram','rivian','rolls-royce','subaru','tesla','toyota','vinfast','volkswagen','vw','volvo'];
    var makeAliases = {'chevy':'Chevrolet','vw':'Volkswagen','mercedes':'Mercedes-Benz','benz':'Mercedes-Benz'};
    var modelShortcuts = {'crv':'CR-V','cr-v':'CR-V','hrv':'HR-V','hr-v':'HR-V','rav':'RAV4','rav4':'RAV4','f150':'F-150','f-150':'F-150','f250':'F-250','f-250':'F-250','f350':'F-350','f-350':'F-350','4runner':'4Runner','forerunner':'4Runner','camry':'Camry','corolla':'Corolla','cx5':'CX-5','cx-5':'CX-5','cx50':'CX-50','cx-50':'CX-50','cx9':'CX-9','cx-9':'CX-9','cx30':'CX-30','cx-30':'CX-30','mazda3':'Mazda3','mazda6':'Mazda6','q5':'Q5','q7':'Q7','q3':'Q3','x3':'X3','x5':'X5','x1':'X1','crz':'CR-Z','brz':'BRZ','gr86':'GR86','wrx':'WRX','sti':'WRX STI','outback':'Outback','forester':'Forester','crosstrek':'Crosstrek','silverado':'Silverado 1500','sierra':'Sierra 1500','tahoe':'Tahoe','suburban':'Suburban','wrangler':'Wrangler','cherokee':'Cherokee','grandcherokee':'Grand Cherokee','grand cherokee':'Grand Cherokee','mustang':'Mustang','bronco':'Bronco','escape':'Escape','explorer':'Explorer','expedition':'Expedition','tacoma':'Tacoma','tundra':'Tundra','highlander':'Highlander','prius':'Prius','supra':'GR Supra','civic':'Civic','accord':'Accord','pilot':'Pilot','odyssey':'Odyssey','ridgeline':'Ridgeline','altima':'Altima','maxima':'Maxima','sentra':'Sentra','rogue':'Rogue','pathfinder':'Pathfinder','frontier':'Frontier','elantra':'Elantra','sonata':'Sonata','tucson':'Tucson','santafe':'Santa Fe','santa fe':'Santa Fe','palisade':'Palisade','sorento':'Sorento','sportage':'Sportage','forte':'Forte','telluride':'Telluride','jetta':'Jetta','tiguan':'Tiguan','atlas':'Atlas','golf':'Golf','passat':'Passat','model3':'Model 3','modely':'Model Y','modelx':'Model X','models':'Model S','glc':'GLC','gle':'GLE','gls':'GLS','ram1500':'1500','ram2500':'2500','ram3500':'3500','malibu':'Malibu','equinox':'Equinox','traverse':'Traverse','trax':'Trax','blazer':'Blazer','terrain':'Terrain','acadia':'Acadia','yukon':'Yukon','durango':'Durango','charger':'Charger','challenger':'Challenger','impreza':'Impreza','legacy':'Legacy','maverick':'Maverick','ranger':'Ranger','ioniq5':'Ioniq 5','ioniq6':'Ioniq 6','kona':'Kona','ct4':'CT4','ct5':'CT5','escalade':'Escalade','xt5':'XT5','xt6':'XT6'};
    var noiseWords = ['tires','tire','for','my','the','a','an','need','needs','looking','want','i','on','new','set','of','best','good','cheap','get','find','buy','shop','what','fit','fits','size','sizes'];

    function levenshtein(a, b) {
      if (a.length === 0) return b.length;
      if (b.length === 0) return a.length;
      var matrix = [];
      for (var i = 0; i <= b.length; i++) matrix[i] = [i];
      for (var j = 0; j <= a.length; j++) matrix[0][j] = j;
      for (var i = 1; i <= b.length; i++) {
        for (var j = 1; j <= a.length; j++) {
          var cost = a[j - 1] === b[i - 1] ? 0 : 1;
          matrix[i][j] = Math.min(matrix[i - 1][j] + 1, matrix[i][j - 1] + 1, matrix[i - 1][j - 1] + cost);
        }
      }
      return matrix[b.length][a.length];
    }

    function fuzzyMatchMake(word) {
      if (knownMakes.indexOf(word) >= 0) return makeAliases[word] || word;
      var maxDist = word.length <= 4 ? 1 : 2;
      var best = null, bestDist = maxDist + 1;
      for (var i = 0; i < knownMakes.length; i++) {
        var mk = knownMakes[i];
        if (Math.abs(mk.length - word.length) > maxDist) continue;
        var d = levenshtein(word, mk);
        if (d < bestDist) { bestDist = d; best = mk; }
      }
      return best ? (makeAliases[best] || best) : null;
    }

    function normalizeTireSize(query) {
      var m = query.match(/[Pp]?[LlTtSs]?[Tt]?(\d{3})\/?(\d{2,3})[Rr](\d{2}(?:\.\d)?)/);
      if (m) return { width: m[1], aspect: m[2], rim: m[3], size: m[1] + '/' + m[2] + 'R' + m[3] };
      var compact = query.replace(/[\s\/\-rR]/g, '');
      var dm = compact.match(/[Pp]?[LlTtSs]?[Tt]?(\d{3})(\d{2})(\d{2})$/);
      if (dm) return { width: dm[1], aspect: dm[2], rim: dm[3], size: dm[1] + '/' + dm[2] + 'R' + dm[3] };
      var spaced = query.match(/(\d{3})\s+(\d{2})\s+(\d{2})/);
      if (spaced) return { width: spaced[1], aspect: spaced[2], rim: spaced[3], size: spaced[1] + '/' + spaced[2] + 'R' + spaced[3] };
      return null;
    }

    function parseIntent(query) {
      var q = query.toLowerCase();
      var intent = { season: null, brand: null };
      if (q.includes('winter') || q.includes('snow') || q.includes('ice')) intent.season = 'Winter';
      else if (q.includes('all-season') || q.includes('all season') || q.includes('allseason')) intent.season = 'All-Season';
      else if (q.includes('all-weather') || q.includes('all weather')) intent.season = 'All-Weather';
      else if (q.includes('summer') || q.includes('performance')) intent.season = 'Summer';
      for (var i = 0; i < brands.length; i++) {
        if (q.includes(brands[i])) {
          intent.brand = brands[i].split(' ').map(function(w) { return w.charAt(0).toUpperCase() + w.slice(1); }).join(' ');
          if (intent.brand === 'Bfgoodrich' || intent.brand === 'Bf Goodrich') intent.brand = 'BFGoodrich';
          if (intent.brand === 'Mickey Thompson') intent.brand = 'Mickey Thompson';
          break;
        }
      }
      return intent;
    }

    function cleanQueryForVehicle(query, intent) {
      var q = query.toLowerCase();
      var seasonWords = ['winter','snow','ice','all-season','all season','allseason','all-weather','all weather','summer','performance'];
      for (var i = 0; i < seasonWords.length; i++) {
        q = q.replace(new RegExp('\\b' + seasonWords[i].replace(/-/g, '[-\\s]?') + '\\b', 'g'), ' ');
      }
      if (intent.brand) {
        var brandLower = intent.brand.toLowerCase();
        q = q.replace(new RegExp('\\b' + brandLower.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '\\b', 'g'), ' ');
        for (var b of brands) {
          if (q.includes(b)) q = q.replace(new RegExp('\\b' + b.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '\\b', 'g'), ' ');
        }
      }
      return q.replace(/\s+/g, ' ').trim();
    }

    function buildUrl(p) {
      var base = '/collections/tires';
      var urlP = new URLSearchParams();
      if (p.tireSize) urlP.set('filter.p.m.custom.tire_size', p.tireSize);
      if (p.brand) urlP.set('filter.p.vendor', p.brand);
      if (p.season) urlP.set('filter.p.m.custom.seasonality', p.season);
      var qs = urlP.toString();
      return qs ? base + '?' + qs : base;
    }

    function extractSize(q) {
      var n = normalizeTireSize(q);
      return n ? n.size : null;
    }

    input.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function() {
        var q = input.value.trim();
        if (q.length < 2) { results.hidden = true; return; }
        search(q);
      }, 300);
    });

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        var q = this.value.trim();
        if (!q) return;
        var size = extractSize(q);
        var intent = parseIntent(q);
        if (size || intent.brand || intent.season) {
          window.location.href = buildUrl({ tireSize: size, brand: intent.brand, season: intent.season });
        } else {
          window.location.href = '/search?q=' + encodeURIComponent(q) + '&type=product';
        }
      } else if (e.key === 'Escape') {
        results.hidden = true;
      }
    });

    document.addEventListener('click', function(e) {
      if (!wrap.contains(e.target)) results.hidden = true;
    });

    function search(query) {
      var normalized = normalizeTireSize(query);
      if (normalized) {
        var intent = parseIntent(query);
        var label = normalized.size + (intent.brand ? ' by ' + intent.brand : '');
        var meta = 'Filter collection' + (intent.season ? ' · ' + intent.season : '');
        renderResults([{ type: 'size', title: label, meta: meta, url: buildUrl({ tireSize: normalized.size, brand: intent.brand, season: intent.season }) }]);
        return;
      }
      searchVehicle(query);
    }

    async function searchVehicle(query) {
      results.hidden = false;
      loading.hidden = false;
      list.innerHTML = '';
      var intent = parseIntent(query);
      var cleanedQuery = cleanQueryForVehicle(query, intent);

      try {
        var vehicle = cleanedQuery.length >= 2 ? tryDirectParse(cleanedQuery) : null;

        if (!vehicle || (!vehicle.year && !vehicle.model && !vehicle.make)) {
          if (intent.brand || intent.season) {
            var filterTitle = [intent.brand, intent.season].filter(Boolean).join(' ') + ' tires';
            renderResults([{ type: 'search', title: filterTitle, meta: 'Filter collection', url: buildUrl({ brand: intent.brand, season: intent.season }) }]);
          } else {
            renderResults([{ type: 'search', title: 'Search "' + query + '"', meta: 'Browse all products', url: '/search?q=' + encodeURIComponent(query) + '&type=product' }]);
          }
          return;
        }

        var trims = await lookupTrims(vehicle);
        var vLabel = (vehicle.year + ' ' + (vehicle.make || '') + ' ' + (vehicle.model || '')).replace(/\s+/g, ' ').trim();

        if (trims.length === 1 && vehicle.trim) {
          /* User specified a trim — go straight to collection */
          var url = buildUrl({ tireSize: trims[0].size, brand: intent.brand, season: intent.season });
          renderResults([{ type: 'vehicle', title: vLabel + ' ' + trims[0].trim, meta: trims[0].size + (intent.season ? ' · ' + intent.season : '') + (intent.brand ? ' · ' + intent.brand : ''), url: url }]);
        } else if (trims.length > 0) {
          renderTrimResults(vLabel, trims, intent);
        } else {
          renderResults([{ type: 'vehicle', title: vLabel, meta: 'Browse all tires', url: buildUrl({ brand: intent.brand, season: intent.season }) }]);
        }
      } catch(e) {
        if (intent.brand || intent.season) {
          renderResults([{ type: 'search', title: [intent.brand, intent.season].filter(Boolean).join(' ') + ' tires', meta: 'Filter collection', url: buildUrl({ brand: intent.brand, season: intent.season }) }]);
        } else {
          renderResults([{ type: 'search', title: 'Search "' + query + '"', meta: 'Browse all products', url: '/search?q=' + encodeURIComponent(query) + '&type=product' }]);
        }
      }
    }

    function tryDirectParse(query) {
      var q = query.trim().toLowerCase();
      var words = q.split(/\s+/).filter(function(w) { return noiseWords.indexOf(w) === -1; });
      if (words.length === 0) return null;

      /* Extract year from anywhere */
      var year = null;
      var yearIndex = -1;
      for (var i = 0; i < words.length; i++) {
        var w = words[i].replace(/^[''\u2018\u2019]/, '');
        var ym = w.match(/^(\d{2,4})$/);
        if (ym) {
          var y = ym[1];
          if (y.length === 2) y = (parseInt(y) > 50 ? '19' : '20') + y;
          var yn = parseInt(y);
          if (yn >= 1990 && yn <= config.maxYear) { year = yn; yearIndex = i; break; }
        }
      }
      if (yearIndex >= 0) words.splice(yearIndex, 1);
      if (words.length === 0) return null;

      /* Try to find a known make */
      var make = null;
      /* Check two-word makes first */
      for (var i = 0; i < words.length - 1; i++) {
        var twoWord = words[i] + ' ' + words[i + 1];
        if (knownMakes.indexOf(twoWord) >= 0) {
          make = makeAliases[twoWord] || twoWord.split(' ').map(function(w) { return w.charAt(0).toUpperCase() + w.slice(1); }).join(' ');
          words.splice(i, 2); break;
        }
      }
      if (!make) {
        for (var i = 0; i < words.length; i++) {
          var matched = fuzzyMatchMake(words[i]);
          if (matched) {
            make = matched;
            if (make === 'Bmw') make = 'BMW';
            if (make === 'Gmc') make = 'GMC';
            if (make === 'Ram') make = 'RAM';
            make = make.charAt(0).toUpperCase() + make.slice(1);
            if (makeAliases[words[i]]) make = makeAliases[words[i]];
            words.splice(i, 1); break;
          }
        }
      }

      if (words.length === 0 && !make) return null;
      var model = null, trim = null;
      if (words.length > 0) {
        var modelJoined = words.join(' ');
        var modelNoSpace = words.join('');
        if (modelShortcuts[modelJoined]) { model = modelShortcuts[modelJoined]; words = []; }
        else if (modelShortcuts[modelNoSpace]) { model = modelShortcuts[modelNoSpace]; words = []; }
        else if (modelShortcuts[words[0]]) { model = modelShortcuts[words[0]]; words.splice(0, 1); trim = words.length > 0 ? words.join(' ') : null; }
        else { model = words[0]; trim = words.length > 1 ? words.slice(1).join(' ') : null; }
      }
      if (!year) year = config.maxYear;
      return { year: year, make: make, model: model, trim: trim };
    }

    async function lookupTrims(vehicle) {
      var year = vehicle.year;
      if (!vehicleCache[year]) {
        try {
          var url = config.assetUrlBase + 'pt-vehicle-' + year + '.json';
          var r = await fetch(url);
          if (r.ok) vehicleCache[year] = await r.json();
        } catch(e) {}
      }
      var data = vehicleCache[year];
      if (!data || !data.models) return [];

      var makeData = null, modelData = null;

      if (vehicle.make) {
        makeData = data.models[vehicle.make];
        if (!makeData) {
          var ml = vehicle.make.toLowerCase();
          for (var k in data.models) { if (k.toLowerCase() === ml) { makeData = data.models[k]; vehicle.make = k; break; } }
        }
      }

      if (vehicle.model) {
        var modelLower = vehicle.model.toLowerCase();
        var modelClean = modelLower.replace(/[-\s]/g, '');
        var searchIn = makeData ? [[vehicle.make, makeData]] : Object.entries(data.models);
        for (var [mk, models] of searchIn) {
          for (var [mn, md] of Object.entries(models)) {
            if (mn.toLowerCase() === modelLower) { modelData = md; vehicle.make = mk; vehicle.model = mn; break; }
          }
          if (modelData) break;
          for (var [mn, md] of Object.entries(models)) {
            var mnClean = mn.toLowerCase().replace(/[-\s]/g, '');
            if (mnClean.includes(modelClean) || modelClean.includes(mnClean)) { modelData = md; vehicle.make = mk; vehicle.model = mn; break; }
          }
          if (modelData) break;
          /* Fuzzy match */
          var bestModel = null, bestDist = 3, bestMd = null;
          for (var [mn, md] of Object.entries(models)) {
            var mnClean = mn.toLowerCase().replace(/[-\s]/g, '');
            var maxDist = modelClean.length <= 4 ? 1 : 2;
            if (Math.abs(mnClean.length - modelClean.length) > maxDist) continue;
            var d = levenshtein(modelClean, mnClean);
            if (d <= maxDist && d < bestDist) { bestDist = d; bestModel = mn; bestMd = md; }
          }
          if (bestModel) { modelData = bestMd; vehicle.make = mk; vehicle.model = bestModel; break; }
        }
      }

      if (!modelData) return [];

      /* If trim specified, filter to matching trims */
      var trims = [];
      if (vehicle.trim) {
        var trimLower = vehicle.trim.toLowerCase();
        for (var [tn, sizes] of Object.entries(modelData)) {
          if (Array.isArray(sizes) && sizes.length > 0) {
            var tnl = tn.toLowerCase();
            if (tnl === trimLower || tnl.includes(trimLower) || trimLower.includes(tnl)) {
              trims.push({ trim: tn, size: sizes[0] });
            }
          }
        }
      }
      if (trims.length === 0) {
        for (var [tn, sizes] of Object.entries(modelData)) {
          if (Array.isArray(sizes) && sizes.length > 0) trims.push({ trim: tn, size: sizes[0] });
        }
      }
      return trims;
    }

    function renderTrimResults(vLabel, trims, intent) {
      loading.hidden = true;
      var seasonBadge = intent.season ? ' <span style="font-size:0.85rem;color:#F5820B;background:rgba(245,130,11,0.1);padding:0.1rem 0.4rem;border-radius:3px;margin-left:0.3rem">' + esc(intent.season) + '</span>' : '';
      var brandBadge = intent.brand ? ' <span style="font-size:0.85rem;color:#F5820B;background:rgba(245,130,11,0.1);padding:0.1rem 0.4rem;border-radius:3px;margin-left:0.3rem">' + esc(intent.brand) + '</span>' : '';

      var html = '<li style="padding:0.8rem 1rem;border-bottom:1px solid #f0f0f0">' +
        '<div style="font-weight:600;color:#111;font-size:1.2rem">' + esc(vLabel) + seasonBadge + brandBadge + '</div>' +
        '<div style="font-size:0.95rem;color:#9ca3af;text-transform:uppercase;letter-spacing:0.06em;margin-top:0.2rem">Choose your trim</div>' +
      '</li>';

      html += trims.map(function(t) {
        var url = buildUrl({ tireSize: t.size, brand: intent.brand, season: intent.season });
        return '<li class="ptg__search-item" data-url="' + url + '" style="display:flex;justify-content:space-between;padding:0.7rem 1rem;cursor:pointer">' +
          '<span style="font-weight:500;color:#374151">' + esc(t.trim) + '</span>' +
          '<span style="color:#F5820B;font-size:1.1rem">' + esc(t.size) + '</span>' +
        '</li>';
      }).join('');

      list.innerHTML = html;
      results.hidden = false;
      list.querySelectorAll('.ptg__search-item').forEach(function(item) {
        item.addEventListener('click', function() { window.location.href = this.dataset.url; });
      });
    }

    function renderResults(items) {
      loading.hidden = true;
      if (!items.length) { results.hidden = true; return; }
      list.innerHTML = items.map(function(r) {
        return '<li class="ptg__search-item" data-url="' + r.url + '">' +
          '<span class="ptg__search-item-info"><span class="ptg__search-item-title">' + esc(r.title) + '</span><span class="ptg__search-item-meta">' + esc(r.meta) + '</span></span>' +
        '</li>';
      }).join('');
      results.hidden = false;
      list.querySelectorAll('.ptg__search-item').forEach(function(item) {
        item.addEventListener('click', function() { window.location.href = this.dataset.url; });
      });
    }

    function esc(t) { var d = document.createElement('div'); d.textContent = t; return d.innerHTML; }
  })();

  // Mobile filter drawer
  var openBtn = document.querySelector('[data-open-filters]');
  var closeBtn = document.querySelector('[data-close-filters]');
  var sidebar = document.querySelector('[data-sidebar]');
  var backdrop = document.querySelector('[data-filter-backdrop]');

  function openFilters() {
    if (sidebar) sidebar.classList.add('is-open');
    if (backdrop) backdrop.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeFilters() {
    if (sidebar) sidebar.classList.remove('is-open');
    if (backdrop) backdrop.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  if (openBtn) openBtn.addEventListener('click', openFilters);
  if (closeBtn) closeBtn.addEventListener('click', closeFilters);
  if (backdrop) backdrop.addEventListener('click', closeFilters);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeFilters();
  });

  // Reopen filter drawer after a filter is selected on mobile
  try {
    if (sessionStorage.getItem('ptg_filter_open') === '1') {
      sessionStorage.removeItem('ptg_filter_open');
      openFilters();
    }
  } catch(e) {}

  // Sort
  var sortSelect = document.querySelector('[data-ptg-sort]');
  if (sortSelect) {
    // Default to price low-to-high if no sort param
    var urlParams = new URLSearchParams(window.location.search);
    if (!urlParams.has('sort_by')) {
      var url = new URL(window.location.href);
      url.searchParams.set('sort_by', 'price-ascending');
      window.location.replace(url.toString());
    }
    sortSelect.addEventListener('change', function() {
      var url = new URL(window.location.href);
      url.searchParams.set('sort_by', this.value);
      window.location.href = url.toString();
    });
  }

  // Compare feature
  (function() {
    var tray = document.querySelector('[data-compare-tray]');
    var itemsWrap = document.querySelector('[data-compare-items]');
    var countEl = document.querySelector('[data-compare-count]');
    var openBtn = document.querySelector('[data-compare-open]');
    var clearBtn = document.querySelector('[data-compare-clear]');
    var modal = document.querySelector('[data-compare-modal]');
    var tableWrap = document.querySelector('[data-compare-table]');
    if (!tray) return;

    var compareList = [];
    var MAX_COMPARE = 4;

    function updateTray() {
      if (compareList.length === 0) {
        tray.classList.remove('is-visible');
        return;
      }
      tray.classList.add('is-visible');
      countEl.textContent = compareList.length;
      openBtn.disabled = compareList.length < 2;

      var html = '';
      compareList.forEach(function(item) {
        html += '<div class="ptg__compare-item">' +
          (item.img ? '<img src="' + item.img + '" alt="">' : '') +
          '<span>' + item.vendor + ' ' + item.title + '</span>' +
          '<button type="button" class="ptg__compare-item-remove" data-remove-id="' + item.id + '">&times;</button>' +
        '</div>';
      });
      itemsWrap.innerHTML = html;

      itemsWrap.querySelectorAll('[data-remove-id]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          removeFromCompare(this.dataset.removeId);
        });
      });
    }

    function addToCompare(data) {
      if (compareList.length >= MAX_COMPARE) return;
      if (compareList.find(function(i) { return i.id === data.id; })) return;
      compareList.push(data);
      updateTray();
    }

    function removeFromCompare(id) {
      compareList = compareList.filter(function(i) { return i.id !== id; });
      var cb = document.querySelector('.ptg__compare-check[data-compare-id="' + id + '"]');
      if (cb) cb.checked = false;
      updateTray();
    }

    document.querySelectorAll('.ptg__compare-check').forEach(function(cb) {
      cb.addEventListener('change', function() {
        if (this.checked) {
          if (compareList.length >= MAX_COMPARE) { this.checked = false; return; }
          addToCompare({
            id: this.dataset.compareId,
            title: this.dataset.compareTitle,
            vendor: this.dataset.compareVendor,
            price: this.dataset.comparePrice,
            setPrice: this.dataset.compareSet,
            img: this.dataset.compareImg,
            size: this.dataset.compareSize,
            url: this.dataset.compareUrl,
            season: this.dataset.compareSeason,
            type: this.dataset.compareType,
            speed: this.dataset.compareSpeed,
            load: this.dataset.compareLoad,
            warranty: this.dataset.compareWarranty
          });
        } else {
          removeFromCompare(this.dataset.compareId);
        }
      });
    });

    if (clearBtn) clearBtn.addEventListener('click', function() {
      compareList = [];
      document.querySelectorAll('.ptg__compare-check').forEach(function(cb) { cb.checked = false; });
      updateTray();
    });

    function buildTable() {
      var rows = [
        { label: '', key: 'img', render: function(v) { return v.img ? '<img src="' + v.img + '" alt="">' : ''; } },
        { label: 'Brand', key: 'vendor' },
        { label: 'Model', key: 'title' },
        { label: 'Size', key: 'size' },
        { label: 'Price / tire', key: 'price', cls: 'ptg__cmp-price', render: function(v) { return '$' + v.price; } },
        { label: 'Set of 4', key: 'setPrice', render: function(v) { return '$' + v.setPrice; } },
        { label: 'Season', key: 'season' },
        { label: 'Type', key: 'type' },
        { label: 'Speed rating', key: 'speed' },
        { label: 'Load index', key: 'load' },
        { label: 'Warranty', key: 'warranty' },
        { label: '', key: 'url', render: function(v) { return '<a href="' + v.url + '" class="ptg__cmp-link">View tire →</a>'; } }
      ];

      var html = '<table class="ptg__cmp-table">';
      rows.forEach(function(row) {
        html += '<tr><th>' + row.label + '</th>';
        compareList.forEach(function(item) {
          var val = row.render ? row.render(item) : (item[row.key] || '—');
          html += '<td' + (row.cls ? ' class="' + row.cls + '"' : '') + '>' + val + '</td>';
        });
        html += '</tr>';
      });
      html += '</table>';
      tableWrap.innerHTML = html;
    }

    if (openBtn) openBtn.addEventListener('click', function() {
      if (compareList.length < 2) return;
      buildTable();
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
    });

    function closeModal() {
      if (modal) { modal.hidden = true; document.body.style.overflow = ''; }
    }

    document.querySelectorAll('[data-compare-modal-close]').forEach(function(el) {
      el.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal && !modal.hidden) closeModal();
    });
  })();
});
</script>

