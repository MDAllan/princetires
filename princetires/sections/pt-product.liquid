{% stylesheet %}
  .ptp {
    --ptp-max-width: 100%; --ptp-gap: 4rem; --ptp-font: 'Outfit', sans-serif;
    --ptp-heading: 'Barlow Condensed', sans-serif;
    --ptp-text: #111; --ptp-muted: #9ca3af; --ptp-subtle: #6b7280;
    --ptp-border: #f0f0f0; --ptp-border-soft: #e5e7eb;
    --ptp-bg: #ffffff; --ptp-bg2: #f7f7f8;
    --ptp-accent: #F5820B; --ptp-accent-dark: #d97006;
    --ptp-success: #16a34a; --ptp-sale: #dc2626;
    --ptp-cta: #dc2626; --ptp-cta-hover: #b91c1c;
    --ptp-r: 10px; --ptp-r-sm: 8px;
    background: var(--ptp-bg); font-family: var(--ptp-font); color: var(--ptp-text);
  }
  .ptp__container { max-width: 1200px; margin: 0 auto; padding: 4rem 2rem 6rem; }

  /* Breadcrumb */
  .ptp__breadcrumb { margin-bottom: 3rem; }
  .ptp__breadcrumb-list { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; font-family: 'Outfit', sans-serif; font-size: 1.15rem; font-weight: 400; color: #9ca3af; list-style: none; padding: 0; margin: 0; }
  .ptp__breadcrumb-list li:not(:last-child)::after { content: '/'; margin-left: 0.6rem; color: #d1d5db; }
  .ptp__breadcrumb-list a { color: #9ca3af; text-decoration: none; transition: color 0.2s; }
  .ptp__breadcrumb-list a:hover { color: #111; }
  .ptp__breadcrumb-list li:last-child { color: #6b7280; }

  /* Fitment */
  .ptp__fitment { display: flex; align-items: center; gap: 0.6rem; padding: 0.75rem 1.2rem; background: #ecfdf5; border: 1px solid #a7f3d0; border-radius: var(--ptp-r-sm); margin-bottom: 1.5rem; font-size: 0.95rem; color: #374151; }
  .ptp__fitment[hidden] { display: none; }
  .ptp__fitment strong { color: var(--ptp-text); }
  .ptp__fitment-change { margin-left: auto; font-size: 0.85rem; color: var(--ptp-muted); text-decoration: underline; text-underline-offset: 2px; }

  /* Layout */
  .ptp__layout { display: grid; grid-template-columns: 1fr; gap: 2.5rem; margin-bottom: 3.5rem; }
  @media (min-width: 750px) {
    .ptp__layout { grid-template-columns: 1fr 1fr; gap: 4rem; }
    .ptp__info-col--sticky { position: sticky; top: 2rem; align-self: start; }
  }

  /* Gallery — matches ft__card-image */
  .ptp__gallery-main-wrap { position: relative; background: transparent; border-radius: 12px; min-height: 380px; max-height: 460px; display: flex; align-items: center; justify-content: center; padding: 2.5rem; overflow: hidden; }
  .ptp__gallery-main-img { max-height: 340px; }
  .ptp__gallery-main-img { width: 100%; height: 100%; object-fit: contain; cursor: zoom-in; transition: transform 0.3s ease; }
  .ptp__gallery-main-wrap:hover .ptp__gallery-main-img { transform: scale(1.03); }
  .ptp__sale-badge { position: absolute; top: 1rem; left: 1rem; background: var(--ptp-sale); color: #fff; font-size: 0.8rem; font-weight: 700; padding: 0.35rem 0.9rem; border-radius: 100px; z-index: 1; }
  .ptp__gallery-thumbs { display: flex; gap: 0.5rem; margin-top: 0.8rem; overflow-x: auto; scrollbar-width: none; }
  .ptp__gallery-thumbs::-webkit-scrollbar { display: none; }
  .ptp__gallery-thumb { flex: 0 0 5.5rem; width: 5.5rem; height: 5.5rem; border: 2px solid var(--ptp-border); border-radius: var(--ptp-r-sm); background: #fff; cursor: pointer; padding: 0.4rem; transition: all 0.2s; box-shadow: 0 1px 2px rgba(0,0,0,0.04); }
  .ptp__gallery-thumb--active { border-color: var(--ptp-accent); box-shadow: 0 0 0 1px var(--ptp-accent); }
  .ptp__gallery-thumb--video { display: flex; align-items: center; justify-content: center; background: #f1f5f9; }
  .ptp__gallery-video { position: relative; background: #000; border-radius: var(--ptp-r); overflow: hidden; aspect-ratio: 16/9; margin-bottom: 0.8rem; }
  .ptp__gallery-video[hidden] { display: none; }
  .ptp__gallery-video-close { position: absolute; top: 0.5rem; right: 0.5rem; z-index: 2; width: 2rem; height: 2rem; background: rgba(0,0,0,0.6); color: #fff; border: none; border-radius: 50%; font-size: 1.2rem; cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .ptp__gallery-video-wrap { width: 100%; height: 100%; }
  .ptp__gallery-video-wrap iframe { width: 100%; height: 100%; border: none; }
  .ptp__gallery-thumb:hover { border-color: var(--ptp-accent); }
  .ptp__gallery-thumb-img { width: 100%; height: 100%; object-fit: contain; }

  /* Info Column — matches ft__eyebrow + ft__heading exactly */
  .ptp__vendor { font-family: 'Outfit', sans-serif; font-size: 1.15rem; font-weight: 400; color: #9ca3af; text-decoration: none; display: inline-block; margin-bottom: 0.5rem; letter-spacing: 0.02em; }
  .ptp__vendor:hover { color: #111; }
  .ptp__title { font-family: 'Barlow Condensed', sans-serif; font-size: 2.8rem; font-weight: 700; color: #111; margin: 0 0 1rem; line-height: 1.1; letter-spacing: 0.02em; }
  .ptp__quick-specs { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.8rem; }
  .ptp__quick-spec-tag { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.85rem; font-weight: 500; padding: 0.35rem 0.8rem; border-radius: 100px; color: #6b7280; background: #f3f4f6; border: 1px solid #e5e7eb; }
  .ptp__quick-spec-tag svg { stroke: #9ca3af; }
  .ptp__rating-row { margin-bottom: 1rem; }
  .ptp__rating { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 1rem; font-weight: 500; }
  .ptp .rating-star { --color-rating-star: #F5820B; --letter-spacing: 0.6; --font-size: 1.5; }
  .ptp__rating-text { font-weight: 600; color: var(--ptp-text); }
  .ptp__rating-count { color: var(--ptp-muted); font-weight: 400; font-size: 0.9rem; }

  /* Pricing Card — matches ft__card style */
  .ptp__pricing-card { background: #fff; padding: 0; margin-bottom: 1.5rem; border-bottom: 1px solid #f3f4f6; padding-bottom: 1.5rem; }
  .ptp__price-hero { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.4rem; }
  .ptp__price-hero-left { display: flex; align-items: baseline; gap: 0.5rem; }
  .ptp__price-hero-amount { font-family: 'Barlow Condensed', sans-serif; font-size: 3rem; font-weight: 700; color: #111; letter-spacing: 0.02em; }
  .ptp__price-hero-label { font-family: 'Outfit', sans-serif; font-size: 1.1rem; font-weight: 300; color: #9ca3af; }
  .ptp__stock { font-family: 'Outfit', sans-serif; font-size: 0.85rem; font-weight: 600; padding: 0.3rem 0.7rem; border-radius: 100px; display: inline-flex; align-items: center; gap: 0.3rem; }
  .ptp__stock--in { color: #16a34a; background: #f0fdf4; }
  .ptp__stock--low { color: #d97706; background: #fffbeb; }
  .ptp__stock--out { color: #dc2626; background: #fef2f2; }
  .ptp__price-per-tire { display: flex; align-items: baseline; gap: 0.4rem; flex-wrap: wrap; border-top: 1px solid var(--ptp-border); padding-top: 0.6rem; margin-top: 0.2rem; }
  .ptp__price-current { font-family: 'Barlow Condensed', sans-serif; font-size: 1.5rem; font-weight: 700; color: #111; }
  .ptp__price-current--sale { color: #dc2626; }
  .ptp__price-was { font-size: 1rem; color: #9ca3af; text-decoration: line-through; }
  .ptp__price-per { font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 300; color: #9ca3af; }
  .ptp__save-tag { font-family: 'Outfit', sans-serif; font-size: 0.78rem; font-weight: 600; color: #fff; background: #dc2626; padding: 0.2rem 0.55rem; border-radius: 100px; }
  .ptp__installed-price { border-top: 1px dashed var(--ptp-border); padding-top: 0.7rem; margin-top: 0.5rem; }
  .ptp__installed-price-row { display: flex; align-items: center; justify-content: space-between; }
  .ptp__installed-label { display: flex; align-items: center; gap: 0.4rem; font-size: 0.9rem; font-weight: 500; color: var(--ptp-subtle); }
  .ptp__installed-label svg { stroke: var(--ptp-accent); }
  .ptp__installed-amount { font-family: 'Barlow Condensed', sans-serif; font-size: 1.4rem; font-weight: 700; color: var(--ptp-accent); }
  .ptp__installed-note { font-size: 0.75rem; color: var(--ptp-muted); display: block; margin-top: 0.15rem; }
  .ptp__rebate-banner { display: flex; align-items: center; gap: 0.5rem; padding: 0.65rem 1rem; margin-bottom: 0.8rem; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border: 1px solid #fbbf24; border-radius: var(--ptp-r-sm); font-size: 0.88rem; font-weight: 600; color: #92400e; }
  .ptp__rebate-banner svg { stroke: #d97706; flex-shrink: 0; }

  /* Back in stock */
  .ptp__back-in-stock { padding: 1.2rem; background: #f8fafc; border: 1.5px dashed var(--ptp-border-soft); border-radius: var(--ptp-r-sm); }
  .ptp__bis-text { display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; font-weight: 500; color: var(--ptp-subtle); margin: 0 0 0.8rem; }
  .ptp__bis-text svg { stroke: var(--ptp-muted); flex-shrink: 0; }
  .ptp__bis-form { display: flex; gap: 0.5rem; }
  .ptp__bis-email { flex: 1; height: 3rem; padding: 0 1rem; border: 1.5px solid var(--ptp-border); border-radius: var(--ptp-r-sm); font-family: var(--ptp-font); font-size: 0.9rem; color: var(--ptp-text); background: #fff; }
  .ptp__bis-email:focus { outline: none; border-color: var(--ptp-accent); }
  .ptp__bis-btn { height: 3rem; padding: 0 1.4rem; background: var(--ptp-cta); color: #fff; border: none; border-radius: var(--ptp-r-sm); font-family: var(--ptp-font); font-size: 0.9rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: background 0.2s; }
  .ptp__bis-btn:hover { background: var(--ptp-cta-hover); }
  .ptp__bis-success { display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; font-weight: 500; color: #16a34a; margin: 0.6rem 0 0; }
  .ptp__bis-success[hidden] { display: none; }

  /* CTA Stack */
  .ptp__cta-stack { display: flex; flex-direction: column; gap: 0.7rem; }
  .ptp__book-btn {
    display: flex; width: 100%; background: #dc2626; color: #fff; border: none;
    text-align: center; padding: 1rem; border-radius: 10px;
    font-family: 'Outfit', sans-serif; font-size: 1.15rem; font-weight: 600;
    cursor: pointer; transition: all 0.2s; align-items: center; justify-content: center; gap: 0.5rem;
  }
  .ptp__book-btn:hover { background: #b91c1c; }
  @media (max-width: 749px) {
    .ptp__book-btn { padding: 0.6rem 0.75rem; font-size: 0.9rem; white-space: nowrap; }
  }

  .ptp__cart-row { display: flex; gap: 0.6rem; }
  .ptp__qty { display: flex; align-items: center; background: #fff; border: 1.5px solid #e5e7eb; border-radius: 10px; overflow: hidden; flex-shrink: 0; }
  .ptp__qty button { width: 3.2rem; height: 3.4rem; border: none; background: transparent; cursor: pointer; color: #9ca3af; display: flex; align-items: center; justify-content: center; transition: all 0.15s; }
  .ptp__qty button:hover { color: #111; background: #f9fafb; }
  .ptp__qty input { width: 2.6rem; height: 3.4rem; text-align: center; border: none; background: transparent; font-family: 'Outfit', sans-serif; font-size: 1.1rem; font-weight: 600; color: #111; -moz-appearance: textfield; }
  .ptp__qty input::-webkit-inner-spin-button { -webkit-appearance: none; }
  .ptp__add-btn {
    flex: 1; height: 3.4rem; background: #f3f4f6; color: #374151;
    border: none; border-radius: 10px;
    font-family: 'Outfit', sans-serif; font-size: 0.95rem; font-weight: 600;
    cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 0.4rem;
  }
  .ptp__add-btn:hover { background: #e5e7eb; }
  .ptp__add-btn:disabled { background: #f9fafb; color: #d1d5db; cursor: not-allowed; }
  .ptp__add-btn--loading { opacity: 0.65; pointer-events: none; }
  .ptp__add-btn--loading svg { animation: ptp-spin 0.7s linear infinite; }
  .ptp__add-btn--success { background: #16a34a !important; color: #fff !important; }
  .ptp__add-btn--success:hover { background: #15803d !important; }
  .ptp__add-btn--error { background: #fef2f2 !important; color: #dc2626 !important; }

  /* Cart toast */
  .ptp-toast { position: fixed; bottom: 1.75rem; left: 50%; transform: translateX(-50%) translateY(10px); background: #111; color: #fff; padding: .75rem 1.25rem; border-radius: 10px; font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 500; display: flex; align-items: center; gap: .5rem; z-index: 99999; opacity: 0; transition: opacity .22s, transform .22s; pointer-events: none; white-space: nowrap; box-shadow: 0 4px 24px rgba(0,0,0,.18); }
  .ptp-toast--in { opacity: 1; transform: translateX(-50%) translateY(0); }
  .ptp-toast--error { background: #dc2626; }
  .loading__spinner { display: flex; align-items: center; justify-content: center; padding: 1rem; }
  .loading__spinner.hidden { display: none; }
  .loading__spinner .spinner { width: 2rem; height: 2rem; animation: ptp-spin 0.8s linear infinite; }
  .loading__spinner .path { stroke: var(--ptp-cta); stroke-linecap: round; animation: ptp-dash 1.5s ease-in-out infinite; }
  @keyframes ptp-spin { to { transform: rotate(360deg); } }
  @keyframes ptp-dash { 0% { stroke-dasharray: 1, 150; stroke-dashoffset: 0; } 50% { stroke-dasharray: 90, 150; stroke-dashoffset: -35; } 100% { stroke-dasharray: 90, 150; stroke-dashoffset: -124; } }

  /* Trust */
  .ptp__trust { display: flex; flex-direction: column; gap: 0.8rem; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid #f3f4f6; }
  .ptp__trust-item { display: flex; align-items: center; gap: 0.8rem; }
  .ptp__trust-item:hover { opacity: 0.8; }
  .ptp__trust-item + .ptp__trust-item { }
  .ptp__trust-icon { width: 2rem; height: 2rem; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
  .ptp__trust-icon svg { stroke: #9ca3af; width: 18px; height: 18px; }
  .ptp__trust-text { display: flex; flex-direction: column; gap: 0; }
  .ptp__trust-text strong { font-family: 'Outfit', sans-serif; font-size: 0.95rem; font-weight: 500; color: #111; line-height: 1.3; }
  .ptp__trust-text span { font-family: 'Outfit', sans-serif; font-size: 0.85rem; font-weight: 300; color: #9ca3af; }

  /* ===== HORIZONTAL TABS — section-level styling ===== */
  .ptp__tabs-section { background: #fff; padding: 3.5rem 0 3rem; margin-top: 0; border-top: 1px solid #f3f4f6; }
  .ptp__tabs-heading span { color: #dc2626; }
  .ptp__tabs { max-width: 780px; margin: 0 auto 2rem; }
  .ptp__tab-bar { display: flex; gap: 0; border-bottom: 2px solid var(--ptp-border); overflow-x: auto; scrollbar-width: none; }
  .ptp__tab-bar::-webkit-scrollbar { display: none; }
  .ptp__tab {
    padding: 1rem 1.4rem; font-family: var(--ptp-font); font-size: 0.9rem; font-weight: 600;
    color: var(--ptp-muted); background: none; border: none;
    border-bottom: 2px solid transparent; margin-bottom: -2px;
    cursor: pointer; white-space: nowrap; display: flex; align-items: center; gap: 0.45rem;
    transition: all 0.2s;
  }
  .ptp__tab svg { width: 16px; height: 16px; flex-shrink: 0; }
  .ptp__tab--active { color: var(--ptp-cta); border-bottom-color: var(--ptp-cta); }
  .ptp__tab--active svg { stroke: var(--ptp-cta); }
  .ptp__tab:hover:not(.ptp__tab--active) { color: var(--ptp-text); }
  .ptp__tab-panels { min-height: 12rem; }
  .ptp__tab-panel { display: none; padding: 1.5rem 0; animation: ptp-fade 0.25s ease; }
  .ptp__tab-panel--active { display: block; }
  @keyframes ptp-fade { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }

  /* Specs */
  .ptp__specs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
  .ptp__spec-item { display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid #f1f5f9; }
  .ptp__spec-label { font-size: 0.95rem; font-weight: 500; color: var(--ptp-muted); }
  .ptp__spec-val { font-size: 0.95rem; font-weight: 600; color: var(--ptp-text); }
  .ptp__spec-item:nth-child(odd) { padding-right: 1.5rem; border-right: 1px solid #f1f5f9; }
  .ptp__spec-item:nth-child(even) { padding-left: 1.5rem; }
  .ptp__perf-heading { font-family: var(--ptp-font); font-size: 0.95rem; font-weight: 600; color: var(--ptp-muted); margin: 1.5rem 0 1rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .ptp__perf-bars { display: flex; flex-direction: column; gap: 0.9rem; }
  .ptp__perf-row { display: flex; align-items: center; gap: 0.8rem; }
  .ptp__perf-label { width: 9rem; flex-shrink: 0; font-size: 0.95rem; font-weight: 500; color: var(--ptp-muted); }
  .ptp__perf-track { flex: 1; height: 10px; background: #f1f5f9; border-radius: 5px; overflow: hidden; }
  .ptp__perf-fill { height: 100%; border-radius: 5px; transition: width 2.5s cubic-bezier(0.16,1,0.3,1); }
  .ptp__perf-val { width: 2.5rem; text-align: right; font-size: 1.1rem; font-weight: 700; color: var(--ptp-text); }

  /* Warranty */
  .ptp__warranty-grid { display: grid; grid-template-columns: 1fr; gap: 0.5rem; }
  .ptp__warranty-item { display: flex; align-items: center; gap: 1rem; padding: 1rem 1.2rem; background: var(--ptp-bg2); border-radius: var(--ptp-r-sm); border: 1px solid #f1f5f9; }
  .ptp__warranty-item svg { flex-shrink: 0; }
  .ptp__warranty-item div { display: flex; flex-direction: column; gap: 0.15rem; }
  .ptp__warranty-item strong { font-size: 0.95rem; color: var(--ptp-text); }
  .ptp__warranty-item span { font-size: 0.85rem; color: var(--ptp-muted); }
  .ptp__description, .ptp__shipping-info { font-size: 1.05rem; line-height: 1.75; color: #475569; }

  /* Warranty badge in specs */
  .ptp__warranty-badge { display: flex; align-items: center; gap: 0.6rem; margin-top: 1.2rem; padding: 0.8rem 1rem; background: #fff7ed; border: 1px solid #fed7aa; border-radius: 8px; font-size: 0.95rem; font-weight: 600; color: #9a3412; }

  /* Use cases (best for / not recommended) */
  .ptp__use-cases { display: flex; gap: 1rem; margin: 1.5rem 0; }
  .ptp__use-case { flex: 1; padding: 1rem 1.2rem; border-radius: 8px; }
  .ptp__use-case--good { background: #f0fdf4; border: 1px solid #bbf7d0; }
  .ptp__use-case--caution { background: #fef2f2; border: 1px solid #fecaca; }
  .ptp__use-case-label { display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; font-weight: 600; color: #374151; margin-bottom: 0.6rem; }
  .ptp__use-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .ptp__use-tag { font-size: 0.82rem; font-weight: 500; padding: 0.25rem 0.7rem; border-radius: 50px; }
  .ptp__use-tag--green { background: #dcfce7; color: #166534; }
  .ptp__use-tag--red { background: #fee2e2; color: #991b1b; }

  /* Description sub-headings */
  .ptp__desc-subheading { font-size: 1rem; font-weight: 600; color: var(--ptp-text); margin: 1.8rem 0 0.8rem; padding-bottom: 0.4rem; border-bottom: 1px solid #f1f5f9; }

  /* Compatible vehicles */
  .ptp__vehicle-list { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .ptp__vehicle-chip { font-size: 0.85rem; font-weight: 400; color: #374151; padding: 0.35rem 0.8rem; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 6px; }

  /* Calgary driving note */
  .ptp__local-note { font-size: 1rem; line-height: 1.75; color: #475569; padding: 1rem 1.2rem; background: #f8fafc; border-left: 3px solid #F5820B; border-radius: 0 8px 8px 0; }
  .ptp__local-note p { margin: 0; }

  /* FAQ */
  .ptp__faq-list { display: flex; flex-direction: column; }
  .ptp__faq-item { border-bottom: 1px solid #e5e7eb; }
  .ptp__faq-q { font-size: 0.95rem; font-weight: 600; color: var(--ptp-text); padding: 0.9rem 1.8rem 0.9rem 0; cursor: pointer; list-style: none; position: relative; }
  .ptp__faq-q::-webkit-details-marker { display: none; }
  .ptp__faq-q::after { content: '+'; position: absolute; right: 0; top: 50%; transform: translateY(-50%); font-size: 1.3rem; font-weight: 300; color: #9ca3af; }
  .ptp__faq-item[open] .ptp__faq-q::after { content: '\2212'; }
  .ptp__faq-a { font-size: 0.95rem; line-height: 1.75; color: #475569; padding: 0 0 1rem; }

  @media (max-width: 768px) {
    .ptp__use-cases { flex-direction: column; }
  }

  /* AI Assistant */
  .ptp__ai { max-width: 640px; }
  .ptp__ai-header { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1rem; }
  .ptp__ai-logo { width: 2.8rem; height: 2.8rem; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #F5820B 0%, #dc2626 100%); border-radius: 50%; color: #fff; }
  .ptp__ai-logo svg { stroke: #fff; }
  .ptp__ai-header strong { font-size: 1rem; color: var(--ptp-text); display: block; }
  .ptp__ai-header span { font-size: 0.85rem; color: var(--ptp-muted); }
  .ptp__ai-suggestions { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .ptp__ai-chip {
    padding: 0.5rem 1rem; border: 1.5px solid var(--ptp-border); border-radius: 100px;
    background: var(--ptp-bg); font-family: var(--ptp-font); font-size: 0.85rem; font-weight: 500;
    color: var(--ptp-muted); cursor: pointer; transition: all 0.2s;
  }
  .ptp__ai-chip:hover { border-color: var(--ptp-accent); color: var(--ptp-accent); }
  .ptp__ai-chat { display: flex; flex-direction: column; gap: 0.8rem; max-height: 24rem; overflow-y: auto; margin-bottom: 1rem; scrollbar-width: thin; }
  .ptp__ai-msg { padding: 0.8rem 1rem; border-radius: var(--ptp-r-sm); font-size: 0.9rem; line-height: 1.6; max-width: 90%; animation: ptp-fade 0.3s ease; }
  .ptp__ai-msg--user { background: var(--ptp-text); color: #fff; align-self: flex-end; border-bottom-right-radius: 2px; }
  .ptp__ai-msg--bot { background: var(--ptp-bg2); color: var(--ptp-text); border: 1px solid var(--ptp-border); align-self: flex-start; border-bottom-left-radius: 2px; }
  .ptp__ai-input-row { display: flex; gap: 0.5rem; }
  .ptp__ai-input {
    flex: 1; height: 3rem; padding: 0 1rem; border: 1.5px solid var(--ptp-border); border-radius: var(--ptp-r-sm);
    font-family: var(--ptp-font); font-size: 0.9rem; color: var(--ptp-text); background: var(--ptp-bg);
    transition: border-color 0.2s;
  }
  .ptp__ai-input:focus { outline: none; border-color: var(--ptp-accent); }
  .ptp__ai-send {
    width: 3rem; height: 3rem; border: none; border-radius: var(--ptp-r-sm);
    background: var(--ptp-accent); color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
  }
  .ptp__ai-send:hover { background: var(--ptp-accent-dark); }
  .ptp__ai-send svg { stroke: #fff; }

  /* Browse & Share Links */
  .ptp__links-row { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; max-width: 780px; margin: 0 auto; padding-top: 2rem; border-top: 1px solid #f3f4f6; }
  .ptp__links { display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .ptp__link { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.55rem 1.1rem; border: 1.5px solid var(--ptp-border); border-radius: 100px; font-size: 0.9rem; font-weight: 500; color: var(--ptp-muted); text-decoration: none; transition: all 0.2s; }
  .ptp__link:hover { border-color: var(--ptp-accent); color: var(--ptp-accent); }
  .ptp__share { display: flex; align-items: center; gap: 0.5rem; }
  .ptp__share-label { font-size: 0.82rem; font-weight: 500; color: var(--ptp-muted); }
  .ptp__share-btn { width: 2.4rem; height: 2.4rem; display: flex; align-items: center; justify-content: center; border: 1.5px solid transparent; border-radius: 50%; cursor: pointer; transition: all 0.2s; text-decoration: none; }
  .ptp__share-btn svg { width: 14px; height: 14px; }
  /* WhatsApp */
  .ptp__share-btn--wa { background: #25d366; color: #fff; border-color: #25d366; }
  .ptp__share-btn--wa:hover { background: #20ba5a; border-color: #20ba5a; transform: scale(1.08); }
  /* Facebook */
  .ptp__share-btn--fb { background: #1877f2; color: #fff; border-color: #1877f2; }
  .ptp__share-btn--fb:hover { background: #1464d4; border-color: #1464d4; transform: scale(1.08); }
  /* Copy link */
  .ptp__share-btn--link { background: #f3f4f6; color: #6b7280; border-color: #e5e7eb; }
  .ptp__share-btn--link:hover { background: #e5e7eb; color: #374151; transform: scale(1.08); }
  /* Bigger paragraph text in tabs */
  .ptp__tab-panel p, .ptp__tab-panel li, .ptp__description p, .ptp__description li,
  .ptp__shipping-info p, .ptp__warranty-item span { font-size: 1rem; line-height: 1.7; }

  /* Sticky */
  .ptp__sticky { display: none; }
  @media (max-width: 989px) {
    .ptp__container { padding: 3rem 2rem 0; }
    .ptp__tabs-section { padding: 3rem 0 2.5rem; }
    .ptp__install-band { padding: 3.5rem 0; }
  }
  @media (max-width: 749px) {
    .ptp__container { padding: 3rem 2rem 5rem; }
    .ptp__tabs-section { padding: 2.5rem 0 2rem; }
    .ptp__title { font-size: 2rem; }
    .ptp__price-hero-amount { font-size: 2.2rem; }
    .ptp__specs-grid { grid-template-columns: 1fr; }
    .ptp__spec-item:nth-child(odd) { padding-right: 0; border-right: none; }
    .ptp__spec-item:nth-child(even) { padding-left: 0; }
    .ptp__sticky {
      display: flex; position: fixed; bottom: 0; left: 0; right: 0; z-index: 99;
      background: #fff; border-top: 1px solid var(--ptp-border);
      padding: 0.7rem 1.4rem; align-items: center; gap: 0.8rem;
      box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
    }
    .ptp__sticky-thumb { width: 2.8rem; height: 2.8rem; object-fit: contain; border-radius: 6px; background: var(--ptp-bg2); flex-shrink: 0; }
    .ptp__sticky-price { display: flex; flex-direction: column; line-height: 1.2; flex: 1; min-width: 0; }
    .ptp__sticky-set { font-size: 1.25rem; font-weight: 700; color: var(--ptp-text); }
    .ptp__sticky-per { font-size: 0.8rem; color: var(--ptp-subtle); }
    .ptp__sticky-btn { flex-shrink: 0; height: 3.2rem; padding: 0 1.4rem; background: var(--ptp-cta); color: #fff; border: none; border-radius: var(--ptp-r-sm); font-family: var(--ptp-font); font-size: 0.95rem; font-weight: 700; cursor: pointer; box-shadow: 0 2px 8px rgba(220,38,38,0.25); }
  }

  /* Key Stats Strip */
  .ptp__stats-strip {
    display: flex; align-items: stretch;
    overflow: hidden; margin-bottom: 0;
    background: #f9fafb; border-radius: 12px;
  }
  .ptp__stat {
    flex: 1; display: flex; flex-direction: column; align-items: center;
    justify-content: center; text-align: center; padding: 1.5rem 1rem; gap: 0.25rem;
  }
  .ptp__stat + .ptp__stat { border-left: 1px solid #f3f4f6; }
  .ptp__stat-num {
    font-family: 'Barlow Condensed', sans-serif; font-size: 1.4rem; font-weight: 700;
    color: #111; line-height: 1; letter-spacing: 0.02em;
  }
  .ptp__stat-unit { font-size: 1.1rem; font-weight: 400; color: #9ca3af; margin-left: 0.2rem; }
  .ptp__stat-brand { font-size: 1.5rem; }
  .ptp__stat-label {
    font-family: 'Outfit', sans-serif; font-size: 0.82rem; font-weight: 400;
    color: #9ca3af; text-transform: uppercase; letter-spacing: 0.06em;
  }
  @media (max-width: 749px) {
    .ptp__stats-strip { display: grid; grid-template-columns: 1fr 1fr; }
    .ptp__stat:nth-child(odd):not(:last-child) { border-right: 1px solid var(--ptp-border); }
    .ptp__stat + .ptp__stat { border-left: none; }
    .ptp__stat:nth-child(n+3) { border-top: 1px solid var(--ptp-border); }
  }

  /* Season Banner */
  .ptp__season-banner {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 0.9rem; margin-bottom: 0.8rem;
    background: color-mix(in srgb, var(--season-clr) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--season-clr) 22%, transparent);
    border-radius: 6px; font-size: 0.8rem; font-weight: 600;
    color: var(--season-clr);
  }
  .ptp__season-banner svg { fill: var(--season-clr); flex-shrink: 0; }
  .ptp__weather-warn { display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.9rem; margin-bottom: 0.8rem; background: #fef3c7; border: 1px solid #fbbf24; border-radius: 6px; font-size: 0.8rem; font-weight: 500; color: #92400e; }
  .ptp__weather-warn[hidden] { display: none; }
  .ptp__weather-warn svg { stroke: #d97706; flex-shrink: 0; }
  .ptp__weather-warn a { color: #d97706; font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }

  /* Installation Band */
  .ptp__install-band {
    background: #f7f7f7; padding: 4rem 0;
    position: relative; overflow: hidden;
  }
  .ptp__install-band::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, #F5820B 0%, #dc2626 50%, #F5820B 100%);
  }
  .ptp__install-band-grid {
    max-width: var(--ptp-max-width); margin: 0 auto;
    display: grid; grid-template-columns: 1fr auto auto;
    align-items: center; gap: 3rem;
  }
  .ptp__install-eyebrow {
    display: block; font-family: var(--ptp-font); font-size: 0.82rem;
    font-weight: 600; color: #F5820B; text-transform: uppercase;
    letter-spacing: 0.08em; margin-bottom: 0.4rem;
  }
  .ptp__install-heading {
    font-family: var(--ptp-heading); font-size: clamp(1.5rem, 2.2vw, 2rem);
    font-weight: 700; color: #111; margin: 0 0 0.4rem;
    text-transform: uppercase; letter-spacing: 0.02em;
  }
  .ptp__install-sub { font-family: var(--ptp-font); font-size: 0.9rem; color: #6b7280; margin: 0; }
  .ptp__install-perks { display: flex; flex-direction: column; gap: 0.65rem; }
  .ptp__install-perk {
    display: flex; align-items: center; gap: 0.55rem;
    font-family: var(--ptp-font); font-size: 0.88rem; color: #6b7280;
  }
  .ptp__install-perk svg { stroke: #F5820B; flex-shrink: 0; }
  .ptp__install-cta { display: flex; flex-direction: column; align-items: center; gap: 0.55rem; }
  .ptp__install-btn {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0 2rem; height: 3.6rem; background: #dc2626; color: #fff;
    border: none; border-radius: 8px; font-family: var(--ptp-font);
    font-size: 1rem; font-weight: 700; cursor: pointer; white-space: nowrap;
    transition: background 0.2s, transform 0.2s;
    box-shadow: 0 2px 16px rgba(220,38,38,0.4);
  }
  .ptp__install-btn:hover { background: #b91c1c; transform: translateY(-1px); }
  .ptp__install-note { font-family: var(--ptp-font); font-size: 0.75rem; color: #9ca3af; text-align: center; }

  @media (max-width: 989px) {
    .ptp__install-band-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .ptp__install-cta { grid-column: 1 / -1; align-items: flex-start; }
  }
  @media (max-width: 749px) {
    .ptp__install-band-grid { grid-template-columns: 1fr; gap: 1.8rem; }
    .ptp__install-btn { width: 100%; justify-content: center; }
  }
{% endstylesheet %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  /* sec — used by all sub-modules below */
  var sec = document;

  var qtyInput = document.querySelector('[data-ptp-qty]');
  var cartTotal = document.querySelector('[data-ptp-cart-total]');
  var unitPrice = {{ product.selected_or_first_available_variant.price }} / 100;

  function updateTotal() { if (cartTotal && qtyInput) cartTotal.textContent = '$' + (parseInt(qtyInput.value || 1) * unitPrice).toFixed(2); }
  function updateStickyTotal() { var s = document.querySelector('[data-ptp-sticky-total]'); if (s && qtyInput) s.textContent = '$' + (parseInt(qtyInput.value || 1) * unitPrice).toFixed(2); }

  if (qtyInput) {
    var m = document.querySelector('[data-ptp-qty-minus]'), p = document.querySelector('[data-ptp-qty-plus]');
    if (m) m.addEventListener('click', function() { var v = parseInt(qtyInput.value)||1; if(v>1){qtyInput.value=v-1; updateTotal(); updateStickyTotal();} });
    if (p) p.addEventListener('click', function() { var v = parseInt(qtyInput.value)||1; qtyInput.value=v+1; updateTotal(); updateStickyTotal(); });
    qtyInput.addEventListener('change', function() { updateTotal(); updateStickyTotal(); });
  }

  /* ── Cart count updater ─────────────────────────────────────────────── */
  function updateCartCount() {
    fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var count = cart.item_count;
        var cartLink = document.getElementById('cart-icon-bubble');
        if (cartLink) {
          var badge = cartLink.querySelector('.nb-badge');
          if (count > 0) {
            if (badge) { badge.textContent = count; }
            else { badge = document.createElement('span'); badge.className = 'nb-badge'; badge.textContent = count; cartLink.appendChild(badge); }
          } else if (badge) { badge.remove(); }
        }
        var bubble = document.querySelector('.cart-count-bubble span[aria-hidden]');
        if (bubble) bubble.textContent = count;
      })
      .catch(function() {});
  }

  /* ── Toast notification ─────────────────────────────────────────────── */
  function showToast(msg, type) {
    var t = document.createElement('div');
    t.className = 'ptp-toast' + (type === 'error' ? ' ptp-toast--error' : '');
    var icon = type === 'error'
      ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>'
      : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>';
    t.innerHTML = icon + msg;
    document.body.appendChild(t);
    requestAnimationFrame(function() { requestAnimationFrame(function() { t.classList.add('ptp-toast--in'); }); });
    setTimeout(function() {
      t.classList.remove('ptp-toast--in');
      setTimeout(function() { if (t.parentNode) t.parentNode.removeChild(t); }, 280);
    }, 3000);
  }

  /* ── AJAX add-to-cart ────────────────────────────────────────────────── */
  (function() {
    var form = document.querySelector('[data-type="add-to-cart-form"]');
    if (!form) return;
    var addBtn = form.querySelector('.ptp__add-btn');
    if (!addBtn) return;

    var cartIconSVG = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>';
    var spinnerSVG  = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>';
    var checkSVG    = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>';
    var totalEl     = addBtn.querySelector('[data-ptp-cart-total]');
    var idleTotal   = totalEl ? totalEl.textContent : '';
    var idleHTML    = cartIconSVG + 'Add to cart — <span data-ptp-cart-total>' + idleTotal + '</span>';

    /* Keep idleHTML in sync when qty changes */
    var qtyEl = form.querySelector('[name="quantity"]');
    if (qtyEl) {
      qtyEl.addEventListener('change', function() {
        var t2 = addBtn.querySelector('[data-ptp-cart-total]');
        if (t2) idleHTML = cartIconSVG + 'Add to cart — <span data-ptp-cart-total>' + t2.textContent + '</span>';
      });
    }

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var variantId = (form.querySelector('[name="id"]') || {}).value;
      var qty       = parseInt((form.querySelector('[name="quantity"]') || {}).value) || 1;
      if (!variantId) return;

      /* Sync idleHTML to current price label before going loading */
      var t2 = addBtn.querySelector('[data-ptp-cart-total]');
      if (t2) idleHTML = cartIconSVG + 'Add to cart — <span data-ptp-cart-total>' + t2.textContent + '</span>';

      addBtn.disabled = true;
      addBtn.classList.add('ptp__add-btn--loading');
      addBtn.innerHTML = spinnerSVG + ' Adding…';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ id: variantId, quantity: qty })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        addBtn.classList.remove('ptp__add-btn--loading');
        if (data.status) {
          addBtn.disabled = false;
          addBtn.classList.add('ptp__add-btn--error');
          addBtn.innerHTML = cartIconSVG + (data.description || 'Could not add to cart');
          showToast(data.description || 'Could not add to cart', 'error');
          setTimeout(function() { addBtn.classList.remove('ptp__add-btn--error'); addBtn.innerHTML = idleHTML; }, 3000);
        } else {
          addBtn.classList.add('ptp__add-btn--success');
          addBtn.innerHTML = checkSVG + ' Added to cart!';
          updateCartCount();
          showToast(qty + ' tire' + (qty > 1 ? 's' : '') + ' added to your cart');
          setTimeout(function() { addBtn.disabled = false; addBtn.classList.remove('ptp__add-btn--success'); addBtn.innerHTML = idleHTML; }, 2200);
        }
      })
      .catch(function() {
        addBtn.disabled = false;
        addBtn.classList.remove('ptp__add-btn--loading');
        addBtn.classList.add('ptp__add-btn--error');
        addBtn.innerHTML = cartIconSVG + 'Something went wrong';
        showToast('Something went wrong. Please try again.', 'error');
        setTimeout(function() { addBtn.classList.remove('ptp__add-btn--error'); addBtn.innerHTML = idleHTML; }, 3000);
      });
    });
  })();

  /* Fitment */
  (function() {
    var fitment = document.querySelector('[data-ptp-fitment]');
    if (!fitment) return;
    try {
      var keys = Object.keys(localStorage).filter(function(k) { return k.startsWith('pt-garage-'); });
      for (var i = 0; i < keys.length; i++) {
        var vehicles = JSON.parse(localStorage.getItem(keys[i]));
        var def = (vehicles || []).find(function(v) { return v.isDefault; });
        if (def) { var label = def.year + ' ' + def.make + ' ' + def.model; if (def.trim) label += ' ' + def.trim; fitment.querySelector('[data-ptp-fitment-vehicle]').textContent = label; fitment.hidden = false; break; }
      }
    } catch(e) {}
  })();

  /* Thumbnails */
  (function() {
    var thumbs = document.querySelectorAll('[data-ptp-thumb-idx]'), mainImg = document.getElementById('ptp-featured-img');
    if (!thumbs.length || !mainImg) return;
    thumbs.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        var src = this.dataset.ptpThumbSrc; if (!src) return;
        mainImg.src = src; mainImg.removeAttribute('srcset');
        thumbs.forEach(function(t) { t.classList.remove('ptp__gallery-thumb--active'); });
        this.classList.add('ptp__gallery-thumb--active');
      });
    });
  })();

  /* ===== TABS ===== */
  (function() {
    var tabs = document.querySelectorAll('[data-ptp-tab]');
    var panels = document.querySelectorAll('[data-ptp-panel]');
    if (!tabs.length) return;
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var target = this.dataset.ptpTab;
        tabs.forEach(function(t) { t.classList.remove('ptp__tab--active'); t.setAttribute('aria-selected', 'false'); });
        panels.forEach(function(p) { p.classList.remove('ptp__tab-panel--active'); });
        this.classList.add('ptp__tab--active');
        this.setAttribute('aria-selected', 'true');
        var panel = document.querySelector('[data-ptp-panel="' + target + '"]');
        if (panel) panel.classList.add('ptp__tab-panel--active');
        /* Trigger perf animation when specs tab opens */
        if (target === 'specs') triggerPerfAnimation();
      });
    });
  })();

  /* Performance bar animation */
  var perfAnimated = false;
  function triggerPerfAnimation() {
    var perfContainer = document.querySelector('[data-ptp-perf]');
    if (!perfContainer || perfAnimated) return;
    perfAnimated = true;
    perfContainer.querySelectorAll('[data-ptp-bar]').forEach(function(bar, i) {
      setTimeout(function() { bar.style.width = bar.dataset.ptpBar + '%'; }, i * 250);
    });
    perfContainer.querySelectorAll('[data-ptp-count]').forEach(function(el, i) {
      var target = parseInt(el.dataset.ptpCount);
      setTimeout(function() {
        var start = null;
        function step(ts) { if (!start) start = ts; var p = Math.min((ts - start) / 2000, 1); el.textContent = Math.round((1 - Math.pow(1-p,3)) * target); if (p < 1) requestAnimationFrame(step); }
        requestAnimationFrame(step);
      }, i * 250);
    });
  }
  /* Auto-trigger if specs tab is already active */
  var activePanel = document.querySelector('.ptp__tab-panel--active[data-ptp-panel="specs"]');
  if (activePanel && document.querySelector('[data-ptp-perf]')) {
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(function(e) { if (e[0].isIntersecting) triggerPerfAnimation(); }, { threshold: 0.3 }).observe(activePanel);
    } else { triggerPerfAnimation(); }
  }

  /* ===== AI CHAT ===== */
  (function() {
    var chat = document.querySelector('[data-ptp-ai-chat]');
    var input = document.querySelector('[data-ptp-ai-input]');
    var sendBtn = document.querySelector('[data-ptp-ai-send]');
    var chips = document.querySelectorAll('[data-ptp-ai-q]');
    if (!chat || !input) return;

    var productData = {
      title: {{ product.title | json }},
      vendor: {{ product.vendor | json }},
      type: {{ product.type | json }},
      size: {{ tire_size | json }},
      season: {{ season_tag | json }},
      price: unitPrice,
      setPrice: unitPrice * 4,
      available: {{ product.available | json }},
      description: {{ product.description | strip_html | truncate: 500 | json }}
    };

    function addMsg(text, type) {
      var div = document.createElement('div');
      div.className = 'ptp__ai-msg ptp__ai-msg--' + type;
      div.textContent = text;
      chat.appendChild(div);
      chat.scrollTop = chat.scrollHeight;
    }

    /* Fallback keyword-based responses (used when AI API is unavailable) */
    function getFallbackResponse(q) {
      var ql = q.toLowerCase();
      if (ql.indexOf('winter') > -1 || ql.indexOf('snow') > -1 || ql.indexOf('ice') > -1) {
        if (productData.season === 'Winter') return 'Yes! The ' + productData.title + ' is a winter tire designed for excellent traction on snow and ice.';
        if (productData.season === 'All-Weather') return 'This is an All-Weather tire with 3PMSF certification, meaning it\'s approved for winter use while also performing well in other seasons.';
        if (productData.season === 'All-Season') return 'This is an All-Season tire. It handles light winter conditions but for heavy snow/ice, a dedicated winter tire is recommended.';
        return 'This ' + productData.type + ' tire is a ' + (productData.season || 'general use') + ' tire. Check the season rating for winter suitability.';
      }
      if (ql.indexOf('last') > -1 || ql.indexOf('long') > -1 || ql.indexOf('life') > -1 || ql.indexOf('durable') > -1) {
        return 'Tire lifespan depends on driving habits, road conditions, and maintenance. Most ' + productData.vendor + ' tires in this category last 60,000-80,000 km with proper rotation every 8,000-10,000 km. Check the treadwear warranty in the Warranty tab.';
      }
      if (ql.indexOf('size') > -1 || ql.indexOf('rim') > -1 || ql.indexOf('fit') > -1 || ql.indexOf('vehicle') > -1 || ql.indexOf('car') > -1) {
        if (productData.size) return 'This tire is size ' + productData.size + '. Make sure your vehicle\'s door jamb sticker or owner\'s manual lists this size. The tire fits a ' + productData.size.split('R')[1] + '" rim diameter.';
        return 'Check your vehicle\'s door jamb sticker or owner\'s manual for the correct tire size.';
      }
      if (ql.indexOf('price') > -1 || ql.indexOf('cost') > -1 || ql.indexOf('cheap') > -1) {
        return 'This tire is $' + productData.price.toFixed(2) + ' each, or $' + productData.setPrice.toFixed(2) + ' for a set of 4. Book installation through our page for the best service experience.';
      }
      if (ql.indexOf('install') > -1 || ql.indexOf('book') > -1 || ql.indexOf('mount') > -1) {
        return 'You can book professional installation directly from this page using the red "Book installation" button above. We\'ll handle mounting, balancing, and disposal of your old tires.';
      }
      return 'The ' + productData.title + ' is a ' + (productData.season || '') + ' ' + (productData.type || 'tire') + ' by ' + productData.vendor + ' in size ' + (productData.size || 'N/A') + ', priced at $' + productData.price.toFixed(2) + '/tire. What would you like to know?';
    }

    /* AI-powered response via proxy endpoint */
    var AI_ENDPOINT = 'https://prince-tires-ai.vercel.app/api/chat';
    var chatHistory = [];

    function getAIResponse(q, callback) {
      chatHistory.push({ role: 'user', content: q });

      var payload = {
        messages: chatHistory.slice(-6), /* Keep last 3 exchanges */
        product: {
          title: productData.title,
          vendor: productData.vendor,
          type: productData.type,
          size: productData.size,
          season: productData.season,
          price: productData.price,
          available: productData.available,
          description: productData.description,
          warranty_km: {{ product.metafields.custom.warranty_km | json }},
          speed_rating: {{ product.metafields.custom.speed_rating | json }},
          load_index: {{ product.metafields.custom.load_index | json }},
          vehicle_type: {{ product.metafields.custom.vehicle_type | json }},
          three_peak: {{ product.metafields.custom.three_peak_snowflake | json }},
          best_for: {{ product.metafields.custom.best_for | json }},
          not_recommended: {{ product.metafields.custom.not_recommended_for | json }}
        }
      };

      fetch(AI_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      .then(function(r) {
        if (!r.ok) throw new Error('AI unavailable');
        return r.json();
      })
      .then(function(data) {
        var reply = data.reply || data.message || data.response;
        if (reply) {
          chatHistory.push({ role: 'assistant', content: reply });
          callback(reply);
        } else {
          callback(getFallbackResponse(q));
        }
      })
      .catch(function() {
        /* Fallback to keyword matching */
        var fallback = getFallbackResponse(q);
        chatHistory.push({ role: 'assistant', content: fallback });
        callback(fallback);
      });
    }

    function handleQuestion(q) {
      if (!q.trim()) return;
      addMsg(q, 'user');
      input.value = '';
      /* Show typing indicator */
      var typing = document.createElement('div');
      typing.className = 'ptp__ai-msg ptp__ai-msg--bot';
      typing.textContent = 'Thinking...';
      typing.style.opacity = '0.6';
      chat.appendChild(typing);
      chat.scrollTop = chat.scrollHeight;

      getAIResponse(q, function(reply) {
        chat.removeChild(typing);
        addMsg(reply, 'bot');
      });
    }

    if (sendBtn) sendBtn.addEventListener('click', function() { handleQuestion(input.value); });
    input.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); handleQuestion(input.value); } });
    chips.forEach(function(chip) { chip.addEventListener('click', function() { handleQuestion(this.dataset.ptpAiQ); }); });
  })();

  if (typeof enableZoomOnHover === 'function') enableZoomOnHover(2);

  /* Weather-based seasonal warning */
  (function() {
    var warn = sec.querySelector('[data-ptp-weather-warn]');
    if (!warn) return;
    var season = warn.dataset.tireSeason;
    if (!season) return;
    var msgEl = warn.querySelector('[data-ptp-weather-msg]');

    fetch('https://api.open-meteo.com/v1/forecast?latitude=51.0447&longitude=-114.0719&current=temperature_2m&timezone=America/Edmonton')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.current) return;
        var temp = Math.round(data.current.temperature_2m);
        var msg = '';

        if (season === 'summer' && temp < 7) {
          msg = "It's " + temp + "°C in Calgary right now. Summer tires are not recommended below 7°C. <a href='/collections/winter-tires'>Shop winter tires</a>";
        } else if (season === 'winter' && temp > 15) {
          msg = "It's " + temp + "°C in Calgary. Winter tires wear faster in warm weather. <a href='/collections/all-season-tires'>Shop all-season tires</a>";
        }

        if (msg) {
          msgEl.innerHTML = msg;
          warn.hidden = false;
        }
      })
      .catch(function() { /* silently fail */ });
  })();

  /* Video gallery support */
  (function() {
    var videoThumb = sec.querySelector('[data-ptp-video-thumb]');
    if (!videoThumb) return;
    var videoOverlay = sec.querySelector('[data-ptp-video]');
    var videoWrap = sec.querySelector('[data-ptp-video-wrap]');
    var videoClose = sec.querySelector('[data-ptp-video-close]');
    var mainWrap = sec.querySelector('.ptp__gallery-main');

    function getEmbedUrl(url) {
      /* YouTube */
      var yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]+)/);
      if (yt) return 'https://www.youtube-nocookie.com/embed/' + yt[1] + '?autoplay=1&rel=0';
      /* Vimeo */
      var vm = url.match(/vimeo\.com\/(\d+)/);
      if (vm) return 'https://player.vimeo.com/video/' + vm[1] + '?autoplay=1';
      return url;
    }

    videoThumb.addEventListener('click', function() {
      var url = this.dataset.videoUrl;
      videoWrap.innerHTML = '<iframe src="' + getEmbedUrl(url) + '" allow="autoplay; fullscreen" allowfullscreen></iframe>';
      mainWrap.style.display = 'none';
      videoOverlay.hidden = false;
      sec.querySelectorAll('.ptp__gallery-thumb--active').forEach(function(t) { t.classList.remove('ptp__gallery-thumb--active'); });
      videoThumb.classList.add('ptp__gallery-thumb--active');
    });

    videoClose.addEventListener('click', function() {
      videoOverlay.hidden = true;
      videoWrap.innerHTML = '';
      mainWrap.style.display = '';
      sec.querySelectorAll('.ptp__gallery-thumb--active').forEach(function(t) { t.classList.remove('ptp__gallery-thumb--active'); });
      var firstThumb = sec.querySelector('.ptp__gallery-thumb');
      if (firstThumb) firstThumb.classList.add('ptp__gallery-thumb--active');
    });
  })();

  /* Copy URL to clipboard */
  (function() {
    var copyBtn = sec.querySelector('[data-ptp-copy-url]');
    if (!copyBtn) return;
    copyBtn.addEventListener('click', function() {
      navigator.clipboard.writeText(window.location.href).then(function() {
        var orig = copyBtn.innerHTML;
        copyBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>';
        setTimeout(function() { copyBtn.innerHTML = orig; }, 2000);
      });
    });
  })();

  /* Back-in-stock notification */
  (function() {
    var bisSubmit = sec.querySelector('[data-ptp-bis-submit]');
    if (!bisSubmit) return;
    var bisEmail = sec.querySelector('[data-ptp-bis-email]');
    var bisSuccess = sec.querySelector('[data-ptp-bis-success]');
    var bisForm = sec.querySelector('.ptp__bis-form');
    bisSubmit.addEventListener('click', function() {
      var email = bisEmail.value.trim();
      if (!email || !email.includes('@')) { bisEmail.style.borderColor = '#dc2626'; return; }
      bisSubmit.textContent = '...';
      bisSubmit.disabled = true;
      /* Store in localStorage as fallback, integrate with Klaviyo/Mailchimp webhook as needed */
      var bisData = JSON.parse(localStorage.getItem('pt_bis') || '[]');
      bisData.push({ email: email, product_id: '{{ product.id }}', variant_id: '{{ product.selected_or_first_available_variant.id }}', title: '{{ product.title | escape }}', date: new Date().toISOString() });
      localStorage.setItem('pt_bis', JSON.stringify(bisData));
      bisForm.style.display = 'none';
      bisSuccess.hidden = false;
    });
  })();
});
</script>

