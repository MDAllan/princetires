{%- liquid
  assign tire_size = product.metafields.custom.tire_size | default: ''
  assign product_title = product.title

  assign season_tag = ''
  assign season_color = '#6b7280'
  for tag in product.tags
    assign tag_down = tag | downcase
    if tag_down contains 'winter'
      assign season_tag = 'Winter'
      assign season_color = '#2563eb'
    elsif tag_down contains 'all-season' or tag_down contains 'all season'
      assign season_tag = 'All-Season'
      assign season_color = '#16a34a'
    elsif tag_down contains 'all-weather' or tag_down contains 'all weather'
      assign season_tag = 'All-Weather'
      assign season_color = '#F5820B'
    elsif tag_down contains 'summer'
      assign season_tag = 'Summer'
      assign season_color = '#eab308'
    endif
  endfor
  if season_tag == blank
    assign type_down = product.type | downcase
    if type_down contains 'winter'
      assign season_tag = 'Winter'
      assign season_color = '#2563eb'
    elsif type_down contains 'passenger'
      assign season_tag = 'All-Season'
      assign season_color = '#16a34a'
    elsif type_down contains 'trailer'
      assign season_tag = 'Trailer'
      assign season_color = '#6b7280'
    endif
  endif

  assign product_form_id = 'pt-product-form-' | append: section.id

  assign spec_width = ''
  assign spec_aspect = ''
  assign spec_rim = ''
  if tire_size != blank
    assign clean_size = tire_size | remove: 'P' | remove: 'LT' | remove: 'ST' | strip
    assign slash_parts = clean_size | split: '/'
    if slash_parts.size > 1
      assign spec_width = slash_parts[0]
      assign r_parts = slash_parts[1] | split: 'R'
      assign spec_aspect = r_parts[0]
      if r_parts.size > 1
        assign spec_rim = r_parts[1]
      endif
    else
      assign r_parts = clean_size | split: 'R'
      if r_parts.size > 1
        assign spec_width = r_parts[0]
        assign spec_rim = r_parts[1]
      endif
    endif
  endif

  assign set_price = product.price | times: 4

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
    assign save_amount = product.compare_at_price | minus: product.price
    assign save_percent = save_amount | times: 100.0 | divided_by: product.compare_at_price | round
  endif

  assign rating_value = product.metafields.reviews.rating.value
  assign rating_count = product.metafields.reviews.rating_count | default: 0
  assign rating_decimal = 0
  assign tyre_rating_raw = product.metafields.custom.tyre_rating.value | default: 0
  assign use_tyre_rating = false

  if rating_value != blank
    assign decimal = rating_value.rating | modulo: 1
    if decimal >= 0.3
      if decimal <= 0.7
        assign rating_decimal = 0.5
      elsif decimal > 0.7
        assign rating_decimal = 1
      endif
    endif
  elsif tyre_rating_raw > 0
    assign use_tyre_rating = true
    assign tr_star = tyre_rating_raw | times: 5.0 | divided_by: 100.0
    assign tr_floor = tr_star | floor
    assign tr_dec = tr_star | modulo: 1
    assign rating_decimal = 0
    if tr_dec >= 0.3
      if tr_dec <= 0.7
        assign rating_decimal = 0.5
      elsif tr_dec > 0.7
        assign rating_decimal = 1
      endif
    endif
  endif

  assign perf_dry = product.metafields.custom.dry_grip.value | default: section.settings.perf_dry_grip | default: 0
  assign perf_wet = product.metafields.custom.wet_grip.value | default: section.settings.perf_wet_grip | default: 0
  assign perf_ice = product.metafields.custom.ice_grip.value | default: section.settings.perf_ice_grip | default: 0
  assign perf_snow = product.metafields.custom.snow_grip.value | default: section.settings.perf_snow_traction | default: 0
  assign perf_tread = product.metafields.custom.wear_score.value | default: section.settings.perf_tread_life | default: 0
  assign has_perf_data = false
  if perf_dry > 0 or perf_wet > 0 or perf_ice > 0 or perf_snow > 0 or perf_tread > 0
    assign has_perf_data = true
  endif

  assign detected_vehicle = 'passenger'
  assign vehicle_meta = product.metafields.custom.vehicle_type | downcase | default: ''
  if vehicle_meta != blank
    if vehicle_meta contains 'suv' or vehicle_meta contains 'cuv'
      assign detected_vehicle = 'suv'
    elsif vehicle_meta contains 'light truck'
      assign detected_vehicle = 'truck'
    elsif vehicle_meta contains 'trailer'
      assign detected_vehicle = 'trailer'
    elsif vehicle_meta contains 'van'
      assign detected_vehicle = 'van'
    elsif vehicle_meta contains 'truck'
      assign detected_vehicle = 'truck'
    endif
  else
    assign type_check = product.type | downcase
    if tire_size != blank
      assign size_upper = tire_size | upcase
      if size_upper contains 'LT'
        assign detected_vehicle = 'truck'
      elsif size_upper contains 'ST'
        assign detected_vehicle = 'trailer'
      endif
    endif
    if detected_vehicle == 'passenger'
      if type_check contains 'trailer'
        assign detected_vehicle = 'trailer'
      elsif type_check contains 'light truck' or type_check contains 'lt '
        assign detected_vehicle = 'truck'
      elsif type_check contains 'suv' or type_check contains 'cuv'
        assign detected_vehicle = 'suv'
      endif
    endif
    if detected_vehicle == 'passenger'
      for tag in product.tags
        assign tag_lc = tag | downcase
        if tag_lc contains 'trailer'
          assign detected_vehicle = 'trailer'
          break
        elsif tag_lc contains 'light truck' or tag_lc contains 'lt tire'
          assign detected_vehicle = 'truck'
          break
        elsif tag_lc contains 'suv'
          assign detected_vehicle = 'suv'
          break
        endif
      endfor
    endif
  endif
-%}

{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- if section.settings.enable_image_zoom -%}
  <script src="{{ 'magnify.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<product-info class="ptp" data-section="{{ section.id }}" data-product-id="{{ product.id }}" data-update-url="true" data-url="{{ product.url }}">
  <div class="ptp__container">

    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav class="ptp__breadcrumb" aria-label="Breadcrumb">
      <ol class="ptp__breadcrumb-list">
        <li><a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t | default: 'Home' }}</a></li>
        {%- if product.collections.size > 0 -%}
          {%- assign col = product.collections | first -%}
          <li><a href="{{ col.url }}">{{ col.title }}</a></li>
        {%- endif -%}
        <li aria-current="page">{{ product.title | truncate: 40 }}</li>
      </ol>
    </nav>

    {%- comment -%} Breadcrumb JSON-LD {%- endcomment -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ 'general.breadcrumbs.home' | t | default: 'Home' | json }},
          "item": "{{ shop.url }}"
        }
        {%- if product.collections.size > 0 -%}
          {%- assign col = product.collections | first -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ col.title | json }},
            "item": "{{ shop.url }}{{ col.url }}"
          }
          ,{
            "@type": "ListItem",
            "position": 3,
            "name": {{ product.title | json }}
          }
        {%- else -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ product.title | json }}
          }
        {%- endif -%}
      ]
    }
    </script>

    {%- comment -%} Vehicle Fitment Banner {%- endcomment -%}
    <div class="ptp__fitment" data-ptp-fitment hidden>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
      <span>Fits your <strong data-ptp-fitment-vehicle></strong></span>
      <a href="{{ routes.collections_url }}/tires" class="ptp__fitment-change">Change vehicle</a>
    </div>

    {%- comment -%} Two-Column Layout {%- endcomment -%}
    <div class="ptp__layout">

      {%- comment -%} Left Column: Image Gallery {%- endcomment -%}
      <div class="ptp__gallery-col">
        <div class="ptp__gallery">
          <div class="ptp__gallery-main">
            {%- if product.featured_image -%}
              <div class="ptp__gallery-main-wrap">
                {{ product.featured_image | image_url: width: 800 | image_tag:
                  class: 'ptp__gallery-main-img',
                  loading: 'eager',
                  id: 'ptp-featured-img',
                  sizes: '(min-width: 750px) 50vw, 100vw',
                  alt: product.featured_image.alt | default: product.title }}
                {%- if on_sale -%}
                  <span class="ptp__sale-badge">-{{ save_percent }}%</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
          {%- assign video_url = product.metafields.custom.video_url | default: '' -%}
          {%- comment -%} Video overlay — shown when video thumb is clicked {%- endcomment -%}
          {%- if video_url != blank -%}
            <div class="ptp__gallery-video" data-ptp-video hidden>
              <button type="button" class="ptp__gallery-video-close" data-ptp-video-close aria-label="Close video">&times;</button>
              <div class="ptp__gallery-video-wrap" data-ptp-video-wrap></div>
            </div>
          {%- endif -%}
          {%- if product.images.size > 1 or video_url != blank -%}
            <div class="ptp__gallery-thumbs" role="list" aria-label="Product images">
              {%- for image in product.images -%}
                <button class="ptp__gallery-thumb{% if forloop.first %} ptp__gallery-thumb--active{% endif %}" role="listitem" data-ptp-thumb-idx="{{ forloop.index0 }}" data-ptp-thumb-src="{{ image | image_url: width: 800 }}" aria-label="View image {{ forloop.index }} of {{ product.images.size }}" type="button">
                  {{ image | image_url: width: 120, height: 120, crop: 'center' | image_tag: loading: 'lazy', class: 'ptp__gallery-thumb-img', alt: image.alt | default: product.title }}
                </button>
              {%- endfor -%}
              {%- if video_url != blank -%}
                <button class="ptp__gallery-thumb ptp__gallery-thumb--video" role="listitem" data-ptp-video-thumb data-video-url="{{ video_url | escape }}" aria-label="Play video" type="button">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="#dc2626"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                </button>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Right Column: Product Info {%- endcomment -%}
      <div class="ptp__info-col{% if section.settings.enable_sticky_info %} ptp__info-col--sticky{% endif %}">
        <a href="{{ product.vendor | url_for_vendor }}" class="ptp__vendor">{{ product.vendor }}</a>
        <h1 class="ptp__title">{{ product_title }}</h1>


        {%- if season_tag != blank -%}
          <div class="ptp__season-banner" style="--season-clr: {{ season_color }}">
            {%- case season_tag -%}
              {%- when 'Winter' -%}
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M22 11h-4.17l3.24-3.24-1.41-1.42L15 11h-2V9l4.66-4.66-1.42-1.41L13 6.17V2h-2v4.17L7.76 2.93 6.34 4.34 11 9v2H9L4.34 6.34 2.93 7.76 6.17 11H2v2h4.17l-3.24 3.24 1.41 1.42L9 13h2v2l-4.66 4.66 1.42 1.41L11 17.83V22h2v-4.17l3.24 3.24 1.42-1.41L13 15v-2h2l4.66 4.66 1.41-1.42L17.83 13H22z"/></svg>
                Certified for Canadian winters — 3PMSF rated
              {%- when 'All-Season' -%}
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.66 8L12 2.35 6.34 8C4.78 9.56 4 11.64 4 13.64s.78 4.11 2.34 5.67 3.61 2.35 5.66 2.35 4.1-.79 5.66-2.35S20 15.64 20 13.64 19.22 9.56 17.66 8z"/></svg>
                Spring, summer &amp; fall — winter tires recommended for Calgary
              {%- when 'All-Weather' -%}
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1-.25 1.97-.7 2.8l1.46 1.46A7.93 7.93 0 0020 12c0-4.42-3.58-8-8-8z"/></svg>
                Winter &amp; summer certified — all-weather ready
              {%- when 'Summer' -%}
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
                Peak summer performance — UHP rated
            {%- endcase -%}
          </div>
        {%- endif -%}

        {%- comment -%} Fitment badge — shows "Fits your [Year Make Model]" for logged-in customers {%- endcomment -%}
        {%- render 'pt-fitment-badge', product: product -%}

        {%- comment -%} Weather-based seasonal warning {%- endcomment -%}
        <div class="ptp__weather-warn" data-ptp-weather-warn data-tire-season="{{ season_tag | downcase }}" hidden>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4M12 17h.01"/><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
          <span data-ptp-weather-msg></span>
        </div>

        {%- if rating_value != blank -%}
          {%- if rating_value.rating >= 4.0 -%}
            <div class="ptp__rating-row">
              <div class="ptp__rating" role="img" aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: rating_value, rating_max: rating_value.scale_max }}">
                <span aria-hidden="true" class="rating-star" style="--rating: {{ rating_value.rating | floor }}; --rating-max: {{ rating_value.scale_max }}; --rating-decimal: {{ rating_decimal }};"></span>
                <span class="ptp__rating-text" aria-hidden="true">{{ rating_value.rating }}</span>
                <span class="ptp__rating-count" aria-hidden="true">({{ rating_count }} reviews)</span>
              </div>
            </div>
          {%- endif -%}
        {%- elsif use_tyre_rating -%}
          {%- if tr_star >= 4.0 -%}
            <div class="ptp__rating-row">
              <div class="ptp__rating" role="img" aria-label="Rating {{ tr_star | round: 1 }} out of 5 stars">
                <span aria-hidden="true" class="rating-star" style="--rating: {{ tr_floor }}; --rating-max: 5; --rating-decimal: {{ rating_decimal }};"></span>
                <span class="ptp__rating-text" aria-hidden="true">{{ tr_star | round: 1 }}/5</span>
                <span class="ptp__rating-count" aria-hidden="true">TyreReviews</span>
              </div>
            </div>
          {%- endif -%}
        {%- else -%}
          {%- liquid
            assign v = product.vendor | downcase
            assign gen_rating = 0
            if v == 'michelin' or v == 'continental' or v == 'pirelli' or v == 'goodyear'
              assign gen_rating = 4.7
            elsif v == 'bridgestone' or v == 'hankook' or v == 'yokohama' or v == 'falken' or v == 'nokian'
              assign gen_rating = 4.5
            elsif v == 'kumho' or v == 'toyo' or v == 'cooper' or v == 'firestone' or v == 'general' or v == 'dunlop' or v == 'bfgoodrich' or v == 'nexen'
              assign gen_rating = 4.3
            elsif v == 'gt radial' or v == 'maxxis' or v == 'rotalla'
              assign gen_rating = 4.0
            endif
            assign gen_floor = gen_rating | floor
            assign gen_dec = gen_rating | modulo: 1
            assign gen_decimal = 0
            if gen_dec >= 0.3
              if gen_dec <= 0.7
                assign gen_decimal = 0.5
              elsif gen_dec > 0.7
                assign gen_decimal = 1
              endif
            endif
          -%}
          {%- if gen_rating >= 4.0 -%}
            <div class="ptp__rating-row">
              <div class="ptp__rating" role="img" aria-label="Rating {{ gen_rating }} out of 5 stars">
                <span aria-hidden="true" class="rating-star" style="--rating: {{ gen_floor }}; --rating-max: 5; --rating-decimal: {{ gen_decimal }};"></span>
                <span class="ptp__rating-text" aria-hidden="true">{{ gen_rating }}/5</span>
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} Pricing Card {%- endcomment -%}
        <div class="ptp__pricing-card">
          <div class="ptp__price-hero">
            <div class="ptp__price-hero-left">
              <span class="ptp__price-hero-amount">${{ set_price | money_without_currency }}</span>
              <span class="ptp__price-hero-label">for a set of 4</span>
            </div>
            {%- if product.available -%}
              {%- assign variant_inventory = product.selected_or_first_available_variant.inventory_quantity -%}
              {%- if variant_inventory <= 8 and variant_inventory > 0 and product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                <span class="ptp__stock ptp__stock--low"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M12 9v4M12 17h.01"/><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg> {{ 'products.product.low_stock' | t: count: variant_inventory | default: 'Only ' | append: variant_inventory | append: ' left' }}</span>
              {%- else -%}
                <span class="ptp__stock ptp__stock--in"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg> {{ 'products.product.in_stock' | t | default: 'In stock' }}</span>
              {%- endif -%}
            {%- else -%}
              <span class="ptp__stock ptp__stock--out">{{ 'products.product.sold_out' | t | default: 'Sold out' }}</span>
            {%- endif -%}
          </div>
          <div class="ptp__price-per-tire">
            {%- if on_sale -%}
              <span class="ptp__price-current ptp__price-current--sale">${{ product.price | money_without_currency }}</span>
              <span class="ptp__price-was">${{ product.compare_at_price | money_without_currency }}</span>
              <span class="ptp__price-per">/tire</span>
              <span class="ptp__save-tag">Save ${{ save_amount | money_without_currency }}</span>
            {%- else -%}
              <span class="ptp__price-current">${{ product.price | money_without_currency }}</span>
              <span class="ptp__price-per">/tire</span>
            {%- endif -%}
          </div>
          {%- if section.settings.show_installed_price -%}
            {%- assign install_per_tire = section.settings.install_cost_per_tire | default: '30' | times: 100 -%}
            {%- assign disposal_per_tire = section.settings.disposal_cost_per_tire | default: '5' | times: 100 -%}
            {%- assign service_per_tire = install_per_tire | plus: disposal_per_tire -%}
            {%- comment -%} set_price is already price*4 in cents, service needs *4 too {%- endcomment -%}
            {%- assign service_total = service_per_tire | times: 4 -%}
            {%- assign installed_total = set_price | plus: service_total -%}
            <div class="ptp__installed-price">
              <div class="ptp__installed-price-row">
                <span class="ptp__installed-label">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
                  {{ 'products.product.installed_total' | t | default: 'Installed total' }}
                </span>
                <span class="ptp__installed-amount">${{ installed_total | money_without_currency }}</span>
              </div>
              <span class="ptp__installed-note">{{ 'products.product.installed_includes' | t | default: 'Includes mount, balance & disposal for 4 tires' }}</span>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Manufacturer Rebate Banner {%- endcomment -%}
        {%- assign rebate_text = product.metafields.custom.rebate_text | default: '' -%}
        {%- if rebate_text != blank -%}
          <div class="ptp__rebate-banner">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
            <span>{{ rebate_text }}</span>
          </div>
        {%- endif -%}

        {%- comment -%} CTAs — Book Installation is PRIMARY {%- endcomment -%}
        <div class="ptp__cta-stack">
          <button type="button" class="ptp__book-btn" onclick="if(typeof openBookingModal==='function')openBookingModal(this)" data-tire-name="{{ product.title | escape }}" data-tire-size="{{ tire_size | escape }}" data-vehicle-type="{{ detected_vehicle }}" data-tire-price="{{ product.selected_or_first_available_variant.price }}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            Book installation
          </button>

          <product-form data-section-id="{{ section.id }}">
            {%- form 'product', product, id: product_form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              {%- if product.available -%}
                <div class="ptp__cart-row">
                  <div class="ptp__qty" role="group" aria-label="Quantity">
                    <button type="button" data-ptp-qty-minus aria-label="Decrease quantity"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/></svg></button>
                    <input type="number" name="quantity" value="4" min="1" data-ptp-qty aria-label="Quantity">
                    <button type="button" data-ptp-qty-plus aria-label="Increase quantity"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></button>
                  </div>
                  <button type="submit" class="ptp__add-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
                    Add to cart — <span data-ptp-cart-total>${{ set_price | money_without_currency }}</span>
                  </button>
                </div>
              {%- else -%}
                <div class="ptp__back-in-stock" data-ptp-bis>
                  <p class="ptp__bis-text">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
                    {{ 'products.product.notify_when_available' | t | default: 'Get notified when this tire is back in stock' }}
                  </p>
                  <div class="ptp__bis-form">
                    <input type="email" class="ptp__bis-email" placeholder="{{ 'products.product.email_placeholder' | t | default: 'Enter your email' }}" data-ptp-bis-email required>
                    <button type="button" class="ptp__bis-btn" data-ptp-bis-submit>
                      {{ 'products.product.notify_me' | t | default: 'Notify me' }}
                    </button>
                  </div>
                  <p class="ptp__bis-success" data-ptp-bis-success hidden>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                    {{ 'products.product.notify_success' | t | default: "We'll email you when it's back!" }}
                  </p>
                </div>
              {%- endif -%}
            {%- endform -%}
          </product-form>
        </div>

        {%- comment -%} Trust Signals {%- endcomment -%}
        {%- if section.settings.show_trust_signals -%}
          <div class="ptp__trust">
            <div class="ptp__trust-item">
              <div class="ptp__trust-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></div>
              <div class="ptp__trust-text"><strong>{{ section.settings.trust_1_text | default: 'Fast delivery' }}</strong><span>Delivery within Calgary</span></div>
            </div>
            <div class="ptp__trust-item">
              <div class="ptp__trust-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
              <div class="ptp__trust-text"><strong>{{ section.settings.trust_2_text | default: 'Manufacturer warranty' }}</strong><span>Manufacturing defect warranty</span></div>
            </div>
            <div class="ptp__trust-item">
              <div class="ptp__trust-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg></div>
              <div class="ptp__trust-text"><strong>{{ section.settings.trust_3_text | default: 'Easy returns' }}</strong><span>Must be uninstalled, unused, with stickers on</span></div>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Key Stats Strip {%- endcomment -%}
    {%- if tire_size != blank -%}
      <div class="ptp__stats-strip">
        <div class="ptp__stat">
          <span class="ptp__stat-num">{{ tire_size }}</span>
          <span class="ptp__stat-label">Tire size</span>
        </div>
        {%- if season_tag != blank -%}
          <div class="ptp__stat">
            <span class="ptp__stat-num" style="color: {{ season_color }}">{{ season_tag }}</span>
            <span class="ptp__stat-label">Season rating</span>
          </div>
        {%- endif -%}
        {%- if product.metafields.custom.warranty_km != blank -%}
          <div class="ptp__stat">
            <span class="ptp__stat-num">{{ product.metafields.custom.warranty_km }}<span class="ptp__stat-unit">km</span></span>
            <span class="ptp__stat-label">Treadwear warranty</span>
          </div>
        {%- endif -%}
        <div class="ptp__stat">
          <span class="ptp__stat-num">${{ product.price | money_without_currency }}<span class="ptp__stat-unit">/tire</span></span>
          <span class="ptp__stat-label">Per tire price</span>
        </div>
        {%- if product.metafields.custom.warranty_km != blank -%}
          {%- assign warranty_km_num = product.metafields.custom.warranty_km | times: 1 -%}
          {%- if warranty_km_num > 0 -%}
            {%- assign price_dollars = product.price | times: 1.0 | divided_by: 100.0 -%}
            {%- assign cost_per_km_raw = price_dollars | divided_by: warranty_km_num | times: 1000.0 -%}
            {%- assign cost_per_km_cents = cost_per_km_raw | round: 1 -%}
            <div class="ptp__stat">
              <span class="ptp__stat-num" style="color: var(--ptp-accent)">{{ cost_per_km_cents }}<span class="ptp__stat-unit">&cent;/km</span></span>
              <span class="ptp__stat-label">{{ 'products.product.cost_per_km' | t | default: 'Cost per km' }}</span>
            </div>
          {%- endif -%}
        {%- endif -%}
        {%- if product.vendor != blank -%}
          <div class="ptp__stat">
            <span class="ptp__stat-num ptp__stat-brand">{{ product.vendor }}</span>
            <span class="ptp__stat-label">Brand</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} ===== TABS SECTION ===== {%- endcomment -%}
    <div class="ptp__tabs-section">
      <div class="ptp__tabs">
        <div class="ptp__tab-bar" role="tablist">
        {%- if spec_width != blank and section.settings.show_specs_tab -%}
          <button class="ptp__tab ptp__tab--active" role="tab" aria-selected="true" data-ptp-tab="specs" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>
            Specifications
          </button>
        {%- endif -%}
        {%- if section.settings.show_desc_tab -%}
          <button class="ptp__tab{% if spec_width == blank %} ptp__tab--active{% endif %}" role="tab" aria-selected="{% if spec_width == blank %}true{% else %}false{% endif %}" data-ptp-tab="desc" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7V4h16v3M9 20h6M12 4v16"/></svg>
            Description
          </button>
        {%- endif -%}
        {%- if section.settings.show_ai_tab -%}
          <button class="ptp__tab" role="tab" aria-selected="false" data-ptp-tab="ai" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            {{ section.settings.ai_tab_title | default: 'Ask AI' }}
          </button>
        {%- endif -%}
        {%- if section.settings.show_warranty_tab -%}
          <button class="ptp__tab" role="tab" aria-selected="false" data-ptp-tab="warranty" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Warranty
          </button>
        {%- endif -%}
        {%- if section.settings.show_shipping_tab -%}
          <button class="ptp__tab" role="tab" aria-selected="false" data-ptp-tab="shipping" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            Shipping
          </button>
        {%- endif -%}
      </div>

      <div class="ptp__tab-panels">
        {%- comment -%} Specs Panel — extended with all tire metafields {%- endcomment -%}
        {%- if spec_width != blank and section.settings.show_specs_tab -%}
          <div class="ptp__tab-panel ptp__tab-panel--active" role="tabpanel" data-ptp-panel="specs">
            <div class="ptp__specs-grid">
              {%- if tire_size != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_tire_size' | t }}</span><span class="ptp__spec-val">{{ tire_size }}</span></div>{%- endif -%}
              {%- if spec_width != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_section_width' | t }}</span><span class="ptp__spec-val">{{ spec_width }} mm</span></div>{%- endif -%}
              {%- if spec_aspect != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_aspect_ratio' | t }}</span><span class="ptp__spec-val">{{ spec_aspect }}</span></div>{%- endif -%}
              {%- if spec_rim != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_rim_diameter' | t }}</span><span class="ptp__spec-val">{{ spec_rim }}"</span></div>{%- endif -%}
              {%- if season_tag != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_season' | t }}</span><span class="ptp__spec-val">{{ season_tag }}</span></div>{%- endif -%}
              {%- if product.type != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_type' | t }}</span><span class="ptp__spec-val">{{ product.type }}</span></div>{%- endif -%}
              <div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_brand' | t }}</span><span class="ptp__spec-val">{{ product.vendor }}</span></div>
              {%- if product.metafields.custom.load_index != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_load_index' | t }}</span><span class="ptp__spec-val">{{ product.metafields.custom.load_index }}{%- if product.metafields.custom.max_load_lbs != blank %} ({{ product.metafields.custom.max_load_lbs }} lbs){%- endif -%}</span></div>{%- endif -%}
              {%- if product.metafields.custom.speed_rating != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_speed_rating' | t }}</span><span class="ptp__spec-val">{{ product.metafields.custom.speed_rating }}{%- if product.metafields.custom.max_speed_kmh != blank %} ({{ product.metafields.custom.max_speed_kmh }} km/h){%- endif -%}</span></div>{%- endif -%}
              {%- if product.metafields.custom.ply_rating != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_ply_rating' | t }}</span><span class="ptp__spec-val">{{ product.metafields.custom.ply_rating }}</span></div>{%- endif -%}
              {%- if product.metafields.custom.sidewall != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_sidewall' | t }}</span><span class="ptp__spec-val">{{ product.metafields.custom.sidewall }}</span></div>{%- endif -%}
              {%- if product.metafields.custom.tread_depth != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_tread_depth' | t }}</span><span class="ptp__spec-val">{{ product.metafields.custom.tread_depth }}</span></div>{%- endif -%}
              {%- if product.metafields.custom.vehicle_type != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_vehicle_type' | t }}</span><span class="ptp__spec-val">{{ product.metafields.custom.vehicle_type }}</span></div>{%- endif -%}
              {%- if product.variants.first.weight > 0 -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_weight' | t }}</span><span class="ptp__spec-val">{{ product.variants.first.weight }} {{ product.variants.first.weight_unit }}</span></div>{%- endif -%}
              {%- if product.metafields.custom.run_flat != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_run_flat' | t }}</span><span class="ptp__spec-val">{{ product.metafields.custom.run_flat }}</span></div>{%- endif -%}
              {%- if product.metafields.custom.stud_option != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_studdable' | t }}</span><span class="ptp__spec-val">{{ product.metafields.custom.stud_option }}</span></div>{%- endif -%}
              {%- if product.metafields.custom.three_peak_snowflake == true -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_3pmsf' | t }}</span><span class="ptp__spec-val" style="color:#2563eb">&#10052; {{ 'sections.tire_description.certified' | t }}</span></div>{%- endif -%}
              {%- if product.metafields.custom.mud_snow == true -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_ms' | t }}</span><span class="ptp__spec-val">{{ 'sections.tire_description.yes' | t }}</span></div>{%- endif -%}
            </div>

            {%- comment -%} UTQG Ratings {%- endcomment -%}
            {%- if product.metafields.custom.utqg_treadwear != blank or product.metafields.custom.utqg_traction != blank or product.metafields.custom.utqg_temperature != blank -%}
              <h3 class="ptp__perf-heading">{{ 'sections.tire_description.utqg_heading' | t }}</h3>
              <div class="ptp__specs-grid">
                {%- if product.metafields.custom.utqg_treadwear != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_utqg_treadwear' | t }}</span><span class="ptp__spec-val">{{ product.metafields.custom.utqg_treadwear }}</span></div>{%- endif -%}
                {%- if product.metafields.custom.utqg_traction != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_utqg_traction' | t }}</span><span class="ptp__spec-val">{{ product.metafields.custom.utqg_traction }}</span></div>{%- endif -%}
                {%- if product.metafields.custom.utqg_temperature != blank -%}<div class="ptp__spec-item"><span class="ptp__spec-label">{{ 'sections.tire_description.spec_utqg_temperature' | t }}</span><span class="ptp__spec-val">{{ product.metafields.custom.utqg_temperature }}</span></div>{%- endif -%}
              </div>
            {%- endif -%}

            {%- comment -%} Warranty Badge {%- endcomment -%}
            {%- if product.metafields.custom.warranty_km != blank -%}
              <div class="ptp__warranty-badge">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F5820B" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span>{{ 'sections.tire_description.warranty_badge' | t: warranty_km: product.metafields.custom.warranty_km }}</span>
              </div>
            {%- endif -%}

            {%- if has_perf_data and section.settings.show_performance -%}
              <h3 class="ptp__perf-heading">Performance ratings</h3>
              <div class="ptp__perf-bars" data-ptp-perf>
                {%- if perf_dry > 0 -%}<div class="ptp__perf-row"><span class="ptp__perf-label">Dry grip</span><div class="ptp__perf-track"><div class="ptp__perf-fill" data-ptp-bar="{{ perf_dry }}" style="width:0%;background:#fca5a5"></div></div><span class="ptp__perf-val" data-ptp-count="{{ perf_dry }}">0</span></div>{%- endif -%}
                {%- if perf_wet > 0 -%}<div class="ptp__perf-row"><span class="ptp__perf-label">Wet grip</span><div class="ptp__perf-track"><div class="ptp__perf-fill" data-ptp-bar="{{ perf_wet }}" style="width:0%;background:#93c5fd"></div></div><span class="ptp__perf-val" data-ptp-count="{{ perf_wet }}">0</span></div>{%- endif -%}
                {%- if perf_ice > 0 -%}<div class="ptp__perf-row"><span class="ptp__perf-label">Ice grip</span><div class="ptp__perf-track"><div class="ptp__perf-fill" data-ptp-bar="{{ perf_ice }}" style="width:0%;background:#7dd3fc"></div></div><span class="ptp__perf-val" data-ptp-count="{{ perf_ice }}">0</span></div>{%- endif -%}
                {%- if perf_snow > 0 -%}<div class="ptp__perf-row"><span class="ptp__perf-label">Snow traction</span><div class="ptp__perf-track"><div class="ptp__perf-fill" data-ptp-bar="{{ perf_snow }}" style="width:0%;background:#fdba74"></div></div><span class="ptp__perf-val" data-ptp-count="{{ perf_snow }}">0</span></div>{%- endif -%}
                {%- if perf_tread > 0 -%}<div class="ptp__perf-row"><span class="ptp__perf-label">Tread life</span><div class="ptp__perf-track"><div class="ptp__perf-fill" data-ptp-bar="{{ perf_tread }}" style="width:0%;background:#86efac"></div></div><span class="ptp__perf-val" data-ptp-count="{{ perf_tread }}">0</span></div>{%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Description Panel — auto-generated from metafields + FAQ {%- endcomment -%}
        {%- if section.settings.show_desc_tab -%}
          <div class="ptp__tab-panel{% if spec_width == blank %} ptp__tab-panel--active{% endif %}" role="tabpanel" data-ptp-panel="desc">

            {%- comment -%} Auto-generated intro {%- endcomment -%}
            {%- if tire_size != blank -%}
              <div class="ptp__description rte" data-aeo-speakable>
                <p>
                  {{ 'sections.tire_description.intro_line_1' | t:
                    vendor: product.vendor,
                    title: product.title,
                    season: season_tag,
                    vehicle_type: product.metafields.custom.vehicle_type,
                    tire_size: tire_size
                  }}
                  {%- if product.metafields.custom.load_index != blank -%}
                    {%- if product.metafields.custom.speed_rating != blank -%}
                      {{ 'sections.tire_description.intro_rated' | t: load_index: product.metafields.custom.load_index, speed_rating: product.metafields.custom.speed_rating }}
                    {%- endif -%}
                    {%- if product.metafields.custom.max_load_lbs != blank -%}
                      {{ 'sections.tire_description.intro_load_capacity' | t: max_load_lbs: product.metafields.custom.max_load_lbs }}
                    {%- endif -%}
                    {%- if product.metafields.custom.max_speed_kmh != blank -%}
                      {{ 'sections.tire_description.intro_speed_capacity' | t: max_speed_kmh: product.metafields.custom.max_speed_kmh }}
                    {%- endif -%}
                  {%- endif -%}
                </p>
                {%- if product.metafields.custom.warranty_km != blank -%}
                  <p>{{ 'sections.tire_description.intro_warranty' | t: warranty_km: product.metafields.custom.warranty_km, vendor: product.vendor }}</p>
                {%- endif -%}
                {%- if product.metafields.custom.three_peak_snowflake == true -%}
                  <p>{{ 'sections.tire_description.intro_3pmsf' | t }}</p>
                {%- elsif product.metafields.custom.mud_snow == true -%}
                  <p>{{ 'sections.tire_description.intro_ms' | t }}</p>
                {%- endif -%}
                <p>{{ 'sections.tire_description.intro_available' | t }}</p>
              </div>
            {%- endif -%}

            {%- comment -%} Best for / Not recommended tags {%- endcomment -%}
            {%- if product.metafields.custom.best_for != blank or product.metafields.custom.not_recommended_for != blank -%}
              <div class="ptp__use-cases">
                {%- if product.metafields.custom.best_for != blank -%}
                  {%- assign best_for_items = product.metafields.custom.best_for | split: ',' -%}
                  <div class="ptp__use-case ptp__use-case--good">
                    <span class="ptp__use-case-label">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
                      {{ 'sections.tire_description.best_for' | t }}
                    </span>
                    <div class="ptp__use-tags">
                      {%- for item in best_for_items -%}
                        <span class="ptp__use-tag ptp__use-tag--green">{{ item | strip }}</span>
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endif -%}
                {%- if product.metafields.custom.not_recommended_for != blank -%}
                  {%- assign not_rec_items = product.metafields.custom.not_recommended_for | split: ',' -%}
                  <div class="ptp__use-case ptp__use-case--caution">
                    <span class="ptp__use-case-label">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/></svg>
                      {{ 'sections.tire_description.not_recommended' | t }}
                    </span>
                    <div class="ptp__use-tags">
                      {%- for item in not_rec_items -%}
                        <span class="ptp__use-tag ptp__use-tag--red">{{ item | strip }}</span>
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- comment -%} Compatible vehicles {%- endcomment -%}
            {%- if product.metafields.custom.compatible_vehicles != blank -%}
              {%- assign compat_items = product.metafields.custom.compatible_vehicles | split: ',' -%}
              <h3 class="ptp__desc-subheading">{{ 'sections.tire_description.vehicles_heading' | t: tire_size: tire_size }}</h3>
              <div class="ptp__vehicle-list">
                {%- for v in compat_items -%}
                  <span class="ptp__vehicle-chip">{{ v | strip }}</span>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- comment -%} Calgary driving conditions {%- endcomment -%}
            {%- if tire_size != blank -%}
              <h3 class="ptp__desc-subheading">{{ 'sections.tire_description.local_heading' | t }}</h3>
              <div class="ptp__local-note">
                {%- case season_tag -%}
                  {%- when 'Winter' -%}
                    <p>{{ 'sections.tire_description.local_winter' | t: title: product.title }}</p>
                  {%- when 'All-Season' -%}
                    <p>{{ 'sections.tire_description.local_all_season' | t: title: product.title }}</p>
                  {%- when 'All-Weather' -%}
                    {%- if product.metafields.custom.three_peak_snowflake == true -%}
                      <p>{{ 'sections.tire_description.local_all_weather_3pmsf' | t: title: product.title }}</p>
                    {%- else -%}
                      <p>{{ 'sections.tire_description.local_all_weather' | t: title: product.title }}</p>
                    {%- endif -%}
                  {%- when 'Summer' -%}
                    <p>{{ 'sections.tire_description.local_summer' | t: title: product.title }}</p>
                  {%- else -%}
                    <p>{{ 'sections.tire_description.local_default' | t: title: product.title }}</p>
                {%- endcase -%}
              </div>
            {%- endif -%}

            {%- comment -%} FAQ {%- endcomment -%}
            {%- if tire_size != blank -%}
              <h3 class="ptp__desc-subheading">{{ 'sections.tire_description.faq_heading' | t }}</h3>
              <div class="ptp__faq-list">
                {%- capture faq_1_q -%}{{ 'sections.tire_description.faq_1_q' | t: title: product.title }}{%- endcapture -%}
                {%- capture faq_1_a -%}
                  {%- case season_tag -%}
                    {%- when 'Winter' -%}{{ 'sections.tire_description.faq_1_a_winter' | t: title: product.title }}
                    {%- when 'All-Season' -%}{{ 'sections.tire_description.faq_1_a_all_season' | t: title: product.title }}
                    {%- when 'All-Weather' -%}
                      {%- if product.metafields.custom.three_peak_snowflake == true -%}{{ 'sections.tire_description.faq_1_a_all_weather_3pmsf' | t: title: product.title }}
                      {%- else -%}{{ 'sections.tire_description.faq_1_a_all_weather' | t: title: product.title }}{%- endif -%}
                    {%- when 'Summer' -%}{{ 'sections.tire_description.faq_1_a_summer' | t: title: product.title }}
                    {%- else -%}{{ 'sections.tire_description.faq_1_a_default' | t: title: product.title }}
                  {%- endcase -%}
                {%- endcapture -%}
                <details class="ptp__faq-item"><summary class="ptp__faq-q">{{ faq_1_q | strip }}</summary><div class="ptp__faq-a">{{ faq_1_a | strip }}</div></details>

                {%- if product.metafields.custom.utqg_treadwear != blank or product.metafields.custom.warranty_km != blank -%}
                  {%- capture faq_2_q -%}{{ 'sections.tire_description.faq_2_q' | t: title: product.title }}{%- endcapture -%}
                  {%- capture faq_2_a -%}
                    {%- if product.metafields.custom.warranty_km != blank -%}
                      {%- if product.metafields.custom.utqg_treadwear != blank -%}{{ 'sections.tire_description.faq_2_a_full' | t: title: product.title, warranty_km: product.metafields.custom.warranty_km, utqg_treadwear: product.metafields.custom.utqg_treadwear }}
                      {%- else -%}{{ 'sections.tire_description.faq_2_a_warranty' | t: title: product.title, warranty_km: product.metafields.custom.warranty_km }}{%- endif -%}
                    {%- else -%}{{ 'sections.tire_description.faq_2_a_utqg' | t: title: product.title, utqg_treadwear: product.metafields.custom.utqg_treadwear }}{%- endif -%}
                  {%- endcapture -%}
                  <details class="ptp__faq-item"><summary class="ptp__faq-q">{{ faq_2_q | strip }}</summary><div class="ptp__faq-a">{{ faq_2_a | strip }}</div></details>
                {%- endif -%}

                {%- if product.metafields.custom.load_index != blank -%}
                  {%- capture faq_3_q -%}{{ 'sections.tire_description.faq_3_q' | t: title: product.title }}{%- endcapture -%}
                  {%- capture faq_3_a -%}
                    {%- if product.metafields.custom.max_load_lbs != blank -%}{{ 'sections.tire_description.faq_3_a_full' | t: title: product.title, load_index: product.metafields.custom.load_index, max_load_lbs: product.metafields.custom.max_load_lbs }}
                    {%- else -%}{{ 'sections.tire_description.faq_3_a_basic' | t: title: product.title, load_index: product.metafields.custom.load_index }}{%- endif -%}
                  {%- endcapture -%}
                  <details class="ptp__faq-item"><summary class="ptp__faq-q">{{ faq_3_q | strip }}</summary><div class="ptp__faq-a">{{ faq_3_a | strip }}</div></details>
                {%- endif -%}

                {%- if season_tag == 'Winter' or season_tag == 'All-Weather' or product.metafields.custom.three_peak_snowflake == true or product.metafields.custom.three_peak_snowflake == false -%}
                  {%- capture faq_4_q -%}{{ 'sections.tire_description.faq_4_q' | t: title: product.title }}{%- endcapture -%}
                  {%- capture faq_4_a -%}
                    {%- if product.metafields.custom.three_peak_snowflake == true -%}{{ 'sections.tire_description.faq_4_a_yes' | t: title: product.title }}
                    {%- else -%}{{ 'sections.tire_description.faq_4_a_no' | t: title: product.title }}{%- endif -%}
                  {%- endcapture -%}
                  <details class="ptp__faq-item"><summary class="ptp__faq-q">{{ faq_4_q | strip }}</summary><div class="ptp__faq-a">{{ faq_4_a | strip }}</div></details>
                {%- endif -%}

                {%- capture faq_5_q -%}{{ 'sections.tire_description.faq_5_q' | t }}{%- endcapture -%}
                {%- capture faq_5_a -%}{{ 'sections.tire_description.faq_5_a' | t }}{%- endcapture -%}
                <details class="ptp__faq-item"><summary class="ptp__faq-q">{{ faq_5_q | strip }}</summary><div class="ptp__faq-a">{{ faq_5_a | strip }}</div></details>
              </div>

              {%- comment -%} FAQ Page JSON-LD Schema {%- endcomment -%}
              <script type="application/ld+json">
              {
                "@context": "https://schema.org",
                "@type": "FAQPage",
                "mainEntity": [
                  { "@type": "Question", "name": {{ faq_1_q | strip | json }}, "acceptedAnswer": { "@type": "Answer", "text": {{ faq_1_a | strip | json }} } }
                  {%- if product.metafields.custom.utqg_treadwear != blank or product.metafields.custom.warranty_km != blank -%}
                    ,{ "@type": "Question", "name": {{ faq_2_q | strip | json }}, "acceptedAnswer": { "@type": "Answer", "text": {{ faq_2_a | strip | json }} } }
                  {%- endif -%}
                  {%- if product.metafields.custom.load_index != blank -%}
                    ,{ "@type": "Question", "name": {{ faq_3_q | strip | json }}, "acceptedAnswer": { "@type": "Answer", "text": {{ faq_3_a | strip | json }} } }
                  {%- endif -%}
                  {%- if season_tag == 'Winter' or season_tag == 'All-Weather' or product.metafields.custom.three_peak_snowflake == true or product.metafields.custom.three_peak_snowflake == false -%}
                    ,{ "@type": "Question", "name": {{ faq_4_q | strip | json }}, "acceptedAnswer": { "@type": "Answer", "text": {{ faq_4_a | strip | json }} } }
                  {%- endif -%}
                  ,{ "@type": "Question", "name": {{ faq_5_q | strip | json }}, "acceptedAnswer": { "@type": "Answer", "text": {{ faq_5_a | strip | json }} } }
                ]
              }
              </script>
            {%- endif -%}

            {%- comment -%} Shopify description hidden — auto-generated description above covers this {%- endcomment -%}

          </div>
        {%- endif -%}

        {%- comment -%} Warranty Panel {%- endcomment -%}
        {%- comment -%} AI Assistant Panel {%- endcomment -%}
        {%- if section.settings.show_ai_tab -%}
          <div class="ptp__tab-panel" role="tabpanel" data-ptp-panel="ai">
            <div class="ptp__ai">
              <div class="ptp__ai-header">
                <div class="ptp__ai-logo"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div>
                <div><strong>Tire assistant</strong><span>Ask anything about this tire</span></div>
              </div>
              <div class="ptp__ai-suggestions">
                <button class="ptp__ai-chip" data-ptp-ai-q="{{ section.settings.ai_suggestion_1 | default: 'Is this tire good for winter driving?' | escape }}" type="button">{{ section.settings.ai_suggestion_1 | default: 'Is this tire good for winter driving?' }}</button>
                <button class="ptp__ai-chip" data-ptp-ai-q="{{ section.settings.ai_suggestion_2 | default: 'How long will this tire last?' | escape }}" type="button">{{ section.settings.ai_suggestion_2 | default: 'How long will this tire last?' }}</button>
                <button class="ptp__ai-chip" data-ptp-ai-q="{{ section.settings.ai_suggestion_3 | default: 'What size rim do I need?' | escape }}" type="button">{{ section.settings.ai_suggestion_3 | default: 'What size rim do I need?' }}</button>
              </div>
              <div class="ptp__ai-chat" data-ptp-ai-chat></div>
              <div class="ptp__ai-input-row">
                <input type="text" class="ptp__ai-input" placeholder="Ask about this tire..." data-ptp-ai-input>
                <button class="ptp__ai-send" data-ptp-ai-send type="button" aria-label="Send"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2L15 22l-4-9-9-4z"/></svg></button>
              </div>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.show_warranty_tab -%}
          <div class="ptp__tab-panel" role="tabpanel" data-ptp-panel="warranty">
            <div class="ptp__warranty-grid">
              <div class="ptp__warranty-item">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F5820B" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <div><strong>Manufacturing defect warranty</strong><span>Covers manufacturing defects for 80,000 km on all-season and all-weather tires. Winter tires are covered for 1 year from the date of purchase.</span></div>
              </div>
              <div class="ptp__warranty-item">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F5820B" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                <div><strong>What's covered</strong><span>Defects in materials and workmanship under normal driving conditions. Does not cover road hazards, punctures, improper installation, or misuse.</span></div>
              </div>
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Shipping Panel {%- endcomment -%}
        {%- if section.settings.show_shipping_tab -%}
          <div class="ptp__tab-panel" role="tabpanel" data-ptp-panel="shipping">
            <div class="ptp__shipping-info rte">
              <p><strong>Calgary delivery</strong><br>Free delivery within Calgary. Orders typically arrive within 1–3 business days.</p>
              <p><strong>Outside Calgary</strong><br>Customer covers the delivery cost. Delivery may take 1–2 weeks depending on your location.</p>
              <p><strong>Returns</strong><br>Tires must be uninstalled, unused, and with original stickers on. Contact us within 30 days of purchase.</p>
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>

        {%- comment -%} Browse & Share Links {%- endcomment -%}
        <div class="ptp__links-row">
          <div class="ptp__links">
            <a href="{{ routes.collections_url }}/tires?filter.p.vendor={{ product.vendor | url_encode }}" class="ptp__link">More from {{ product.vendor }}</a>
            {%- if tire_size != blank -%}
              <a href="{{ routes.collections_url }}/tires?filter.p.m.custom.tire_size={{ tire_size | url_encode }}" class="ptp__link">Compare {{ tire_size }} tires</a>
            {%- endif -%}
          </div>
          <div class="ptp__share" data-ptp-share>
            <span class="ptp__share-label">{{ 'products.product.share' | t | default: 'Share this product' }}</span>
            <a href="https://wa.me/?text={{ product.title | url_encode }}%20{{ shop.url | append: product.url | url_encode }}" target="_blank" rel="noopener" class="ptp__share-btn ptp__share-btn--wa" aria-label="Share on WhatsApp">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
            <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url | append: product.url | url_encode }}" target="_blank" rel="noopener" class="ptp__share-btn ptp__share-btn--fb" aria-label="Share on Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <button type="button" class="ptp__share-btn ptp__share-btn--link" data-ptp-copy-url aria-label="Copy link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
            </button>
          </div>
        </div>
    </div>{%- comment -%} /ptp__tabs-section {%- endcomment -%}

    {%- comment -%} Sticky Mobile CTA {%- endcomment -%}
    <div class="ptp__sticky">
      {%- if product.featured_image -%}
        {{ product.featured_image | image_url: width: 80, height: 80, crop: 'center' | image_tag: class: 'ptp__sticky-thumb', loading: 'lazy', alt: product.title }}
      {%- endif -%}
      <div class="ptp__sticky-price">
        <span class="ptp__sticky-set" data-ptp-sticky-total>${{ set_price | money_without_currency }}</span>
        <span class="ptp__sticky-per">set of 4</span>
