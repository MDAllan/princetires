<div class="services-grid">
  <div class="services-grid__container">
    <div class="services-grid__header">
      <h2 class="services-grid__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="services-grid__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="services-grid__items">
      {%- for block in section.blocks -%}
        <div class="services-grid__item" {{ block.shopify_attributes }}>
          <div class="services-grid__icon">
            {%- case block.settings.icon -%}
              {%- when 'wrench' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              {%- when 'shield' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- when 'truck' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'dollar' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="6" x2="12" y2="18"/><path d="M15.5 9.5c0-1.38-1.57-2.5-3.5-2.5S8.5 8.12 8.5 9.5 10.07 12 12 12s3.5 1.12 3.5 2.5-1.57 2.5-3.5 2.5-3.5-1.12-3.5-2.5"/></svg>
              {%- else -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
            {%- endcase -%}
          </div>
          <h3 class="services-grid__title">{{ block.settings.title }}</h3>
          {%- if block.settings.description != blank -%}
            <p class="services-grid__desc">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .services-grid {
    background: #fff;
    padding: 5rem 0;
  }
  .services-grid__container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .services-grid__header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .services-grid__heading {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111;
    margin: 0 0 0.5rem;
  }
  .services-grid__subtitle {
    color: #9ca3af;
    font-size: 0.875rem;
    margin: 0;
  }
  .services-grid__items {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
  }
  .services-grid__item {
    text-align: center;
  }
  .services-grid__icon {
    width: 3rem;
    height: 3rem;
    background: #f9fafb;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    color: #9ca3af;
  }
  .services-grid__title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #111;
    margin: 0 0 0.25rem;
  }
  .services-grid__desc {
    font-size: 0.75rem;
    color: #9ca3af;
    margin: 0;
  }
  @media (max-width: 768px) {
    .services-grid__items {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.services_grid.name",
  "blocks": [
    {
      "type": "service",
      "name": "t:sections.services_grid.blocks.service.name",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.services_grid.blocks.service.settings.icon",
          "options": [
            { "value": "wrench", "label": "Wrench" },
            { "value": "shield", "label": "Shield" },
            { "value": "truck", "label": "Truck" },
            { "value": "dollar", "label": "Dollar" }
          ],
          "default": "wrench"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.services_grid.blocks.service.settings.title",
          "default": "Service"
        },
        {
          "type": "text",
          "id": "description",
          "label": "t:sections.services_grid.blocks.service.settings.description"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.services_grid.settings.heading",
      "default": "Services"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.services_grid.settings.subtitle",
      "default": "Everything your vehicle needs"
    }
  ],
  "presets": [
    {
      "name": "t:sections.services_grid.name",
      "blocks": [
        { "type": "service", "settings": { "icon": "wrench", "title": "Installation", "description": "Professional mounting and balancing" } },
        { "type": "service", "settings": { "icon": "shield", "title": "Rotation", "description": "Extend your tire lifespan" } },
        { "type": "service", "settings": { "icon": "truck", "title": "Wholesale", "description": "Competitive pricing for dealers" } },
        { "type": "service", "settings": { "icon": "dollar", "title": "Price match", "description": "We'll beat any local price" } }
      ]
    }
  ]
}
{% endschema %}
