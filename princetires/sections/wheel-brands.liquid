<div class="wheel-brands" data-wheel-brands>
  <div class="wheel-brands__container">
    <div class="wheel-brands__header">
      <h2 class="wheel-brands__heading">
        {{ section.settings.heading }}
        {%- if section.settings.heading_accent != blank -%}
          <span class="wheel-brands__accent">{{ section.settings.heading_accent }}</span>
        {%- endif -%}
      </h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="wheel-brands__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- assign brand_blocks = section.blocks | where: "type", "brand" -%}
    {%- assign wheel_blocks = section.blocks | where: "type", "wheel_card" -%}

    {%- if brand_blocks.size > 0 -%}
      {%- capture wheel_tab_items -%}
        {%- for block in brand_blocks -%}
          <button
            class="wheel-brands__tab{% if forloop.first %} wheel-brands__tab--active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            data-wheel-brand="{{ block.settings.name | handleize }}"
            data-wheel-brand-name="{{ block.settings.name | escape }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.logo != blank -%}
              {{ block.settings.logo | image_url: height: 28 | image_tag: class: "wheel-brands__tab-logo", alt: block.settings.name }}
            {%- else -%}
              <span class="wheel-brands__tab-text">{{ block.settings.name }}</span>
            {%- endif -%}
          </button>
        {%- endfor -%}
      {%- endcapture -%}

      <div class="wheel-brands__tabs-marquee">
        <div class="wheel-brands__tabs-track" role="tablist">
          {{ wheel_tab_items }}
          {{ wheel_tab_items }}
        </div>
      </div>
    {%- endif -%}

    <div class="wheel-brands__carousel-wrap">
      <button class="wheel-brands__arrow wheel-brands__arrow--left" data-wheel-prev aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>

      <div class="wheel-brands__carousel" data-wheel-carousel>
        <div class="wheel-brands__track" data-wheel-track>
          {%- if wheel_blocks.size > 0 -%}
            {%- for block in wheel_blocks -%}
              <div
                class="wheel-brands__card"
                data-wheel-card-brand="{{ block.settings.brand | handleize }}"
                {{ block.shopify_attributes }}
              >
                <div class="wheel-brands__card-image">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 500 | image_tag }}
                  {%- else -%}
                    <div class="wheel-brands__card-placeholder"></div>
                  {%- endif -%}
                </div>
                <div class="wheel-brands__card-body">
                  <span class="wheel-brands__card-brand">{{ block.settings.brand | escape }}</span>
                  <h3 class="wheel-brands__card-model">{{ block.settings.model | escape }}</h3>
                  {%- if block.settings.style != blank -%}
                    <span class="wheel-brands__card-style">{{ block.settings.style | escape }}</span>
                  {%- endif -%}
                  {%- if block.settings.sizes != blank -%}
                    <span class="wheel-brands__card-sizes">{{ block.settings.sizes | escape }}</span>
                  {%- endif -%}
                </div>
                <div class="wheel-brands__card-action">
                  <a href="{{ block.settings.link | default: '#' }}" class="wheel-brands__card-btn">
                    {{ block.settings.button_text | default: 'Request Quote' }}
                  </a>
                </div>
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- comment -%} Placeholder cards when no wheel cards added yet {%- endcomment -%}
            {%- for i in (1..4) -%}
              <div class="wheel-brands__card">
                <div class="wheel-brands__card-image">
                  <div class="wheel-brands__card-placeholder"></div>
                </div>
                <div class="wheel-brands__card-body">
                  <span class="wheel-brands__card-brand">Brand</span>
                  <h3 class="wheel-brands__card-model">Wheel model</h3>
                  <span class="wheel-brands__card-style">Add wheels in theme editor</span>
                </div>
                <div class="wheel-brands__card-action">
                  <a href="#" class="wheel-brands__card-btn">Request Quote</a>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      <button class="wheel-brands__arrow wheel-brands__arrow--right" data-wheel-next aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

    <div class="wheel-brands__footer">
      <a href="{{ section.settings.view_all_link | default: '/collections/wheels' }}" class="wheel-brands__view-all">
        {{ 'sections.wheel_brands.view_all' | t }} →
      </a>
    </div>
  </div>
</div>

{% stylesheet %}
  .wheel-brands {
    background: #f9fafb;
    padding: 5rem 0 4rem;
  }

  .wheel-brands__container {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 10rem;
  }

  .wheel-brands__header {
    text-align: center;
    margin-bottom: 2.4rem;
  }

  .wheel-brands__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.8rem;
    font-weight: 700;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.6rem;
  }

  .wheel-brands__accent {
    color: #dc2626;
  }

  .wheel-brands__subtitle {
    font-family: 'Outfit', sans-serif;
    color: #9ca3af;
    font-size: 1.4rem;
    font-weight: 300;
    margin: 0;
    max-width: 50rem;
    margin-left: auto;
    margin-right: auto;
  }

  .wheel-brands__tabs-marquee {
    overflow: hidden;
    margin-bottom: 3rem;
    mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);
  }

  .wheel-brands__tabs-track {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: max-content;
    animation: wb-marquee 30s linear infinite;
  }

  .wheel-brands__tabs-marquee:hover .wheel-brands__tabs-track {
    animation-play-state: paused;
  }

  @keyframes wb-marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .wheel-brands__tab {
    background: transparent;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 0.8rem 2rem;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .wheel-brands__tab:hover {
    background: #f9fafb;
    border-color: #d1d5db;
  }

  .wheel-brands__tab--active {
    border-color: #dc2626;
    background: #fef2f2;
  }

  .wheel-brands__tab-logo {
    height: 24px;
    width: auto;
    display: block;
  }

  .wheel-brands__tab-text {
    font-size: 1.2rem;
    font-weight: 500;
    color: #374151;
    white-space: nowrap;
  }

  .wheel-brands__carousel-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .wheel-brands__carousel {
    overflow: hidden;
    flex: 1;
    border-radius: 8px;
  }

  .wheel-brands__track {
    display: flex;
    gap: 1.6rem;
    transition: transform 0.4s ease;
    cursor: grab;
    user-select: none;
  }

  .wheel-brands__track:active {
    cursor: grabbing;
  }

  .wheel-brands__arrow {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid #e5e7eb;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #6b7280;
    transition: all 0.2s;
  }

  .wheel-brands__arrow:hover {
    border-color: #d1d5db;
    color: #111;
    background: #f3f4f6;
  }

  .wheel-brands__card {
    min-width: calc(25% - 1.2rem);
    max-width: calc(25% - 1.2rem);
    border: 1px solid #f0f0f0;
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .wheel-brands__card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    transform: translateY(-2px);
  }

  .wheel-brands__card[hidden] {
    display: none;
  }

  .wheel-brands__card-image {
    background: #f7f7f8;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 2rem;
  }

  .wheel-brands__card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .wheel-brands__card-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e5e7eb, #d1d5db);
    opacity: 0.5;
  }

  .wheel-brands__card-body {
    padding: 1.4rem 1.6rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }

  .wheel-brands__card-brand {
    font-family: 'Outfit', sans-serif;
    font-size: 1.05rem;
    font-weight: 400;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .wheel-brands__card-model {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.7rem;
    font-weight: 600;
    color: #111;
    margin: 0;
    line-height: 1.2;
  }

  .wheel-brands__card-style {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    color: #6b7280;
    font-weight: 300;
  }

  .wheel-brands__card-sizes {
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    color: #9ca3af;
    font-weight: 300;
    margin-top: 0.2rem;
  }

  .wheel-brands__card-action {
    padding: 0 1.6rem 1.6rem;
    margin-top: auto;
  }

  .wheel-brands__card-btn {
    display: block;
    background: #dc2626;
    color: #fff;
    text-align: center;
    padding: 0.9rem;
    border-radius: 8px;
    text-decoration: none;
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    transition: background 0.2s;
  }

  .wheel-brands__card-btn:hover {
    background: #b91c1c;
    color: #fff;
  }

  .wheel-brands__footer {
    text-align: center;
    margin-top: 2.4rem;
  }

  .wheel-brands__view-all {
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 500;
    color: #dc2626;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .wheel-brands__view-all:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .wheel-brands__container {
      padding: 0 1.6rem;
    }
    .wheel-brands__card {
      min-width: 70vw;
      max-width: 70vw;
    }
    .wheel-brands__arrow {
      display: none;
    }
    .wheel-brands__tabs {
      gap: 0.4rem;
    }
    .wheel-brands__heading {
      font-size: 2.2rem;
    }
  }
{% endstylesheet %}

{% javascript %}
  class WheelBrandsSwitcher {
    constructor(section) {
      this.section = section;
      this.carousel = section.querySelector('[data-wheel-carousel]');
      this.track = section.querySelector('[data-wheel-track]');
      this.prevBtn = section.querySelector('[data-wheel-prev]');
      this.nextBtn = section.querySelector('[data-wheel-next]');
      this.tabs = section.querySelectorAll('.wheel-brands__tabs-track .wheel-brands__tab');
      this.cards = section.querySelectorAll('[data-wheel-card-brand]');
      this.isDragging = false;
      this.startX = 0;
      this.scrollLeft = 0;

      this.bindEvents();
      if (this.tabs.length > 0) this.switchBrand(this.tabs[0]);
    }

    bindEvents() {
      var self = this;
      this.tabs.forEach(function(tab) {
        tab.addEventListener('click', function() { self.switchBrand(tab); });
      });
      this.prevBtn.addEventListener('click', function() { self.scroll(-1); });
      this.nextBtn.addEventListener('click', function() { self.scroll(1); });

      this.track.addEventListener('mousedown', function(e) { self.dragStart(e); });
      this.track.addEventListener('mousemove', function(e) { self.dragMove(e); });
      this.track.addEventListener('mouseup', function() { self.dragEnd(); });
      this.track.addEventListener('mouseleave', function() { self.dragEnd(); });
      this.track.addEventListener('touchstart', function(e) { self.dragStart(e); }, { passive: true });
      this.track.addEventListener('touchmove', function(e) { self.dragMove(e); }, { passive: true });
      this.track.addEventListener('touchend', function() { self.dragEnd(); });
    }

    dragStart(e) {
      this.isDragging = true;
      this.startX = (e.touches ? e.touches[0].pageX : e.pageX);
      this.scrollLeft = this.carousel.scrollLeft;
    }

    dragMove(e) {
      if (!this.isDragging) return;
      var x = (e.touches ? e.touches[0].pageX : e.pageX);
      this.carousel.scrollLeft = this.scrollLeft - (x - this.startX) * 1.2;
    }

    dragEnd() { this.isDragging = false; }

    scroll(dir) {
      var w = this.carousel.offsetWidth * 0.6;
      this.carousel.scrollBy({ left: dir * w, behavior: 'smooth' });
    }

    switchBrand(tab) {
      var brandHandle = tab.dataset.wheelBrand;

      this.tabs.forEach(function(t) {
        t.classList.remove('wheel-brands__tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('wheel-brands__tab--active');
      tab.setAttribute('aria-selected', 'true');

      this.cards.forEach(function(card) {
        if (card.dataset.wheelCardBrand === brandHandle) {
          card.hidden = false;
          card.style.display = '';
        } else {
          card.hidden = true;
          card.style.display = 'none';
        }
      });

      this.carousel.scrollLeft = 0;
    }
  }

  document.querySelectorAll('[data-wheel-brands]').forEach(function(el) {
    new WheelBrandsSwitcher(el);
  });
{% endjavascript %}

{% schema %}
