<div class="wheel-brands" data-wheel-brands>
  <div class="wheel-brands__container">
    <div class="wheel-brands__header">
      <h2 class="wheel-brands__heading">
        {{ section.settings.heading }}
        {%- if section.settings.heading_accent != blank -%}
          <span class="wheel-brands__accent">{{ section.settings.heading_accent }}</span>
        {%- endif -%}
      </h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="wheel-brands__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- assign brand_blocks = section.blocks | where: "type", "brand" -%}
    {%- assign wheel_blocks = section.blocks | where: "type", "wheel_card" -%}

    {%- if brand_blocks.size > 0 -%}
      <div class="wheel-brands__tabs-wrap">
        <button class="wheel-brands__tabs-arrow wheel-brands__tabs-arrow--left" data-wb-tabs-prev aria-label="{{ 'general.accessibility.previous' | t }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>

        <div class="wheel-brands__tabs-scroll" data-wb-tabs-scroll>
          <div class="wheel-brands__tabs-track" role="tablist">
            {%- for block in brand_blocks -%}
              <button
                class="wheel-brands__tab{% if forloop.first %} wheel-brands__tab--active{% endif %}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                data-wheel-brand="{{ block.settings.name | handleize }}"
                data-wheel-brand-name="{{ block.settings.name | escape }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.logo != blank -%}
                  {{ block.settings.logo | image_url: height: 28 | image_tag: class: "wheel-brands__tab-logo", alt: block.settings.name }}
                {%- else -%}
                  <span class="wheel-brands__tab-text">{{ block.settings.name }}</span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        </div>

        <button class="wheel-brands__tabs-arrow wheel-brands__tabs-arrow--right" data-wb-tabs-next aria-label="{{ 'general.accessibility.next' | t }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    {%- endif -%}

    <div class="wheel-brands__carousel-wrap">
      <button class="wheel-brands__arrow wheel-brands__arrow--left" data-wheel-prev aria-label="{{ 'general.accessibility.previous' | t }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>

      <div class="wheel-brands__carousel" data-wheel-carousel>
        <div class="wheel-brands__track" data-wheel-track>
          {%- if wheel_blocks.size > 0 -%}
            {%- for block in wheel_blocks -%}
              {%- assign auto_link = block.settings.brand | append: ' ' | append: block.settings.model -%}
              {%- assign card_link = block.settings.link | default: blank -%}
              <div
                class="wheel-brands__card"
                data-wheel-card-brand="{{ block.settings.brand | handleize }}"
                {{ block.shopify_attributes }}
              >
                <div class="wheel-brands__card-image">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 500 | image_tag }}
                  {%- else -%}
                    <div class="wheel-brands__card-placeholder"></div>
                  {%- endif -%}
                </div>
                <div class="wheel-brands__card-body">
                  <span class="wheel-brands__card-brand">{{ block.settings.brand | escape }}</span>
                  <h3 class="wheel-brands__card-model">{{ block.settings.model | escape }}</h3>
                  {%- if block.settings.style != blank -%}
                    <span class="wheel-brands__card-style">{{ block.settings.style | escape }}</span>
                  {%- endif -%}
                  {%- if block.settings.sizes != blank -%}
                    <span class="wheel-brands__card-sizes">{{ block.settings.sizes | escape }}</span>
                  {%- endif -%}
                </div>
                <div class="wheel-brands__card-action">
                  {%- capture quote_url -%}/pages/wheel-quote?brand={{ block.settings.brand | url_encode }}&model={{ block.settings.model | url_encode }}&style={{ block.settings.style | url_encode }}&sizes={{ block.settings.sizes | url_encode }}{%- endcapture -%}
                  <a href="{% if card_link != blank %}{{ card_link }}{% else %}{{ quote_url }}{% endif %}" class="wheel-brands__card-btn">
                    {{ block.settings.button_text | default: 'Request Quote' }}
                  </a>
                </div>
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..4) -%}
              <div class="wheel-brands__card">
                <div class="wheel-brands__card-image">
                  <div class="wheel-brands__card-placeholder"></div>
                </div>
                <div class="wheel-brands__card-body">
                  <span class="wheel-brands__card-brand">Brand</span>
                  <h3 class="wheel-brands__card-model">Wheel model</h3>
                  <span class="wheel-brands__card-style">Add wheels in theme editor</span>
                </div>
                <div class="wheel-brands__card-action">
                  <a href="#" class="wheel-brands__card-btn">Request Quote</a>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      <button class="wheel-brands__arrow wheel-brands__arrow--right" data-wheel-next aria-label="{{ 'general.accessibility.next' | t }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

    <div class="wheel-brands__footer">
      <a href="{{ section.settings.view_all_link | default: '/collections/wheels' }}" class="wheel-brands__view-all" data-wb-view-all>
        {{ 'sections.wheel_brands.view_all' | t }} <span data-wb-view-all-name>{{ brand_blocks.first.settings.name }}</span> →
      </a>
    </div>
  </div>
</div>

{% stylesheet %}
  .wheel-brands {
    background: #f9fafb;
    padding: 5rem 0 4rem;
  }

  .wheel-brands__container {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 10rem;
  }

  .wheel-brands__header {
    text-align: center;
    margin-bottom: 2.4rem;
  }

  .wheel-brands__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.8rem;
    font-weight: 700;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.6rem;
  }

  .wheel-brands__accent {
    color: #dc2626;
  }

  .wheel-brands__subtitle {
    font-family: 'Outfit', sans-serif;
    color: #9ca3af;
    font-size: 1.4rem;
    font-weight: 300;
    margin: 0;
    max-width: 50rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Swipeable tab bar ── */
  .wheel-brands__tabs-wrap {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 3rem;
    position: relative;
  }

  .wheel-brands__tabs-scroll {
    flex: 1;
    overflow: hidden;
  }

  .wheel-brands__tabs-track {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: max-content;
    padding: 0.4rem 0;
  }

  .wheel-brands__tabs-arrow {
    display: none;
  }

  .wheel-brands__tab {
    background: transparent;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 0.8rem 2rem;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .wheel-brands__tab:hover {
    background: #f9fafb;
    border-color: #d1d5db;
    transform: scale(1.04);
  }

  .wheel-brands__tab--active {
    border-color: #111;
    background: #f9fafb;
  }

  .wheel-brands__tab-logo {
    height: 24px;
    width: auto;
    display: block;
  }

  .wheel-brands__tab-text {
    font-size: 1.2rem;
    font-weight: 500;
    color: #374151;
  }

  /* ── Product carousel ── */
  .wheel-brands__carousel-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .wheel-brands__carousel {
    overflow: hidden;
    flex: 1;
    border-radius: 8px;
  }

  .wheel-brands__track {
    display: flex;
    gap: 1.6rem;
    transition: transform 0.4s ease;
    cursor: grab;
    user-select: none;
  }

  .wheel-brands__track:active {
    cursor: grabbing;
  }

  .wheel-brands__arrow {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid #e5e7eb;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #6b7280;
    transition: all 0.2s;
  }

  .wheel-brands__arrow:hover {
    border-color: #d1d5db;
    color: #111;
    background: #f3f4f6;
  }

  .wheel-brands__card {
    min-width: calc(25% - 1.2rem);
    max-width: calc(25% - 1.2rem);
    border: 1px solid #f0f0f0;
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .wheel-brands__card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    transform: translateY(-2px);
  }

  .wheel-brands__card[hidden] {
    display: none;
  }

  .wheel-brands__card-image {
    background: #f7f7f8;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 2rem;
  }

  .wheel-brands__card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .wheel-brands__card-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e5e7eb, #d1d5db);
    opacity: 0.5;
  }

  .wheel-brands__card-body {
    padding: 1.4rem 1.6rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }

  .wheel-brands__card-brand {
    font-family: 'Outfit', sans-serif;
    font-size: 1.05rem;
    font-weight: 400;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .wheel-brands__card-model {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.7rem;
    font-weight: 600;
    color: #111;
    margin: 0;
    line-height: 1.2;
  }

  .wheel-brands__card-style {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    color: #6b7280;
    font-weight: 300;
  }

  .wheel-brands__card-sizes {
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    color: #9ca3af;
    font-weight: 300;
    margin-top: 0.2rem;
  }

  .wheel-brands__card-action {
    padding: 0 1.6rem 1.6rem;
    margin-top: auto;
  }

  .wheel-brands__card-btn {
    display: block;
    background: #dc2626;
    color: #fff;
    text-align: center;
    padding: 0.9rem;
    border-radius: 8px;
    text-decoration: none;
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    transition: background 0.2s;
  }

  .wheel-brands__card-btn:hover {
    background: #b91c1c;
    color: #fff;
  }

  .wheel-brands__footer {
    text-align: center;
    margin-top: 2.4rem;
  }

  .wheel-brands__view-all {
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 500;
    color: #dc2626;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .wheel-brands__view-all:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .wheel-brands__container {
      padding: 0 1.6rem;
    }
    .wheel-brands__card {
      min-width: 70vw;
      max-width: 70vw;
    }
    .wheel-brands__arrow {
      display: none;
    }
    .wheel-brands__heading {
      font-size: 2.2rem;
    }
    .wheel-brands__tabs-arrow {
      display: none;
    }
    .wheel-brands__tabs-scroll {
      mask-image: none;
      -webkit-mask-image: none;
    }
  }

  @media (max-width: 480px) {
    .wheel-brands {
      padding: 4rem 0 3rem;
    }
    .wheel-brands__container {
      padding: 0 1.6rem;
    }
    .wheel-brands__heading {
      font-size: clamp(1.8rem, 5vw, 2.2rem);
    }
    .wheel-brands__subtitle {
      font-size: 1.2rem;
    }
    .wheel-brands__card {
      min-width: 80vw;
      max-width: 80vw;
    }
    .wheel-brands__card-btn {
      padding: 1.2rem;
      min-height: 4.4rem;
      font-size: 1.4rem;
    }
    .wheel-brands__tab {
      padding: 1rem 1.8rem;
      min-height: 4.4rem;
    }
    .wheel-brands__tabs-wrap {
      margin-bottom: 2rem;
    }
    .wheel-brands__view-all {
      font-size: 1.3rem;
      min-height: 4.4rem;
      display: inline-flex;
      align-items: center;
    }
  }

  @media (max-width: 360px) {
    .wheel-brands__container {
      padding: 0 1.2rem;
    }
    .wheel-brands__card {
      min-width: 85vw;
      max-width: 85vw;
    }
    .wheel-brands__heading {
      font-size: 1.8rem;
    }
    .wheel-brands__card-body {
      padding: 1.2rem 1.4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wheel-brands__card {
      transition: none !important;
    }
    .wheel-brands__tab {
      transition: none !important;
    }
  }
{% endstylesheet %}

{% javascript %}
  class WheelBrandsSwitcher {
    constructor(section) {
      this.section = section;
      this.carousel = section.querySelector('[data-wheel-carousel]');
      this.track = section.querySelector('[data-wheel-track]');
      this.prevBtn = section.querySelector('[data-wheel-prev]');
      this.nextBtn = section.querySelector('[data-wheel-next]');
      this.viewAllLink = section.querySelector('[data-wb-view-all]');
      this.viewAllName = section.querySelector('[data-wb-view-all-name]');

      this.tabsScroll = section.querySelector('[data-wb-tabs-scroll]');
      this.tabsPrev = section.querySelector('[data-wb-tabs-prev]');
      this.tabsNext = section.querySelector('[data-wb-tabs-next]');
      this.tabs = section.querySelectorAll('.wheel-brands__tabs-track .wheel-brands__tab');
      this.cards = section.querySelectorAll('[data-wheel-card-brand]');

      this.bindEvents();
      if (this.tabs.length > 0) this.switchBrand(this.tabs[0], false);
    }

    bindEvents() {
      var self = this;

      /* ── Tab clicks ── */
      this.tabs.forEach(function(tab) {
        tab.addEventListener('click', function() { self.switchBrand(tab, true); });
      });

      /* ── Tab strip swipe (touch + mouse drag) ── */
      if (this.tabsScroll) {
        var tabDrag = { active: false, startX: 0, scrollLeft: 0 };

        this.tabsScroll.addEventListener('mousedown', function(e) {
          tabDrag.active = true;
          tabDrag.startX = e.pageX;
          tabDrag.scrollLeft = self.tabsScroll.scrollLeft;
          self.tabsScroll.style.cursor = 'grabbing';
        });
        this.tabsScroll.addEventListener('mousemove', function(e) {
          if (!tabDrag.active) return;
          e.preventDefault();
          self.tabsScroll.scrollLeft = tabDrag.scrollLeft - (e.pageX - tabDrag.startX);
        });
        this.tabsScroll.addEventListener('mouseup', function() { tabDrag.active = false; self.tabsScroll.style.cursor = ''; });
        this.tabsScroll.addEventListener('mouseleave', function() { tabDrag.active = false; self.tabsScroll.style.cursor = ''; });

        if (this.tabsPrev) {
          this.tabsPrev.addEventListener('click', function() {
            self.tabsScroll.scrollBy({ left: -200, behavior: 'smooth' });
          });
        }
        if (this.tabsNext) {
          this.tabsNext.addEventListener('click', function() {
            self.tabsScroll.scrollBy({ left: 200, behavior: 'smooth' });
          });
        }
      }

      /* ── Product carousel arrows ── */
      this.prevBtn.addEventListener('click', function() { self.scrollCarousel(-1); });
      this.nextBtn.addEventListener('click', function() { self.scrollCarousel(1); });

      /* ── Product carousel drag ── */
      var drag = { active: false, startX: 0, scrollLeft: 0 };
      this.carousel.style.overflowX = 'auto';
      this.carousel.style.scrollbarWidth = 'none';

      this.track.addEventListener('mousedown', function(e) {
        drag.active = true;
        drag.startX = e.pageX;
        drag.scrollLeft = self.carousel.scrollLeft;
      });
      this.track.addEventListener('mousemove', function(e) {
        if (!drag.active) return;
        e.preventDefault();
        self.carousel.scrollLeft = drag.scrollLeft - (e.pageX - drag.startX);
      });
      this.track.addEventListener('mouseup', function() { drag.active = false; });
      this.track.addEventListener('mouseleave', function() { drag.active = false; });
      this.track.addEventListener('touchstart', function(e) {
        drag.active = true;
        drag.startX = e.touches[0].pageX;
        drag.scrollLeft = self.carousel.scrollLeft;
      }, { passive: true });
      this.track.addEventListener('touchmove', function(e) {
        if (!drag.active) return;
        self.carousel.scrollLeft = drag.scrollLeft - (e.touches[0].pageX - drag.startX);
      }, { passive: true });
      this.track.addEventListener('touchend', function() { drag.active = false; });

      /* ── Tab strip marquee auto-scroll ── */
      this.startTabMarquee();
    }

    startTabMarquee() {
      var self = this;
      var scroll = this.tabsScroll;
      if (!scroll) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      var origTrack = scroll.querySelector('.wheel-brands__tabs-track');
      if (!origTrack) return;

      /* Wrap original + clone in a single flex row for seamless loop */
      var wrapper = document.createElement('div');
      wrapper.style.cssText = 'display:flex;align-items:center;gap:1rem;width:max-content;will-change:transform';

      scroll.appendChild(wrapper);
      wrapper.appendChild(origTrack);

      var clone = origTrack.cloneNode(true);
      clone.setAttribute('aria-hidden', 'true');
      clone.querySelectorAll('button').forEach(function(b) {
        b.setAttribute('tabindex', '-1');
        b.setAttribute('aria-hidden', 'true');
        b.style.pointerEvents = 'none';
      });
      wrapper.appendChild(clone);

      var pos = 0;
      this._marqueePaused = false;

      scroll.addEventListener('mouseenter', function() { self._marqueePaused = true; });
      scroll.addEventListener('mouseleave', function() { self._marqueePaused = false; });
      scroll.addEventListener('touchstart', function() { self._marqueePaused = true; }, { passive: true });
      scroll.addEventListener('touchend', function() {
        setTimeout(function() { self._marqueePaused = false; }, 1500);
      });

      function tick() {
        if (!self._marqueePaused) {
          pos += 0.5;
          /* Loop when we've scrolled one full copy of the original track */
          var loopAt = origTrack.offsetWidth + 16; /* +16 for the 1rem gap between copies */
          if (pos >= loopAt) pos = 0;
          wrapper.style.transform = 'translateX(-' + pos + 'px)';
        }
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    scrollCarousel(dir) {
      var w = this.carousel.offsetWidth * 0.6;
      this.carousel.scrollBy({ left: dir * w, behavior: 'smooth' });
    }

    switchBrand(tab, scrollTab) {
      var brandHandle = tab.dataset.wheelBrand;
      var brandName = tab.dataset.wheelBrandName;

      this.tabs.forEach(function(t) {
        t.classList.remove('wheel-brands__tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('wheel-brands__tab--active');
      tab.setAttribute('aria-selected', 'true');

      /* Scroll active tab into view — only on user clicks, not on init */
      if (scrollTab) tab.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });

      if (this.viewAllName) this.viewAllName.textContent = brandName;
      if (this.viewAllLink) {
        this.viewAllLink.href = '/search?q=' + encodeURIComponent(brandName) + '&type=product';
      }

      this.cards.forEach(function(card) {
        if (card.dataset.wheelCardBrand === brandHandle) {
          card.hidden = false;
          card.style.display = '';
        } else {
          card.hidden = true;
          card.style.display = 'none';
        }
      });

      this.carousel.scrollLeft = 0;
    }
  }

  document.querySelectorAll('[data-wheel-brands]').forEach(function(el) {
    new WheelBrandsSwitcher(el);
  });
{% endjavascript %}

{% schema %}
{
  "name": "Wheel brands",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Wheels by"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent",
      "default": "Brand"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>Browse wheel styles, choose your size, enter your vehicle, and request a quote from our Calgary team.</p>"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link",
      "info": "Default: /collections/wheels"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand tab",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Brand name",
          "default": "Brand"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand logo"
        }
      ]
    },
    {
      "type": "wheel_card",
      "name": "Wheel",
      "settings": [
        {
          "type": "text",
          "id": "brand",
          "label": "Brand name",
          "info": "Must match a brand tab name exactly",
          "default": "XF Off-Road"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Wheel image"
        },
        {
          "type": "text",
          "id": "model",
          "label": "Model name",
          "default": "XF-220"
        },
        {
          "type": "text",
          "id": "style",
          "label": "Style",
          "default": "Matte Black Milled"
        },
