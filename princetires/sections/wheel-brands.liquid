<div class="wheel-brands" data-wheel-brands>
  <div class="wheel-brands__container">
    <div class="wheel-brands__header">
      <h2 class="wheel-brands__heading">
        {{ section.settings.heading }}
        {%- if section.settings.heading_accent != blank -%}
          <span class="wheel-brands__accent">{{ section.settings.heading_accent }}</span>
        {%- endif -%}
      </h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="wheel-brands__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- assign brand_blocks = section.blocks | where: "type", "brand" -%}
    {%- assign wheel_blocks = section.blocks | where: "type", "wheel_card" -%}

    {%- if brand_blocks.size > 0 -%}
      <div class="wheel-brands__marquee" data-wheel-marquee>
        <div class="wheel-brands__marquee-inner">
          <div class="wheel-brands__tabs-track" role="tablist" data-wheel-tabs-track>
            {%- for block in brand_blocks -%}
              <button
                class="wheel-brands__tab{% if forloop.first %} wheel-brands__tab--active{% endif %}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                data-wheel-brand="{{ block.settings.name | handleize }}"
                data-wheel-brand-name="{{ block.settings.name | escape }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.logo != blank -%}
                  {{ block.settings.logo | image_url: height: 28 | image_tag: class: "wheel-brands__tab-logo", alt: block.settings.name }}
                {%- else -%}
                  <span class="wheel-brands__tab-text">{{ block.settings.name }}</span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>
          <div class="wheel-brands__tabs-track" aria-hidden="true">
            {%- for block in brand_blocks -%}
              <button
                class="wheel-brands__tab"
                tabindex="-1"
                aria-hidden="true"
                data-wheel-brand="{{ block.settings.name | handleize }}"
                data-wheel-brand-name="{{ block.settings.name | escape }}"
              >
                {%- if block.settings.logo != blank -%}
                  {{ block.settings.logo | image_url: height: 28 | image_tag: class: "wheel-brands__tab-logo", alt: block.settings.name }}
                {%- else -%}
                  <span class="wheel-brands__tab-text">{{ block.settings.name }}</span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        </div>
      </div>
    {%- endif -%}

    <div class="wheel-brands__carousel-wrap">
      <button class="wheel-brands__arrow wheel-brands__arrow--left" data-wheel-prev aria-label="{{ 'general.accessibility.previous' | t }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>

      <div class="wheel-brands__carousel" data-wheel-carousel>
        <div class="wheel-brands__track" data-wheel-track>
          {%- if wheel_blocks.size > 0 -%}
            {%- for block in wheel_blocks -%}
              {%- assign card_link = block.settings.link | default: blank -%}
              <div
                class="wheel-brands__card"
                data-wheel-card-brand="{{ block.settings.brand | handleize }}"
                {{ block.shopify_attributes }}
              >
                <div class="wheel-brands__card-image">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 500 | image_tag }}
                  {%- else -%}
                    <div class="wheel-brands__card-placeholder"></div>
                  {%- endif -%}
                </div>
                <div class="wheel-brands__card-body">
                  <span class="wheel-brands__card-brand">{{ block.settings.brand | escape }}</span>
                  <h3 class="wheel-brands__card-model">{{ block.settings.model | escape }}</h3>
                  {%- if block.settings.style != blank -%}
                    <span class="wheel-brands__card-style">{{ block.settings.style | escape }}</span>
                  {%- endif -%}
                  {%- if block.settings.sizes != blank -%}
                    <span class="wheel-brands__card-sizes">{{ block.settings.sizes | escape }}</span>
                  {%- endif -%}
                </div>
                <div class="wheel-brands__card-action">
                  {%- capture quote_url -%}/pages/wheel-quote?brand={{ block.settings.brand | url_encode }}&model={{ block.settings.model | url_encode }}&style={{ block.settings.style | url_encode }}&sizes={{ block.settings.sizes | url_encode }}{%- endcapture -%}
                  <a href="{% if card_link != blank %}{{ card_link }}{% else %}{{ quote_url }}{% endif %}" class="wheel-brands__card-btn">
                    {{ block.settings.button_text | default: 'Request Quote' }}
                  </a>
                </div>
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..4) -%}
              <div class="wheel-brands__card">
                <div class="wheel-brands__card-image">
                  <div class="wheel-brands__card-placeholder"></div>
                </div>
                <div class="wheel-brands__card-body">
                  <span class="wheel-brands__card-brand">Brand</span>
                  <h3 class="wheel-brands__card-model">Wheel model</h3>
                  <span class="wheel-brands__card-style">Add wheels in theme editor</span>
                </div>
                <div class="wheel-brands__card-action">
                  <a href="#" class="wheel-brands__card-btn">Request Quote</a>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      <button class="wheel-brands__arrow wheel-brands__arrow--right" data-wheel-next aria-label="{{ 'general.accessibility.next' | t }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

    <div class="wheel-brands__footer">
      <a href="{{ section.settings.view_all_link | default: '/collections/wheels' }}" class="wheel-brands__view-all" data-wb-view-all>
        {{ 'sections.wheel_brands.view_all' | t }} <span data-wb-view-all-name>{{ brand_blocks.first.settings.name }}</span> →
      </a>
    </div>
  </div>

  <script>
  (function() {
    var section = document.currentScript.closest('[data-wheel-brands]');
    if (!section) return;

    var marqueeEl    = section.querySelector('[data-wheel-marquee]');
    var marqueeInner = marqueeEl && marqueeEl.querySelector('.wheel-brands__marquee-inner');
    var tabsTrack    = section.querySelector('[data-wheel-tabs-track]');
    var carousel     = section.querySelector('[data-wheel-carousel]');
    var prevBtn      = section.querySelector('[data-wheel-prev]');
    var nextBtn      = section.querySelector('[data-wheel-next]');
    var viewAllLink  = section.querySelector('[data-wb-view-all]');
    var viewAllName  = section.querySelector('[data-wb-view-all-name]');

    if (!carousel) return;

    function switchBrand(brandHandle, brandName) {
      var cards = section.querySelectorAll('[data-wheel-card-brand]');
      if (marqueeEl) {
        marqueeEl.querySelectorAll('[data-wheel-brand]').forEach(function(b) {
          var isActive = b.dataset.wheelBrand === brandHandle;
          b.classList.toggle('wheel-brands__tab--active', isActive);
          b.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
      }
      if (viewAllName) viewAllName.textContent = brandName;
      if (viewAllLink) viewAllLink.href = '/search?q=' + encodeURIComponent(brandName) + '&type=product';
      cards.forEach(function(card) {
        card.style.display = card.dataset.wheelCardBrand === brandHandle ? 'flex' : 'none';
      });
      carousel.scrollLeft = 0;
    }

    if (marqueeEl) {
      // Auto-marquee removed — tabs are user-scrolled. Click handler still
      // switches the active brand.
      marqueeEl.addEventListener('click', function(e) {
        var btn = e.target.closest('[data-wheel-brand]');
        if (!btn) return;
        switchBrand(btn.dataset.wheelBrand, btn.dataset.wheelBrandName);
      });
    }

    var firstBtn = tabsTrack && tabsTrack.querySelector('[data-wheel-brand]');
    if (firstBtn) switchBrand(firstBtn.dataset.wheelBrand, firstBtn.dataset.wheelBrandName);

    // Auto-scroll tick loop removed — wheels move only on user swipe / drag /
    // arrow click.

    var drag = { on: false, startX: 0, startLeft: 0 };
    carousel.addEventListener('mousedown', function(e) {
      drag.on = true; drag.startX = e.pageX; drag.startLeft = carousel.scrollLeft;
      carousel.style.cursor = 'grabbing';
    });
    document.addEventListener('mousemove', function(e) {
      if (!drag.on) return;
      e.preventDefault();
      carousel.scrollLeft = drag.startLeft - (e.pageX - drag.startX);
    }, { passive: false });
    document.addEventListener('mouseup', function() {
      if (!drag.on) return;
      drag.on = false; carousel.style.cursor = '';
    });
    carousel.addEventListener('touchstart', function(e) {
      drag.on = true; drag.startX = e.touches[0].pageX; drag.startLeft = carousel.scrollLeft;
    }, { passive: true });
    carousel.addEventListener('touchmove', function(e) {
      if (!drag.on) return;
      carousel.scrollLeft = drag.startLeft - (e.touches[0].pageX - drag.startX);
    }, { passive: true });
    carousel.addEventListener('touchend', function() {
      drag.on = false;
    });

    if (prevBtn) prevBtn.addEventListener('click', function() {
      carousel.scrollBy({ left: -carousel.offsetWidth * 0.6, behavior: 'smooth' });
    });
    if (nextBtn) nextBtn.addEventListener('click', function() {
      carousel.scrollBy({ left: carousel.offsetWidth * 0.6, behavior: 'smooth' });
    });
  }());
  </script>
</div>

{% stylesheet %}
  .wheel-brands {
    background: #f9fafb;
    padding: 5rem 0 4rem;
  }

  .wheel-brands__container {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 10rem;
  }

  .wheel-brands__header {
    text-align: center;
    margin-bottom: 2.4rem;
  }

  .wheel-brands__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.8rem;
    font-weight: 700;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.6rem;
  }

  .wheel-brands__accent {
    color: #dc2626;
  }

  .wheel-brands__subtitle {
    font-family: 'Outfit', sans-serif;
    color: #9ca3af;
    font-size: 1.4rem;
    font-weight: 300;
    margin: 0 auto;
    max-width: 50rem;
  }

  /* ── Brand tab bar (horizontal-scroll, user-controlled) ── */
  .wheel-brands__marquee {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    margin-bottom: 3rem;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x proximity;
  }
  .wheel-brands__marquee::-webkit-scrollbar { display: none; }

  .wheel-brands__marquee-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: max-content;
  }

  .wheel-brands__tabs-track {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: max-content;
    padding: 0.4rem 0;
  }

  .wheel-brands__tab {
    background: transparent;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 0.8rem 2rem;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .wheel-brands__tab:hover {
    background: transparent;
    border-color: #F5820B;
    box-shadow: 0 0 0 2px rgba(245, 130, 11, 0.25);
  }

  .wheel-brands__tab--active {
    background: transparent;
    border-color: #F5820B;
    box-shadow: 0 0 0 2px rgba(245, 130, 11, 0.35);
  }

  .wheel-brands__tab-logo {
    height: 24px;
    width: auto;
    display: block;
  }

  .wheel-brands__tab-text {
    font-size: 1.2rem;
    font-weight: 500;
    color: #374151;
  }

  /* ── Product carousel ── */
  .wheel-brands__carousel-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .wheel-brands__carousel {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    flex: 1;
    border-radius: 8px;
  }
  .wheel-brands__carousel::-webkit-scrollbar { display: none; }

  .wheel-brands__track {
    display: flex;
    gap: 1.6rem;
    cursor: grab;
    user-select: none;
    scroll-snap-type: x mandatory;
  }
  .wheel-brands__card {
    scroll-snap-align: start;
  }

  .wheel-brands__track:active {
    cursor: grabbing;
  }

  .wheel-brands__arrow {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid #e5e7eb;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #6b7280;
    transition: all 0.2s;
  }

  .wheel-brands__arrow:hover {
    border-color: #d1d5db;
    color: #111;
    background: #f3f4f6;
  }

  .wheel-brands__card {
    min-width: calc(25% - 1.2rem);
    max-width: calc(25% - 1.2rem);
    border: 1px solid #f0f0f0;
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .wheel-brands__card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    transform: translateY(-2px);
  }

  .wheel-brands__card[hidden] {
    display: none;
  }

  .wheel-brands__card-image {
    background: #f7f7f8;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 2rem;
  }

  .wheel-brands__card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .wheel-brands__card-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e5e7eb, #d1d5db);
    opacity: 0.5;
  }

  .wheel-brands__card-body {
    padding: 1.4rem 1.6rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }

  .wheel-brands__card-brand {
    font-family: 'Outfit', sans-serif;
    font-size: 1.05rem;
    font-weight: 400;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .wheel-brands__card-model {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.7rem;
    font-weight: 600;
    color: #111;
    margin: 0;
    line-height: 1.2;
  }

  .wheel-brands__card-style {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    color: #6b7280;
    font-weight: 300;
  }

  .wheel-brands__card-sizes {
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    color: #9ca3af;
    font-weight: 300;
    margin-top: 0.2rem;
  }

  .wheel-brands__card-action {
    padding: 0 1.6rem 1.6rem;
    margin-top: auto;
  }

  .wheel-brands__card-btn {
    display: block;
    background: #dc2626;
    color: #fff;
    text-align: center;
    padding: 0.9rem;
    border-radius: 8px;
    text-decoration: none;
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    transition: background 0.2s;
  }

  .wheel-brands__card-btn:hover {
    background: #b91c1c;
    color: #fff;
  }

  .wheel-brands__footer {
    text-align: center;
    margin-top: 2.4rem;
  }

  .wheel-brands__view-all {
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 500;
    color: #dc2626;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .wheel-brands__view-all:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .wheel-brands__container { padding: 0 1.6rem; }
    .wheel-brands__card { min-width: 70vw; max-width: 70vw; }
    .wheel-brands__arrow {
      width: 36px;
      height: 36px;
      background: rgba(0, 0, 0, 0.06);
      border-color: transparent;
    }
    .wheel-brands__heading { font-size: 2.2rem; }
  }

  @media (max-width: 480px) {
    .wheel-brands { padding: 4rem 0 3rem; }
    .wheel-brands__container { padding: 0 1.6rem; }
    .wheel-brands__heading { font-size: clamp(1.8rem, 5vw, 2.2rem); }
    .wheel-brands__subtitle { font-size: 1.2rem; }
    .wheel-brands__card { min-width: 80vw; max-width: 80vw; }
    .wheel-brands__card-btn { padding: 1.2rem; min-height: 4.4rem; font-size: 1.4rem; }
    .wheel-brands__tab { padding: 1rem 1.8rem; min-height: 4.4rem; }
    .wheel-brands__view-all { font-size: 1.3rem; min-height: 4.4rem; display: inline-flex; align-items: center; }
  }

  @media (max-width: 360px) {
    .wheel-brands__container { padding: 0 1.2rem; }
    .wheel-brands__card { min-width: 85vw; max-width: 85vw; }
    .wheel-brands__heading { font-size: 1.8rem; }
    .wheel-brands__card-body { padding: 1.2rem 1.4rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wheel-brands__card { transition: none !important; }
    .wheel-brands__tab { transition: none !important; }
  }
{% endstylesheet %}

