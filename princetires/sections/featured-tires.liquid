<div class="ft" data-ft-section>
  <div class="ft__container">

    <div class="ft__top">
      <div class="ft__header">
        {%- if section.settings.eyebrow != blank -%}
          <span class="ft__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="ft__heading">
          {{ section.settings.heading }}
          {%- if section.settings.heading_accent != blank -%}
            <span class="ft__accent">{{ section.settings.heading_accent }}</span>
          {%- endif -%}
        </h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="ft__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>

      <div class="ft__controls">
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="ft__cta">
            {{ section.settings.cta_label }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        {%- endif -%}
        <div class="ft__arrows">
          <button class="ft__arrow" data-ft-prev aria-label="{{ 'general.accessibility.previous' | t }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button class="ft__arrow" data-ft-next aria-label="{{ 'general.accessibility.next' | t }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    </div>

    <div class="ft__carousel" data-ft-carousel>
      <div class="ft__track" data-ft-track>
        {%- for block in section.blocks -%}
          {%- assign auto_link = block.settings.brand | append: ' ' | append: block.settings.model -%}
          {%- assign card_link = block.settings.link | default: blank -%}
          <div class="ft__card" {{ block.shopify_attributes }}>
            <div class="ft__card-image">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 600 | image_tag }}
              {%- else -%}
                <div class="ft__card-placeholder">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                </div>
              {%- endif -%}
              {%- if block.settings.badge != blank -%}
                <span class="ft__card-badge">{{ block.settings.badge | escape }}</span>
              {%- endif -%}
            </div>
            <div class="ft__card-body">
              <span class="ft__card-brand">{{ block.settings.brand | escape }}</span>
              <h3 class="ft__card-model">{{ block.settings.model | escape }}</h3>
              {%- if block.settings.season != blank -%}
                <span class="ft__card-season">{{ block.settings.season | escape }}</span>
              {%- endif -%}
              {%- if block.settings.price != blank -%}
                <span class="ft__card-price">{{ block.settings.price | escape }}</span>
              {%- endif -%}
            </div>
            <div class="ft__card-action">
              <a href="{% if card_link != blank %}{{ card_link }}{% else %}/search?q={{ auto_link | url_encode }}&type=product{% endif %}" class="ft__card-btn">
                {{ block.settings.button_text | default: 'Shop now' }}
              </a>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

  </div>
</div>

{% stylesheet %}
  .ft {
    background: #fff;
    padding: 5rem 0 4rem;
  }

  .ft__container {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 10rem;
  }

  .ft__top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 3rem;
  }

  .ft__header {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .ft__eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 400;
    color: #dc2626;
    letter-spacing: 0.02em;
  }

  .ft__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.8rem;
    font-weight: 700;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
    line-height: 1.1;
  }

  .ft__accent { color: #dc2626; }

  .ft__subtitle {
    font-family: 'Outfit', sans-serif;
    color: #9ca3af;
    font-size: 1.4rem;
    font-weight: 300;
    margin: 0.3rem 0 0;
  }

  .ft__controls {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-shrink: 0;
  }

  .ft__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    color: #dc2626;
    text-decoration: none;
    white-space: nowrap;
    transition: gap 0.2s;
  }
  .ft__cta:hover { gap: 0.8rem; }

  .ft__arrows {
    display: flex;
    gap: 0.5rem;
  }

  .ft__arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid #e5e7eb;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #6b7280;
    transition: all 0.2s;
  }
  .ft__arrow:hover { border-color: #d1d5db; color: #111; background: #f9fafb; }

  /* ── Carousel ── */
  .ft__carousel {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    cursor: grab;
  }
  .ft__carousel::-webkit-scrollbar { display: none; }
  .ft__carousel:active { cursor: grabbing; }

  .ft__track {
    display: flex;
    gap: 1.6rem;
    user-select: none;
  }

  /* ── Card ── */
  .ft__card {
    min-width: calc(25% - 1.2rem);
    max-width: calc(25% - 1.2rem);
    border: 1px solid #f0f0f0;
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }
  .ft__card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.06); transform: translateY(-2px); }

  .ft__card-image {
    background: #f7f7f8;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 2rem;
    position: relative;
  }
  .ft__card-image img { width: 100%; height: 100%; object-fit: contain; }

  .ft__card-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.5;
  }

  .ft__card-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: #dc2626;
    color: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .ft__card-body {
    padding: 1.4rem 1.6rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }

  .ft__card-brand {
    font-family: 'Outfit', sans-serif;
    font-size: 1.05rem;
    font-weight: 400;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ft__card-model {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.7rem;
    font-weight: 600;
    color: #111;
    margin: 0;
    line-height: 1.2;
  }

  .ft__card-season {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    color: #6b7280;
    font-weight: 300;
  }

  .ft__card-price {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #dc2626;
    margin-top: 0.3rem;
  }

  .ft__card-action {
    padding: 0 1.6rem 1.6rem;
    margin-top: auto;
  }

  .ft__card-btn {
    display: block;
    background: #dc2626;
    color: #fff;
    text-align: center;
    padding: 0.9rem;
    border-radius: 8px;
    text-decoration: none;
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    transition: background 0.2s;
  }
  .ft__card-btn:hover { background: #b91c1c; color: #fff; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .ft__container { padding: 0 1.6rem; }
    .ft__card { min-width: 70vw; max-width: 70vw; }
    .ft__arrow { display: none; }
    .ft__heading { font-size: 2.2rem; }
  }

  @media (max-width: 480px) {
    .ft { padding: 4rem 0 3rem; }
    .ft__container { padding: 0 1.6rem; }
    .ft__top {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .ft__heading { font-size: clamp(1.8rem, 5vw, 2.2rem); }
    .ft__subtitle { font-size: 1.2rem; }
    .ft__card { min-width: 80vw; max-width: 80vw; }
    .ft__card-btn { padding: 1.2rem; min-height: 4.4rem; font-size: 1.4rem; }
    .ft__cta { font-size: 1.2rem; min-height: 4.4rem; display: inline-flex; align-items: center; }
  }

  @media (max-width: 360px) {
    .ft__container { padding: 0 1.2rem; }
    .ft__card { min-width: 85vw; max-width: 85vw; }
    .ft__heading { font-size: 1.8rem; }
    .ft__card-body { padding: 1.2rem 1.4rem 0.8rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ft__card { transition: none !important; }
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('[data-ft-section]').forEach(function(section) {
    var carousel = section.querySelector('[data-ft-carousel]');
    var prevBtn = section.querySelector('[data-ft-prev]');
    var nextBtn = section.querySelector('[data-ft-next]');
    if (!carousel) return;

    if (prevBtn) {
      prevBtn.addEventListener('click', function() {
        carousel.scrollBy({ left: -carousel.offsetWidth * 0.6, behavior: 'smooth' });
      });
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        carousel.scrollBy({ left: carousel.offsetWidth * 0.6, behavior: 'smooth' });
      });
    }

    var drag = { active: false, startX: 0, scrollLeft: 0 };
    carousel.addEventListener('mousedown', function(e) {
      drag.active = true;
      drag.startX = e.pageX;
      drag.scrollLeft = carousel.scrollLeft;
      carousel.style.cursor = 'grabbing';
    });
    carousel.addEventListener('mousemove', function(e) {
      if (!drag.active) return;
      e.preventDefault();
      carousel.scrollLeft = drag.scrollLeft - (e.pageX - drag.startX);
    });
    carousel.addEventListener('mouseup', function() { drag.active = false; carousel.style.cursor = ''; });
    carousel.addEventListener('mouseleave', function() { drag.active = false; carousel.style.cursor = ''; });
  });
{% endjavascript %}

