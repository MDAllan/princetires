{%- liquid
  assign phone = section.settings.phone
  assign phone_digits = phone | replace: ' ', '' | replace: '-', '' | replace: '.', '' | replace: '(', '' | replace: ')', ''
  assign phone_href = phone_digits | prepend: 'tel:'
  assign email = section.settings.email
  assign email_href = email | prepend: 'mailto:'

  assign service_options = section.settings.service_options | split: '|'
-%}

<section class="pt-contact" data-pt-contact>
  <!-- ── Background ── -->
  <div class="pt-contact__bg" aria-hidden="true">
    {%- if section.settings.bg_image != blank -%}
      <div class="pt-contact__bg-image">
        {{ section.settings.bg_image | image_url: width: 2400 | image_tag: loading: 'eager', widths: '900,1400,2000,2400' }}
      </div>
    {%- else -%}
      <div class="pt-contact__bg-fallback"></div>
    {%- endif -%}
    <div class="pt-contact__bg-tread"></div>
    <div class="pt-contact__bg-vignette"></div>

    <!-- Animated particles -->
    <div class="pt-contact__particles">
      {%- for i in (1..18) -%}
        {%- assign seed_x  = i  | times: 23 | modulo: 100 -%}
        {%- assign seed_d  = i  | times: 1.7 -%}
        {%- assign seed_dur = i | modulo: 8  | plus: 12 -%}
        {%- assign seed_sz  = i | modulo: 6  | plus: 5  -%}
        <span class="pt-contact__particle" style="--x:{{ seed_x }};--d:{{ seed_d }}s;--dur:{{ seed_dur }}s;--sz:{{ seed_sz }}px;"></span>
      {%- endfor -%}
    </div>
  </div>

  <!-- ── Layout grid ── -->
  <div class="pt-contact__grid">
    <!-- Left: editorial title -->
    <div class="pt-contact__title-col">
      <span class="pt-contact__eyebrow">{{ section.settings.eyebrow }}</span>
      <h1 class="pt-contact__title">{{ section.settings.title }}</h1>
      {%- if section.settings.title_sub != blank -%}
        <p class="pt-contact__title-sub">{{ section.settings.title_sub }}</p>
      {%- endif -%}
    </div>

    <!-- Right: glass form card -->
    <div class="pt-contact__card">
      <h2 class="pt-contact__card-h2">{{ section.settings.card_heading }}</h2>

      <!-- Direct contact row -->
      <div class="pt-contact__contact-row">
        <span class="pt-contact__contact-label">Call us at</span>
        <a class="pt-contact__phone" href="{{ phone_href }}" aria-label="Call Prince Tires at {{ phone }}">
          {{ phone }}
        </a>

        <div class="pt-contact__socials">
          <span class="pt-contact__or">OR</span>
          {%- if section.settings.facebook_url != blank -%}
            <a class="pt-contact__social" href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.instagram_url != blank -%}
            <a class="pt-contact__social" href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.google_url != blank -%}
            <a class="pt-contact__social" href="{{ section.settings.google_url }}" target="_blank" rel="noopener" aria-label="Google reviews">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <hr class="pt-contact__rule">

      <!-- Form -->
      {%- form 'contact', id: 'PTContactForm', class: 'pt-contact__form' -%}
        <p class="pt-contact__form-lead">{{ section.settings.form_lead }}</p>

        {%- if form.posted_successfully? -%}
          <div class="pt-contact__form-success" tabindex="-1" autofocus>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            <span>{{ 'templates.contact.form.post_success' | t }}</span>
          </div>
        {%- elsif form.errors -%}
          <div class="pt-contact__form-error" role="alert" tabindex="-1" autofocus>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span>{{ 'templates.contact.form.error_heading' | t }}</span>
          </div>
        {%- endif -%}

        <div class="pt-contact__field-row">
          <label class="pt-contact__field">
            <span class="pt-contact__field-label">{{ 'templates.contact.form.name' | t }}</span>
            <input
              class="pt-contact__input"
              type="text"
              name="contact[{{ 'templates.contact.form.name' | t }}]"
              autocomplete="name"
              placeholder="Your name"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              required
            >
          </label>
          <label class="pt-contact__field">
            <span class="pt-contact__field-label">{{ 'templates.contact.form.email' | t }}</span>
            <input
              class="pt-contact__input"
              type="email"
              name="contact[email]"
              autocomplete="email"
              spellcheck="false"
              autocapitalize="off"
              placeholder="you@email.com"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              aria-required="true"
              required
            >
          </label>
        </div>

        <label class="pt-contact__field">
          <span class="pt-contact__field-label">{{ section.settings.message_label }}</span>
          <textarea
            class="pt-contact__input pt-contact__input--textarea"
            name="contact[{{ 'templates.contact.form.comment' | t }}]"
            rows="3"
            placeholder="{{ section.settings.message_placeholder }}"
            required
          >{{- form.body -}}</textarea>
        </label>

        <!-- Service checkboxes -->
        <div class="pt-contact__services">
          <p class="pt-contact__services-label">{{ section.settings.services_label }}</p>
          <div class="pt-contact__checks">
            {%- for opt in service_options -%}
              {%- assign opt_trim = opt | strip -%}
              {%- assign opt_id = opt_trim | handleize -%}
              {%- if opt_trim != blank -%}
                <label class="pt-contact__check" for="pt-svc-{{ opt_id }}">
                  <input
                    type="checkbox"
                    id="pt-svc-{{ opt_id }}"
                    class="pt-contact__check-input"
                    data-pt-service
                    value="{{ opt_trim | escape }}"
                  >
                  <span class="pt-contact__check-box" aria-hidden="true">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  </span>
                  <span class="pt-contact__check-label">{{ opt_trim }}</span>
                </label>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <input type="hidden" name="contact[Looking for]" data-pt-services-aggregate value="">
        </div>

        <button type="submit" class="pt-contact__send">
          <span>Send a message</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </button>

        <p class="pt-contact__form-foot">
          Or email <a href="{{ email_href }}">{{ email }}</a>
        </p>
      {%- endform -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* ═══════════════════════════════════════════════════════════
     PT-CONTACT — split-screen w/ glass card · Ferrari editorial
     ═══════════════════════════════════════════════════════════ */
  .pt-contact {
    --pt-red: #DA291C;
    --pt-red-soft: rgba(218, 41, 28, 0.65);
    --pt-black: #050505;
    --pt-glass: rgba(20, 20, 20, 0.55);
    --pt-glass-border: rgba(255, 255, 255, 0.10);
    --pt-line: rgba(255, 255, 255, 0.14);
    font-family: 'Outfit', sans-serif;
    color: #fff;
    position: relative;
    overflow: hidden;
    background: var(--pt-black);
    min-height: 100vh;
    min-height: 100dvh;
    isolation: isolate;
  }
  .pt-contact * { box-sizing: border-box; }
  .pt-contact a { color: inherit; }

  /* ── Background layers ── */
  .pt-contact__bg { position: absolute; inset: 0; z-index: 0; }
  .pt-contact__bg-image, .pt-contact__bg-fallback { position: absolute; inset: 0; }
  .pt-contact__bg-image img {
    width: 100%; height: 100%; object-fit: cover; object-position: center;
    filter: grayscale(100%) contrast(1.05) brightness(0.45);
  }
  .pt-contact__bg-fallback {
    background:
      radial-gradient(ellipse at 30% 30%, rgba(218,41,28,0.18) 0%, transparent 60%),
      linear-gradient(135deg, #0a0a0a 0%, #1a0606 100%);
  }
  .pt-contact__bg-tread {
    position: absolute; inset: 0;
    background-image:
      repeating-linear-gradient(
        -45deg,
        transparent 0,
        transparent 22px,
        rgba(255,255,255,0.025) 22px,
        rgba(255,255,255,0.025) 24px
      );
    pointer-events: none;
    mix-blend-mode: screen;
  }
  .pt-contact__bg-vignette {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 50% 80%, transparent 0%, rgba(0,0,0,0.55) 80%),
      linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, transparent 30%);
    pointer-events: none;
  }

  /* ── Particles ── */
  .pt-contact__particles {
    position: absolute; inset: 0; overflow: hidden;
    pointer-events: none;
  }
  .pt-contact__particle {
    position: absolute;
    left: calc(var(--x, 50) * 1%);
    bottom: -40px;
    width: var(--sz, 10px);
    height: var(--sz, 10px);
    background: rgba(255, 255, 255, 0.18);
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(218, 41, 28, 0.25);
    animation: pt-particle var(--dur, 14s) linear infinite;
    animation-delay: var(--d, 0s);
    opacity: 0;
  }
  .pt-contact__particle:nth-child(3n)    { background: rgba(218, 41, 28, 0.28); }
  .pt-contact__particle:nth-child(5n+1)  { background: rgba(255, 255, 255, 0.25); }
  @keyframes pt-particle {
    0%   { transform: translateY(0)        scale(0.4); opacity: 0; }
    10%  { opacity: 0.9; }
    90%  { opacity: 0.9; }
    100% { transform: translateY(-110vh)   scale(1.1); opacity: 0; }
  }

  /* ── Grid ── */
  .pt-contact__grid {
    position: relative; z-index: 1;
    max-width: 1320px;
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 6rem) clamp(1.25rem, 4vw, 3.5rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    min-height: 100vh; min-height: 100dvh;
    align-items: center;
  }
  @media (min-width: 1000px) {
    .pt-contact__grid { grid-template-columns: 1fr 1fr; align-items: stretch; }
  }

  /* ── Title column ── */
  .pt-contact__title-col {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 1.2rem;
    padding: 0 0 0.5rem;
  }
  .pt-contact__eyebrow {
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: rgba(255, 255, 255, 0.55);
  }
  .pt-contact__title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(3.2rem, 7vw, 6.5rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.015em;
    color: #fff;
    margin: 0;
    text-transform: uppercase;
    text-shadow: 0 4px 40px rgba(0, 0, 0, 0.5);
    max-width: 14ch;
  }
  .pt-contact__title-sub {
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.72);
    max-width: 38ch;
    margin: 0;
  }

  /* ── Card column ── */
  .pt-contact__card {
    background: var(--pt-glass);
    border: 1px solid var(--pt-glass-border);
    backdrop-filter: blur(24px) saturate(140%);
    -webkit-backdrop-filter: blur(24px) saturate(140%);
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    position: relative;
  }
  .pt-contact__card::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 36px;
    height: 3px;
    background: var(--pt-red);
  }
  .pt-contact__card-h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(1.7rem, 2.4vw, 2.1rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.005em;
    margin: 0;
    color: #fff;
  }

  /* Contact row */
  .pt-contact__contact-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .pt-contact__contact-label {
    font-size: 0.74rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.55);
  }
  .pt-contact__phone {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(1.6rem, 2.5vw, 2.1rem);
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    letter-spacing: 0.005em;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    width: fit-content;
    transition: color 160ms ease;
    font-variant-numeric: tabular-nums;
  }
  .pt-contact__phone:hover { color: var(--pt-red); }

  .pt-contact__socials {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 0.4rem;
  }
  .pt-contact__or {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.4);
    margin-right: 0.3rem;
  }
  .pt-contact__social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    border: 1px solid rgba(255,255,255,0.18);
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    transition: background-color 160ms ease, color 160ms ease, border-color 160ms ease, transform 80ms ease;
  }
  .pt-contact__social:hover {
    background: var(--pt-red);
    border-color: var(--pt-red);
    color: #fff;
  }
  .pt-contact__social:active { transform: translateY(1px); }

  .pt-contact__rule {
    border: 0;
    border-top: 1px solid var(--pt-line);
    margin: 0.4rem 0;
  }

  /* ── Form ── */
  .pt-contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .pt-contact__form-lead {
    font-size: 0.74rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }
  .pt-contact__field-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 600px) {
    .pt-contact__field-row { grid-template-columns: 1fr 1fr; }
  }
  .pt-contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .pt-contact__field-label {
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.55);
  }
  .pt-contact__input {
    width: 100%;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: #fff;
    font-family: inherit;
    font-size: 0.96rem;
    padding: 0.85rem 0.95rem;
    border-radius: 2px;
    transition: border-color 160ms ease, background-color 160ms ease;
  }
  .pt-contact__input::placeholder { color: rgba(255, 255, 255, 0.32); }
  .pt-contact__input:focus,
  .pt-contact__input:focus-visible {
    outline: none;
    border-color: var(--pt-red);
    background: rgba(218, 41, 28, 0.06);
  }
  .pt-contact__input--textarea {
    resize: vertical;
    min-height: 96px;
    line-height: 1.5;
    font-family: inherit;
  }

  /* ── Service checkboxes ── */
  .pt-contact__services { display: flex; flex-direction: column; gap: 0.7rem; }
  .pt-contact__services-label {
    font-size: 0.74rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }
  .pt-contact__checks {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }
  @media (min-width: 480px) { .pt-contact__checks { grid-template-columns: repeat(3, 1fr); } }
  .pt-contact__check {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.55rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 2px;
    font-size: 0.83rem;
    color: rgba(255, 255, 255, 0.85);
    cursor: pointer;
    transition: background-color 140ms ease, border-color 140ms ease, color 140ms ease;
    user-select: none;
  }
  .pt-contact__check:hover {
    border-color: rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.04);
  }
  .pt-contact__check-input {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }
  .pt-contact__check-box {
    display: inline-flex;
    align-items: center; justify-content: center;
    width: 16px; height: 16px;
    border: 1.5px solid rgba(255, 255, 255, 0.32);
    border-radius: 2px;
    color: transparent;
    flex-shrink: 0;
    transition: background-color 140ms ease, border-color 140ms ease, color 140ms ease;
  }
  .pt-contact__check-input:focus-visible + .pt-contact__check-box {
    outline: 2px solid var(--pt-red);
    outline-offset: 2px;
  }
  .pt-contact__check-input:checked + .pt-contact__check-box {
    background: var(--pt-red);
    border-color: var(--pt-red);
    color: #fff;
  }
  .pt-contact__check:has(.pt-contact__check-input:checked) {
    border-color: var(--pt-red);
    background: rgba(218, 41, 28, 0.08);
    color: #fff;
  }
  /* Fallback for browsers without :has() */
  .pt-contact__check-input:checked ~ .pt-contact__check-label { color: #fff; }

  .pt-contact__check-label { line-height: 1.2; }

  /* ── Send button ── */
  .pt-contact__send {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    width: 100%;
    background: var(--pt-red);
    color: #fff;
    border: 0;
    border-radius: 2px;
    padding: 1rem 1.5rem;
    font-family: 'Outfit', sans-serif;
    font-size: 0.86rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    cursor: pointer;
    transition: background-color 160ms ease, transform 80ms ease;
    margin-top: 0.3rem;
  }
  .pt-contact__send:hover { background: #b9221a; }
  .pt-contact__send:active { transform: translateY(1px); }
  .pt-contact__send:focus-visible { outline: 2px solid #fff; outline-offset: 3px; }
  .pt-contact__send svg { transition: transform 160ms ease; }
  .pt-contact__send:hover svg { transform: translateX(4px); }

  .pt-contact__form-foot {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    text-align: center;
    margin: 0.2rem 0 0;
  }
  .pt-contact__form-foot a {
    color: #fff;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .pt-contact__form-foot a:hover { color: var(--pt-red); }

  /* Status messages */
  .pt-contact__form-success,
  .pt-contact__form-error {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.85rem 1rem;
    font-size: 0.92rem;
    font-weight: 500;
    border-radius: 2px;
  }
  .pt-contact__form-success {
    background: rgba(34, 197, 94, 0.12);
    border: 1px solid rgba(34, 197, 94, 0.4);
    color: #6ee7a3;
  }
  .pt-contact__form-error {
    background: rgba(218, 41, 28, 0.12);
    border: 1px solid var(--pt-red);
    color: #ff8a82;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .pt-contact__particle { animation: none !important; opacity: 0 !important; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const root = document.querySelector("[data-pt-contact]");
    if (!root) return;
    const aggregate = root.querySelector("[data-pt-services-aggregate]");
    const boxes = root.querySelectorAll("[data-pt-service]");
    if (!aggregate || !boxes.length) return;

    const sync = () => {
      const selected = [];
      boxes.forEach((b) => { if (b.checked) selected.push(b.value); });
      aggregate.value = selected.join(", ");
    };

    boxes.forEach((b) => b.addEventListener("change", sync));
    sync();
  })();
{% endjavascript %}

