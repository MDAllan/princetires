<div class="trusted-brands" data-trusted-brands>
  <div class="trusted-brands__container">
    <div class="trusted-brands__header">
      <h2 class="trusted-brands__heading">
        {{ section.settings.heading }}
        {%- if section.settings.heading_accent != blank -%}
          <span class="trusted-brands__accent">{{ section.settings.heading_accent }}</span>
        {%- endif -%}
      </h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="trusted-brands__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- assign brand_blocks = section.blocks | where: "type", "brand" -%}
    {%- assign tire_blocks = section.blocks | where: "type", "tire_card" -%}

    {%- if brand_blocks.size > 0 -%}
      <div class="trusted-brands__tabs-wrap">
        <button class="trusted-brands__tabs-arrow trusted-brands__tabs-arrow--left" data-tabs-prev aria-label="{{ 'general.accessibility.previous' | t }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>

        <div class="trusted-brands__tabs-scroll" data-brand-tabs-scroll>
          <div class="trusted-brands__tabs-track" role="tablist" data-brand-tabs-track>
            {%- for block in brand_blocks -%}
              <button
                class="trusted-brands__tab{% if forloop.first %} trusted-brands__tab--active{% endif %}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                data-brand="{{ block.settings.name | handleize }}"
                data-brand-name="{{ block.settings.name | escape }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.logo != blank -%}
                  {{ block.settings.logo | image_url: height: 28 | image_tag: class: "trusted-brands__tab-logo", alt: block.settings.name }}
                {%- else -%}
                  <span class="trusted-brands__tab-text">{{ block.settings.name }}</span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        </div>

        <button class="trusted-brands__tabs-arrow trusted-brands__tabs-arrow--right" data-tabs-next aria-label="{{ 'general.accessibility.next' | t }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    {%- endif -%}

    <div class="trusted-brands__carousel-wrap">
      <button class="trusted-brands__arrow trusted-brands__arrow--left" data-carousel-prev aria-label="{{ 'general.accessibility.previous' | t }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>

      <div class="trusted-brands__carousel" data-brand-carousel>
        <div class="trusted-brands__track" data-brand-track data-has-blocks="{{ tire_blocks.size }}">
          {%- if tire_blocks.size > 0 -%}
            {%- for block in tire_blocks -%}
              {%- assign auto_link = block.settings.brand | append: ' ' | append: block.settings.model -%}
              {%- assign card_link = block.settings.link | default: blank -%}
              <div class="trusted-brands__card" data-tire-brand="{{ block.settings.brand | handleize }}" {{ block.shopify_attributes }}>
                <div class="trusted-brands__card-image">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 500 | image_tag }}
                  {%- else -%}
                    <div class="trusted-brands__card-placeholder"></div>
                  {%- endif -%}
                </div>
                <div class="trusted-brands__card-body">
                  <span class="trusted-brands__card-brand">{{ block.settings.brand | escape }}</span>
                  <h3 class="trusted-brands__card-model">{{ block.settings.model | escape }}</h3>
                  {%- if block.settings.season != blank -%}
                    <span class="trusted-brands__card-season">{{ block.settings.season | escape }}</span>
                  {%- endif -%}
                </div>
                <div class="trusted-brands__card-action">
                  <a href="{% if card_link != blank %}{{ card_link }}{% else %}/search?q={{ auto_link | url_encode }}&type=product{% endif %}" class="trusted-brands__card-btn">{{ 'sections.trusted_brands.shop_tire' | t }}</a>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      <button class="trusted-brands__arrow trusted-brands__arrow--right" data-carousel-next aria-label="{{ 'general.accessibility.next' | t }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

    <div class="trusted-brands__footer">
      <a href="/collections/all" class="trusted-brands__view-all" data-brand-view-all>
        {{ 'sections.trusted_brands.view_all' | t }} <span data-brand-view-all-name>{{ brand_blocks.first.settings.name }}</span> →
      </a>
    </div>
  </div>
</div>

{% stylesheet %}
  .trusted-brands {
    background: #fff;
    padding: 5rem 0 4rem;
  }

  .trusted-brands__container {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 10rem;
  }

  .trusted-brands__header {
    text-align: center;
    margin-bottom: 2.4rem;
  }

  .trusted-brands__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.8rem;
    font-weight: 700;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.6rem;
  }

  .trusted-brands__accent { color: #dc2626; }

  .trusted-brands__subtitle {
    font-family: 'Outfit', sans-serif;
    color: #9ca3af;
    font-size: 1.4rem;
    font-weight: 300;
    margin: 0;
  }

  /* ── Swipeable tab bar ── */
  .trusted-brands__tabs-wrap {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 3rem;
    position: relative;
  }

  .trusted-brands__tabs-scroll {
    flex: 1;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    cursor: grab;
    mask-image: linear-gradient(to right, transparent, black 3%, black 97%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 3%, black 97%, transparent);
  }
  .trusted-brands__tabs-scroll::-webkit-scrollbar { display: none; }
  .trusted-brands__tabs-scroll:active { cursor: grabbing; }

  .trusted-brands__tabs-track {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: max-content;
    padding: 0.4rem 0;
  }

  .trusted-brands__tabs-arrow {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid #e5e7eb;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #9ca3af;
    transition: all 0.2s;
    z-index: 2;
  }
  .trusted-brands__tabs-arrow:hover { border-color: #d1d5db; color: #111; background: #f9fafb; }

  .trusted-brands__tab {
    background: transparent;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 0.8rem 2rem;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .trusted-brands__tab:hover {
    background: #f9fafb;
    border-color: #d1d5db;
    transform: scale(1.04);
  }

  .trusted-brands__tab--active {
    border-color: #dc2626;
    background: #fef2f2;
    transform: scale(1.06);
    box-shadow: 0 2px 8px rgba(220, 38, 38, 0.15);
  }

  .trusted-brands__tab-logo {
    height: 24px;
    width: auto;
    display: block;
  }

  .trusted-brands__tab-text { font-size: 1.2rem; font-weight: 500; color: #374151; }

  /* ── Product carousel ── */
  .trusted-brands__carousel-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .trusted-brands__carousel {
    overflow: hidden;
    flex: 1;
    border-radius: 8px;
  }
  .trusted-brands__track {
    display: flex;
    gap: 1.6rem;
    transition: transform 0.4s ease;
    cursor: grab;
    user-select: none;
  }
  .trusted-brands__track:active { cursor: grabbing; }

  .trusted-brands__arrow {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid #e5e7eb;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #6b7280;
    transition: all 0.2s;
  }
  .trusted-brands__arrow:hover { border-color: #d1d5db; color: #111; background: #f9fafb; }

  .trusted-brands__card {
    min-width: calc(25% - 1.2rem);
    max-width: calc(25% - 1.2rem);
    border: 1px solid #f0f0f0;
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }
  .trusted-brands__card[hidden] { display: none; }
  .trusted-brands__card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.06); transform: translateY(-2px); }

  .trusted-brands__card-image {
    background: #f7f7f8;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 2rem;
  }
  .trusted-brands__card-image img { width: 100%; height: 100%; object-fit: contain; }
  .trusted-brands__card-placeholder { width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #e5e7eb, #d1d5db); opacity: 0.5; }

  .trusted-brands__card-body { padding: 1.4rem 1.6rem 1.6rem; display: flex; flex-direction: column; gap: 0.3rem; flex: 1; }
  .trusted-brands__card-brand { font-family: 'Outfit', sans-serif; font-size: 1.05rem; font-weight: 400; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.08em; }
  .trusted-brands__card-model { font-family: 'Barlow Condensed', sans-serif; font-size: 1.7rem; font-weight: 600; color: #111; margin: 0; line-height: 1.2; }
  .trusted-brands__card-season { font-family: 'Outfit', sans-serif; font-size: 1.2rem; color: #6b7280; font-weight: 300; margin-top: 0.2rem; }

  .trusted-brands__card-action { padding: 0 1.6rem 1.6rem; margin-top: auto; }
  .trusted-brands__card-btn { display: block; background: #dc2626; color: #fff; text-align: center; padding: 0.9rem; border-radius: 8px; text-decoration: none; font-family: 'Outfit', sans-serif; font-size: 1.3rem; font-weight: 500; transition: background 0.2s; }
  .trusted-brands__card-btn:hover { background: #b91c1c; color: #fff; }

  .trusted-brands__footer { text-align: center; margin-top: 2.4rem; }
  .trusted-brands__view-all { font-family: 'Outfit', sans-serif; font-size: 1.4rem; font-weight: 500; color: #dc2626; text-decoration: none; transition: opacity 0.2s; }
  .trusted-brands__view-all:hover { opacity: 0.7; }

  @media (max-width: 768px) {
    .trusted-brands__container { padding: 0 1.6rem; }
    .trusted-brands__card { min-width: 70vw; max-width: 70vw; }
    .trusted-brands__arrow { display: none; }
    .trusted-brands__heading { font-size: 2.2rem; }
    .trusted-brands__tabs-arrow { display: none; }
    .trusted-brands__tabs-scroll {
      mask-image: none;
      -webkit-mask-image: none;
    }
  }

  @media (max-width: 480px) {
    .trusted-brands {
      padding: 4rem 0 3rem;
    }
    .trusted-brands__container {
      padding: 0 1.6rem;
    }
    .trusted-brands__heading {
      font-size: clamp(1.8rem, 5vw, 2.2rem);
    }
    .trusted-brands__subtitle {
      font-size: 1.2rem;
    }
    .trusted-brands__card {
      min-width: 80vw;
      max-width: 80vw;
    }
    .trusted-brands__card-btn {
      padding: 1.2rem;
      min-height: 4.4rem;
      font-size: 1.4rem;
    }
    .trusted-brands__tab {
      padding: 1rem 1.8rem;
      min-height: 4.4rem;
    }
    .trusted-brands__tabs-wrap {
      margin-bottom: 2rem;
    }
    .trusted-brands__view-all {
      font-size: 1.3rem;
      min-height: 4.4rem;
      display: inline-flex;
      align-items: center;
    }
  }

  @media (max-width: 360px) {
    .trusted-brands__container {
      padding: 0 1.2rem;
    }
    .trusted-brands__card {
      min-width: 85vw;
      max-width: 85vw;
    }
    .trusted-brands__heading {
      font-size: 1.8rem;
    }
    .trusted-brands__card-body {
      padding: 1.2rem 1.4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .trusted-brands__card {
      transition: none !important;
    }
    .trusted-brands__tab {
      transition: none !important;
    }
  }
{% endstylesheet %}

{% javascript %}
  class TrustedBrandsSwitcher {
    constructor(section) {
      this.section = section;
      this.carousel = section.querySelector('[data-brand-carousel]');
      this.track = section.querySelector('[data-brand-track]');
      this.prevBtn = section.querySelector('[data-carousel-prev]');
      this.nextBtn = section.querySelector('[data-carousel-next]');
      this.viewAllLink = section.querySelector('[data-brand-view-all]');
      this.viewAllName = section.querySelector('[data-brand-view-all-name]');

      this.tabsScroll = section.querySelector('[data-brand-tabs-scroll]');
      this.tabsPrev = section.querySelector('[data-tabs-prev]');
      this.tabsNext = section.querySelector('[data-tabs-next]');
      this.tabs = section.querySelectorAll('[data-brand-tabs-track] .trusted-brands__tab');
      this.cards = section.querySelectorAll('[data-tire-brand]');

      this.hasBlocks = parseInt(this.track.dataset.hasBlocks || '0') > 0;

      this.bindEvents();
      this.init();
    }

    init() {
      if (this.tabs.length > 0) this.switchBrand(this.tabs[0]);
    }

    bindEvents() {
      var self = this;

      /* ── Tab clicks ── */
      this.tabs.forEach(function(tab) {
        tab.addEventListener('click', function() { self.switchBrand(tab); });
      });

      /* ── Tab strip swipe (touch + mouse drag) ── */
      if (this.tabsScroll) {
        var tabDrag = { active: false, startX: 0, scrollLeft: 0 };

        this.tabsScroll.addEventListener('mousedown', function(e) {
          tabDrag.active = true;
          tabDrag.startX = e.pageX;
          tabDrag.scrollLeft = self.tabsScroll.scrollLeft;
          self.tabsScroll.style.cursor = 'grabbing';
        });
        this.tabsScroll.addEventListener('mousemove', function(e) {
          if (!tabDrag.active) return;
          e.preventDefault();
          self.tabsScroll.scrollLeft = tabDrag.scrollLeft - (e.pageX - tabDrag.startX);
        });
        this.tabsScroll.addEventListener('mouseup', function() { tabDrag.active = false; self.tabsScroll.style.cursor = ''; });
        this.tabsScroll.addEventListener('mouseleave', function() { tabDrag.active = false; self.tabsScroll.style.cursor = ''; });

        if (this.tabsPrev) {
          this.tabsPrev.addEventListener('click', function() {
            self.tabsScroll.scrollBy({ left: -200, behavior: 'smooth' });
          });
        }
        if (this.tabsNext) {
          this.tabsNext.addEventListener('click', function() {
            self.tabsScroll.scrollBy({ left: 200, behavior: 'smooth' });
          });
        }
      }

      /* ── Product carousel arrows ── */
      this.prevBtn.addEventListener('click', function() { self.scrollCarousel(-1); });
      this.nextBtn.addEventListener('click', function() { self.scrollCarousel(1); });

      /* ── Product carousel drag ── */
      var drag = { active: false, startX: 0, scrollLeft: 0 };
      this.carousel.style.overflowX = 'auto';
      this.carousel.style.scrollbarWidth = 'none';

      this.track.addEventListener('mousedown', function(e) {
        drag.active = true;
        drag.startX = e.pageX;
        drag.scrollLeft = self.carousel.scrollLeft;
      });
      this.track.addEventListener('mousemove', function(e) {
        if (!drag.active) return;
        e.preventDefault();
        self.carousel.scrollLeft = drag.scrollLeft - (e.pageX - drag.startX);
      });
      this.track.addEventListener('mouseup', function() { drag.active = false; });
      this.track.addEventListener('mouseleave', function() { drag.active = false; });
      this.track.addEventListener('touchstart', function(e) {
        drag.active = true;
        drag.startX = e.touches[0].pageX;
        drag.scrollLeft = self.carousel.scrollLeft;
      }, { passive: true });
      this.track.addEventListener('touchmove', function(e) {
        if (!drag.active) return;
        self.carousel.scrollLeft = drag.scrollLeft - (e.touches[0].pageX - drag.startX);
      }, { passive: true });
      this.track.addEventListener('touchend', function() { drag.active = false; });
    }

    scrollCarousel(dir) {
      var w = this.carousel.offsetWidth * 0.6;
      this.carousel.scrollBy({ left: dir * w, behavior: 'smooth' });
    }

    switchBrand(tab) {
      var brandHandle = tab.dataset.brand;
      var brandName = tab.dataset.brandName;

      this.tabs.forEach(function(t) {
        t.classList.remove('trusted-brands__tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('trusted-brands__tab--active');
      tab.setAttribute('aria-selected', 'true');

      /* Scroll active tab into view */
      tab.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });

      if (this.viewAllName) this.viewAllName.textContent = brandName;
      if (this.viewAllLink) {
        this.viewAllLink.href = '/search?q=' + encodeURIComponent(brandName) + '&type=product';
      }

      this.cards.forEach(function(card) {
        if (card.dataset.tireBrand === brandHandle) {
          card.hidden = false;
          card.style.display = '';
        } else {
          card.hidden = true;
          card.style.display = 'none';
        }
      });

      this.carousel.scrollLeft = 0;
    }
  }

  document.querySelectorAll('[data-trusted-brands]').forEach(function(el) {
    new TrustedBrandsSwitcher(el);
  });
{% endjavascript %}

