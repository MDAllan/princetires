<div class="wheel-quote" data-wheel-quote>
  <div class="wheel-quote__container">
    <div class="wheel-quote__header">
      <a href="{{ routes.root_url }}" class="wheel-quote__back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
        {{ 'sections.wheel_quote.back_home' | t }}
      </a>
      <h1 class="wheel-quote__heading">
        {{ 'sections.wheel_quote.heading' | t }}
        <span class="wheel-quote__accent">{{ 'sections.wheel_quote.heading_accent' | t }}</span>
      </h1>
      <p class="wheel-quote__subtitle">{{ 'sections.wheel_quote.subtitle' | t }}</p>
    </div>

    <div class="wheel-quote__grid">
      {%- comment -%} Left column: wheel summary + trust signals {%- endcomment -%}
      <div class="wheel-quote__left">
        <div class="wheel-quote__summary" data-quote-summary>
          <div class="wheel-quote__summary-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            {{ 'sections.wheel_quote.selected_wheel' | t }}
          </div>
          <div class="wheel-quote__summary-details">
            <div class="wheel-quote__summary-row">
              <span class="wheel-quote__summary-label">{{ 'sections.wheel_quote.brand_label' | t }}</span>
              <span class="wheel-quote__summary-value" data-quote-brand>&mdash;</span>
            </div>
            <div class="wheel-quote__summary-row">
              <span class="wheel-quote__summary-label">{{ 'sections.wheel_quote.model_label' | t }}</span>
              <span class="wheel-quote__summary-value" data-quote-model>&mdash;</span>
            </div>
            <div class="wheel-quote__summary-row" data-quote-style-row>
              <span class="wheel-quote__summary-label">{{ 'sections.wheel_quote.style_label' | t }}</span>
              <span class="wheel-quote__summary-value" data-quote-style>&mdash;</span>
            </div>
            <div class="wheel-quote__summary-row" data-quote-sizes-row>
              <span class="wheel-quote__summary-label">{{ 'sections.wheel_quote.sizes_label' | t }}</span>
              <span class="wheel-quote__summary-value" data-quote-sizes>&mdash;</span>
            </div>
          </div>
        </div>

        <div class="wheel-quote__trust">
          <div class="wheel-quote__trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            <div>
              <strong>{{ 'sections.wheel_quote.trust_call' | t }}</strong>
              <span>{{ 'sections.wheel_quote.trust_call_number' | t }}</span>
            </div>
          </div>
          <div class="wheel-quote__trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <div>
              <strong>{{ 'sections.wheel_quote.trust_response' | t }}</strong>
              <span>{{ 'sections.wheel_quote.trust_response_detail' | t }}</span>
            </div>
          </div>
          <div class="wheel-quote__trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <div>
              <strong>{{ 'sections.wheel_quote.trust_guarantee' | t }}</strong>
              <span>{{ 'sections.wheel_quote.trust_guarantee_detail' | t }}</span>
            </div>
          </div>
        </div>
      </div>

      {%- comment -%} Right column: quote form {%- endcomment -%}
      <div class="wheel-quote__form-wrap">
        {%- assign form_class = 'wheel-quote__form' -%}
        {%- form 'contact', id: 'WheelQuoteForm', class: form_class -%}
          {%- if form.posted_successfully? -%}
            <div class="wheel-quote__success" tabindex="-1" autofocus>
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>
              <h2 class="wheel-quote__success-title">{{ 'sections.wheel_quote.success_title' | t }}</h2>
              <p class="wheel-quote__success-text">{{ 'sections.wheel_quote.success_text' | t }}</p>
              <a href="{{ routes.root_url }}" class="wheel-quote__success-btn">{{ 'sections.wheel_quote.success_cta' | t }}</a>
            </div>
          {%- elsif form.errors -%}
            <div class="wheel-quote__error" role="alert" tabindex="-1" autofocus>
              <p>{{ 'sections.wheel_quote.error_text' | t }}</p>
            </div>
          {%- endif -%}

          {%- unless form.posted_successfully? -%}
            {%- comment -%} Hidden fields for wheel details {%- endcomment -%}
            <input type="hidden" name="contact[Wheel Brand]" data-hidden-brand>
            <input type="hidden" name="contact[Wheel Model]" data-hidden-model>
            <input type="hidden" name="contact[Wheel Style]" data-hidden-style>
            <input type="hidden" name="contact[Preferred Size]" data-hidden-size>
            <input type="hidden" name="contact[Quantity]" data-hidden-qty>

            {%- comment -%} Section: Contact info {%- endcomment -%}
            <fieldset class="wheel-quote__fieldset">
              <legend class="wheel-quote__legend">{{ 'sections.wheel_quote.contact_heading' | t }}</legend>
              <div class="wheel-quote__field-row wheel-quote__field-row--2">
                <div class="wheel-quote__field">
                  <input
                    type="text"
                    id="WheelQuote-name"
                    name="contact[Name]"
                    class="wheel-quote__input"
                    autocomplete="name"
                    required
                    value="{% if customer %}{{ customer.name }}{% endif %}"
                    placeholder=" "
                  >
                  <label for="WheelQuote-name" class="wheel-quote__label">{{ 'sections.wheel_quote.name' | t }} <span aria-hidden="true">*</span></label>
                </div>
                <div class="wheel-quote__field">
                  <input
                    type="email"
                    id="WheelQuote-email"
                    name="contact[email]"
                    class="wheel-quote__input"
                    autocomplete="email"
                    required
                    value="{% if customer %}{{ customer.email }}{% endif %}"
                    placeholder=" "
                  >
                  <label for="WheelQuote-email" class="wheel-quote__label">{{ 'sections.wheel_quote.email' | t }} <span aria-hidden="true">*</span></label>
                </div>
              </div>
              <div class="wheel-quote__field">
                <input
                  type="tel"
                  id="WheelQuote-phone"
                  name="contact[Phone]"
                  class="wheel-quote__input"
                  autocomplete="tel"
                  value="{% if customer %}{{ customer.phone }}{% endif %}"
                  placeholder=" "
                >
                <label for="WheelQuote-phone" class="wheel-quote__label">{{ 'sections.wheel_quote.phone' | t }}</label>
              </div>
            </fieldset>

            {%- comment -%} Section: Vehicle info {%- endcomment -%}
            <fieldset class="wheel-quote__fieldset">
              <legend class="wheel-quote__legend">{{ 'sections.wheel_quote.vehicle_heading' | t }}</legend>
              <div class="wheel-quote__field-row wheel-quote__field-row--3">
                <div class="wheel-quote__field">
                  <input
                    type="text"
                    id="WheelQuote-year"
                    name="contact[Vehicle Year]"
                    class="wheel-quote__input"
                    inputmode="numeric"
                    maxlength="4"
                    placeholder=" "
                  >
                  <label for="WheelQuote-year" class="wheel-quote__label">{{ 'sections.wheel_quote.vehicle_year' | t }}</label>
                </div>
                <div class="wheel-quote__field">
                  <input
                    type="text"
                    id="WheelQuote-make"
                    name="contact[Vehicle Make]"
                    class="wheel-quote__input"
                    placeholder=" "
                  >
                  <label for="WheelQuote-make" class="wheel-quote__label">{{ 'sections.wheel_quote.vehicle_make' | t }}</label>
                </div>
                <div class="wheel-quote__field">
                  <input
                    type="text"
                    id="WheelQuote-model"
                    name="contact[Vehicle Model]"
                    class="wheel-quote__input"
                    placeholder=" "
                  >
                  <label for="WheelQuote-model" class="wheel-quote__label">{{ 'sections.wheel_quote.vehicle_model' | t }}</label>
                </div>
              </div>
            </fieldset>

            {%- comment -%} Section: Wheel preferences {%- endcomment -%}
            <fieldset class="wheel-quote__fieldset">
              <legend class="wheel-quote__legend">{{ 'sections.wheel_quote.preferences_heading' | t }}</legend>
              <div class="wheel-quote__field-row wheel-quote__field-row--2">
                <div class="wheel-quote__field">
                  <select
                    id="WheelQuote-size"
                    class="wheel-quote__input wheel-quote__select"
                    data-quote-size-select
                  >
                    <option value="">{{ 'sections.wheel_quote.select_size' | t }}</option>
                  </select>
                  <label for="WheelQuote-size" class="wheel-quote__label wheel-quote__label--select">{{ 'sections.wheel_quote.preferred_size' | t }}</label>
                </div>
                <div class="wheel-quote__field">
                  <select
                    id="WheelQuote-qty"
                    class="wheel-quote__input wheel-quote__select"
                    data-quote-qty-select
                  >
                    <option value="4" selected>4</option>
                    <option value="2">2</option>
                    <option value="1">1</option>
                    <option value="5">5+</option>
                  </select>
                  <label for="WheelQuote-qty" class="wheel-quote__label wheel-quote__label--select">{{ 'sections.wheel_quote.quantity' | t }}</label>
                </div>
              </div>
            </fieldset>

            {%- comment -%} Notes {%- endcomment -%}
            <div class="wheel-quote__field">
              <textarea
                id="WheelQuote-notes"
                name="contact[Message]"
                class="wheel-quote__input wheel-quote__textarea"
                rows="4"
                placeholder=" "
              ></textarea>
              <label for="WheelQuote-notes" class="wheel-quote__label">{{ 'sections.wheel_quote.notes' | t }}</label>
            </div>

            <button type="submit" class="wheel-quote__submit">
              {{ 'sections.wheel_quote.submit' | t }}
            </button>
          {%- endunless -%}
        {%- endform -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .wheel-quote {
    background: #f9fafb;
    min-height: 100vh;
    padding: 4rem 0 6rem;
  }

  .wheel-quote__container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Header ── */
  .wheel-quote__back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    color: #6b7280;
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s;
  }
  .wheel-quote__back:hover { color: #111; }

  .wheel-quote__header {
    margin-bottom: 3rem;
  }

  .wheel-quote__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(2.4rem, 5vw, 3.2rem);
    font-weight: 700;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.6rem;
    line-height: 1.1;
  }

  .wheel-quote__accent {
    color: #dc2626;
  }

  .wheel-quote__subtitle {
    font-family: 'Outfit', sans-serif;
    color: #6b7280;
    font-size: 1.4rem;
    font-weight: 300;
    margin: 0;
  }

  /* ── Grid layout ── */
  .wheel-quote__grid {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* ── Left: Summary + Trust ── */
  .wheel-quote__left {
    position: sticky;
    top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .wheel-quote__summary {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
  }

  .wheel-quote__summary-badge {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1.2rem 1.6rem;
    background: #111;
    color: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: 0.03em;
  }
  .wheel-quote__summary-badge svg { opacity: 0.7; }

  .wheel-quote__summary-details {
    padding: 1.4rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .wheel-quote__summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .wheel-quote__summary-label {
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    color: #9ca3af;
    font-weight: 400;
  }

  .wheel-quote__summary-value {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    color: #111;
    font-weight: 500;
    text-align: right;
  }

  /* ── Trust signals ── */
  .wheel-quote__trust {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .wheel-quote__trust-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.2rem 1.4rem;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
  }

  .wheel-quote__trust-item svg {
    flex-shrink: 0;
    color: #dc2626;
    margin-top: 0.1rem;
  }

  .wheel-quote__trust-item div {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .wheel-quote__trust-item strong {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: #111;
  }

  .wheel-quote__trust-item span {
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    color: #6b7280;
    font-weight: 300;
  }

  /* ── Form ── */
  .wheel-quote__form-wrap {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 2.4rem;
  }

  .wheel-quote__fieldset {
    border: none;
    padding: 0;
    margin: 0 0 2rem;
  }

  .wheel-quote__legend {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 1.2rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid #f3f4f6;
    width: 100%;
  }

  .wheel-quote__field-row {
    display: grid;
    gap: 1rem;
  }
  .wheel-quote__field-row--2 { grid-template-columns: 1fr 1fr; }
  .wheel-quote__field-row--3 { grid-template-columns: 1fr 1fr 1fr; }

  .wheel-quote__field {
    position: relative;
    margin-bottom: 1rem;
  }

  .wheel-quote__input {
    width: 100%;
    padding: 1.4rem 1.2rem 0.6rem;
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 400;
    color: #111;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    appearance: none;
    -webkit-appearance: none;
  }

  .wheel-quote__input:focus {
    border-color: #dc2626;
    box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.08);
    background: #fff;
  }

  .wheel-quote__label {
    position: absolute;
    top: 50%;
    left: 1.2rem;
    transform: translateY(-50%);
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    color: #9ca3af;
    pointer-events: none;
    transition: all 0.2s ease;
  }

  .wheel-quote__input:focus ~ .wheel-quote__label,
  .wheel-quote__input:not(:placeholder-shown) ~ .wheel-quote__label {
    top: 0.6rem;
    transform: translateY(0);
    font-size: 1rem;
    color: #6b7280;
  }

  .wheel-quote__label--select {
    top: 0.6rem;
    transform: translateY(0);
    font-size: 1rem;
    color: #6b7280;
  }

  .wheel-quote__select {
    padding-right: 2.4rem;
    cursor: pointer;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 24 24' fill='none' stroke='%239ca3af' stroke-width='2.5' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M6 9l6 6 6-6'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
  }

  .wheel-quote__textarea {
    resize: vertical;
    min-height: 10rem;
    padding-top: 2rem;
  }

  .wheel-quote__textarea ~ .wheel-quote__label {
    top: 1.4rem;
    transform: translateY(0);
  }
  .wheel-quote__textarea:focus ~ .wheel-quote__label,
  .wheel-quote__textarea:not(:placeholder-shown) ~ .wheel-quote__label {
    top: 0.6rem;
    font-size: 1rem;
    color: #6b7280;
  }

  .wheel-quote__submit {
    width: 100%;
    padding: 1.4rem;
    margin-top: 0.5rem;
    background: #dc2626;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    letter-spacing: 0.02em;
  }
  .wheel-quote__submit:hover { background: #b91c1c; }

  /* ── Success / Error ── */
  .wheel-quote__success {
    text-align: center;
    padding: 4rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .wheel-quote__success-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .wheel-quote__success-text {
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    color: #6b7280;
    font-weight: 300;
    margin: 0;
    max-width: 36rem;
  }

  .wheel-quote__success-btn {
    display: inline-block;
    margin-top: 1rem;
    padding: 1rem 2.4rem;
    background: #111;
    color: #fff;
    border-radius: 8px;
    text-decoration: none;
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    transition: background 0.2s;
  }
  .wheel-quote__success-btn:hover { background: #333; color: #fff; }

  .wheel-quote__error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    padding: 1.2rem 1.6rem;
    margin-bottom: 2rem;
  }
  .wheel-quote__error p {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    color: #dc2626;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .wheel-quote {
      padding: 2rem 0 4rem;
    }
    .wheel-quote__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .wheel-quote__left {
      position: static;
    }
    .wheel-quote__field-row--2,
    .wheel-quote__field-row--3 {
      grid-template-columns: 1fr;
    }
    .wheel-quote__form-wrap {
      padding: 1.8rem 1.4rem;
    }
    .wheel-quote__trust {
      flex-direction: row;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 0.4rem;
    }
    .wheel-quote__trust-item {
      min-width: 75vw;
      scroll-snap-align: start;
      flex-shrink: 0;
    }
  }

  @media (max-width: 480px) {
    .wheel-quote__container {
      padding: 0 1.4rem;
    }
    .wheel-quote__heading {
      font-size: 2.2rem;
    }
    .wheel-quote__submit {
      min-height: 4.8rem;
      font-size: 1.5rem;
    }
    .wheel-quote__trust-item {
      min-width: 80vw;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    var section = document.querySelector('[data-wheel-quote]');
    if (!section) return;

    var params = new URLSearchParams(window.location.search);
    var brand = params.get('brand') || '';
    var model = params.get('model') || '';
    var style = params.get('style') || '';
    var sizes = params.get('sizes') || '';

    /* Populate summary card */
    var brandEl = section.querySelector('[data-quote-brand]');
    var modelEl = section.querySelector('[data-quote-model]');
    var styleEl = section.querySelector('[data-quote-style]');
    var sizesEl = section.querySelector('[data-quote-sizes]');
    var styleRow = section.querySelector('[data-quote-style-row]');
    var sizesRow = section.querySelector('[data-quote-sizes-row]');
    var summary = section.querySelector('[data-quote-summary]');

    if (brand) brandEl.textContent = brand;
    if (model) modelEl.textContent = model;
    if (style) {
      styleEl.textContent = style;
    } else if (styleRow) {
      styleRow.style.display = 'none';
    }
    if (sizes) {
      sizesEl.textContent = sizes;
    } else if (sizesRow) {
      sizesRow.style.display = 'none';
    }

    /* Hide summary if no wheel params at all */
    if (!brand && !model) {
      summary.style.display = 'none';
    }

    /* Populate hidden form fields */
    var hiddenBrand = section.querySelector('[data-hidden-brand]');
    var hiddenModel = section.querySelector('[data-hidden-model]');
    var hiddenStyle = section.querySelector('[data-hidden-style]');
    var hiddenSize = section.querySelector('[data-hidden-size]');
    var hiddenQty = section.querySelector('[data-hidden-qty]');

    if (hiddenBrand) hiddenBrand.value = brand;
    if (hiddenModel) hiddenModel.value = model;
    if (hiddenStyle) hiddenStyle.value = style;

    /* Build size dropdown from URL param */
    var sizeSelect = section.querySelector('[data-quote-size-select]');
    if (sizeSelect && sizes) {
      var sizeList = sizes.replace(/"/g, '"').split(/\s+/).filter(function(s) {
        return s.replace(/[^0-9.]/g, '').length > 0;
      });
      sizeList.forEach(function(size) {
        var clean = size.replace(/[^0-9."]/g, '');
        if (!clean) return;
        var opt = document.createElement('option');
        opt.value = clean;
        opt.textContent = clean;
        sizeSelect.appendChild(opt);
      });
    }

    /* Sync select values to hidden fields */
    if (sizeSelect) {
      sizeSelect.addEventListener('change', function() {
        if (hiddenSize) hiddenSize.value = sizeSelect.value;
      });
    }
    var qtySelect = section.querySelector('[data-quote-qty-select]');
    if (qtySelect) {
      if (hiddenQty) hiddenQty.value = qtySelect.value;
      qtySelect.addEventListener('change', function() {
        if (hiddenQty) hiddenQty.value = qtySelect.value;
      });
    }
  })();
{% endjavascript %}

