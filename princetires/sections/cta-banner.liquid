<div class="cta-banner">
  <div class="cta-banner__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="cta-banner__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="cta-banner__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    <div class="cta-banner__actions">
      {%- if section.settings.primary_label != blank -%}
        <a
          href="{{ section.settings.primary_link | default: '#' }}"
          class="cta-banner__btn cta-banner__btn--primary"
        >
          {{ section.settings.primary_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_label != blank -%}
        <a
          href="{{ section.settings.secondary_link | default: '#' }}"
          class="cta-banner__btn cta-banner__btn--secondary"
        >
          {{ section.settings.secondary_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .cta-banner {
    background: #000;
    padding: 5rem 0;
  }
  .cta-banner__container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }
  .cta-banner__heading {
    font-size: 1.875rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.75rem;
  }
  .cta-banner__subtitle {
    color: #6b7280;
    font-size: 0.875rem;
    margin: 0 0 2rem;
  }
  .cta-banner__actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
  }
  .cta-banner__btn {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }
  .cta-banner__btn--primary {
    background: #dc2626;
    color: #fff;
  }
  .cta-banner__btn--primary:hover {
    background: #b91c1c;
  }
  .cta-banner__btn--secondary {
    background: transparent;
    color: #fff;
    border: 1px solid #525252;
  }
  .cta-banner__btn--secondary:hover {
    border-color: #9ca3af;
  }
  @media (max-width: 768px) {
    .cta-banner__actions {
      flex-direction: column;
      align-items: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.cta_banner.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.cta_banner.settings.heading",
      "default": "Need help finding the right tires?"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.cta_banner.settings.subtitle",
      "default": "Our experts are ready to help"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "t:sections.cta_banner.settings.primary_label",
      "default": "Call us"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "t:sections.cta_banner.settings.primary_link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "t:sections.cta_banner.settings.secondary_label",
      "default": "Get a quote"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "t:sections.cta_banner.settings.secondary_link"
    }
  ],
  "presets": [
    {
      "name": "t:sections.cta_banner.name"
    }
  ]
}
{% endschema %}
