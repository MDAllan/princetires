<div class="pt-rv" data-pt-rv data-section-id="{{ section.id }}" data-current-product="{{ product.id }}">
  <div class="pt-rv__inner" hidden>
    <p class="pt-rv__label">{{ 'sections.recently_viewed.heading' | t | default: 'Recently viewed' }}</p>
    <div class="pt-rv__scroll" data-pt-rv-scroll></div>
  </div>
</div>

{% stylesheet %}
  .pt-rv { border-top: 1px solid #f3f4f6; }
  .pt-rv__inner { max-width: 1200px; margin: 0 auto; padding: 3rem 2rem 4rem; }
  .pt-rv__inner[hidden] { display: none; }
  .pt-rv__label {
    font-family: 'Outfit', sans-serif; font-size: 1.1rem; font-weight: 500;
    color: #9ca3af; text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 1.5rem;
  }
  .pt-rv__scroll {
    display: flex; gap: 1.4rem; overflow-x: auto; scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch; scrollbar-width: none; padding-bottom: 0.5rem;
  }
  .pt-rv__scroll::-webkit-scrollbar { display: none; }
  .pt-rv__card {
    display: flex; flex-direction: column; flex: 0 0 18rem; scroll-snap-align: start;
    text-decoration: none; color: inherit; background: transparent; border-radius: 10px;
    overflow: hidden; transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .pt-rv__card:hover { box-shadow: 0 8px 28px rgba(0, 0, 0, 0.07); transform: translateY(-2px); }
  .pt-rv__img {
    aspect-ratio: 1; overflow: hidden; background: transparent;
    display: flex; align-items: center; justify-content: center; padding: 1.5rem;
  }
  .pt-rv__img img { width: 100%; height: 100%; object-fit: contain; }
  .pt-rv__body { padding: 1rem 1.2rem 1.4rem; display: flex; flex-direction: column; gap: 0.2rem; background: #fff; }
  .pt-rv__vendor { font-family: 'Outfit', sans-serif; font-size: 0.9rem; color: #9ca3af; }
  .pt-rv__title {
    font-family: 'Outfit', sans-serif; font-size: 1.1rem; font-weight: 600; color: #111;
    margin: 0; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden; transition: color 0.2s;
  }
  .pt-rv__card:hover .pt-rv__title { color: #dc2626; }
  .pt-rv__price { font-family: 'Outfit', sans-serif; font-size: 1.05rem; font-weight: 600; color: #111; margin-top: 0.2rem; }
  .pt-rv__price-per { font-size: 0.9rem; font-weight: 400; color: #9ca3af; }

  @media (max-width: 749px) {
    .pt-rv__inner { padding: 2rem 1.6rem 3rem; }
    .pt-rv__card { flex: 0 0 15rem; }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    var RV_KEY = 'pt_recently_viewed';
    var MAX_ITEMS = 8;
    var container = document.querySelector('[data-pt-rv]');
    if (!container) return;
    var currentId = container.dataset.currentProduct;
    var scroll = container.querySelector('[data-pt-rv-scroll]');
    var inner = container.querySelector('.pt-rv__inner');

    /* Save current product */
    var items = [];
    try { items = JSON.parse(localStorage.getItem(RV_KEY) || '[]'); } catch(e) {}

    /* Get current product data from page */
    var productData = null;
    if (currentId && window.location.pathname.indexOf('/products/') > -1) {
      var existingIdx = -1;
      for (var i = 0; i < items.length; i++) {
        if (String(items[i].id) === String(currentId)) { existingIdx = i; break; }
      }
      if (existingIdx > -1) items.splice(existingIdx, 1);

      /* Extract data from meta tags and existing elements */
      var titleEl = document.querySelector('.ptp__title');
      var vendorEl = document.querySelector('.ptp__vendor');
      var imgEl = document.querySelector('.ptp__gallery-main-img');
      var priceEl = document.querySelector('.ptp__price-current');

      if (titleEl) {
        productData = {
          id: currentId,
          title: titleEl.textContent.trim(),
          vendor: vendorEl ? vendorEl.textContent.trim() : '',
          url: window.location.pathname,
          image: imgEl ? imgEl.src : '',
          price: priceEl ? priceEl.textContent.trim() : ''
        };
        items.unshift(productData);
        if (items.length > MAX_ITEMS) items = items.slice(0, MAX_ITEMS);
        localStorage.setItem(RV_KEY, JSON.stringify(items));
      }
    }

    /* Render recently viewed (excluding current product) */
    var toShow = items.filter(function(item) { return String(item.id) !== String(currentId); });
    if (toShow.length === 0) return;

    var html = '';
    toShow.forEach(function(item) {
      html += '<a href="' + item.url + '" class="pt-rv__card">';
      html += '<div class="pt-rv__img">';
      if (item.image) {
        html += '<img src="' + item.image + '" alt="' + (item.title || '').replace(/"/g, '&quot;') + '" loading="lazy" width="300" height="300">';
      }
      html += '</div>';
      html += '<div class="pt-rv__body">';
      if (item.vendor) html += '<span class="pt-rv__vendor">' + item.vendor + '</span>';
      html += '<h3 class="pt-rv__title">' + (item.title || '') + '</h3>';
      if (item.price) html += '<div class="pt-rv__price">' + item.price + '<span class="pt-rv__price-per">/tire</span></div>';
      html += '</div></a>';
    });

    scroll.innerHTML = html;
    inner.hidden = false;
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.recently_viewed.name",
  "tag": "section",
  "class": "section-pt-recently-viewed",
  "settings": [],
  "presets": [
    {
      "name": "t:sections.recently_viewed.name"
    }
  ]
}
{% endschema %}
