{%- comment -%}
  Live counts pulled from collections.all (paginated up to 250 products):
    total_inventory  — sum of every variant's inventory_quantity (>0)
    total_products   — count of products in the catalogue
    vendors_count    — number of unique product.vendor values (brands)
{%- endcomment -%}
{%- assign total_inventory = 0 -%}
{%- assign total_products  = 0 -%}
{%- assign vendor_seen     = '' -%}
{%- assign vendors_count   = 0 -%}
{%- paginate collections.all.products by 250 -%}
  {%- for product in collections.all.products -%}
    {%- assign total_products = total_products | plus: 1 -%}
    {%- if product.vendor != blank -%}
      {%- assign vendor_token = '|' | append: product.vendor | append: '|' -%}
      {%- unless vendor_seen contains vendor_token -%}
        {%- assign vendor_seen = vendor_seen | append: vendor_token -%}
        {%- assign vendors_count = vendors_count | plus: 1 -%}
      {%- endunless -%}
    {%- endif -%}
    {%- for variant in product.variants -%}
      {%- if variant.inventory_quantity > 0 -%}
        {%- assign total_inventory = total_inventory | plus: variant.inventory_quantity -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endfor -%}
{%- endpaginate -%}

<div class="inv-pulse">
  <div class="inv-pulse__container">

    <div class="inv-pulse__stat">
      <div class="inv-pulse__live">
        <span class="inv-pulse__dot"></span>
        <span class="inv-pulse__live-text">{{ section.settings.live_label }}</span>
      </div>
      <div class="inv-pulse__number" data-count-to="{{ total_inventory }}" data-pt-inv="tires">0</div>
      <div class="inv-pulse__label">{{ section.settings.tire_label }}</div>
    </div>

    <div class="inv-pulse__divider"></div>

    <div class="inv-pulse__stat">
      <div class="inv-pulse__number" data-count-to="{{ vendors_count }}" data-pt-inv="vendors">0</div>
      <div class="inv-pulse__label">{{ section.settings.brand_label }}</div>
    </div>

    <div class="inv-pulse__divider"></div>

    <div class="inv-pulse__stat">
      <div class="inv-pulse__number" data-count-to="{{ total_products }}" data-pt-inv="products">0</div>
      <div class="inv-pulse__label">{{ section.settings.size_label }}</div>
    </div>

    <div class="inv-pulse__divider"></div>

    <div class="inv-pulse__stat">
      <div class="inv-pulse__badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="inv-pulse__label-bold">{{ section.settings.update_label }}</div>
      <div class="inv-pulse__label">{{ section.settings.update_sub }}</div>
    </div>

  </div>
</div>

{% stylesheet %}
  .inv-pulse {
    background: #000;
    padding: 3rem 2rem;
    overflow: hidden;
  }

  .inv-pulse__container {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 8rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .inv-pulse__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.3rem;
  }

  .inv-pulse__live {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }

  .inv-pulse__dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    display: inline-block;
    animation: inv-pulse-beat 2s ease-in-out infinite;
    box-shadow: 0 0 8px rgba(34, 197, 94, 0.6);
  }

  @keyframes inv-pulse-beat {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.3); opacity: 0.7; }
  }

  .inv-pulse__live-text {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: #22c55e;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .inv-pulse__number {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 3.2rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
    letter-spacing: 0.02em;
  }

  .inv-pulse__label {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    font-weight: 300;
    color: #6b7280;
    letter-spacing: 0.02em;
  }

  .inv-pulse__label-bold {
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    color: #fff;
  }

  .inv-pulse__badge {
    width: 32px;
    height: 32px;
    background: rgba(34, 197, 94, 0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #22c55e;
    margin-bottom: 0.2rem;
  }

  .inv-pulse__divider {
    width: 1px;
    height: 48px;
    background: rgba(255, 255, 255, 0.08);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .inv-pulse__container {
      flex-wrap: wrap;
      justify-content: center;
      gap: 2rem 3rem;
      padding: 0 2rem;
    }
    .inv-pulse__divider {
      display: none;
    }
    .inv-pulse__number {
      font-size: 2.6rem;
    }
  }

  @media (max-width: 480px) {
    .inv-pulse {
      padding: 1.5rem 1rem;
    }
    .inv-pulse__container {
      display: flex;
      flex-wrap: nowrap;
      justify-content: space-between;
      gap: 0.6rem;
      padding: 0;
    }
    .inv-pulse__stat {
      gap: 0.15rem;
    }
    .inv-pulse__divider {
      display: none;
    }
    .inv-pulse__number {
      font-size: 1.4rem;
    }
    .inv-pulse__label {
      font-size: 0.65rem;
      line-height: 1.2;
    }
    .inv-pulse__label-bold {
      font-size: 0.7rem;
    }
    .inv-pulse__live {
      margin-bottom: 0.15rem;
      gap: 0.25rem;
    }
    .inv-pulse__live-text {
      font-size: 0.6rem;
    }
    .inv-pulse__dot {
      width: 5px;
      height: 5px;
    }
    .inv-pulse__badge {
      width: 22px;
      height: 22px;
    }
    .inv-pulse__badge svg {
      width: 12px;
      height: 12px;
    }
  }

  @media (max-width: 360px) {
    .inv-pulse {
      padding: 1.2rem 0.8rem;
    }
    .inv-pulse__container {
      gap: 0.4rem;
    }
    .inv-pulse__number {
      font-size: 1.2rem;
    }
    .inv-pulse__label {
      font-size: 0.6rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .inv-pulse__dot {
      animation: none !important;
      box-shadow: none;
    }
  }
{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var counters = document.querySelectorAll('[data-count-to]');

    // 1. Fetch live inventory stats (paginated full-catalog count, cached
    //    server-side for 1h). Updates data-count-to *before* count-up runs
    //    when possible, and snap-overrides if it already ran.
    fetch('https://app.princetires.ca/api/inventory-stats', {
      method: 'GET', credentials: 'omit', cache: 'default'
    })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (data) {
        if (!data) return;
        var map = { tires: data.totalInventory, vendors: data.vendorsCount, products: data.totalProducts };
        Object.keys(map).forEach(function (k) {
          var el = document.querySelector('[data-pt-inv="' + k + '"]');
          if (!el || typeof map[k] !== 'number') return;
          el.dataset.countTo = String(map[k]);
          // If the IntersectionObserver already ran (text isn't '0' anymore),
          // snap to the live value. Otherwise leave it for the animation.
          if (el.textContent !== '0') el.textContent = map[k].toLocaleString();
        });
      })
      .catch(function () { /* silent — Liquid-computed values stay as fallback */ });

    // 2. Count-up animation, unchanged.
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var target = parseInt(el.dataset.countTo);
        if (!target) { el.textContent = '0'; return; }
        var startTime = null;
        function step(timestamp) {
          if (!startTime) startTime = timestamp;
          var progress = Math.min((timestamp - startTime) / 2000, 1);
          var eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.floor(eased * target).toLocaleString();
          if (progress < 1) requestAnimationFrame(step);
          else el.textContent = target.toLocaleString();
        }
        requestAnimationFrame(step);
        observer.unobserve(el);
      });
    }, { threshold: 0.3 });
    counters.forEach(function(c) { observer.observe(c); });
  });
</script>

{% schema %}
{
  "name": "Inventory pulse",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "live_label",
      "label": "Live badge text",
      "default": "Live inventory"
    },
    {
      "type": "text",
      "id": "tire_count",
      "label": "Tires in stock (auto-computed)",
      "info": "No longer used — the live number is summed from variant inventory automatically.",
      "default": "0"
    },
    {
      "type": "text",
      "id": "tire_label",
      "label": "Tires label",
      "default": "Tires in stock right now"
    },
    {
      "type": "text",
      "id": "brand_count",
      "label": "Number of brands (auto-computed)",
      "info": "No longer used — counts unique product.vendor values automatically.",
      "default": "0"
    },
    {
      "type": "text",
      "id": "brand_label",
      "label": "Brands label",
      "default": "Trusted brands"
    },
    {
      "type": "text",
      "id": "size_count",
      "label": "Items count (auto-computed)",
      "info": "No longer used — counts total products in catalog automatically.",
      "default": "0"
    },
    {
      "type": "text",
      "id": "size_label",
      "label": "Items label",
      "default": "Items in catalog"
    },
    {
      "type": "text",
      "id": "update_label",
      "label": "Update label",
      "default": "Inventory synced daily"
    },
    {
      "type": "text",
      "id": "update_sub",
      "label": "Update sublabel",
      "default": "Powered by Prince Tires"
    }
  ],
  "presets": [
    {
      "name": "Inventory pulse"
    }
  ]
}
{% endschema %}
