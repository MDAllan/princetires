{%- comment -%} PrinceTires – Individual Service Page {%- endcomment -%}

<div class="ptsd">
  <div class="ptsd__container">

    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav class="ptsd__breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}" class="ptsd__crumb">Home</a>
      <span class="ptsd__crumb-sep" aria-hidden="true">/</span>
      <a href="/pages/services" class="ptsd__crumb">Services</a>
      <span class="ptsd__crumb-sep" aria-hidden="true">/</span>
      <span class="ptsd__crumb ptsd__crumb--current">{{ page.title }}</span>
    </nav>

    {%- comment -%} Hero {%- endcomment -%}
    <div class="ptsd__hero">
      <div class="ptsd__hero-icon">
        {%- case section.settings.icon -%}
          {%- when 'tire' -%}
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 2c1.85 0 3.55.63 4.9 1.69L15.46 7.5A6.96 6.96 0 0012 6.5c-1.25 0-2.42.34-3.46 1L7.1 5.69A7.96 7.96 0 0112 4zm-6.31 3.1L7.5 8.54A6.96 6.96 0 006.5 12c0 1.25.34 2.42 1 3.46l-1.81 1.44A7.96 7.96 0 014 12c0-1.85.63-3.55 1.69-4.9zM12 8.5a3.5 3.5 0 110 7 3.5 3.5 0 010-7zm0 1.5a2 2 0 100 4 2 2 0 000-4zm6.31 1.1A7.96 7.96 0 0120 12c0 1.85-.63 3.55-1.69 4.9L16.5 15.46c.66-1.04 1-2.21 1-3.46 0-1.25-.34-2.42-1-3.46l1.81-1.44zM12 17.5c1.25 0 2.42-.34 3.46-1l1.44 1.81A7.96 7.96 0 0112 20a7.96 7.96 0 01-4.9-1.69L8.54 16.5c1.04.66 2.21 1 3.46 1z"/></svg>
          {%- when 'wrench' -%}
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/></svg>
          {%- when 'balance' -%}
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 2.18l7 3.12v4.7c0 4.67-3.13 9.06-7 10.28-3.87-1.22-7-5.61-7-10.28V6.3l7-3.12zM12 7a1 1 0 00-1 1v4a1 1 0 001 1h3a1 1 0 100-2h-2V8a1 1 0 00-1-1z"/></svg>
          {%- when 'rotation' -%}
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1-.25 1.97-.7 2.8l1.46 1.46A7.93 7.93 0 0020 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1 .25-1.97.7-2.8L5.24 7.74A7.93 7.93 0 004 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"/></svg>
          {%- when 'repair' -%}
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M7 5h10v2h2V3c0-1.1-.9-2-2-2H7c-1.1 0-2 .9-2 2v4h2V5zm-4 6v8c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-8c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2zm9 7c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm0-4.5c-.83 0-1.5.67-1.5 1.5s.67 1.5 1.5 1.5 1.5-.67 1.5-1.5-.67-1.5-1.5-1.5z"/></svg>
          {%- when 'sensor' -%}
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M15 1H9v2h6V1zm-4 13h2V8h-2v6zm8.03-6.61l1.42-1.42c-.43-.51-.9-.99-1.41-1.41l-1.42 1.42A8.962 8.962 0 0012 4c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-2.12-.74-4.07-1.97-5.61zM12 20c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/></svg>
          {%- when 'seasonal' -%}
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M22 11h-4.17l3.24-3.24-1.41-1.42L15 11h-2V9l4.66-4.66-1.42-1.41L13 6.17V2h-2v4.17L7.76 2.93 6.34 4.34 11 9v2H9L4.34 6.34 2.93 7.76 6.17 11H2v2h4.17l-3.24 3.24 1.41 1.42L9 13h2v2l-4.66 4.66 1.42 1.41L11 17.83V22h2v-4.17l3.24 3.24 1.42-1.41L13 15v-2h2l4.66 4.66 1.41-1.42L17.83 13H22z"/></svg>
          {%- when 'wheel' -%}
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13.5v3.11l-2.68-1.55-.5.87L10.5 10.5H7.39v1h3.11l-2.68 1.55.5.87L11 12.37v3.13h1v-3.13l2.68 1.55.5-.87-2.68-1.55h3.11v-1H12.5l2.68-1.55-.5-.87L12 10.63V7.5h-1z"/></svg>
          {%- else -%}
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
        {%- endcase -%}
      </div>
      <span class="ptsd__eyebrow">{{ section.settings.eyebrow }}</span>
      <h1 class="ptsd__title">{{ page.title }}</h1>
      <p class="ptsd__subtitle">{{ section.settings.subtitle }}</p>
    </div>

    {%- comment -%} Quick Stats {%- endcomment -%}
    {%- if section.settings.stat_1_value != blank -%}
      <div class="ptsd__stats">
        {%- if section.settings.stat_1_value != blank -%}
          <div class="ptsd__stat">
            <span class="ptsd__stat-value">{{ section.settings.stat_1_value }}</span>
            <span class="ptsd__stat-label">{{ section.settings.stat_1_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_2_value != blank -%}
          <div class="ptsd__stat">
            <span class="ptsd__stat-value">{{ section.settings.stat_2_value }}</span>
            <span class="ptsd__stat-label">{{ section.settings.stat_2_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_3_value != blank -%}
          <div class="ptsd__stat">
            <span class="ptsd__stat-value">{{ section.settings.stat_3_value }}</span>
            <span class="ptsd__stat-label">{{ section.settings.stat_3_label }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Page Content {%- endcomment -%}
    {%- if page.content != blank -%}
      <div class="ptsd__content rte">
        {{ page.content }}
      </div>
    {%- endif -%}

    {%- comment -%} Benefits {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="ptsd__benefits">
        <h2 class="ptsd__benefits-heading">{{ section.settings.benefits_heading }}</h2>
        <div class="ptsd__benefits-grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'benefit' -%}
              <div class="ptsd__benefit" {{ block.shopify_attributes }}>
                <div class="ptsd__benefit-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
                </div>
                <div>
                  <h3 class="ptsd__benefit-title">{{ block.settings.title }}</h3>
                  <p class="ptsd__benefit-desc">{{ block.settings.description }}</p>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} CTA {%- endcomment -%}
    <div class="ptsd__cta-block">
      <h2 class="ptsd__cta-heading">{{ section.settings.cta_heading }}</h2>
      <p class="ptsd__cta-desc">{{ section.settings.cta_description }}</p>
      <div class="ptsd__cta-buttons">
        <button
          class="ptsd__cta-btn ptsd__cta-btn--primary"
          data-book-service
          data-service-name="{{ page.title | escape }}"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          {{ section.settings.cta_label | default: 'Book this service' }}
        </button>
        {%- if section.settings.cta_phone != blank -%}
          <a href="tel:{{ section.settings.cta_phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}" class="ptsd__cta-btn ptsd__cta-btn--secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            {{ section.settings.cta_phone }}
          </a>
        {%- endif -%}
      </div>
    </div>

  </div>
</div>

{% stylesheet %}
  .ptsd {
    background: #fff;
    padding: 5rem 0 7rem;
  }

  .ptsd__container {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Breadcrumb ── */
  .ptsd__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 3.5rem;
    flex-wrap: wrap;
  }

  .ptsd__crumb {
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 400;
    color: #9ca3af;
    text-decoration: none;
    transition: color 0.2s;
  }

  a.ptsd__crumb:hover { color: #111; }

  .ptsd__crumb--current { color: #6b7280; }

  .ptsd__crumb-sep {
    font-size: 1rem;
    color: #d1d5db;
  }

  /* ── Hero ── */
  .ptsd__hero {
    text-align: center;
    margin-bottom: 4rem;
  }

  .ptsd__hero-icon {
    width: 7.2rem;
    height: 7.2rem;
    border-radius: 50%;
    background: #fef2f2;
    color: #dc2626;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  .ptsd__eyebrow {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 400;
    color: #dc2626;
    letter-spacing: 0.02em;
    margin-bottom: 0.5rem;
  }

  .ptsd__title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 3.6rem;
    font-weight: 700;
    color: #111;
    margin: 0 0 1rem;
    line-height: 1.05;
  }

  .ptsd__subtitle {
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 300;
    color: #6b7280;
    margin: 0;
    line-height: 1.6;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ── Stats ── */
  .ptsd__stats {
    display: flex;
    justify-content: center;
    gap: 4rem;
    padding: 2.5rem 0;
    margin-bottom: 3rem;
    border-top: 1px solid #f3f4f6;
    border-bottom: 1px solid #f3f4f6;
  }

  .ptsd__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .ptsd__stat-value {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.4rem;
    font-weight: 700;
    color: #111;
    line-height: 1;
  }

  .ptsd__stat-label {
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: #9ca3af;
  }

  /* ── Content ── */
  .ptsd__content {
    font-family: 'Outfit', sans-serif;
    font-size: 1.45rem;
    font-weight: 300;
    color: #374151;
    line-height: 1.8;
    margin-bottom: 4rem;
  }

  .ptsd__content h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.2rem;
    font-weight: 600;
    color: #111;
    margin: 2.5rem 0 0.8rem;
    line-height: 1.15;
  }

  .ptsd__content p { margin: 0 0 1.4rem; }

  .ptsd__content a {
    color: #dc2626;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .ptsd__content ul,
  .ptsd__content ol {
    padding-left: 2rem;
    margin: 0 0 1.4rem;
  }

  .ptsd__content li { margin-bottom: 0.4rem; }

  /* ── Benefits ── */
  .ptsd__benefits {
    margin-bottom: 4rem;
  }

  .ptsd__benefits-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.2rem;
    font-weight: 600;
    color: #111;
    margin: 0 0 2rem;
    line-height: 1.1;
  }

  .ptsd__benefits-grid {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .ptsd__benefit {
    display: flex;
    gap: 1.2rem;
    padding: 1.6rem 2rem;
    background: #fafafa;
    border-radius: 10px;
    align-items: flex-start;
  }

  .ptsd__benefit-icon {
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .ptsd__benefit-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 600;
    color: #111;
    margin: 0 0 0.2rem;
    line-height: 1.3;
  }

  .ptsd__benefit-desc {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    font-weight: 300;
    color: #6b7280;
    margin: 0;
    line-height: 1.5;
  }

  /* ── CTA Block ── */
  .ptsd__cta-block {
    text-align: center;
    padding: 4rem 3rem;
    background: #111;
    border-radius: 12px;
  }

  .ptsd__cta-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.4rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.6rem;
    line-height: 1.1;
  }

  .ptsd__cta-desc {
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 300;
    color: #9ca3af;
    margin: 0 0 2rem;
  }

  .ptsd__cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ptsd__cta-btn {
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    padding: 1rem 2.4rem;
    border-radius: 8px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.2s;
  }

  .ptsd__cta-btn--primary {
    background: #dc2626;
    color: #fff;
    border: none;
    cursor: pointer;
  }

  .ptsd__cta-btn--primary:hover {
    background: #b91c1c;
  }

  .ptsd__cta-btn--secondary {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.2);
  }

  .ptsd__cta-btn--secondary:hover {
    border-color: rgba(255,255,255,0.5);
  }

  /* ── Responsive ── */
  @media (max-width: 749px) {
    .ptsd { padding: 4rem 0 5rem; }
    .ptsd__title { font-size: 2.8rem; }
    .ptsd__stats { gap: 2rem; }
    .ptsd__stat-value { font-size: 2rem; }
    .ptsd__cta-block { padding: 3rem 2rem; }
    .ptsd__cta-heading { font-size: 2rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Service detail",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our services"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        { "value": "tire", "label": "Tire" },
        { "value": "wrench", "label": "Wrench" },
        { "value": "balance", "label": "Balance" },
        { "value": "rotation", "label": "Rotation" },
        { "value": "repair", "label": "Repair" },
        { "value": "sensor", "label": "Sensor" },
        { "value": "seasonal", "label": "Seasonal" },
        { "value": "wheel", "label": "Wheel" }
      ],
      "default": "tire"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "header",
      "content": "Quick stats"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 value"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stat 2 value"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Stat 3 value"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label"
    },
    {
      "type": "header",
      "content": "Benefits"
    },
    {
      "type": "text",
      "id": "benefits_heading",
      "label": "Benefits heading",
      "default": "Why choose this service"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA heading",
      "default": "Ready to get started?"
    },
    {
      "type": "text",
      "id": "cta_description",
      "label": "CTA description",
      "default": "Book your appointment today or give us a call."
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Book appointment"
    },
    {
      "type": "text",
      "id": "cta_phone",
      "label": "Phone number"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Describe the benefit."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service detail"
    }
  ]
}
{% endschema %}
