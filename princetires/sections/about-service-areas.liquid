<section
  class="abtsa"
  style="
    --abtsa-bg: {{ section.settings.bg_color }};
    --abtsa-text: {{ section.settings.text_color }};
    --abtsa-accent: {{ section.settings.accent_color }};
  "
  itemscope
  itemtype="https://schema.org/LocalBusiness"
>
  <div class="abtsa__container">

    <div class="abtsa__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="abtsa__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="abtsa__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="abtsa__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="abtsa__body">

      <div class="abtsa__areas-col">
        <div class="abtsa__areas-grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'area' -%}
              <div class="abtsa__area" {{ block.shopify_attributes }}>
                <div class="abtsa__area-dot" aria-hidden="true"></div>
                <div class="abtsa__area-text">
                  <span class="abtsa__area-name" itemprop="areaServed">{{ block.settings.name }}</span>
                  {%- if block.settings.note != blank -%}
                    <span class="abtsa__area-note">{{ block.settings.note }}</span>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.disclaimer != blank -%}
          <p class="abtsa__disclaimer">{{ section.settings.disclaimer }}</p>
        {%- endif -%}
      </div>

      <div class="abtsa__cta-col">
        {%- if section.settings.map_embed_url != blank -%}
          <div class="abtsa__map">
            <iframe
              src="{{ section.settings.map_embed_url }}"
              width="100%"
              height="220"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Prince Tires location on Google Maps"
            ></iframe>
          </div>
        {%- endif -%}
        <div class="abtsa__cta-card">
          <div class="abtsa__cta-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          </div>
          <h3 class="abtsa__cta-heading">{{ section.settings.cta_heading | default: "Not sure if we serve your area?" }}</h3>
          <p class="abtsa__cta-body">{{ section.settings.cta_body | default: "Give us a call or send a message — if you're anywhere near Calgary, chances are we can help." }}</p>

          {%- if section.settings.phone != blank -%}
            {%- assign pd = section.settings.phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' -%}
            <a href="tel:+1{{ pd }}" class="abtsa__cta-btn abtsa__cta-btn--phone">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              {{ section.settings.phone }}
            </a>
          {%- endif -%}

          {%- if section.settings.cta_label != blank -%}
            <a href="{{ section.settings.cta_link | default: '#' }}" class="abtsa__cta-btn abtsa__cta-btn--book">
              {{ section.settings.cta_label }}
            </a>
          {%- endif -%}

          {%- if section.settings.address != blank -%}
            <div class="abtsa__address">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              <address itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
                <span itemprop="streetAddress">{{ section.settings.address }}</span><br>
                <span itemprop="addressLocality">Calgary</span>, <span itemprop="addressRegion">AB</span>
              </address>
            </div>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</section>

{% stylesheet %}
  .abtsa {
    background: #fff;
    color: #111;
    font-family: 'Outfit', sans-serif;
    padding: 5rem 0;
  }

  .abtsa__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 6rem;
  }

  .abtsa__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 4rem;
  }

  .abtsa__eyebrow {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 400;
    color: #dc2626;
    margin-bottom: 0.875rem;
  }

  .abtsa__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 3.6rem;
    font-weight: 700;
    line-height: 1.05;
    margin: 0 0 1rem;
    color: #111;
  }

  .abtsa__subheading {
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 300;
    color: #9ca3af;
    line-height: 1.6;
    margin: 0;
  }

  .abtsa__body {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 4rem;
    align-items: start;
  }

  .abtsa__areas-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem 1.5rem;
    margin-bottom: 1.5rem;
  }

  .abtsa__area {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #e5e7eb;
  }

  .abtsa__area-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #dc2626;
    flex-shrink: 0;
    margin-top: 0.4rem;
  }

  .abtsa__area-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .abtsa__area-name {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: #111;
  }

  .abtsa__area-note {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: #9ca3af;
  }

  .abtsa__disclaimer {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: #9ca3af;
    line-height: 1.5;
    margin: 0;
  }

  .abtsa__map {
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 1.25rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    border: 1px solid #e5e7eb;
  }

  .abtsa__map iframe {
    display: block;
  }

  .abtsa__cta-card {
    background: #111;
    border-radius: 10px;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 2rem;
  }

  .abtsa__cta-icon {
    width: 56px;
    height: 56px;
    background: rgba(220,38,38,0.15);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #dc2626;
  }

  .abtsa__cta-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .abtsa__cta-body {
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 300;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    margin: 0;
  }

  .abtsa__cta-btn {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    padding: 0.875rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    text-align: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .abtsa__cta-btn--phone {
    background: rgba(220,38,38,0.12);
    color: #dc2626;
    border: 1px solid rgba(220,38,38,0.25);
  }

  .abtsa__cta-btn--phone:hover {
    background: rgba(220,38,38,0.2);
  }

  .abtsa__cta-btn--book {
    background: #F5820B;
    color: #fff;
  }

  .abtsa__cta-btn--book:hover {
    background: #d96e00;
    transform: translateY(-1px);
  }

  .abtsa__address {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    color: rgba(255,255,255,0.45);
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .abtsa__address svg {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: rgba(255,255,255,0.3);
  }

  .abtsa__address address {
    font-style: normal;
    line-height: 1.5;
  }

  @media (max-width: 1100px) {
    .abtsa__body {
      grid-template-columns: 1fr;
    }
    .abtsa__cta-card {
      position: static;
    }
    .abtsa__container {
      padding: 0 4rem;
    }
  }

  @media (max-width: 749px) {
    .abtsa {
      padding: 5rem 0;
    }
    .abtsa__areas-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .abtsa__container {
      padding: 0 2rem;
    }
  }

  @media (max-width: 480px) {
    .abtsa__areas-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

