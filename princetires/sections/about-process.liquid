{%- liquid
  assign step_blocks = section.blocks | where: 'type', 'step'
  assign enable_schema = section.settings.enable_howto_schema
-%}

{%- if enable_schema and step_blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": {{ section.settings.schema_name | default: "How to get new tires at Prince Tires Calgary" | json }},
  "description": {{ section.settings.schema_description | default: "Getting new tires at Prince Tires in Calgary is fast and simple. Same-day service available." | json }},
  "totalTime": "PT1H",
  "step": [
    {%- for block in step_blocks -%}
    {
      "@type": "HowToStep",
      "position": {{ forloop.index }},
      "name": {{ block.settings.title | json }},
      "text": {{ block.settings.body | json }}
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

<section
  class="abtpr"
  style="
    --abtpr-bg: {{ section.settings.bg_color }};
    --abtpr-text: {{ section.settings.text_color }};
    --abtpr-accent: {{ section.settings.accent_color }};
  "
>
  <div class="abtpr__container">

    <div class="abtpr__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="abtpr__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="abtpr__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="abtpr__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <ol class="abtpr__steps">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            <li class="abtpr__step" {{ block.shopify_attributes }}>
              <div class="abtpr__step-number" aria-hidden="true">{{ forloop.index }}</div>
              <div class="abtpr__step-connector" aria-hidden="true"></div>
              <div class="abtpr__step-icon" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'search' -%}
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                  {%- when 'calendar' -%}
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/></svg>
                  {%- when 'car' -%}
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"/></svg>
                  {%- when 'check' -%}
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  {%- when 'phone' -%}
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                  {%- when 'tire' -%}
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-12c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm0 6c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/></svg>
                  {%- else -%}
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                {%- endcase -%}
              </div>
              <div class="abtpr__step-content">
                {%- if block.settings.title != blank -%}
                  <h3 class="abtpr__step-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.body != blank -%}
                  <p class="abtpr__step-body">{{ block.settings.body }}</p>
                {%- endif -%}
                {%- if block.settings.badge != blank -%}
                  <span class="abtpr__step-badge">{{ block.settings.badge }}</span>
                {%- endif -%}
              </div>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ol>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="abtpr__footer">
        <a href="{{ section.settings.cta_link | default: '#' }}" class="abtpr__cta">
          {{ section.settings.cta_label }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
  .abtpr {
    background: #f9fafb;
    color: #111;
    font-family: 'Outfit', sans-serif;
    padding: 5rem 0;
  }

  .abtpr__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 6rem;
  }

  .abtpr__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 5rem;
  }

  .abtpr__eyebrow {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 400;
    color: #dc2626;
    margin-bottom: 0.875rem;
  }

  .abtpr__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 3.6rem;
    font-weight: 700;
    line-height: 1.05;
    margin: 0 0 1rem;
    color: #111;
  }

  .abtpr__subheading {
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 300;
    color: #9ca3af;
    line-height: 1.6;
    margin: 0;
  }

  .abtpr__steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }

  .abtpr__steps::before {
    content: '';
    position: absolute;
    top: 56px;
    left: calc(12.5% + 28px);
    right: calc(12.5% + 28px);
    height: 2px;
    background: linear-gradient(to right, #dc2626, rgba(220,38,38,0.15));
    z-index: 0;
  }

  .abtpr__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  .abtpr__step-number {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 22px;
    height: 22px;
    background: #dc2626;
    color: #fff;
    border-radius: 50%;
    font-family: 'Outfit', sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .abtpr__step-connector {
    display: none;
  }

  .abtpr__step-icon {
    width: 80px;
    height: 80px;
    background: #fff;
    border: 2px solid #e5e7eb;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #dc2626;
    margin-bottom: 1.5rem;
    margin-top: 1rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    flex-shrink: 0;
  }

  .abtpr__step:hover .abtpr__step-icon {
    border-color: #dc2626;
    box-shadow: 0 8px 30px rgba(220,38,38,0.15);
    transform: translateY(-3px);
  }

  .abtpr__step-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.625rem;
  }

  .abtpr__step-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.35rem;
    font-weight: 600;
    color: #111;
    margin: 0;
    line-height: 1.3;
  }

  .abtpr__step-body {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    font-weight: 300;
    color: #9ca3af;
    line-height: 1.65;
    margin: 0;
  }

  .abtpr__step-badge {
    display: inline-block;
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: #dc2626;
    background: rgba(220,38,38,0.08);
    border: 1px solid rgba(220,38,38,0.15);
    border-radius: 100px;
    padding: 0.25rem 0.75rem;
  }

  .abtpr__footer {
    text-align: center;
    margin-top: 4rem;
  }

  .abtpr__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    background: #F5820B;
    color: #fff;
    padding: 0.875rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .abtpr__cta:hover {
    background: #d96e00;
    transform: translateY(-1px);
  }

  @media (max-width: 989px) {
    .abtpr__steps {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem 2rem;
    }
    .abtpr__steps::before {
      display: none;
    }
    .abtpr__container {
      padding: 0 4rem;
    }
  }

  @media (max-width: 749px) {
    .abtpr {
      padding: 5rem 0;
    }
    .abtpr__steps {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .abtpr__container {
      padding: 0 2rem;
    }
    .abtpr__header {
      margin-bottom: 3.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "About — Process",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "How it works"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New tires in 4 easy steps"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From browsing to driving away — we make getting new tires as simple as possible."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Book your appointment"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "header",
      "content": "SEO — HowTo schema"
    },
    {
      "type": "checkbox",
      "id": "enable_howto_schema",
      "label": "Enable HowTo JSON-LD schema",
      "default": true,
      "info": "Helps Google understand your service process for rich results and AI Overviews."
    },
    {
      "type": "text",
      "id": "schema_name",
      "label": "HowTo name (schema)",
      "default": "How to get new tires at Prince Tires Calgary"
    },
    {
      "type": "textarea",
      "id": "schema_description",
      "label": "HowTo description (schema)",
      "default": "Getting new tires at Prince Tires in Calgary is fast and simple. Same-day service available."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#f7f7f7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#F5820B"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Process step",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "search", "label": "Browse / search" },
            { "value": "calendar", "label": "Calendar / book" },
            { "value": "car", "label": "Vehicle / drop-off" },
            { "value": "check", "label": "Checkmark / done" },
            { "value": "phone", "label": "Phone" },
            { "value": "tire", "label": "Tire" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Choose your tires"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Step description",
          "default": "Browse our inventory online or talk to our team in-store. We'll match the right tire to your vehicle and driving habits."
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge label (optional)",
          "info": "E.g. 'Same-day' or 'Free consultation'"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About — Process",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "icon": "search",
            "title": "Choose your tires",
            "body": "Browse our inventory online or talk to our team in-store. We'll match the right tire to your vehicle and budget.",
            "badge": "50+ brands"
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "calendar",
            "title": "Book an appointment",
            "body": "Same-day and next-day slots are usually available. Book online in minutes or give us a quick call.",
            "badge": "Same-day available"
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "car",
            "title": "Drop off your vehicle",
            "body": "Pull in, hand us your keys, and relax. Most installs are done in under an hour while you wait.",
            "badge": "~60 min install"
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "check",
            "title": "Drive away confident",
            "body": "Every install includes balancing, a safety inspection, and free lifetime rotations. Your vehicle, road-ready.",
            "badge": "Lifetime rotations"
          }
        }
      ]
    }
  ]
}
{% endschema %}
