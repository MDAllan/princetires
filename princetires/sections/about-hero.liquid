      "label": "Heading (H1)",
      "default": "Calgary's Trusted Tire Shop — Quality You Can Drive On"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Serving Calgary drivers across every neighbourhood since day one. From winter tires to wheel alignments, we keep your vehicle road-ready with honest pricing and same-day service."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
