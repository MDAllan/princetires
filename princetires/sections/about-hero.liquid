{%- liquid
  assign show_schema = section.settings.enable_schema
-%}

{%- if show_schema -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": ["AutoPartsStore", "LocalBusiness"],
        "@id": "{{ shop.url }}/#organization",
        "name": {{ shop.name | json }},
        "url": {{ shop.url | json }},
        "description": {{ section.settings.schema_description | json }},
        "telephone": {{ section.settings.phone | json }},
        "email": {{ section.settings.email | json }},
        "address": {
          "@type": "PostalAddress",
          "streetAddress": {{ section.settings.street_address | json }},
          "addressLocality": "Calgary",
          "addressRegion": "Alberta",
          "postalCode": {{ section.settings.postal_code | json }},
          "addressCountry": "CA"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": {{ section.settings.latitude | json }},
          "longitude": {{ section.settings.longitude | json }}
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
            "opens": {{ section.settings.weekday_open | json }},
            "closes": {{ section.settings.weekday_close | json }}
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": "Saturday",
            "opens": {{ section.settings.saturday_open | json }},
            "closes": {{ section.settings.saturday_close | json }}
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": "Sunday",
            "opens": {{ section.settings.sunday_open | json }},
            "closes": {{ section.settings.sunday_close | json }}
          }
        ],
        "priceRange": {{ section.settings.price_range | default: "$$" | json }},
        "areaServed": [
          "NE Calgary", "NW Calgary", "SE Calgary", "SW Calgary",
          "Downtown Calgary", "Airdrie", "Cochrane", "Okotoks",
          "Chestermere", "Crossfield", "Strathmore", "Calgary Metropolitan Area"
        ],
        "hasMap": {{ section.settings.google_maps_url | json }},
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": {{ section.settings.rating_value | default: "4.9" | json }},
          "reviewCount": {{ section.settings.review_count | default: "320" | json }},
          "bestRating": "5",
          "worstRating": "1"
        },
        "sameAs": [
          {{ section.settings.facebook_url | json }},
          {{ section.settings.instagram_url | json }},
          {{ section.settings.google_profile_url | json }}
        ]
      },
      {
        "@type": "AboutPage",
        "@id": "{{ shop.url }}{{ page.url }}#webpage",
        "url": "{{ shop.url }}{{ page.url }}",
        "name": {{ section.settings.heading | json }},
        "description": {{ section.settings.subtitle | json }},
        "isPartOf": {
          "@id": "{{ shop.url }}/#organization"
        },
        "speakable": {
          "@type": "SpeakableSpecification",
          "cssSelector": [".abth__heading", ".abth__subtitle"]
        }
      },
      {
        "@type": "BreadcrumbList",
        "@id": "{{ shop.url }}{{ page.url }}#breadcrumb",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ shop.url }}"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": {{ section.settings.heading | json }},
            "item": "{{ shop.url }}{{ page.url }}"
          }
        ]
      }
    ]
  }
  </script>
{%- endif -%}

<section
  class="abth"
  style="
    --abth-bg: {{ section.settings.bg_color }};
    --abth-text: {{ section.settings.text_color }};
    --abth-accent: {{ section.settings.accent_color }};
    --abth-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  {%- if section.settings.image != blank -%}
    <div class="abth__bg" aria-hidden="true">
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', fetchpriority: 'high', alt: '' }}
      <div class="abth__overlay"></div>
    </div>
  {%- endif -%}

  <div class="abth__container">
    <div class="abth__content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="abth__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="abth__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="abth__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      <div class="abth__ctas">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_link | default: routes.root_url }}" class="abth__btn abth__btn--primary">
            {{ section.settings.cta_primary_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_link | default: '#' }}" class="abth__btn abth__btn--secondary">
            {{ section.settings.cta_secondary_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="abth__stats">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="abth__stat" {{ block.shopify_attributes }}>
              <span class="abth__stat-value">{{ block.settings.value }}</span>
              <span class="abth__stat-label">{{ block.settings.label }}</span>
            </div>
        {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .abth {
    background: #fff;
    font-family: 'Outfit', sans-serif;
    padding: 7rem 0 0;
  }

  .abth__bg { display: none; }
  .abth__overlay { display: none; }

  .abth__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 6rem;
    width: 100%;
  }

  .abth__content {
    max-width: 780px;
    padding-bottom: 3rem;
  }

  .abth__eyebrow {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 400;
    color: #dc2626;
    letter-spacing: 0.02em;
    margin-bottom: 0.5rem;
  }

  .abth__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 3.6rem;
    font-weight: 700;
    line-height: 1.05;
    margin: 0 0 1rem;
    color: #111;
  }

  .abth__subtitle {
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 300;
    line-height: 1.7;
    color: #6b7280;
    margin: 0 0 2rem;
    max-width: 600px;
  }

  .abth__ctas {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  .abth__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    font-weight: 500;
    padding: 0.8rem 1.75rem;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .abth__btn--primary {
    background: #dc2626;
    color: #fff;
  }

  .abth__btn--primary:hover {
    background: #b91c1c;
    transform: translateY(-1px);
  }

  .abth__btn--secondary {
    background: #f9fafb;
    color: #111;
    border: 1px solid #e5e7eb;
  }

  .abth__btn--secondary:hover {
    background: #f0f0f0;
    transform: translateY(-1px);
  }

  .abth__stats {
    display: flex;
    border-top: 1px solid #f3f4f6;
    margin-top: 3rem;
  }

  .abth__stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 1.5rem 1rem;
    border-right: 1px solid #f3f4f6;
  }

  .abth__stat:last-child {
    border-right: none;
  }

  .abth__stat-value {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #F5820B;
    line-height: 1;
  }

  .abth__stat-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 400;
    color: #6b7280;
    text-align: center;
    line-height: 1.3;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  @media (max-width: 989px) {
    .abth__container {
      padding: 0 4rem;
    }
    .abth__stats {
      flex-wrap: wrap;
    }
    .abth__stat {
      flex: 1 1 50%;
      border-right: none;
      border-bottom: 1px solid #f3f4f6;
    }
    .abth__stat:nth-child(odd) {
      border-right: 1px solid #f3f4f6;
    }
    .abth__stat:last-child,
    .abth__stat:nth-last-child(2):nth-child(odd) {
      border-bottom: none;
    }
  }

  @media (max-width: 749px) {
    .abth {
      padding: 5rem 0 0;
    }
    .abth__heading {
      font-size: clamp(2.2rem, 8vw, 3.6rem);
    }
    .abth__container {
      padding: 0 2rem;
    }
    .abth__subtitle {
      font-size: 1.25rem;
    }
    .abth__stat {
      flex: 1 1 50%;
      border-right: none;
      border-bottom: 1px solid #f3f4f6;
    }
    .abth__stat:nth-child(odd) {
      border-right: 1px solid #f3f4f6;
    }
    .abth__stat:last-child {
      border-bottom: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "About — Hero",
  "settings": [
    {
      "type": "header",
