{%- liquid
  assign phone     = section.settings.phone     | default: '403 452 4283'
  assign phone_dig = phone | replace: ' ', '' | replace: '-', '' | replace: '.', '' | replace: '(', '' | replace: ')', ''
  assign book_url  = section.settings.booking_url | default: '/pages/booking'

  assign account_url = routes.account_url
  assign account_label = 'Account'
  if customer
    if customer.tags contains 'wholesale'
      assign account_url = '/pages/wholesale-portal'
      assign account_label = 'Portal'
    else
      assign account_url = '/account'
      assign account_label = 'Garage'
    endif
  else
    assign account_url = routes.account_login_url
    assign account_label = 'Sign in'
  endif

  assign cart_count = cart.item_count
-%}

<nav
  class="pt-tabbar"
  id="pt-sticky-bar"
  role="navigation"
  aria-label="Mobile quick nav"
>
  <a
    class="pt-tabbar__item"
    href="{{ routes.root_url }}"
    data-pt-event="tabbar_home"
    aria-label="Home"
  >
    <svg class="pt-tabbar__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1h-5v-7H9v7H4a1 1 0 0 1-1-1V9.5z"/></svg>
    <span class="pt-tabbar__label">Home</span>
  </a>

  <a
    class="pt-tabbar__item{% unless customer %} pt-tabbar__item--has-dot{% endunless %}"
    href="{{ account_url }}"
    data-pt-event="tabbar_account"
    aria-label="{{ account_label }}"
  >
    {%- if customer -%}
      <svg class="pt-tabbar__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/><path d="M9 21V12h6v9"/></svg>
    {%- else -%}
      <svg class="pt-tabbar__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    {%- endif -%}
    <span class="pt-tabbar__label">{{ account_label }}</span>
  </a>

  <a
    class="pt-tabbar__item pt-tabbar__item--cta"
    href="{{ book_url }}"
    data-pt-event="tabbar_book"
    aria-label="Book a service"
  >
    <span class="pt-tabbar__cta-circle">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    </span>
    <span class="pt-tabbar__label pt-tabbar__label--cta">Book</span>
  </a>

  <a
    class="pt-tabbar__item"
    href="{{ routes.cart_url }}"
    data-pt-event="tabbar_cart"
    aria-label="Cart{% if cart_count > 0 %} ({{ cart_count }} items){% endif %}"
  >
    <span class="pt-tabbar__icon-wrap">
      <svg class="pt-tabbar__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      {%- if cart_count > 0 -%}
        <span class="pt-tabbar__badge" aria-hidden="true">{{ cart_count }}</span>
      {%- endif -%}
    </span>
    <span class="pt-tabbar__label">Cart</span>
  </a>

  <button
    class="pt-tabbar__item pt-tabbar__item--menu"
    type="button"
    data-pt-tabbar-menu
    aria-label="Open menu"
    aria-expanded="false"
  >
    <span class="pt-tabbar__menu-text">Menu</span>
  </button>
</nav>

{% stylesheet %}
.pt-tabbar {
  display: none;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: rgba(8, 8, 8, 0.94);
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  padding: 0.55rem 0.4rem calc(0.55rem + env(safe-area-inset-bottom));
  box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.45);
  backdrop-filter: blur(18px) saturate(140%);
  -webkit-backdrop-filter: blur(18px) saturate(140%);

  display: grid;
  grid-template-columns: repeat(5, 1fr);
  align-items: end;

  font-family: 'Outfit', sans-serif;
}

@media (min-width: 769px) {
  .pt-tabbar { display: none; }
}
@media (max-width: 768px) {
  .pt-tabbar { display: grid; }
}
.pt-tabbar--hidden { display: none !important; }

/* Each tab item */
.pt-tabbar__item {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  gap: 0.18rem;
  min-height: 56px;
  padding: 0.45rem 0.2rem;
  background: transparent;
  border: 0;
  color: rgba(255, 255, 255, 0.78);
  text-decoration: none;
  font-family: inherit;
  font-size: 0.62rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  transition: color 140ms ease, transform 80ms ease;
}
.pt-tabbar__item:active { transform: translateY(1px); }
.pt-tabbar__item:hover,
.pt-tabbar__item:focus-visible { color: #fff; }
.pt-tabbar__item:focus-visible { outline: 2px solid #fff; outline-offset: -2px; border-radius: 6px; }

.pt-tabbar__icon { color: currentColor; }
.pt-tabbar__icon-wrap { position: relative; display: inline-flex; }
.pt-tabbar__label { line-height: 1; }

/* Notification dot (e.g. "Sign in needed") */
.pt-tabbar__item--has-dot::before {
  content: "";
  position: absolute;
  top: 0.55rem;
  right: calc(50% - 16px);
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #DA291C;
  box-shadow: 0 0 0 2px rgba(8, 8, 8, 0.94);
}

/* Cart badge */
.pt-tabbar__badge {
  position: absolute;
  top: -6px; right: -8px;
  min-width: 17px; height: 17px;
  padding: 0 4px;
  border-radius: 999px;
  background: #DA291C;
  color: #fff;
  font-size: 9px;
  font-weight: 700;
  line-height: 17px;
  text-align: center;
  letter-spacing: 0;
  box-shadow: 0 0 0 2px rgba(8, 8, 8, 0.94);
}

/* CTA — Book FAB in the middle */
.pt-tabbar__item--cta {
  position: relative;
}
.pt-tabbar__cta-circle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 52px; height: 52px;
  margin-top: -16px;
  border-radius: 50%;
  background: linear-gradient(135deg, #DA291C 0%, #b9221a 100%);
  color: #fff;
  box-shadow: 0 8px 22px -6px rgba(218, 41, 28, 0.7), 0 0 0 4px rgba(8, 8, 8, 0.94);
  transition: transform 120ms ease, box-shadow 160ms ease;
}
.pt-tabbar__item--cta:hover .pt-tabbar__cta-circle,
.pt-tabbar__item--cta:focus-visible .pt-tabbar__cta-circle {
  transform: translateY(-2px);
  box-shadow: 0 12px 28px -6px rgba(218, 41, 28, 0.9), 0 0 0 4px rgba(8, 8, 8, 0.94);
}
.pt-tabbar__label--cta {
  color: #DA291C;
  font-weight: 700;
}

/* Text-only Menu item — replaces the hamburger icon */
.pt-tabbar__item--menu {
  padding-top: 0.6rem;
}
.pt-tabbar__menu-text {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: 'Outfit', sans-serif;
  font-size: 0.86rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: #fff;
  line-height: 1;
}

@media (max-width: 360px) {
  .pt-tabbar { padding-left: 0.25rem; padding-right: 0.25rem; }
  .pt-tabbar__item { font-size: 0.58rem; padding: 0.4rem 0.1rem; }
  .pt-tabbar__cta-circle { width: 48px; height: 48px; }
  .pt-tabbar__menu-text { font-size: 0.78rem; letter-spacing: 0.12em; }
}
{% endstylesheet %}

{% javascript %}
(function () {
  var bar = document.getElementById('pt-sticky-bar');
  if (!bar) return;
  // Hide on the booking page itself — Book CTA is redundant there.
  if (window.location.pathname.indexOf('/pages/booking') === 0 ||
      window.location.pathname === '/pages/booking') {
    bar.classList.add('pt-tabbar--hidden');
  }

  // Wire the Menu button to the existing pt-header mobile drawer.
  var btn = bar.querySelector('[data-pt-tabbar-menu]');
  if (btn) {
    btn.addEventListener('click', function () {
      var menu = document.querySelector('[data-pt-mobile-menu]');
      var hdrToggle = document.querySelector('[data-pt-menu-toggle]');
      if (menu) {
        var isOpen = menu.classList.toggle('pt-header__mobile-menu--open');
        btn.setAttribute('aria-expanded', String(isOpen));
        if (hdrToggle) hdrToggle.setAttribute('aria-expanded', String(isOpen));
      }
    });
  }
})();
{% endjavascript %}

{% schema %}
{
  "name": "Mobile tab bar",
  "settings": [
    {
      "type": "header",
      "content": "Bottom tab bar (mobile only)"
    },
    {
      "type": "url",
      "id": "booking_url",
      "label": "Book button URL",
      "info": "Where the central red Book button goes."
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone (used elsewhere; kept for parity)",
      "default": "403 452 4283"
    }
  ],
  "presets": [
    {
      "name": "Mobile tab bar"
    }
  ]
}
{% endschema %}
