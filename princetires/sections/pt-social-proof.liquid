<div class="pt-sp">
  <div class="pt-sp__inner">
    <p class="pt-sp__eyebrow">{{ section.settings.eyebrow | default: 'Why choose us' }}</p>
    <h2 class="pt-sp__heading">{{ section.settings.heading | default: 'Calgary trusts Prince Tires' }}</h2>
    <div class="pt-sp__grid">
      {%- if section.settings.stat_1_value != blank -%}
        <div class="pt-sp__item">
          <span class="pt-sp__value">{{ section.settings.stat_1_value }}</span>
          <span class="pt-sp__label">{{ section.settings.stat_1_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_2_value != blank -%}
        <div class="pt-sp__item">
          <span class="pt-sp__value">{{ section.settings.stat_2_value }}</span>
          <span class="pt-sp__label">{{ section.settings.stat_2_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_3_value != blank -%}
        <div class="pt-sp__item">
          <span class="pt-sp__value">{{ section.settings.stat_3_value }}</span>
          <span class="pt-sp__label">{{ section.settings.stat_3_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_4_value != blank -%}
        <div class="pt-sp__item">
          <span class="pt-sp__value">{{ section.settings.stat_4_value }}</span>
          <span class="pt-sp__label">{{ section.settings.stat_4_label }}</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .pt-sp { background: #fff; color: #111; border-top: 1px solid #f3f4f6; }
  .pt-sp__inner { max-width: 1200px; margin: 0 auto; padding: 3.5rem 2rem; text-align: center; }
  .pt-sp__eyebrow {
    font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 400;
    color: #F5820B; text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 0.4rem;
  }
  .pt-sp__heading {
    font-family: 'Barlow Condensed', sans-serif; font-size: 2rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.04em; margin: 0 0 2rem; line-height: 1.1; color: #111;
  }
  .pt-sp__grid { display: flex; justify-content: center; gap: 0; }
  .pt-sp__item {
    flex: 1; max-width: 16rem; display: flex; flex-direction: column; align-items: center;
    padding: 1.2rem 1.5rem; gap: 0.3rem;
  }
  .pt-sp__item + .pt-sp__item { border-left: 1px solid #e5e7eb; }
  .pt-sp__value {
    font-family: 'Barlow Condensed', sans-serif; font-size: 2.2rem; font-weight: 700;
    color: #F5820B; line-height: 1;
  }
  .pt-sp__label {
    font-family: 'Outfit', sans-serif; font-size: 0.85rem; font-weight: 400;
    color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em;
  }

  @media (max-width: 749px) {
    .pt-sp__inner { padding: 2.5rem 1.6rem; }
    .pt-sp__heading { font-size: 1.6rem; }
    .pt-sp__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
    .pt-sp__item + .pt-sp__item { border-left: none; }
    .pt-sp__item:nth-child(even) { border-left: 1px solid #e5e7eb; }
    .pt-sp__item:nth-child(n+3) { border-top: 1px solid #e5e7eb; }
    .pt-sp__value { font-size: 1.8rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.social_proof.name",
  "tag": "section",
  "class": "section-pt-social-proof",
  "settings": [
    { "type": "text", "id": "eyebrow", "default": "Why choose us", "label": "t:sections.social_proof.settings.eyebrow.label" },
    { "type": "text", "id": "heading", "default": "Calgary trusts Prince Tires", "label": "t:sections.social_proof.settings.heading.label" },
    { "type": "text", "id": "stat_1_value", "default": "40,000+", "label": "t:sections.social_proof.settings.stat_1_value.label" },
    { "type": "text", "id": "stat_1_label", "default": "Tires installed", "label": "t:sections.social_proof.settings.stat_1_label.label" },
    { "type": "text", "id": "stat_2_value", "default": "4.9 ★", "label": "t:sections.social_proof.settings.stat_2_value.label" },
    { "type": "text", "id": "stat_2_label", "default": "Google rating", "label": "t:sections.social_proof.settings.stat_2_label.label" },
    { "type": "text", "id": "stat_3_value", "default": "Same day", "label": "t:sections.social_proof.settings.stat_3_value.label" },
    { "type": "text", "id": "stat_3_label", "default": "Installation available", "label": "t:sections.social_proof.settings.stat_3_label.label" },
    { "type": "text", "id": "stat_4_value", "default": "100%", "label": "t:sections.social_proof.settings.stat_4_value.label" },
    { "type": "text", "id": "stat_4_label", "default": "Satisfaction guaranteed", "label": "t:sections.social_proof.settings.stat_4_label.label" }
  ],
  "presets": [{ "name": "t:sections.social_proof.name" }]
}
{% endschema %}
