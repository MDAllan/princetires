{% comment %}
  Prince Tires — Custom Navbar
  Section: pt-navbar
  Fixed primary links + account, contact (phone), cart, book.
{% endcomment %}

{%- liquid
  assign book_url = section.settings.book_url | default: '/pages/booking'
  assign phone = section.settings.phone | default: '(403) 452-4283'
  assign phone_digits = phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-'
  assign tel_href = 'tel:+1' | append: phone_digits

  assign href_about = section.settings.about_url
  if href_about == blank
    assign href_about = '/pages/about'
  endif
  assign href_services = section.settings.services_url
  if href_services == blank
    assign href_services = '/pages/services'
  endif
  assign href_brands = section.settings.brands_url
  if href_brands == blank
    assign href_brands = '/pages/brands'
  endif
  assign href_wholesale = section.settings.wholesale_url
  if href_wholesale == blank
    assign href_wholesale = '/pages/wholesale'
  endif
  assign href_contact = section.settings.contact_url
  if href_contact == blank
    assign href_contact = tel_href
  endif
-%}

<style>
/* ═══════════════════════════════════════
   PT-NAVBAR  —  CSS VARS & RESET
═══════════════════════════════════════ */
#pt-navbar {
  --nb-h:          70px;
  --nb-bg-scroll:  rgba(8, 8, 10, 0.92);
  --nb-border:     rgba(255,255,255,0.07);
  --nb-text:       #f3f4f6;
  --nb-muted:      #9ca3af;
  --nb-red:        #dc2626;
  --nb-red-dim:    #b91c1c;
  --nb-red-glow:   rgba(220,38,38,0.35);
  --nb-red-glow2:  rgba(220,38,38,0.15);
  --nb-drop-bg:    #0d0d10;
  --nb-font:       'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --nb-ease:       cubic-bezier(0.16, 1, 0.3, 1);
  font-family: var(--nb-font);
  position: relative;
  z-index: 300;
}

/* ── sticky root ── */
#pt-navbar .nb-root {
  position: sticky;
  top: 0;
  left: 0;
  right: 0;
  z-index: 300;
  background: transparent;
  border-bottom: 1px solid transparent;
  transition:
    background 0.3s var(--nb-ease),
    box-shadow 0.3s var(--nb-ease),
    border-color 0.3s var(--nb-ease);
}

/* scrolled glass state */
#pt-navbar .nb-root.is-scrolled {
  background: var(--nb-bg-scroll);
  backdrop-filter: blur(20px) saturate(1.4);
  -webkit-backdrop-filter: blur(20px) saturate(1.4);
  box-shadow: 0 1px 0 rgba(255,255,255,0.05), 0 8px 40px rgba(0,0,0,0.55);
  border-bottom-color: rgba(255,255,255,0.06);
}

/* red accent hairline at very bottom on scroll */
#pt-navbar .nb-root::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--nb-red), transparent);
  transform: translateX(-50%);
  transition: width 0.5s var(--nb-ease);
  pointer-events: none;
}
#pt-navbar .nb-root.is-scrolled::after {
  width: 60%;
}

/* ── inner row ── */
#pt-navbar .nb-inner {
  height: var(--nb-h);
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  align-items: center;
}

/* ══════════════════════════════════════
   LOGO
══════════════════════════════════════ */
#pt-navbar .nb-logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  text-decoration: none;
  margin-right: 32px;
  position: relative;
}

#pt-navbar .nb-logo img {
  height: 40px;
  width: auto;
  display: block;
  transition: filter 0.2s;
}
#pt-navbar .nb-logo:hover img {
  filter: drop-shadow(0 0 8px var(--nb-red-glow2));
}

#pt-navbar .nb-logo__wordmark {
  font-size: 20px;
  font-weight: 800;
  letter-spacing: -0.3px;
  line-height: 1;
  color: #f3f4f6;
  transition: opacity 0.2s;
}
#pt-navbar .nb-logo__wordmark em {
  color: var(--nb-red);
  font-style: normal;
}
#pt-navbar .nb-logo:hover .nb-logo__wordmark {
  opacity: 0.9;
}

/* ══════════════════════════════════════
   DESKTOP NAV — frosted pill
══════════════════════════════════════ */
#pt-navbar .nb-links-frost {
  position: relative;
  display: flex;
  flex: 1;
  align-items: center;
  align-self: center;
  height: 42px;
  margin-right: 12px;
  padding: 3px 6px;
  background: rgba(255,255,255,0.04);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.09);
  border-radius: 6px;
  overflow: hidden;
}

/* sliding glide indicator */
#pt-navbar .nb-indicator {
  position: absolute;
  top: 3px;
  left: 0;
  height: calc(100% - 6px);
  background: rgba(255,255,255,0.07);
  border-radius: 4px;
  pointer-events: none;
  transition: left 0.22s var(--nb-ease), width 0.22s var(--nb-ease), opacity 0.15s;
  opacity: 0;
  z-index: 0;
}
#pt-navbar .nb-links-frost:hover .nb-indicator,
#pt-navbar .nb-links-frost:focus-within .nb-indicator {
  opacity: 1;
}

#pt-navbar .nb-links {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: stretch;
  height: 100%;
  flex: 1;
  gap: 0;
  list-style: none;
  margin: 0;
  padding: 0;
}

#pt-navbar .nb-item {
  position: relative;
  display: flex;
  align-items: center;
}

#pt-navbar .nb-link {
  display: flex;
  align-items: center;
  padding: 0 15px;
  height: 100%;
  color: var(--nb-muted);
  text-decoration: none;
  font-size: 14.5px;
  font-weight: 400;
  white-space: nowrap;
  letter-spacing: 0.01em;
  transition: color 0.18s var(--nb-ease);
  border-radius: 4px;
}

#pt-navbar .nb-item:hover .nb-link,
#pt-navbar .nb-link.is-active {
  color: var(--nb-text);
}

/* active red dot */
#pt-navbar .nb-link.is-active::after {
  content: '';
  position: absolute;
  bottom: 4px;
  left: 50%;
  transform: translateX(-50%);
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: var(--nb-red);
  box-shadow: 0 0 6px var(--nb-red);
}

/* ══════════════════════════════════════
   RIGHT ACTIONS
══════════════════════════════════════ */
#pt-navbar .nb-actions {
  display: flex;
  align-items: center;
  gap: 2px;
  margin-left: auto;
  flex-shrink: 0;
}

#pt-navbar .nb-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 6px;
  background: transparent;
  border: none;
  color: var(--nb-muted);
  cursor: pointer;
  text-decoration: none;
  transition: background 0.15s, color 0.15s, box-shadow 0.15s;
}
#pt-navbar .nb-icon:hover {
  background: rgba(255,255,255,0.06);
  color: var(--nb-text);
}
#pt-navbar .nb-icon svg { width: 19px; height: 19px; }
#pt-navbar .nb-icon--cart svg { width: 20px; height: 20px; }

/* cart badge */
#pt-navbar .nb-badge {
  position: absolute;
  top: 4px;
  right: 4px;
  min-width: 15px;
  height: 15px;
  background: var(--nb-red);
  color: #fff;
  font-size: 9px;
  font-weight: 700;
  border-radius: 99px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 3px;
  pointer-events: none;
  line-height: 1;
  box-shadow: 0 0 8px var(--nb-red-glow2);
}

/* separator */
#pt-navbar .nb-sep {
  width: 1px;
  height: 20px;
  background: rgba(255,255,255,0.1);
  margin: 0 8px;
  flex-shrink: 0;
}

/* ── Book Now — shimmer CTA ── */
#pt-navbar .nb-book {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: 36px;
  padding: 0 18px;
  margin-left: 8px;
  background: var(--nb-red);
  color: #fff;
  text-decoration: none;
  font-size: 13.5px;
  font-weight: 600;
  border-radius: 6px;
  border: none;
  cursor: pointer;
  white-space: nowrap;
  overflow: hidden;
  letter-spacing: 0.02em;
  transition: background 0.18s, box-shadow 0.18s, transform 0.18s;
  box-shadow: 0 2px 16px var(--nb-red-glow2), inset 0 1px 0 rgba(255,255,255,0.15);
}
#pt-navbar .nb-book::before {
  content: '';
  position: absolute;
  top: 0;
  left: -75%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
  transform: skewX(-20deg);
  animation: nb-shimmer 3s ease-in-out infinite;
}
#pt-navbar .nb-book:hover {
  background: var(--nb-red-dim);
  box-shadow: 0 4px 24px var(--nb-red-glow), inset 0 1px 0 rgba(255,255,255,0.15);
  transform: translateY(-1px);
}
#pt-navbar .nb-book svg { width: 13px; height: 13px; flex-shrink: 0; }

@keyframes nb-shimmer {
  0%   { left: -75%; }
  60%  { left: 125%; }
  100% { left: 125%; }
}

/* hamburger */
#pt-navbar .nb-burger { display: none; }

/* ══════════════════════════════════════
   MOBILE  (≤ 989px)
══════════════════════════════════════ */
@media (max-width: 989px) {
  #pt-navbar .nb-links-frost,
  #pt-navbar .nb-sep,
  #pt-navbar .nb-book { display: none; }

  #pt-navbar .nb-burger { display: flex; }
  #pt-navbar .nb-logo { margin-right: auto; }
  #pt-navbar .nb-inner { padding: 0 16px; }
}

/* ══════════════════════════════════════
   MOBILE DRAWER
══════════════════════════════════════ */
#pt-navbar .nb-drawer {
  position: fixed;
  inset: 0 0 0 auto;
  width: min(300px, 90vw);
  background: var(--nb-drop-bg);
  z-index: 600;
  transform: translateX(100%);
  transition: transform 0.32s var(--nb-ease);
  display: flex;
  flex-direction: column;
  box-shadow: -32px 0 80px rgba(0,0,0,0.8);
  overflow-y: auto;
  border-left: 1px solid rgba(255,255,255,0.06);
}
#pt-navbar .nb-drawer.is-open { transform: translateX(0); }

#pt-navbar .nb-backdrop {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.7);
  z-index: 590;
  backdrop-filter: blur(4px);
}
#pt-navbar .nb-backdrop.is-open { display: block; }

/* drawer header with red accent */
#pt-navbar .nb-drawer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 20px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  flex-shrink: 0;
  background: linear-gradient(135deg, rgba(220,38,38,0.06) 0%, transparent 60%);
}

#pt-navbar .nb-drawer-x {
  width: 34px;
  height: 34px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 6px;
  color: var(--nb-muted);
  font-size: 18px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s, color 0.15s;
}
#pt-navbar .nb-drawer-x:hover {
  background: rgba(255,255,255,0.1);
  color: var(--nb-text);
}

/* drawer links */
#pt-navbar .nb-drawer-links { flex: 1; padding: 6px 0; }

#pt-navbar .nb-drawer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  color: var(--nb-muted);
  text-decoration: none;
  font-size: 14.5px;
  font-weight: 500;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  cursor: pointer;
  transition: background 0.13s, color 0.13s, padding-left 0.18s var(--nb-ease);
  letter-spacing: 0.01em;
}
#pt-navbar .nb-drawer-row:hover {
  background: rgba(220,38,38,0.07);
  color: var(--nb-text);
  padding-left: 24px;
}

/* drawer footer */
#pt-navbar .nb-drawer-foot {
  padding: 18px 20px;
  border-top: 1px solid rgba(255,255,255,0.06);
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex-shrink: 0;
}

#pt-navbar .nb-drawer-book {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  height: 46px;
  background: var(--nb-red);
  color: #fff;
  border-radius: 8px;
  text-decoration: none;
  font-size: 14px;
  font-weight: 600;
  overflow: hidden;
  transition: background 0.15s, box-shadow 0.15s;
  box-shadow: 0 4px 20px var(--nb-red-glow2);
  letter-spacing: 0.02em;
}
#pt-navbar .nb-drawer-book::before {
  content: '';
  position: absolute;
  top: 0; left: -75%;
  width: 50%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
  transform: skewX(-20deg);
  animation: nb-shimmer 3.5s ease-in-out infinite;
}
#pt-navbar .nb-drawer-book:hover {
  background: var(--nb-red-dim);
  box-shadow: 0 6px 28px var(--nb-red-glow);
}

#pt-navbar .nb-drawer-tel {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  color: var(--nb-muted);
  font-size: 13px;
  text-decoration: none;
  padding: 8px 0;
  transition: color 0.13s;
}
#pt-navbar .nb-drawer-tel svg { width: 13px; height: 13px; }
#pt-navbar .nb-drawer-tel:hover { color: var(--nb-text); }

/* ══════════════════════════════════════
   KEYFRAMES
══════════════════════════════════════ */
@keyframes nb-fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@media (max-width: 480px) {
  #pt-navbar .nb-inner { padding: 0 12px; }
  #pt-navbar .nb-drawer { width: min(280px, 90vw); }
  #pt-navbar .nb-drawer-row { padding: 14px 16px; font-size: 14px; min-height: 44px; }
  #pt-navbar .nb-drawer-x { width: 40px; height: 40px; }
  #pt-navbar .nb-icon { width: 40px; height: 40px; }
}

@media (max-width: 360px) {
  #pt-navbar .nb-drawer { width: 100vw; }
  #pt-navbar .nb-inner { padding: 0 10px; }
}

@media (prefers-reduced-motion: reduce) {
  #pt-navbar .nb-book::before,
  #pt-navbar .nb-drawer-book::before { animation: none; }
  #pt-navbar .nb-indicator { transition: none; }
  #pt-navbar .nb-root::after { transition: none; }
}
</style>

<div id="pt-navbar">

  {%- comment -%} ── BACKDROP ─────────────────────────── {%- endcomment -%}
  <div class="nb-backdrop" id="nb-backdrop"></div>

  {%- comment -%} ── STICKY ROOT ──────────────────────── {%- endcomment -%}
  <div class="nb-root" id="nb-root">
    <div class="nb-inner">

      {%- comment -%} Hamburger (mobile) {%- endcomment -%}
      <button class="nb-icon nb-burger" id="nb-open" aria-label="Open menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

      {%- comment -%} Logo {%- endcomment -%}
      {%- liquid
        assign nav_logo = section.settings.logo | default: settings.logo
        assign logo_h = section.settings.logo_height | default: 40
      -%}
      <a href="{{ routes.root_url }}" class="nb-logo" aria-label="{{ shop.name }}">
        {%- if nav_logo != blank -%}
          {{- nav_logo | image_url: width: 280 | image_tag: alt: shop.name, loading: 'eager', style: 'height:' | append: logo_h | append: 'px;width:auto' -}}
        {%- else -%}
          <span class="nb-logo__wordmark">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- comment -%} Desktop nav — frosted pill {%- endcomment -%}
      <div class="nb-links-frost">
        <div class="nb-indicator" id="nb-indicator"></div>
        <ul class="nb-links" role="list">
          <li class="nb-item">
            <a href="{{ href_about }}" class="nb-link{% if request.path == href_about %} is-active{% endif %}"><span>About us</span></a>
          </li>
          <li class="nb-item">
            <a href="{{ href_services }}" class="nb-link{% if request.path == href_services %} is-active{% endif %}"><span>Services</span></a>
          </li>
          <li class="nb-item">
            <a href="{{ href_brands }}" class="nb-link{% if request.path == href_brands %} is-active{% endif %}"><span>All brands</span></a>
          </li>
          <li class="nb-item">
            <a href="{{ href_wholesale }}" class="nb-link{% if request.path == href_wholesale %} is-active{% endif %}"><span>Wholesale</span></a>
          </li>
        </ul>
      </div>

      {%- comment -%} Right-side actions {%- endcomment -%}
      <div class="nb-actions">

        {%- comment -%} Account {%- endcomment -%}
        {%- if shop.customer_accounts_enabled -%}
          <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="nb-icon" aria-label="{% if customer %}Account{% else %}Log in{% endif %}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </a>
        {%- endif -%}

        {%- comment -%} Contact (phone or contact page) {%- endcomment -%}
        <a href="{{ href_contact }}" class="nb-icon" aria-label="Contact us" title="Contact us">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.26 12 19.79 19.79 0 0 1 1.17 3.39 2 2 0 0 1 3.14 1.22h3a2 2 0 0 1 2 1.72c.127.96.36 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16v.92z"/></svg>
        </a>

        {%- comment -%} Cart — id required for Dawn cart-drawer.js {%- endcomment -%}
        <a href="{{ routes.cart_url }}" class="nb-icon nb-icon--cart" id="cart-icon-bubble" aria-label="{{ 'templates.cart.cart' | t }}{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="nb-badge">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>

        <div class="nb-sep"></div>

        {%- comment -%} Book Now {%- endcomment -%}
        <a href="{{ book_url }}" class="nb-book">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Book Now
        </a>

      </div>{%- comment -%} /nb-actions {%- endcomment -%}
    </div>{%- comment -%} /nb-inner {%- endcomment -%}
  </div>{%- comment -%} /nb-root {%- endcomment -%}

  {%- comment -%} ── MOBILE DRAWER ────────────────────── {%- endcomment -%}
  <div class="nb-drawer" id="nb-drawer" role="dialog" aria-modal="true" aria-label="Navigation">

    <div class="nb-drawer-head">
      {%- if nav_logo != blank -%}
        <a href="{{ routes.root_url }}">
          {{- nav_logo | image_url: width: 160 | image_tag: alt: shop.name, style: 'height:30px;width:auto' -}}
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" style="font-size:16px;font-weight:700;color:#E8EAED;text-decoration:none">{{ shop.name }}</a>
      {%- endif -%}
      <button class="nb-drawer-x" id="nb-close" aria-label="Close menu">&times;</button>
    </div>

    <div class="nb-drawer-links">
      <a class="nb-drawer-row" href="{{ href_about }}">About us</a>
      <a class="nb-drawer-row" href="{{ href_services }}">Services</a>
      <a class="nb-drawer-row" href="{{ href_brands }}">All brands</a>
      <a class="nb-drawer-row" href="{{ href_wholesale }}">Wholesale</a>
      <a class="nb-drawer-row" href="{{ href_contact }}">Contact us</a>
    </div>

    <div class="nb-drawer-foot">
      <a href="{{ book_url }}" class="nb-drawer-book">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Book an Appointment
      </a>
      <a href="tel:+1{{ phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}" class="nb-drawer-tel">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.26 12 19.79 19.79 0 0 1 1.17 3.39 2 2 0 0 1 3.14 1.22h3a2 2 0 0 1 2 1.72c.127.96.36 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16v.92z"/></svg>
        {{ phone }}
      </a>
    </div>

  </div>{%- comment -%} /nb-drawer {%- endcomment -%}

</div>{%- comment -%} /#pt-navbar {%- endcomment -%}

<script>
(function () {
  var root      = document.getElementById('nb-root');
  var backdrop  = document.getElementById('nb-backdrop');
  var openBtn   = document.getElementById('nb-open');
  var closeBtn  = document.getElementById('nb-close');
  var drawer    = document.getElementById('nb-drawer');
  var indicator = document.getElementById('nb-indicator');
  var frost     = indicator && indicator.closest('.nb-links-frost');

  /* ── scroll state ── */
  function onScroll() {
    if (root) root.classList.toggle('is-scrolled', window.scrollY > 10);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  /* ── sliding indicator ── */
  function moveIndicator(el) {
    if (!indicator || !frost || !el) return;
    var frostRect = frost.getBoundingClientRect();
    var elRect    = el.getBoundingClientRect();
    indicator.style.left  = (elRect.left - frostRect.left) + 'px';
    indicator.style.width = elRect.width + 'px';
  }

  if (frost) {
    var links = frost.querySelectorAll('.nb-link');
    links.forEach(function (link) {
      link.addEventListener('mouseenter', function () { moveIndicator(link); });
    });
    frost.addEventListener('mouseleave', function () {
      /* slide back to active if present, else fade out */
      var active = frost.querySelector('.nb-link.is-active');
      if (active) {
        moveIndicator(active);
      } else {
        indicator.style.opacity = '0';
        setTimeout(function () { indicator.style.opacity = ''; }, 200);
      }
    });
    /* init to active link */
    var active = frost.querySelector('.nb-link.is-active');
    if (active) moveIndicator(active);
  }

  /* ── drawer ── */
  function openDrawer() {
    drawer.classList.add('is-open');
    backdrop.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    if (openBtn) openBtn.setAttribute('aria-expanded', 'true');
  }
  function closeDrawer() {
    drawer.classList.remove('is-open');
    backdrop.classList.remove('is-open');
    document.body.style.overflow = '';
    if (openBtn) openBtn.setAttribute('aria-expanded', 'false');
  }
  if (openBtn)  openBtn.addEventListener('click', openDrawer);
  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if (backdrop) backdrop.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeDrawer();
  });
})();
</script>

