<div
  class="chatbot-section"
  style="
    --chatbot-bg: {{ section.settings.background_color }};
    --chatbot-text: {{ section.settings.text_color }};
    --chatbot-accent: {{ section.settings.accent_color }};
    --chatbot-user-bubble: {{ section.settings.accent_color }};
    --chatbot-bot-bubble: {{ section.settings.bot_bubble_color }};
    --chatbot-border: {{ section.settings.border_color }};
    --chatbot-radius: {{ section.settings.border_radius }}px;
    --chatbot-height: {{ section.settings.chat_height }}px;
  "
  id="chatbot-{{ section.id }}"
>
  <div class="chatbot-section__inner page-width">
    <div class="chatbot-section__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="chatbot-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="chatbot-section__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="chatbot-section__widget">
      <div class="chatbot-section__messages" id="chatbot-messages-{{ section.id }}" role="log" aria-live="polite" aria-label="Chat messages"></div>

      <div class="chatbot-section__input-area">
        <input
          type="text"
          class="chatbot-section__input"
          id="chatbot-input-{{ section.id }}"
          placeholder="{{ 'sections.chatbot.placeholder' | t }}"
          maxlength="500"
          autocomplete="off"
          aria-label="{{ 'sections.chatbot.placeholder' | t }}"
        >
        <button
          class="chatbot-section__send-btn"
          id="chatbot-send-{{ section.id }}"
          aria-label="{{ 'sections.chatbot.send' | t }}"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
      </div>

      <div class="chatbot-section__footer">
        <button class="chatbot-section__new-chat" id="chatbot-reset-{{ section.id }}">
          {{ 'sections.chatbot.new_chat' | t }}
        </button>
        <span class="chatbot-section__powered-by">Powered by Gemini AI</span>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .chatbot-section {
    padding: 60px 0;
    background-color: var(--chatbot-bg);
    color: var(--chatbot-text);
  }

  .chatbot-section__inner {
    display: flex;
    flex-direction: column;
    gap: 32px;
    max-width: 760px;
    margin: 0 auto;
  }

  .chatbot-section__header {
    text-align: center;
  }

  .chatbot-section__heading {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    margin: 0 0 8px;
    color: var(--chatbot-text);
  }

  .chatbot-section__subheading {
    font-size: 1rem;
    opacity: 0.7;
    margin: 0;
  }

  .chatbot-section__widget {
    border: 1px solid var(--chatbot-border);
    border-radius: var(--chatbot-radius);
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
  }

  .chatbot-section__messages {
    flex: 1;
    min-height: var(--chatbot-height);
    max-height: var(--chatbot-height);
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background-color: var(--chatbot-bg);
    scroll-behavior: smooth;
  }

  .chatbot-section__message {
    display: flex;
    gap: 10px;
    max-width: 85%;
    animation: chatbot-fade-in 0.2s ease;
  }

  @keyframes chatbot-fade-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .chatbot-section__message--user {
    align-self: flex-end;
    flex-direction: row-reverse;
  }

  .chatbot-section__message--bot {
    align-self: flex-start;
  }

  .chatbot-section__bubble {
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 0.9375rem;
    line-height: 1.5;
    word-break: break-word;
    white-space: pre-wrap;
  }

  .chatbot-section__message--user .chatbot-section__bubble {
    background-color: var(--chatbot-user-bubble);
    color: #fff;
    border-bottom-right-radius: 4px;
  }

  .chatbot-section__message--bot .chatbot-section__bubble {
    background-color: var(--chatbot-bot-bubble);
    color: var(--chatbot-text);
    border-bottom-left-radius: 4px;
    border: 1px solid var(--chatbot-border);
  }

  .chatbot-section__thinking {
    display: flex;
    gap: 4px;
    align-items: center;
    padding: 12px 14px;
  }

  .chatbot-section__thinking span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--chatbot-text);
    opacity: 0.4;
    animation: chatbot-bounce 1.2s infinite;
  }

  .chatbot-section__thinking span:nth-child(2) { animation-delay: 0.2s; }
  .chatbot-section__thinking span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes chatbot-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-5px); opacity: 1; }
  }

  .chatbot-section__input-area {
    display: flex;
    gap: 0;
    border-top: 1px solid var(--chatbot-border);
    background-color: var(--chatbot-bg);
  }

  .chatbot-section__input {
    flex: 1;
    padding: 14px 16px;
    border: none;
    background: transparent;
    color: var(--chatbot-text);
    font-size: 0.9375rem;
    outline: none;
    font-family: inherit;
  }

  .chatbot-section__input::placeholder {
    opacity: 0.5;
  }

  .chatbot-section__send-btn {
    padding: 0 18px;
    background-color: var(--chatbot-accent);
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.15s ease;
  }

  .chatbot-section__send-btn:hover {
    opacity: 0.85;
  }

  .chatbot-section__send-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .chatbot-section__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 16px;
    border-top: 1px solid var(--chatbot-border);
    background-color: var(--chatbot-bg);
  }

  .chatbot-section__new-chat {
    background: none;
    border: none;
    font-size: 0.8125rem;
    color: var(--chatbot-accent);
    cursor: pointer;
    padding: 2px 0;
    text-decoration: underline;
    font-family: inherit;
  }

  .chatbot-section__powered-by {
    font-size: 0.75rem;
    opacity: 0.45;
  }

  .chatbot-section__error {
    color: #e53e3e;
    font-size: 0.875rem;
    padding: 4px 14px 10px;
    align-self: flex-start;
  }

  @media screen and (max-width: 749px) {
    .chatbot-section {
      padding: 40px 0;
    }
    .chatbot-section__message {
      max-width: 95%;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const sectionId = {{ section.id | json }};
    const apiEndpoint = {{ section.settings.api_endpoint | json }};
    const systemPrompt = {{ section.settings.system_prompt | json }};
    const greeting = {{ 'sections.chatbot.greeting' | t | json }};

    const messagesEl = document.getElementById('chatbot-messages-' + sectionId);
    const inputEl = document.getElementById('chatbot-input-' + sectionId);
    const sendBtn = document.getElementById('chatbot-send-' + sectionId);
    const resetBtn = document.getElementById('chatbot-reset-' + sectionId);

    let history = [];

    function appendMessage(role, text) {
      const wrapper = document.createElement('div');
      wrapper.className = 'chatbot-section__message chatbot-section__message--' + role;
      const bubble = document.createElement('div');
      bubble.className = 'chatbot-section__bubble';
      bubble.textContent = text;
      wrapper.appendChild(bubble);
      messagesEl.appendChild(wrapper);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return bubble;
    }

    function showThinking() {
      const wrapper = document.createElement('div');
      wrapper.className = 'chatbot-section__message chatbot-section__message--bot';
      wrapper.id = 'chatbot-thinking-' + sectionId;
      const bubble = document.createElement('div');
      bubble.className = 'chatbot-section__bubble chatbot-section__thinking';
      bubble.innerHTML = '<span></span><span></span><span></span>';
      wrapper.appendChild(bubble);
      messagesEl.appendChild(wrapper);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function hideThinking() {
      const el = document.getElementById('chatbot-thinking-' + sectionId);
      if (el) el.remove();
    }

    function showError(msg) {
      const el = document.createElement('div');
      el.className = 'chatbot-section__error';
      el.textContent = msg;
      messagesEl.appendChild(el);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    async function sendMessage() {
      const text = inputEl.value.trim();
      if (!text || !apiEndpoint) return;

      inputEl.value = '';
      sendBtn.disabled = true;
      appendMessage('user', text);
      history.push({ role: 'user', parts: [{ text: text }] });

      showThinking();

      try {
        const body = {
          system_instruction: { parts: [{ text: systemPrompt }] },
          contents: history,
          generationConfig: { temperature: 0.7, maxOutputTokens: 1024 }
        };

        const res = await fetch(apiEndpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });

        if (!res.ok) throw new Error('API error ' + res.status);

        const data = await res.json();
        const reply =
          data?.candidates?.[0]?.content?.parts?.[0]?.text ||
          data?.text ||
          'Sorry, I didn\'t get a response.';

        hideThinking();
        appendMessage('bot', reply);
        history.push({ role: 'model', parts: [{ text: reply }] });
      } catch (err) {
        hideThinking();
        showError('Sorry, something went wrong. Please try again.');
        history.pop();
      } finally {
        sendBtn.disabled = false;
        inputEl.focus();
      }
    }

    function resetChat() {
      history = [];
      messagesEl.innerHTML = '';
      appendMessage('bot', greeting);
    }

    sendBtn.addEventListener('click', sendMessage);
    inputEl.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });
    resetBtn.addEventListener('click', resetChat);

    resetChat();
  })();
{% endjavascript %}

{% schema %}
{
  "name": "AI chatbot",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ask our AI assistant"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get instant help with tire recommendations, sizing, and booking"
    },
    {
      "type": "header",
      "content": "API settings"
    },
    {
      "type": "text",
      "id": "api_endpoint",
      "label": "Gemini API endpoint URL",
      "info": "Paste your Cloudflare Worker URL here (recommended) or the Gemini API URL with your key."
    },
    {
      "type": "textarea",
      "id": "system_prompt",
      "label": "System prompt",
      "default": "You are a helpful AI assistant for Prince Tires, a tire shop. Help customers with tire recommendations, sizing questions (width/profile/rim), brand comparisons, all-season vs winter tire advice, and booking appointments. Be concise, friendly, and professional. If asked about pricing or specific inventory, suggest they call or visit the shop. Do not discuss topics unrelated to tires or the shop."
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "range",
      "id": "chat_height",
      "label": "Chat window height",
      "min": 250,
      "max": 600,
      "step": 10,
      "unit": "px",
      "default": 380
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent & send button color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "bot_bubble_color",
      "label": "Bot message bubble color",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e5e5e5"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "AI chatbot"
    }
  ]
}
{% endschema %}
