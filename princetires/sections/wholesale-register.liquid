{%- comment -%}
  Prince Tires — Wholesale Registration
  Two flows:
    A) Guest → {% form 'create_customer' %} with wholesale data in customer[note]
               Redirects to /pages/wholesale on success (shows pending state there)
    B) Logged-in → {% form 'contact' %} notifies admin for manual review + tagging

  Customer note format (for admin to identify applicants in Shopify):
    "WHOLESALE: Business=X | Type=Y | GST=Z | Phone=P | Volume=V"
{%- endcomment -%}

{%- liquid
  assign show_account_form = false
  assign show_upgrade_form = false
  if customer
    assign show_upgrade_form = true
  else
    assign show_account_form = true
  endif
-%}

<style>
/* ═══════════════════════════════════════════
   WHOLESALE REGISTER — Prince Tires
   Red #DC2626 · Dark #1E293B · Outfit + Barlow Condensed
═══════════════════════════════════════════ */
.whr-page {
  display: flex;
  min-height: 100vh;
  min-height: 100dvh;
  font-family: 'Outfit', sans-serif;
}

/* ── Left panel ── */
.whr-brand {
  display: none;
  width: 42%;
  max-width: 560px;
  background: #0f172a;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}
@media (min-width: 960px) { .whr-brand { display: flex; } }

.whr-brand::before {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 55%;
  background: linear-gradient(to top, rgba(220,38,38,0.06) 0%, transparent 100%);
  pointer-events: none;
}
.whr-brand::after {
  content: '';
  position: absolute;
  top: -80px; right: -80px;
  width: 340px; height: 340px;
  border-radius: 50%;
  background: rgba(220,38,38,0.06);
  pointer-events: none;
}

.whr-brand-content {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 3.5rem;
  width: 100%;
  position: relative;
  z-index: 1;
}

.whr-logo {
  text-decoration: none;
  display: inline-block;
}
.whr-logo-img { max-height: 40px; width: auto; }
.whr-logo-text {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 2rem;
  font-weight: 700;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* perks list */
.whr-perks { flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 2.5rem 0; }
.whr-perks-header { margin-bottom: 2.5rem; }
.whr-perks-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #dc2626;
  background: rgba(220,38,38,0.1);
  border: 1px solid rgba(220,38,38,0.2);
  padding: 5px 12px;
  border-radius: 99px;
  margin-bottom: 16px;
}
.whr-perks-badge svg { width:11px; height:11px; }
.whr-perks-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 2.6rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 10px;
  line-height: 1.1;
}
.whr-perks-sub {
  font-size: 1.3rem;
  font-weight: 300;
  color: rgba(255,255,255,0.4);
  margin: 0;
  line-height: 1.6;
}
.whr-perks-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 1.6rem;
}
.whr-perk {
  display: flex;
  align-items: flex-start;
  gap: 1.2rem;
}
.whr-perk-icon {
  width: 36px; height: 36px;
  border-radius: 9px;
  background: rgba(220,38,38,0.1);
  border: 1px solid rgba(220,38,38,0.15);
  color: #dc2626;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2px;
}
.whr-perk-icon svg { width:16px; height:16px; }
.whr-perk-body strong {
  display: block;
  font-size: 1.4rem;
  font-weight: 600;
  color: rgba(255,255,255,0.88);
  margin-bottom: 3px;
}
.whr-perk-body span {
  font-size: 1.2rem;
  font-weight: 300;
  color: rgba(255,255,255,0.38);
  line-height: 1.5;
}

/* brand bottom */
.whr-brand-bottom {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255,255,255,0.06);
}
