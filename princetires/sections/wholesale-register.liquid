              <div class="whr-field">
                <label class="whr-label" for="WhrGST2">GST / Business registration <span class="whr-optional">(optional)</span></label>
                <div class="whr-input-wrap">
                  <svg class="whr-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  <input class="whr-input" type="text" id="WhrGST2" placeholder="e.g. 123456789 RT0001" data-whr-field="gst">
                </div>
              </div>

              <div class="whr-field">
                <label class="whr-label" for="WhrNotes">Additional notes <span class="whr-optional">(optional)</span></label>
                <textarea class="whr-textarea" id="WhrNotes" placeholder="Tell us about your business, tire needs, or any questions..." rows="3" data-whr-field="notes"></textarea>
              </div>

              {%- comment -%} Hidden field — JS assembles the full body string before submit {%- endcomment -%}
              <input type="hidden" name="contact[body]" id="WhrCompositeBody">

              <button type="submit" class="whr-submit" id="WhrSubmitUpgrade">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span>Submit wholesale application</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left:auto"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>

            {%- endif -%}

          {%- endform -%}

          <p class="whr-terms">
            By applying you agree to our <a href="/policies/terms-of-service">terms of service</a>. Wholesale access is subject to approval.
          </p>
          <div class="whr-switch">
            Want to check your application status?
            <a href="/pages/wholesale">Go to wholesale portal</a>
          </div>

        {%- endif -%}

      </div>
    </div>
  </div>
</div>

{% javascript %}
(function() {

  // ── Shorthand helpers ──
  function $id(id) { return document.getElementById(id); }
  function $all(sel) { return document.querySelectorAll(sel); }
  var CHECK_SVG = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';

  // ── Phone auto-format (xxx) xxx-xxxx ──
  function formatPhone(v) {
    var d = v.replace(/\D/g, '').slice(0, 10);
    if (d.length <= 3) return d;
    if (d.length <= 6) return '(' + d.slice(0, 3) + ') ' + d.slice(3);
    return '(' + d.slice(0, 3) + ') ' + d.slice(3, 6) + '-' + d.slice(6);
  }
  $all('[data-whr-field="phone"]').forEach(function(inp) {
    inp.addEventListener('input', function() {
      var start = this.selectionStart;
      var before = this.value.length;
      this.value = formatPhone(this.value);
      var diff = this.value.length - before;
      try { this.setSelectionRange(start + diff, start + diff); } catch(e) {}
    });
  });

  // ── Inline validation helpers ──
  function fieldError(input, msg) {
    var wrap = input.closest('.whr-field');
    if (!wrap) return;
    var err = wrap.querySelector('.whr-inline-error');
    if (!err) {
      err = document.createElement('span');
      err.className = 'whr-inline-error';
      wrap.appendChild(err);
    }
    err.textContent = msg || '';
    if (msg) {
      input.setAttribute('aria-invalid', 'true');
    } else {
      input.removeAttribute('aria-invalid');
    }
  }

  // Email blur validation
  $all('#WhrAcctEmail, #WhrEmail2').forEach(function(inp) {
    inp.addEventListener('blur', function() {
      if (this.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.value)) {
        fieldError(this, 'Please enter a valid email address.');
      } else {
        fieldError(this, '');
      }
    });
    inp.addEventListener('input', function() { fieldError(this, ''); });
  });

  // Phone blur validation
  $all('[data-whr-field="phone"]').forEach(function(inp) {
    inp.addEventListener('blur', function() {
      var d = this.value.replace(/\D/g, '');
      if (this.value && d.length < 10) {
        fieldError(this, 'Please enter a valid 10-digit phone number.');
      } else {
        fieldError(this, '');
      }
    });
    inp.addEventListener('input', function() { fieldError(this, ''); });
  });

  // Password blur validation
  var pwInput = $id('WhrPassword');
  if (pwInput) {
    pwInput.addEventListener('blur', function() {
      if (this.value && this.value.length < 8) {
        fieldError(this, 'Password must be at least 8 characters.');
      } else {
        fieldError(this, '');
      }
    });
    pwInput.addEventListener('input', function() { fieldError(this, ''); });
  }

  // ── Password visibility toggle ──
  $all('[data-whr-toggle-pw]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var wrap      = this.closest('.whr-input-wrap');
      var input     = wrap.querySelector('input');
      var eyeOpen   = this.querySelector('.whr-eye-open');
      var eyeClosed = this.querySelector('.whr-eye-closed');
      if (input.type === 'password') {
        input.type = 'text';
        eyeOpen.style.display = 'none';
        eyeClosed.style.display = 'block';
      } else {
        input.type = 'password';
        eyeOpen.style.display = 'block';
        eyeClosed.style.display = 'none';
      }
      input.focus();
    });
  });

  // ── Password strength meter ──
  var pwStrength = $id('WhrPwStrength');
  var pwHint     = $id('WhrPwHint');
  var pwBars     = [$id('WhrPwBar1'), $id('WhrPwBar2'), $id('WhrPwBar3'), $id('WhrPwBar4')];
  if (pwInput && pwStrength) {
    pwInput.addEventListener('input', function() {
      var val = this.value;
      if (!val) {
        pwStrength.style.display = 'none';
        if (pwHint) pwHint.textContent = '';
        return;
      }
      pwStrength.style.display = 'flex';
      var score = 0;
      if (val.length >= 8)  score++;
      if (val.length >= 12) score++;
      if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
      if (/[^A-Za-z0-9]/.test(val)) score++;
      var labels  = ['', 'Weak', 'Fair', 'Good', 'Strong'];
      var classes = ['', 'whr-pw-bar--weak', 'whr-pw-bar--fair', 'whr-pw-bar--good', 'whr-pw-bar--strong'];
      var cls = classes[score] || 'whr-pw-bar--weak';
      pwBars.forEach(function(bar, idx) {
        bar.className = 'whr-pw-bar';
        if (idx < score) bar.classList.add(cls);
      });
      if (pwHint) pwHint.textContent = score > 0 ? labels[score] + ' password' : '';
    });
  }

  // ── Step indicator ──
  var stepNums   = $all('.whr-step-ind__num');
  var stepLabels = $all('.whr-step-ind__label');

  function setStep(active) {
    if (!stepNums.length) return;
    stepNums.forEach(function(num, i) {
      var s = i + 1;
      num.className = 'whr-step-ind__num';
      if (s < active) {
        num.classList.add('whr-step-ind__num--done');
        num.innerHTML = CHECK_SVG;
      } else if (s === active) {
        num.classList.add('whr-step-ind__num--active');
        num.textContent = s;
      } else {
        num.classList.add('whr-step-ind__num--pending');
        num.textContent = s;
      }
    });
    stepLabels.forEach(function(label, i) {
      label.className = 'whr-step-ind__label';
      if (i + 1 === active) label.classList.add('whr-step-ind__label--active');
    });
  }

  setStep(1);

  // Advance to step 2 when user first focuses an account field
  ['WhrFirstName', 'WhrLastName', 'WhrAcctEmail', 'WhrPassword'].forEach(function(id) {
    var el = $id(id);
    if (el) {
      el.addEventListener('focus', function() { setStep(2); }, { once: true });
    }
  });

  // ── localStorage persistence ──
  var LS_KEY = 'whr_form_v1';
  var LS_FIELDS = ['WhrBusiness', 'WhrPhone', 'WhrFirstName', 'WhrLastName',
                   'WhrAcctEmail', 'WhrType', 'WhrVolume', 'WhrGST'];

  function saveForm() {
    var data = {};
    LS_FIELDS.forEach(function(id) {
      var el = $id(id);
      if (el) data[id] = el.value;
    });
    try { localStorage.setItem(LS_KEY, JSON.stringify(data)); } catch(e) {}
  }

  function restoreForm() {
    var saved;
    try { saved = JSON.parse(localStorage.getItem(LS_KEY)); } catch(e) {}
    if (!saved) return;
    LS_FIELDS.forEach(function(id) {
      var el = $id(id);
      if (el && saved[id] !== undefined) el.value = saved[id];
    });
  }

  restoreForm();

  LS_FIELDS.forEach(function(id) {
    var el = $id(id);
    if (el) el.addEventListener('input', saveForm);
  });

  // ── Honeypot check — blocks submit if trap field was filled (bot) ──
  function isHoneypotFilled(form) {
    var hp = form.querySelector('[data-whr-hp]');
    return hp && hp.value.length > 0;
  }

  // ── FLOW A: Guest form — build customer[note] from collected fields ──
  var guestForm = document.querySelector('form[action*="/account"]');
  if (guestForm) {
    guestForm.addEventListener('submit', function(e) {
      if (isHoneypotFilled(this)) { e.preventDefault(); return; }

      setStep(3);

      var f = {};
      this.querySelectorAll('[data-whr-field]').forEach(function(el) {
        f[el.dataset.whrField] = el.value.trim();
      });

      var noteField = $id('WhrCustomerNote');
      if (noteField) {
        noteField.value = 'WHOLESALE: Business=' + (f.business || '') +
          ' | Type=' + (f.type || '') +
          ' | GST=' + (f.gst || '') +
          ' | Phone=' + (f.phone || '') +
          ' | Volume=' + (f.volume || '');
      }

      // Notify admin platform (fire-and-forget; never blocks Shopify account creation)
      try {
        var first = (($id('WhrFirstName') || {}).value || '').trim();
        var last  = (($id('WhrLastName')  || {}).value || '').trim();
        var contactName = (first + ' ' + last).trim();
        fetch('https://app.princetires.ca/api/wholesale/register', {
          method: 'POST',
          mode: 'cors',
          keepalive: true,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: (($id('WhrAcctEmail') || {}).value || '').trim(),
            businessName: f.business || '',
            contactName: contactName,
            phone: f.phone || '',
            taxNumber: f.gst || '',
            businessType: f.type || '',
            monthlyVolume: f.volume || ''
          })
        }).catch(function() {});
      } catch (err) {}

      try { localStorage.removeItem(LS_KEY); } catch(e) {}

      var btn = $id('WhrSubmitGuest');
      if (btn) {
        btn.classList.add('whr-submit--loading');
        btn.querySelector('span').textContent = 'Creating your account\u2026';
      }
    });
  }

  // ── FLOW B: Logged-in upgrade form — assemble composite body for contact form ──
  var upgradeForm = $id('WholesaleApplicationForm');
  if (upgradeForm) {
    upgradeForm.addEventListener('submit', function(e) {
      if (isHoneypotFilled(this)) { e.preventDefault(); return; }

      var f = {};
      this.querySelectorAll('[data-whr-field]').forEach(function(el) {
        f[el.dataset.whrField] = el.value.trim();
        el.removeAttribute('name');
      });

      var body = [
        '=== WHOLESALE UPGRADE APPLICATION ===',
        'Business: '  + (f.business || '\u2014'),
        'Type: '      + (f.type     || '\u2014'),
        'Phone: '     + (f.phone    || '\u2014'),
        'Volume: '    + (f.volume   || '\u2014'),
        'GST/BN: '    + (f.gst     || '\u2014'),
        'Notes: '     + (f.notes   || '\u2014'),
        '====================================',
        'Customer email: ' + (upgradeForm.dataset.customerEmail || ''),
        'Customer ID: '    + (upgradeForm.dataset.customerId    || '')
      ].join('\n');

      var composite = $id('WhrCompositeBody');
      if (composite) composite.value = body;

      // Notify admin platform (fire-and-forget; never blocks Shopify contact form)
      try {
        fetch('https://app.princetires.ca/api/wholesale/register', {
          method: 'POST',
          mode: 'cors',
          keepalive: true,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: upgradeForm.dataset.customerEmail || '',
            businessName: f.business || '',
            contactName: (($id('WhrContactName') || {}).value || '').trim(),
            phone: f.phone || '',
            taxNumber: f.gst || '',
            businessType: f.type || '',
            monthlyVolume: f.volume || '',
            notes: f.notes || ''
          })
        }).catch(function() {});
      } catch (err) {}

      var btn = $id('WhrSubmitUpgrade');
      if (btn) {
        btn.classList.add('whr-submit--loading');
        btn.querySelector('span').textContent = 'Submitting application\u2026';
      }
    });
  }

})();
{% endjavascript %}

