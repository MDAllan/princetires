  font-weight: 300;
  color: rgba(255,255,255,0.3);
  line-height: 1.5;
}
.whr-brand-bottom-text strong { color: rgba(255,255,255,0.5); font-weight: 500; }

/* ── Trust bar on brand panel ── */
.whr-trust-bar {
  display: flex;
  gap: 1.6rem;
  margin-top: 2rem;
  padding: 1.4rem 0 0;
}
.whr-trust-item {
  display: flex;
