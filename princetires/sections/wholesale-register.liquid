  align-items: flex-start;
}
.whr-trust-val {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 2.2rem;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}
.whr-trust-label {
  font-size: 1rem;
  font-weight: 300;
  color: rgba(255,255,255,0.3);
