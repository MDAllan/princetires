            { "value": "All-Weather", "label": "All-Weather" },
            { "value": "Performance", "label": "Performance" }
          ],
          "default": "All-Season"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Short description",
          "default": "Describe what makes this model stand out."
        },
        {
          "type": "url",
          "id": "shop_link",
          "label": "Shop link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand detail"
    }
  ]
}
{% endschema %}
