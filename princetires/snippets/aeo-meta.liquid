{% doc %}
  Renders Answer Engine Optimization (AEO) structured data.

  Outputs JSON-LD for FAQ pages, Speakable markup for voice assistants,
  and Q&A structured data to target featured snippets, answer boxes,
  and voice search results (Google Assistant, Alexa, Siri).

  @example
  {% render 'aeo-meta' %}
{% enddoc %}

{%- comment -%}
  Speakable markup — tells voice assistants which parts of the page
  are most suitable for text-to-speech. Applied to page title and description.
{%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": {{ page_title | json }},
  "url": {{ canonical_url | json }},
  "description": {{ page_description | default: shop.description | escape | json }},
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": [
      ".aeo-speakable-title",
      ".aeo-speakable-summary"
    ]
  },
  "mainEntity": {
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": {{ request.origin | json }}
  }
}
</script>

{%- comment -%}
  FAQ structured data is now handled by the FAQ section (sections/faq.liquid).
  Add the FAQ section to any page via the theme editor — no metafields needed.
{%- endcomment -%}

{%- comment -%}
  HowTo structured data for articles tagged with "how-to".
  Uses the article body content split by h2/h3 headings as steps.
{%- endcomment -%}
{%- if request.page_type == 'article' -%}
  {%- if article.tags contains 'how-to' -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": {{ article.title | json }},
      "description": {{ article.excerpt_or_content | strip_html | truncate: 300 | json }},
      {%- if article.image -%}
        "image": {{ article.image | image_url: width: 1200 | prepend: 'https:' | json }},
      {%- endif -%}
      "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
      "author": {
        "@type": "Person",
        "name": {{ article.author | json }}
      }
    }
    </script>
  {%- endif -%}
{%- endif -%}

{%- comment -%}
  SearchAction — enables sitelinks searchbox in Google results.
{%- endcomment -%}
{%- if request.page_type == 'index' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": {{ request.origin | json }},
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        {%- capture search_url_template -%}{{ request.origin }}/search?q={% raw %}{search_term_string}{% endraw %}{%- endcapture -%}
        "urlTemplate": {{ search_url_template | json }}
      },
      "query-input": "required name=search_term_string"
    }
  }
  </script>
{%- endif -%}
