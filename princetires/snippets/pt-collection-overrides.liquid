{% doc %}
  CSS overrides to restyle Dawn's default collection grid
  to match Prince Tires design system.

  @example
  {% render 'pt-collection-overrides' %}
{% enddoc %}

<style>
  /* ══════════════════════════════════════
     PT COLLECTION OVERRIDES
     Reskins Dawn's collection grid to match
     Prince Tires minimal design.
  ══════════════════════════════════════ */

  /* ── Page layout ── */
  .collection .section-template--*-padding,
  .collection [class*="section-"][class*="-padding"] {
    padding-top: 0 !important;
  }

  /* ── Facets / Filter sidebar ── */
  .facets-wrapper {
    padding: 0 !important;
  }

  .facets__heading,
  .facet-filters__heading {
    font-family: 'Barlow Condensed', sans-serif !important;
    font-size: 1.4rem !important;
    font-weight: 600 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.04em !important;
    color: #111 !important;
  }

  .facets__summary span,
  .facets__header span {
    font-family: 'Outfit', sans-serif !important;
    font-size: 1.25rem !important;
    font-weight: 500 !important;
    color: #111 !important;
  }

  .facets__disclosure label,
  .facets__item label,
  .facet-checkbox {
    font-family: 'Outfit', sans-serif !important;
    font-size: 1.2rem !important;
    font-weight: 300 !important;
    color: #6b7280 !important;
  }

  .facet-checkbox input[type="checkbox"] {
    border-color: #d1d5db !important;
    border-radius: 3px !important;
  }

  .facet-checkbox input[type="checkbox"]:checked {
    background-color: #dc2626 !important;
    border-color: #dc2626 !important;
  }

  /* ── Vertical filter ── */
  .facets-vertical .facets-wrapper {
    max-width: 24rem;
    padding-right: 2rem !important;
  }

  /* ── Active filters ── */
  .active-facets .active-facets__button {
    font-family: 'Outfit', sans-serif !important;
    font-size: 1.1rem !important;
    background: #fef2f2 !important;
    color: #dc2626 !important;
    border: none !important;
    border-radius: 99px !important;
    padding: 0.3rem 0.8rem !important;
  }

  .active-facets .active-facets__button:hover {
    background: #dc2626 !important;
    color: #fff !important;
  }

  .active-facets__button-wrapper a[href*="clear_all"],
  .facets__reset {
    font-family: 'Outfit', sans-serif !important;
    font-size: 1.1rem !important;
    color: #9ca3af !important;
    text-decoration: none !important;
  }

  .active-facets__button-wrapper a:hover,
  .facets__reset:hover {
    color: #dc2626 !important;
  }

  /* ── Sort dropdown ── */
  .facet-filters__sort .select__select,
  .collection-sort select {
    font-family: 'Outfit', sans-serif !important;
    font-size: 1.15rem !important;
    border-radius: 4px !important;
    border-color: #e5e7eb !important;
    background: #f7f7f7 !important;
    color: #374151 !important;
  }

  .facet-filters__sort .select__select:focus {
    border-color: #dc2626 !important;
  }

  .facet-filters__label label,
  .facet-filters__sort label {
    font-family: 'Outfit', sans-serif !important;
    font-size: 1.2rem !important;
    color: #6b7280 !important;
  }

  /* ── Product count ── */
  .product-count__text,
  .facets__product-count {
    font-family: 'Outfit', sans-serif !important;
    font-size: 1.2rem !important;
    font-weight: 300 !important;
    color: #9ca3af !important;
  }

  /* ── Product cards ── */
  .product-grid .grid__item .card-wrapper {
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }

  .product-grid .card {
    border: none !important;
    border-radius: 8px !important;
    background: #fff !important;
  }

  .product-grid .card__inner {
    border: none !important;
    border-radius: 8px !important;
  }

  .product-grid .card--media .card__inner .card__media {
    border-radius: 8px 8px 0 0 !important;
  }

  .product-grid .card__content {
    padding: 0.8rem 1rem !important;
  }

  .product-grid .card__heading,
  .product-grid .card-information__text h3 {
    font-family: 'Outfit', sans-serif !important;
    font-size: 1.1rem !important;
    font-weight: 700 !important;
    color: #111 !important;
    line-height: 1.3 !important;
  }

  .product-grid .card-information__wrapper .caption-with-letter-spacing,
  .product-grid .card__information .card-information__text .caption-with-letter-spacing {
    font-family: 'Outfit', sans-serif !important;
    font-size: 0.95rem !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.04em !important;
    color: #8b1a1a !important;
  }

  /* Brand colors for vendors */
  .product-grid .card-information__text .caption-with-letter-spacing {
    color: #8b1a1a !important;
  }

  .product-grid .price {
    font-family: 'Outfit', sans-serif !important;
    font-weight: 600 !important;
    color: #111 !important;
  }

  .product-grid .price-item--sale {
    color: #dc2626 !important;
  }

  .product-grid .price-item--regular.price-item--last {
    color: #9ca3af !important;
    text-decoration: line-through !important;
  }

  /* ── Page width override ── */
  .collection .page-width {
    max-width: 1400px !important;
    padding-left: 6rem !important;
    padding-right: 6rem !important;
  }

  /* ── Pagination ── */
  .pagination__list .pagination__item a,
  .pagination__list .pagination__item span {
    font-family: 'Outfit', sans-serif !important;
    font-size: 1.2rem !important;
    border-radius: 4px !important;
  }

  .pagination__list .pagination__item a:hover {
    border-color: #dc2626 !important;
    color: #dc2626 !important;
  }

  .pagination__list .pagination__item--current span {
    background: #dc2626 !important;
    color: #fff !important;
    border-color: #dc2626 !important;
  }

  /* ── Price range inputs ── */
  .facets__price .field__input {
    font-family: 'Outfit', sans-serif !important;
    border-radius: 4px !important;
    border-color: #e5e7eb !important;
  }

  .facets__price .field__input:focus {
    border-color: #dc2626 !important;
  }

  /* ── Disclosure triangles ── */
  .disclosure-has-popup summary svg,
  .facets__summary svg {
    color: #9ca3af;
  }

  /* ── Hide Dawn elements we don't need ── */
  .collection-hero { display: none !important; }
  .breadcrumbs { display: none !important; }

  /* ── Mobile ── */
  @media (max-width: 989px) {
    .collection .page-width {
      padding-left: 2rem !important;
      padding-right: 2rem !important;
    }
  }
</style>
