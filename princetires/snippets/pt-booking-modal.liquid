function rv(){document.getElementById('bk-vehicles').innerHTML=vehs.map(function(v){return'<div class="bk-vehicle-card'+(st.vehicle===v.id?' bk-vehicle-card--active':'')+'" data-v="'+v.id+'"><div class="bk-vehicle-icon">'+(vIcons[v.id]||vIcons.other)+'</div><div class="bk-vehicle-name">'+v.name+'</div><div class="bk-vehicle-price">'+(v.price?'$'+v.price+'/tire':'Ask us')+'</div></div>'}).join('');
document.querySelectorAll('.bk-vehicle-card').forEach(function(e){e.addEventListener('click',function(){st.vehicle=this.dataset.v;rv();rp()})})}
function rq(){var o=[1,2,4,'Other'];document.getElementById('bk-qty-grid').innerHTML=o.map(function(q){var a=(q==='Other'?st.qty>4||st.qty===3:st.qty===q);
if(q==='Other'){return'<div class="bk-qty-btn'+(a?' bk-qty-btn--active':'')+'" data-q="Other"><input type="number" class="bk-qty-input" placeholder="Other" min="1" max="20" value="'+(a?st.qty:'')+'" data-qty-other></div>'}
return'<button class="bk-qty-btn'+(a?' bk-qty-btn--active':'')+'" data-q="'+q+'"><strong>'+q+'</strong><span style="font-size:.75rem;color:#9ca3af;display:block">tire'+(q>1?'s':'')+'</span></button>'}).join('');
document.querySelectorAll('.bk-qty-btn[data-q]:not([data-q="Other"])').forEach(function(e){e.addEventListener('click',function(){st.qty=parseInt(this.dataset.q);rq();rp()})});
var otherInput=document.querySelector('[data-qty-other]');
if(otherInput){otherInput.addEventListener('input',function(){var n=parseInt(this.value);if(n>0){st.qty=n;rp()}});otherInput.addEventListener('focus',function(){this.closest('.bk-qty-btn').classList.add('bk-qty-btn--active');document.querySelectorAll('.bk-qty-btn:not([data-q="Other"])').forEach(function(b){b.classList.remove('bk-qty-btn--active')})})}}
function rw(){var td=new Date();td.setHours(0,0,0,0);var s=new Date(td);s.setDate(s.getDate()-s.getDay()+1+wk*7);var dn=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],mn=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
var e=new Date(s);e.setDate(e.getDate()+6);document.getElementById('bk-week-label').textContent=s.getDate()+' '+mn[s.getMonth()]+' – '+e.getDate()+' '+mn[e.getMonth()];
document.getElementById('bk-prev-week').disabled=wk<=0;var h='';
for(var i=0;i<7;i++){var d=new Date(s);d.setDate(d.getDate()+i);var ip=d<td,it=d.getTime()===td.getTime(),ia=st.date&&d.toDateString()===st.date.toDateString();
var c='bk-day-card';if(ip)c+=' bk-day-card--past';if(it)c+=' bk-day-card--today';if(ia)c+=' bk-day-card--active';
h+='<div class="'+c+'" data-date="'+d.toISOString()+'"><div class="bk-day-name">'+dn[i]+'</div><div class="bk-day-num">'+d.getDate()+'</div></div>'}
document.getElementById('bk-day-strip').innerHTML=h;
document.querySelectorAll('.bk-day-card:not(.bk-day-card--past)').forEach(function(e){e.addEventListener('click',function(){st.date=new Date(this.dataset.date);rw();rt()})})}
async function rt(){if(!st.date){document.getElementById('bk-time-grid').innerHTML='<p style="color:#9ca3af;font-size:.9rem;grid-column:1/-1">Select a day first</p>';return}
var sun=st.date.getDay()===0,sh=sun?10:9,sm=sun?0:30,eh=sun?15:17,em=sun?30:30,sl=[];
for(var h=sh;h<=eh;h++){for(var m=(h===sh?sm:0);m<60;m+=30){if(h===eh&&m>em)break;var hr=h>12?h-12:h;sl.push(hr+':'+(m<10?'0':'')+m+' '+(h>=12?'PM':'AM'))}}
document.getElementById('bk-time-grid').innerHTML='<p style="color:#9ca3af;font-size:.9rem;grid-column:1/-1">Loading availability...</p>';
var booked=[];
try{var ds=st.date.toISOString().split('T')[0];var r=await fetch('https://prince-tires-booking.vercel.app/api/availability?date='+ds);var d=await r.json();booked=d.booked||[]}catch(e){}
document.getElementById('bk-time-grid').innerHTML=sl.map(function(s){var isBooked=booked.indexOf(s)>-1;return'<div class="bk-time-slot'+(st.time===s?' bk-time-slot--active':'')+(isBooked?' bk-time-slot--booked':'')+'" data-time="'+s+'"'+(isBooked?' title="Already booked"':'')+'>'+s+'</div>'}).join('');
document.querySelectorAll('.bk-time-slot:not(.bk-time-slot--booked)').forEach(function(e){e.addEventListener('click',function(){st.time=this.dataset.time;rt();document.getElementById('bk-next-2').disabled=false})})}
function rs(){var c=calc(),v=vehs.find(function(x){return x.id===st.vehicle}),ds=st.date?st.date.toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'})+' at '+st.time:'',ao=[];
if(st.tpms)ao.push('TPMS Sensors');if(st.disposal)ao.push('Tire Disposal');var h='';
h+='<div class="bk-summary-row"><span class="bk-summary-label">Date & Time</span><span class="bk-summary-val">'+ds+'</span></div>';
h+='<div class="bk-summary-row"><span class="bk-summary-label">Vehicle</span><span class="bk-summary-val">'+(v?v.name:'')+'</span></div>';
h+='<div class="bk-summary-row"><span class="bk-summary-label">Tire</span><span class="bk-summary-val">'+st.tireSize+' × '+st.qty+' tires</span></div>';
if(ao.length)h+='<div class="bk-summary-row"><span class="bk-summary-label">Add-ons</span><span class="bk-summary-val">'+ao.join(', ')+'</span></div>';
h+='<div class="bk-summary-row"><span class="bk-summary-label">Subtotal</span><span class="bk-summary-val">$'+c.s.toFixed(2)+'</span></div>';
h+='<div class="bk-summary-row"><span class="bk-summary-label">GST (5%)</span><span class="bk-summary-val">$'+c.g.toFixed(2)+'</span></div>';
h+='<div class="bk-summary-row"><span class="bk-summary-label" style="font-weight:700;color:#111">Total (incl. GST)</span><span class="bk-summary-val bk-summary-val--green">$'+c.total.toFixed(2)+'</span></div>';
document.getElementById('bk-summary').innerHTML=h}
window.openBookingModal=function(btn){st.tireName=btn.dataset.tireName||'Tire';st.tireSize=btn.dataset.tireSize||'';st.vehicle='suv';st.qty=4;st.tpms=false;st.disposal=true;st.date=null;st.time=null;wk=0;
document.getElementById('bk-tire-name-display').textContent=st.tireName;document.getElementById('bk-tire-size-display').textContent=st.tireSize;
document.getElementById('bk-tpms').checked=false;document.getElementById('bk-disposal').checked=true;
document.getElementById('bk-addon-tpms').classList.remove('bk-addon--active');document.getElementById('bk-addon-disposal').classList.add('bk-addon--active');
rv();rq();rp();bkGoTo(1);document.getElementById('bk-overlay').hidden=false;document.body.style.overflow='hidden'};
window.closeBookingModal=function(){document.getElementById('bk-overlay').hidden=true;document.body.style.overflow=''};
window.bkGoTo=function(step){[1,2,3].forEach(function(s){document.getElementById('bk-page-'+s).hidden=s!==step});document.getElementById('bk-page-done').hidden=true;document.getElementById('bk-stepper').style.opacity='1';
[1,2,3].forEach(function(s){var ci=document.querySelector('[data-step="'+s+'"] .bk-step-circle'),la=document.querySelector('[data-step="'+s+'"] .bk-step-label'),li=document.querySelector('[data-line="'+s+'"]');
ci.className='bk-step-circle';la.className='bk-step-label';if(li)li.className='bk-step-line';
if(s<step){ci.className='bk-step-circle bk-step-circle--done';ci.innerHTML='&#10003;';la.className='bk-step-label bk-step-label--active';if(li)li.className='bk-step-line bk-step-line--done'}
else if(s===step){ci.className='bk-step-circle bk-step-circle--active';ci.textContent=s;la.className='bk-step-label bk-step-label--active'}
else{ci.textContent=s}});if(step===2){rw();rt()}if(step===3){rs()}};
window.bkSubmit=function(){var n=document.getElementById('bk-name').value.trim(),p=document.getElementById('bk-phone').value.trim(),e=document.getElementById('bk-email').value.trim();
if(!n||!p||!e){alert('Please fill in your name, phone, and email.');return}
var c=calc(),v=vehs.find(function(x){return x.id===st.vehicle}),ds=st.date.toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'})+' at '+st.time;
var h='<div class="bk-summary-row"><span class="bk-summary-label">Date & Time</span><span class="bk-summary-val">'+ds+'</span></div>';
h+='<div class="bk-summary-row"><span class="bk-summary-label">Address</span><span class="bk-summary-val">111 42 Ave SW, Calgary, AB</span></div>';
h+='<div class="bk-summary-row"><span class="bk-summary-label">Phone</span><span class="bk-summary-val">(403) 452-4283</span></div>';
h+='<div class="bk-summary-row"><span class="bk-summary-label">Tire</span><span class="bk-summary-val">'+st.tireSize+' × '+st.qty+' — '+(v?v.name:'')+'</span></div>';
h+='<div class="bk-summary-row"><span class="bk-summary-label" style="font-weight:700;color:#111">Total (incl. GST)</span><span class="bk-summary-val bk-summary-val--green">$'+c.total.toFixed(2)+'</span></div>';
document.getElementById('bk-done-card').innerHTML=h;[1,2,3].forEach(function(s){document.getElementById('bk-page-'+s).hidden=true});
document.getElementById('bk-page-done').hidden=false;document.getElementById('bk-stepper').style.opacity='0';
if(typeof confetti==='function'){var co=['#16a34a','#22c55e','#F5820B','#ffffff','#dc2626','#bbf7d0'];
confetti({particleCount:80,spread:70,origin:{y:.6},colors:co});setTimeout(function(){confetti({particleCount:40,angle:60,spread:55,origin:{x:0},colors:co})},200);setTimeout(function(){confetti({particleCount:40,angle:120,spread:55,origin:{x:1},colors:co})},400)}};
window.bkDownloadICS=function(){var ds=st.date.toISOString().split('T')[0].replace(/-/g,''),tm=st.time.match(/(\d+):(\d+)\s*(AM|PM)/),h=parseInt(tm[1]),m=parseInt(tm[2]);
if(tm[3]==='PM'&&h<12)h+=12;if(tm[3]==='AM'&&h===12)h=0;var st2=(h<10?'0':'')+h+(m<10?'0':'')+m+'00',eh=h+Math.ceil(st.qty*.5),et=(eh<10?'0':'')+eh+(m<10?'0':'')+m+'00';
var ics='BEGIN:VCALENDAR\nVERSION:2.0\nBEGIN:VEVENT\nDTSTART;TZID=America/Edmonton:'+ds+'T'+st2+'\nDTEND;TZID=America/Edmonton:'+ds+'T'+et+'\nSUMMARY:Tire Installation at Prince Tires\nLOCATION:111 42 Ave SW\\, Calgary\\, AB\nDESCRIPTION:'+st.tireSize+' x '+st.qty+' tires\nEND:VEVENT\nEND:VCALENDAR';
var b=new Blob([ics],{type:'text/calendar'}),a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='prince-tires-booking.ics';a.click()};
document.getElementById('bk-tpms').addEventListener('change',function(){st.tpms=this.checked;document.getElementById('bk-addon-tpms').classList.toggle('bk-addon--active',this.checked);rp()});
document.getElementById('bk-disposal').addEventListener('change',function(){st.disposal=this.checked;document.getElementById('bk-addon-disposal').classList.toggle('bk-addon--active',this.checked);rp()});
document.getElementById('bk-prev-week').addEventListener('click',function(){if(wk>0){wk--;rw()}});
document.getElementById('bk-next-week').addEventListener('click',function(){wk++;rw()});
document.getElementById('bk-overlay').addEventListener('click',function(e){if(e.target===this)closeBookingModal()});
document.addEventListener('keydown',function(e){if(e.key==='Escape')closeBookingModal()});
})();
</script>
