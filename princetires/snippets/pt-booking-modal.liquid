  };

  // ── Helpers ──────────────────────────────────────────────────────────────
  function vehPrice() {
    var v = vehs.find(function (x) { return x.id === st.vehicle; });
    return v ? v.price : 30;
  }

  function calcPrice() {
    var tp = st.tirePrice > 0 ? st.tirePrice * st.qty : 0;
    var i = vehPrice() * st.qty;
    var t = st.tpms ? 75 * st.qty : 0;
    var d = st.disposal ? 5 * st.qty : 0;
    var s = tp + i + t + d;
    var g = s * 0.05;
    return { tires: tp, install: i, tpms: t, disposal: d, subtotal: s, gst: g, total: s + g };
  }

  function autoDetectVehicle(tireSize, garage) {
    // Detect from saved garage vehicle make/model first
    if (garage) {
      var mk = (garage.make || '').toLowerCase();
      var md = (garage.model || '').toLowerCase();
      var evMakes = ['tesla', 'rivian', 'lucid', 'polestar'];
      var evModels = ['bolt', 'leaf', 'ioniq', 'mustang mach', 'id.4', 'id.3', 'taycan', 'e-tron'];
      var truckWords = ['f-150', 'f150', 'f-250', 'f250', 'f-350', 'f350', 'ranger', 'maverick', 'sierra', 'silverado', 'ram', 'tundra', 'tacoma', 'titan', 'frontier', 'colorado', 'canyon', 'ridgeline', 'pickup', 'truck'];
      var suvWords = ['suv', 'explorer', 'tahoe', 'suburban', 'highlander', '4runner', 'pathfinder', 'pilot', 'rav4', 'cr-v', 'rogue', 'murano', 'escape', 'edge', 'bronco', 'equinox', 'traverse', 'blazer', 'wrangler', 'cherokee', 'durango', 'tucson', 'santa fe', 'cx-', 'sportage', 'sorento', 'telluride', 'forester', 'outback', 'crosstrek', 'armada', 'expedition', 'sequoia'];
      var vanWords = ['sienna', 'odyssey', 'pacifica', 'carnival', 'transit', 'sprinter', 'promaster', 'quest', 'van'];
      if (evMakes.indexOf(mk) > -1) return 'electric';
      for (var i = 0; i < evModels.length; i++) { if (md.indexOf(evModels[i]) > -1) return 'electric'; }
      for (var i = 0; i < truckWords.length; i++) { if (md.indexOf(truckWords[i]) > -1) return 'truck'; }
      for (var i = 0; i < vanWords.length; i++) { if (md.indexOf(vanWords[i]) > -1) return 'van'; }
      for (var i = 0; i < suvWords.length; i++) { if (md.indexOf(suvWords[i]) > -1) return 'suv'; }
      if (md.indexOf('3500') > -1 || md.indexOf('dually') > -1) return 'dually';
      return 'passenger';
    }
    // Fallback: tire size prefix
    var sz = (tireSize || '').toUpperCase();
    if (sz.indexOf('ST') === 0) return 'trailer';
    if (sz.indexOf('LT') === 0 || sz.indexOf('/LT') > -1) return 'truck';
    return 'passenger';
  }

  // ── Render: order summary card (Step 1) ─────────────────────────────────
  function renderPrice() {
    var c = calcPrice();
    var linesEl = document.getElementById('bk-order-lines');
    var totalEl = document.getElementById('bk-order-total-row');
    if (!linesEl || !totalEl) return;

    var h = '';
    if (st.tirePrice > 0) {
      h += '<div class="bk-order-row"><span>' + st.qty + ' tire' + (st.qty !== 1 ? 's' : '') + ' × $' + st.tirePrice.toFixed(2) + '</span><span>$' + c.tires.toFixed(2) + '</span></div>';
    }
    h += '<div class="bk-order-row"><span>Installation × ' + st.qty + ' ($' + vehPrice() + '/tire)</span><span>$' + c.install.toFixed(2) + '</span></div>';
    if (st.tpms) h += '<div class="bk-order-row"><span>TPMS sensors × ' + st.qty + '</span><span>+$' + c.tpms.toFixed(2) + '</span></div>';
    if (st.disposal) h += '<div class="bk-order-row"><span>Tire disposal × ' + st.qty + '</span><span>+$' + c.disposal.toFixed(2) + '</span></div>';
    h += '<div class="bk-order-row"><span>GST (5%)</span><span>$' + c.gst.toFixed(2) + '</span></div>';
    linesEl.innerHTML = h;
    totalEl.innerHTML = '<span>Total (incl. GST)</span><span class="bk-order-total-val">$' + c.total.toFixed(2) + '</span>';
  }

  // ── Render: vehicle display (read-only) ──────────────────────────────────
  function renderVehicles() {
    var v = vehs.find(function (x) { return x.id === st.vehicle; });
    var nameEl = document.getElementById('bk-vehicle-display-name');
    var priceEl = document.getElementById('bk-vehicle-display-price');
    if (nameEl) nameEl.textContent = v ? v.name : 'Vehicle';
    if (priceEl) priceEl.textContent = v && v.price ? '$' + v.price + '/tire' : 'Ask us';
    renderPrice();
  }

  // ── Render: qty dropdown ─────────────────────────────────────────────────
  function renderQty() {
    var sel = document.getElementById('bk-qty-select');
    if (!sel) return;
    sel.value = String(st.qty);
    if (!sel._wired) {
      sel._wired = true;
      sel.addEventListener('change', function () {
        st.qty = parseInt(this.value);
        renderPrice();
        try { localStorage.setItem('pt-booking-qty', String(st.qty)); } catch (e) {}
      });
    }
  }


  // ── Render: week + day strip ─────────────────────────────────────────────
  function renderWeek() {
    var today = new Date(); today.setHours(0, 0, 0, 0);
    var start = new Date(today);
    start.setDate(start.getDate() - start.getDay() + 1 + wk * 7); // week starts Monday
    var dn = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
    var mn = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    var end = new Date(start); end.setDate(end.getDate() + 6);
    document.getElementById('bk-week-label').textContent = start.getDate() + ' ' + mn[start.getMonth()] + ' – ' + end.getDate() + ' ' + mn[end.getMonth()];
    document.getElementById('bk-prev-week').disabled = wk <= 0;

    var h = '';
    for (var i = 0; i < 7; i++) {
      var d = new Date(start); d.setDate(d.getDate() + i);
      var isPast = d < today;
      var isToday = d.getTime() === today.getTime();
      var isActive = st.date && d.toDateString() === st.date.toDateString();
      var cls = 'bk-day-card';
      if (isPast) cls += ' bk-day-card--past';
      if (isToday) cls += ' bk-day-card--today';
      if (isActive) cls += ' bk-day-card--active';
      h += '<div class="' + cls + '" data-date="' + d.toISOString() + '"><div class="bk-day-name">' + dn[i] + '</div><div class="bk-day-num">' + d.getDate() + '</div></div>';
    }
    document.getElementById('bk-day-strip').innerHTML = h;

    document.querySelectorAll('.bk-day-card:not(.bk-day-card--past)').forEach(function (el) {
      el.addEventListener('click', function () {
        st.date = new Date(this.dataset.date);
        st.time = null;
        document.getElementById('bk-next-2').disabled = true;
        renderWeek();
        renderTimes();
      });
    });
  }

  // ── Helper: convert "9:30 AM" → minutes from midnight ───────────────────
  function slotToMins(slot) {
    var m = slot.match(/(\d+):(\d+)\s*(AM|PM)/i);
    if (!m) return 0;
    var h = parseInt(m[1]), mn = parseInt(m[2]);
    if (m[3].toUpperCase() === 'PM' && h !== 12) h += 12;
    if (m[3].toUpperCase() === 'AM' && h === 12) h = 0;
    return h * 60 + mn;
  }

  // ── Render: time slots ───────────────────────────────────────────────────
  async function renderTimes() {
    if (!st.date) {
      document.getElementById('bk-time-grid').innerHTML = '<p style="color:#9ca3af;font-size:.9rem;grid-column:1/-1">Select a day above</p>';
      return;
    }
    var isSun = st.date.getDay() === 0;
    var startH = isSun ? 10 : 9, startM = isSun ? 0 : 30;
    var endH = isSun ? 15 : 17, endM = 30;
    var slots = [];
    for (var h = startH; h <= endH; h++) {
      for (var m = (h === startH ? startM : 0); m < 60; m += 30) {
        if (h === endH && m > endM) break;
        var hr = h > 12 ? h - 12 : h;
        slots.push(hr + ':' + (m < 10 ? '0' : '') + m + ' ' + (h >= 12 ? 'PM' : 'AM'));
      }
    }

    document.getElementById('bk-time-grid').innerHTML = '<p style="color:#9ca3af;font-size:.9rem;grid-column:1/-1">Checking availability…</p>';
    var booked = [];
    var allDayBlocked = false;
    try {
      var ds = st.date.toISOString().split('T')[0];
      var r = await fetch(AVAILABILITY_API + '?date=' + ds);
      var data = await r.json();
      booked = data.booked || [];
      allDayBlocked = data.allDayBlocked || false;
    } catch (e) {}

    if (allDayBlocked) {
      document.getElementById('bk-time-grid').innerHTML = '<p style="color:#dc2626;font-size:.95rem;grid-column:1/-1;text-align:center;padding:.5rem 0">Not available this day — please pick another date.</p>';
      var noteEl = document.getElementById('bk-trial-note');
      if (noteEl) noteEl.hidden = true;
      return;
    }

    // ── Business-rule blocking ────────────────────────────────────────────
    var blockReason = {}; // slot → reason string
    var trialNote = '';
    try {
      var today = new Date(); today.setHours(0, 0, 0, 0);
      var isToday = st.date.getTime() === today.getTime();
      var now = new Date();
      var nowMins = now.getHours() * 60 + now.getMinutes();

      // Rule 1: block past slots for today (all inventory types)
      if (isToday) {
        slots.forEach(function (s) {
          if (slotToMins(s) <= nowMins) blockReason[s] = 'Time has passed';
        });
      }

      // Rule 2: Trial inventory restrictions (today only)
      if (st.inventorySource === 'trial' && isToday) {
        var month = now.getMonth(); // 0 = Jan … 11 = Dec
        var isWinter = [9, 10, 11, 0, 1, 2].indexOf(month) > -1; // Oct–Mar

        if (isWinter) {
          slots.forEach(function (s) { blockReason[s] = 'No same-day booking in winter for ordered tires'; });
          trialNote = 'Ordered tires: same-day bookings are unavailable in winter — please pick a future date.';
        } else {
          // Trial ships at 8:30, 11:30, 14:30 — need 4 hrs (240 min) after departure
          var TRIAL_SHIPS = [510, 690, 870]; // minutes from midnight
          var nextShip = null;
          for (var i = 0; i < TRIAL_SHIPS.length; i++) {
            if (nowMins <= TRIAL_SHIPS[i]) { nextShip = TRIAL_SHIPS[i]; break; }
          }

          if (nextShip === null) {
            slots.forEach(function (s) { blockReason[s] = blockReason[s] || 'No more deliveries today for ordered tires'; });
            trialNote = 'Ordered tires: no more same-day deliveries today — please pick a future date.';
          } else {
            var earliestAllowed = nextShip + 240;
            slots.forEach(function (s) {
              if (slotToMins(s) < earliestAllowed) {
                blockReason[s] = blockReason[s] || 'Waiting for tire delivery';
              }
            });
            var eH = Math.floor(earliestAllowed / 60);
            var eM = earliestAllowed % 60;
            var eLabel = (eH > 12 ? eH - 12 : eH) + ':' + (eM < 10 ? '0' : '') + eM + ' ' + (eH >= 12 ? 'PM' : 'AM');
            trialNote = 'Ordered tires arrive today — earliest available: ' + eLabel + ' (4 hrs after next shipment).';
          }
        }
      }
    } catch (ruleErr) {
      console.error('renderTimes rule error:', ruleErr);
    }

    var noteEl = document.getElementById('bk-trial-note');
    if (noteEl) { noteEl.textContent = trialNote; noteEl.hidden = !trialNote; }

    document.getElementById('bk-time-grid').innerHTML = slots.map(function (s) {
      var isCalBooked = booked.indexOf(s) > -1;
      var isBlocked = isCalBooked || !!blockReason[s];
      var titleAttr = isCalBooked ? 'Already booked' : (blockReason[s] || '');
      return '<div class="bk-time-slot' +
        (st.time === s ? ' bk-time-slot--active' : '') +
        (isBlocked ? ' bk-time-slot--booked' : '') +
        '" data-time="' + s + '"' +
        (isBlocked ? ' title="' + titleAttr + '"' : '') +
        '>' + s + '</div>';
    }).join('');

    document.querySelectorAll('.bk-time-slot:not(.bk-time-slot--booked)').forEach(function (el) {
      el.addEventListener('click', function () {
        st.time = this.dataset.time;
        renderTimes();
        document.getElementById('bk-next-2').disabled = false;
      });
    });
  }

  // ── Render: order summary (step 3) ───────────────────────────────────────
  function renderSummary() {
    var c = calcPrice();
    var v = vehs.find(function (x) { return x.id === st.vehicle; });
    var ds = st.date ? st.date.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' }) + ' at ' + st.time : '';
    var addons = [];
    if (st.tpms) addons.push('TPMS sensors');
    if (st.disposal) addons.push('Tire disposal');
    var vehLabel = buildVehicleLabel(v);
    var h = '';
    h += '<div class="bk-summary-row"><span class="bk-summary-label">Date & time</span><span class="bk-summary-val">' + ds + '</span></div>';
    h += '<div class="bk-summary-row"><span class="bk-summary-label">Vehicle</span><span class="bk-summary-val">' + vehLabel + '</span></div>';
    h += '<div class="bk-summary-row"><span class="bk-summary-label">Tire</span><span class="bk-summary-val">' + (st.tireSize || '—') + ' × ' + st.qty + '</span></div>';
    if (addons.length) h += '<div class="bk-summary-row"><span class="bk-summary-label">Add-ons</span><span class="bk-summary-val">' + addons.join(', ') + '</span></div>';
    if (st.tirePrice > 0) h += '<div class="bk-summary-row"><span class="bk-summary-label">Tires</span><span class="bk-summary-val">$' + c.tires.toFixed(2) + '</span></div>';
    h += '<div class="bk-summary-row"><span class="bk-summary-label">Installation</span><span class="bk-summary-val">$' + c.install.toFixed(2) + '</span></div>';
    if (st.tpms) h += '<div class="bk-summary-row"><span class="bk-summary-label">TPMS sensors</span><span class="bk-summary-val">$' + c.tpms.toFixed(2) + '</span></div>';
    if (st.disposal) h += '<div class="bk-summary-row"><span class="bk-summary-label">Tire disposal</span><span class="bk-summary-val">$' + c.disposal.toFixed(2) + '</span></div>';
    h += '<div class="bk-summary-row"><span class="bk-summary-label">Subtotal</span><span class="bk-summary-val">$' + c.subtotal.toFixed(2) + '</span></div>';
    h += '<div class="bk-summary-row"><span class="bk-summary-label">GST (5%)</span><span class="bk-summary-val">$' + c.gst.toFixed(2) + '</span></div>';
    h += '<div class="bk-summary-row"><span class="bk-summary-label" style="font-weight:700;color:#111">Total (incl. GST)</span><span class="bk-summary-val bk-summary-val--green">$' + c.total.toFixed(2) + '</span></div>';
    document.getElementById('bk-summary').innerHTML = h;
  }

  function buildVehicleLabel(vehObj) {
    if (st.savedVehicle) {
      var lbl = st.savedVehicle.year + ' ' + st.savedVehicle.make + ' ' + st.savedVehicle.model;
      if (st.savedVehicle.trim) lbl += ' ' + st.savedVehicle.trim;
      return lbl;
    }
    return vehObj ? vehObj.name : '';
  }

  // ── Open modal ───────────────────────────────────────────────────────────
  window.openBookingModal = function (btn) {
    st.tireName = btn.dataset.tireName || 'Tire';
    st.tireSize = btn.dataset.tireSize || '';
    st.tirePrice = parseInt(btn.dataset.tirePrice || '0') / 100;
    st.inventorySource = btn.dataset.inventorySource === 'trial' ? 'trial' : 'store';
    st.tpms = false;
    st.disposal = true;
    st.date = null;
    st.time = null;
    wk = 0;

    // Load saved garage vehicle (default)
    st.savedVehicle = null;
    try {
      var gKeys = Object.keys(localStorage).filter(function (k) { return k.startsWith('pt-garage-'); });
      for (var i = 0; i < gKeys.length; i++) {
        var gVehicles = JSON.parse(localStorage.getItem(gKeys[i]));
        var gDef = (gVehicles || []).find(function (v) { return v.isDefault; });
        if (gDef) { st.savedVehicle = gDef; break; }
      }
    } catch (e) {}

    // Load last-used qty (default 4)
    try {
      var savedQty = parseInt(localStorage.getItem('pt-booking-qty'));
      st.qty = (savedQty > 0 && savedQty <= 20) ? savedQty : 4;
    } catch (e) { st.qty = 4; }

    // Determine vehicle type
    var forceVehicle = btn.dataset.vehicleType || '';
    if (forceVehicle && vehs.find(function (v) { return v.id === forceVehicle; })) {
      st.vehicle = forceVehicle;
    } else {
      st.vehicle = autoDetectVehicle(st.tireSize, st.savedVehicle);
    }
    // Override with last-used vehicle selection if available
    try {
      var lastVehicle = localStorage.getItem('pt-booking-vehicle');
      if (lastVehicle && vehs.find(function (v) { return v.id === lastVehicle; })) {
        st.vehicle = lastVehicle;
      }
    } catch (e) {}

    // Show/hide saved vehicle banner + vehicle grid
    var svEl = document.getElementById('bk-saved-vehicle');
    var svLbl = document.getElementById('bk-saved-vehicle-label');
    var vSection = document.getElementById('bk-vehicle-section');
    if (st.savedVehicle) {
      svLbl.textContent = buildVehicleLabel(null);
      svEl.hidden = false;
      vSection.hidden = true; // collapsed by default — user can open with "Change"
    } else {
      svEl.hidden = true;
      vSection.hidden = false;
    }

    // Update tire display
    document.getElementById('bk-tire-name-display').textContent = st.tireName;
    document.getElementById('bk-tire-size-display').textContent = st.tireSize || '—';

    // Reset add-on state
    document.getElementById('bk-tpms').checked = false;
    document.getElementById('bk-disposal').checked = true;
    document.getElementById('bk-addon-tpms').classList.remove('bk-addon--active');
    document.getElementById('bk-addon-disposal').classList.add('bk-addon--active');

    renderVehicles();
    renderQty();
    renderPrice();

    // Prefill contact: Shopify customer → localStorage → blank
    try {
      var cust = window.__bkCustomer || {};
      var saved = JSON.parse(localStorage.getItem('pt-booking-contact') || 'null');
      document.getElementById('bk-name').value = cust.name || (saved && saved.name) || '';
      document.getElementById('bk-phone').value = cust.phone || (saved && saved.phone) || '';
      document.getElementById('bk-email').value = cust.email || (saved && saved.email) || '';
      document.getElementById('bk-notes').value = '';
    } catch (e) {}

    bkGoTo(1);
    document.getElementById('bk-overlay').hidden = false;
    document.body.style.overflow = 'hidden';
  };

  // ── Close modal ──────────────────────────────────────────────────────────
  window.closeBookingModal = function () {
    document.getElementById('bk-overlay').hidden = true;
    document.body.style.overflow = '';
  };

  // ── Step navigation ──────────────────────────────────────────────────────
  window.bkGoTo = function (step) {
    [1, 2, 3].forEach(function (s) { document.getElementById('bk-page-' + s).hidden = s !== step; });
    document.getElementById('bk-page-done').hidden = true;
    document.getElementById('bk-stepper').style.opacity = '1';

    [1, 2, 3].forEach(function (s) {
      var ci = document.querySelector('[data-step="' + s + '"] .bk-step-circle');
      var la = document.querySelector('[data-step="' + s + '"] .bk-step-label');
      var li = document.querySelector('[data-line="' + s + '"]');
      ci.className = 'bk-step-circle'; if (la) la.className = 'bk-step-label';
      if (li) li.className = 'bk-step-line';
      if (s < step) {
        ci.className = 'bk-step-circle bk-step-circle--done'; ci.innerHTML = '&#10003;';
        if (la) la.className = 'bk-step-label bk-step-label--active';
        if (li) li.className = 'bk-step-line bk-step-line--done';
      } else if (s === step) {
        ci.className = 'bk-step-circle bk-step-circle--active'; ci.textContent = s;
        if (la) la.className = 'bk-step-label bk-step-label--active';
      } else { ci.textContent = s; }
    });

    if (step === 2) {
      // Auto-select today when entering the schedule step
      if (!st.date) { var today = new Date(); today.setHours(0, 0, 0, 0); st.date = today; }
      renderWeek(); renderTimes();
    }
    if (step === 3) { renderSummary(); }
  };

  // ── Submit booking ───────────────────────────────────────────────────────
  window.bkSubmit = async function () {
    var name = document.getElementById('bk-name').value.trim();
    var phone = document.getElementById('bk-phone').value.trim();
    var email = document.getElementById('bk-email').value.trim();
    var notes = document.getElementById('bk-notes').value.trim();

    // Clear previous errors
    var errEl = document.getElementById('bk-form-error');
    ['bk-field-name', 'bk-field-phone', 'bk-field-email'].forEach(function (id) {
      document.getElementById(id).classList.remove('bk-field--error');
    });
    errEl.hidden = true;

    // Inline validation
    var missing = [];
    if (!name) { document.getElementById('bk-field-name').classList.add('bk-field--error'); missing.push('full name'); }
    if (!phone) { document.getElementById('bk-field-phone').classList.add('bk-field--error'); missing.push('phone number'); }
    if (!email || email.indexOf('@') < 1) { document.getElementById('bk-field-email').classList.add('bk-field--error'); missing.push('email address'); }
    if (missing.length) {
      errEl.textContent = 'Please fill in your ' + missing.join(', ') + '.';
      errEl.hidden = false;
      return;
    }

    var btn = document.getElementById('bk-confirm-btn');
    btn.disabled = true;
    btn.textContent = 'Booking…';

    var c = calcPrice();
    var v = vehs.find(function (x) { return x.id === st.vehicle; });

    try {
      var payload = {
        name: name,
        phone: phone,
        email: email,
        notes: notes,
        vehicleType: st.vehicle,
        vehicleYear: st.savedVehicle ? (st.savedVehicle.year || '') : '',
        vehicleMake: st.savedVehicle ? (st.savedVehicle.make || '') : '',
        vehicleModel: st.savedVehicle ? (st.savedVehicle.model || '') : '',
        vehicleTrim: st.savedVehicle ? (st.savedVehicle.trim || '') : '',
        tireName: st.tireName,
        tireSize: st.tireSize,
        qty: st.qty,
        tpms: st.tpms,
        disposal: st.disposal,
        inventorySource: st.inventorySource,
        date: st.date.toISOString().split('T')[0],
        time: st.time,
        subtotal: parseFloat(c.subtotal.toFixed(2)),
        gst: parseFloat(c.gst.toFixed(2)),
        total: parseFloat(c.total.toFixed(2))
      };

      var res = await fetch(BOOKING_API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (!res.ok) {
        var errData = await res.json().catch(function () { return {}; });
        throw new Error(errData.error || 'Booking failed');
      }

      // Save preferences and HMAC lookup token for next visit
      try {
        var bookData = await res.json().catch(function () { return {}; });
        // A01: store the server-issued HMAC token so the customer can look up
        // their own bookings without exposing an IDOR vulnerability
        if (bookData.lookupToken && email) {
          localStorage.setItem('pt-book-token-' + email.toLowerCase(), bookData.lookupToken);
        }
        localStorage.setItem('pt-booking-contact', JSON.stringify({ name: name, phone: phone, email: email, savedAt: new Date().toISOString() }));
        localStorage.setItem('pt-booking-qty', String(st.qty));
        localStorage.setItem('pt-booking-vehicle', st.vehicle);
      } catch (ex) {}

      // Build done card
      var ds = st.date.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' }) + ' at ' + st.time;
      var vehLabel = buildVehicleLabel(v);
      var doneH = '';
      doneH += '<div class="bk-summary-row"><span class="bk-summary-label">Date & time</span><span class="bk-summary-val">' + ds + '</span></div>';
      doneH += '<div class="bk-summary-row"><span class="bk-summary-label">Address</span><span class="bk-summary-val">111 42 Ave SW, Calgary, AB</span></div>';
      doneH += '<div class="bk-summary-row"><span class="bk-summary-label">Phone</span><span class="bk-summary-val">(403) 452-4283</span></div>';
      if (vehLabel) doneH += '<div class="bk-summary-row"><span class="bk-summary-label">Vehicle</span><span class="bk-summary-val">' + vehLabel + '</span></div>';
      doneH += '<div class="bk-summary-row"><span class="bk-summary-label">Tire</span><span class="bk-summary-val">' + (st.tireSize || '—') + ' × ' + st.qty + '</span></div>';
      doneH += '<div class="bk-summary-row"><span class="bk-summary-label" style="font-weight:700;color:#111">Total (incl. GST)</span><span class="bk-summary-val bk-summary-val--green">$' + c.total.toFixed(2) + '</span></div>';
      document.getElementById('bk-done-card').innerHTML = doneH;

      [1, 2, 3].forEach(function (s) { document.getElementById('bk-page-' + s).hidden = true; });
      document.getElementById('bk-page-done').hidden = false;
      document.getElementById('bk-stepper').style.opacity = '0';

      if (typeof confetti === 'function') {
        var co = ['#16a34a', '#22c55e', '#F5820B', '#ffffff', '#dc2626', '#bbf7d0'];
        confetti({ particleCount: 80, spread: 70, origin: { y: .6 }, colors: co });
        setTimeout(function () { confetti({ particleCount: 40, angle: 60, spread: 55, origin: { x: 0 }, colors: co }); }, 200);
        setTimeout(function () { confetti({ particleCount: 40, angle: 120, spread: 55, origin: { x: 1 }, colors: co }); }, 400);
      }
    } catch (err) {
      btn.disabled = false;
      btn.textContent = 'Confirm booking';
      errEl.textContent = err.message && err.message.length < 120 ? err.message : 'Something went wrong. Please try again or call us at (403) 452-4283.';
      errEl.hidden = false;
    }
  };

  // ── Download ICS calendar file ───────────────────────────────────────────
  window.bkDownloadICS = function () {
    var tm = st.time.match(/(\d+):(\d+)\s*(AM|PM)/i);
    var h = parseInt(tm[1]), m = parseInt(tm[2]);
    if (tm[3].toUpperCase() === 'PM' && h < 12) h += 12;
    if (tm[3].toUpperCase() === 'AM' && h === 12) h = 0;
    var ds = st.date.toISOString().split('T')[0].replace(/-/g, '');
    var st2 = (h < 10 ? '0' : '') + h + (m < 10 ? '0' : '') + m + '00';
    var eh = h + Math.ceil(st.qty * 0.5);
    var et = (eh < 10 ? '0' : '') + eh + (m < 10 ? '0' : '') + m + '00';
    var ics = 'BEGIN:VCALENDAR\nVERSION:2.0\nBEGIN:VEVENT\nDTSTART;TZID=America/Edmonton:' + ds + 'T' + st2 + '\nDTEND;TZID=America/Edmonton:' + ds + 'T' + et + '\nSUMMARY:Tire Installation at Prince Tires\nLOCATION:111 42 Ave SW\\, Calgary\\, AB T2G 0G3\nDESCRIPTION:' + (st.tireSize || '') + ' × ' + st.qty + ' tires\nEND:VEVENT\nEND:VCALENDAR';
    var a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([ics], { type: 'text/calendar' }));
    a.download = 'prince-tires-booking.ics';
    a.click();
  };

  // ── Event listeners ──────────────────────────────────────────────────────
  document.getElementById('bk-tpms').addEventListener('change', function () {
    st.tpms = this.checked;
    document.getElementById('bk-addon-tpms').classList.toggle('bk-addon--active', this.checked);
    renderPrice();
  });
  document.getElementById('bk-disposal').addEventListener('change', function () {
    st.disposal = this.checked;
    document.getElementById('bk-addon-disposal').classList.toggle('bk-addon--active', this.checked);
    renderPrice();
  });
  document.getElementById('bk-prev-week').addEventListener('click', function () { if (wk > 0) { wk--; renderWeek(); } });
  document.getElementById('bk-next-week').addEventListener('click', function () { wk++; renderWeek(); });
  document.getElementById('bk-overlay').addEventListener('click', function (e) { if (e.target === this) closeBookingModal(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeBookingModal(); });

  // Event delegation for all [data-book-install] trigger buttons
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-book-install]');
    if (btn) openBookingModal(btn);
  });
})();
</script>
