{% doc %}
  Renders a floating AI chatbot bubble widget powered by Gemini.
  Reads configuration from global theme settings (chatbot_* keys).
  Rendered once in layout/theme.liquid before </body>.
{% enddoc %}

{%- unless settings.chatbot_enabled == false -%}

{%- assign chatbot_endpoint = settings.chatbot_api_endpoint | strip -%}
{%- if chatbot_endpoint == blank -%}
  {%- assign chatbot_endpoint = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=' | append: settings.gemini_api_key -%}
{%- endif -%}

<div
  id="chatbot-bubble-root"
  data-endpoint="{{ chatbot_endpoint | escape }}"
  data-system-prompt="{{ settings.chatbot_system_prompt | escape }}"
  data-title="{{ settings.chatbot_title | escape }}"
  data-greeting="{{ 'sections.chatbot.greeting' | t | escape }}"
  style="--cb-accent: {{ settings.chatbot_accent_color }};"
>
  <!-- Toggle button -->
  <button class="cb-toggle" id="cb-toggle" aria-label="Open chat" aria-expanded="false">
    <span class="cb-toggle__icon cb-toggle__icon--open">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
    </span>
    <span class="cb-toggle__icon cb-toggle__icon--close">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </span>
  </button>

  <!-- Chat panel -->
  <div class="cb-panel" id="cb-panel" role="dialog" aria-label="{{ settings.chatbot_title | escape }}" aria-hidden="true">
    <div class="cb-panel__header">
      <div class="cb-panel__header-info">
        <span class="cb-panel__dot"></span>
        <span class="cb-panel__title">{{ settings.chatbot_title }}</span>
      </div>
      <button class="cb-panel__new-chat" id="cb-new-chat" title="New chat">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="1 4 1 10 7 10"></polyline>
          <path d="M3.51 15a9 9 0 1 0 .49-3.51"></path>
        </svg>
      </button>
    </div>

    <div class="cb-panel__messages" id="cb-messages" role="log" aria-live="polite"></div>

    <div class="cb-panel__input-row">
      <input
        type="text"
        class="cb-panel__input"
        id="cb-input"
        placeholder="{{ 'sections.chatbot.placeholder' | t }}"
        maxlength="500"
        autocomplete="off"
        aria-label="{{ 'sections.chatbot.placeholder' | t }}"
      >
      <button class="cb-panel__send" id="cb-send" aria-label="{{ 'sections.chatbot.send' | t }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>
  </div>
</div>

{% stylesheet %}
  #chatbot-bubble-root {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
    font-family: inherit;
  }

  /* Toggle button */
  .cb-toggle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: var(--cb-accent);
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    position: relative;
    z-index: 1;
  }

  .cb-toggle:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.28);
  }

  .cb-toggle__icon {
    position: absolute;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .cb-toggle__icon--close {
    opacity: 0;
    transform: rotate(-90deg) scale(0.8);
  }

  .cb-toggle[aria-expanded="true"] .cb-toggle__icon--open {
    opacity: 0;
    transform: rotate(90deg) scale(0.8);
  }

  .cb-toggle[aria-expanded="true"] .cb-toggle__icon--close {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  /* Chat panel */
  .cb-panel {
    position: absolute;
    bottom: 68px;
    right: 0;
    width: 340px;
    max-height: 480px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.16);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform-origin: bottom right;
    transform: scale(0.92) translateY(8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .cb-panel[aria-hidden="false"] {
    opacity: 1;
    transform: scale(1) translateY(0);
    pointer-events: all;
  }

  /* Header */
  .cb-panel__header {
    background-color: var(--cb-accent);
    color: #fff;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }

  .cb-panel__header-info {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .cb-panel__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 0 2px rgba(74, 222, 128, 0.3);
  }

  .cb-panel__title {
    font-weight: 600;
    font-size: 0.9375rem;
  }

  .cb-panel__new-chat {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.75);
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }

  .cb-panel__new-chat:hover {
    color: #fff;
  }

  /* Messages */
  .cb-panel__messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: #fafafa;
  }

  .cb-msg {
    display: flex;
    max-width: 88%;
    animation: cb-fadein 0.18s ease;
  }

  @keyframes cb-fadein {
    from { opacity: 0; transform: translateY(5px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .cb-msg--user { align-self: flex-end; }
  .cb-msg--bot  { align-self: flex-start; }

  .cb-bubble {
    padding: 9px 13px;
    border-radius: 14px;
    font-size: 0.875rem;
    line-height: 1.5;
    word-break: break-word;
    white-space: pre-wrap;
  }

  .cb-msg--user .cb-bubble {
    background-color: var(--cb-accent);
    color: #fff;
    border-bottom-right-radius: 3px;
  }

  .cb-msg--bot .cb-bubble {
    background: #fff;
    color: #121212;
    border: 1px solid #e5e5e5;
    border-bottom-left-radius: 3px;
  }

  .cb-thinking {
    display: flex;
    gap: 4px;
    align-items: center;
    padding: 9px 13px;
  }

  .cb-thinking span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #9ca3af;
    animation: cb-bounce 1.2s infinite;
  }

  .cb-thinking span:nth-child(2) { animation-delay: 0.2s; }
  .cb-thinking span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes cb-bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-5px); }
  }

  /* Input row */
  .cb-panel__input-row {
    display: flex;
    border-top: 1px solid #e5e5e5;
    background: #fff;
    flex-shrink: 0;
  }

  .cb-panel__input {
    flex: 1;
    padding: 12px 14px;
    border: none;
    outline: none;
    font-size: 0.875rem;
    font-family: inherit;
    background: transparent;
    color: #121212;
  }

  .cb-panel__input::placeholder { color: #9ca3af; }

  .cb-panel__send {
    padding: 0 16px;
    background: var(--cb-accent);
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    transition: opacity 0.15s;
  }

  .cb-panel__send:hover { opacity: 0.85; }
  .cb-panel__send:disabled { opacity: 0.35; cursor: not-allowed; }

  .cb-error {
    font-size: 0.8125rem;
    color: #ef4444;
    padding: 2px 4px;
    align-self: flex-start;
  }

  @media (max-width: 480px) {
    #chatbot-bubble-root {
      bottom: 16px;
      right: 16px;
    }
    .cb-panel {
      width: calc(100vw - 32px);
      right: 0;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var root = document.getElementById('chatbot-bubble-root');
    if (!root) return;

    var endpoint    = root.dataset.endpoint;
    var sysprompt   = root.dataset.systemPrompt;
    var greeting    = root.dataset.greeting;

    var toggleBtn   = document.getElementById('cb-toggle');
    var panel       = document.getElementById('cb-panel');
    var messagesEl  = document.getElementById('cb-messages');
    var inputEl     = document.getElementById('cb-input');
    var sendBtn     = document.getElementById('cb-send');
    var newChatBtn  = document.getElementById('cb-new-chat');

    var history     = [];
    var isOpen      = false;

    function openPanel() {
      isOpen = true;
      panel.setAttribute('aria-hidden', 'false');
      toggleBtn.setAttribute('aria-expanded', 'true');
      inputEl.focus();
    }

    function closePanel() {
      isOpen = false;
      panel.setAttribute('aria-hidden', 'true');
      toggleBtn.setAttribute('aria-expanded', 'false');
    }

    toggleBtn.addEventListener('click', function () {
      if (isOpen) { closePanel(); } else { openPanel(); }
    });

    function appendMessage(role, text) {
      var wrapper = document.createElement('div');
      wrapper.className = 'cb-msg cb-msg--' + role;
      var bubble = document.createElement('div');
      bubble.className = 'cb-bubble';
      bubble.textContent = text;
      wrapper.appendChild(bubble);
      messagesEl.appendChild(wrapper);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function showThinking() {
      var wrapper = document.createElement('div');
      wrapper.className = 'cb-msg cb-msg--bot';
      wrapper.id = 'cb-thinking';
      var bubble = document.createElement('div');
      bubble.className = 'cb-bubble cb-thinking';
      bubble.innerHTML = '<span></span><span></span><span></span>';
      wrapper.appendChild(bubble);
      messagesEl.appendChild(wrapper);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function hideThinking() {
      var el = document.getElementById('cb-thinking');
      if (el) el.remove();
    }

    function showError(msg) {
      var el = document.createElement('div');
      el.className = 'cb-error';
      el.textContent = msg;
      messagesEl.appendChild(el);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function sendMessage() {
      var text = inputEl.value.trim();
      if (!text || !endpoint) return;

      inputEl.value = '';
      sendBtn.disabled = true;
      appendMessage('user', text);
      history.push({ role: 'user', parts: [{ text: text }] });
      showThinking();

      var body = JSON.stringify({
        system_instruction: { parts: [{ text: sysprompt }] },
        contents: history,
        generationConfig: { temperature: 0.7, maxOutputTokens: 1024 }
      });

      fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: body
      })
      .then(function (res) {
        if (!res.ok) throw new Error('Status ' + res.status);
        return res.json();
      })
      .then(function (data) {
        var reply =
          (data.candidates && data.candidates[0] && data.candidates[0].content &&
           data.candidates[0].content.parts && data.candidates[0].content.parts[0] &&
           data.candidates[0].content.parts[0].text) ||
          data.text ||
          'Sorry, I didn\'t get a response.';
        hideThinking();
        appendMessage('bot', reply);
        history.push({ role: 'model', parts: [{ text: reply }] });
      })
      .catch(function () {
        hideThinking();
        showError('Something went wrong. Please try again.');
        history.pop();
      })
      .finally(function () {
        sendBtn.disabled = false;
        inputEl.focus();
      });
    }

    function resetChat() {
      history = [];
      messagesEl.innerHTML = '';
      appendMessage('bot', greeting);
    }

    sendBtn.addEventListener('click', sendMessage);
    inputEl.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') { e.preventDefault(); sendMessage(); }
    });
    newChatBtn.addEventListener('click', resetChat);

    resetChat();
  })();
{% endjavascript %}

{%- endunless -%}
