{% doc %}
  Renders a "Book Installation" trigger button for product cards.

  @param {string} tire_name - The tire product name
  @param {string} tire_size - The tire size (e.g. "225/65R17")

  @example
  {% render 'pt-booking-modal-trigger', tire_name: product.title, tire_size: product.metafields.custom.tire_size %}
{% enddoc %}

<button
  type="button"
  class="pt-book-btn"
  data-book-install
  data-tire-name="{{ tire_name | escape }}"
  data-tire-size="{{ tire_size | escape }}"
>
  Book Installation
</button>

{% stylesheet %}
  .pt-book-btn {
    background: #dc2626;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 10px 16px;
    font-weight: 700;
    font-family: 'Outfit', sans-serif;
    font-size: 0.875rem;
    cursor: pointer;
    width: 100%;
    margin-top: 8px;
    transition: background 0.15s;
  }
  .pt-book-btn:hover { background: #b91c1c; }
{% endstylesheet %}
